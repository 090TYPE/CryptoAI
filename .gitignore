# ── Build output ──────────────────────────────────────────────────────────────
bin/
obj/
publish/
out/

# ── Visual Studio ─────────────────────────────────────────────────────────────
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.lscache
*.VC.db
*.VC.opendb

# ── Rider ─────────────────────────────────────────────────────────────────────
.idea/
*.DotSettings.user

# ── .NET runtime/SDK artifacts ────────────────────────────────────────────────
.dotnet/
.dotnet-cli/
*.trn
*.sentinel

# ── Publish profiles (keep .pubxml, ignore per-user overrides) ────────────────
*.pubxml.user

# ── NuGet ─────────────────────────────────────────────────────────────────────
.nuget/
packages/
*.nupkg

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.tmp
*.temp
*.bak
*.orig

# ── Application runtime data (user-specific, not source) ──────────────────────
# These are written by the app at runtime in %AppData%
# Nothing to exclude here — they live outside the repo

# ── Sensitive ─────────────────────────────────────────────────────────────────
*.key
*.pem
*.pfx
appsettings.Local.json
secrets.json

# License signing private key — never commit
.license-signing/

# License bot secrets/data
CryptoAITerminal.LicenseBot/appsettings.json
*.db
*.db-shm
*.db-wal

# Claude Code / environment cruft (not part of the .NET solution)
node_modules/
package.json
package-lock.json
.claude/
portfolio/

    <Setter Property="Background">
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#050B11" Offset="0" />
        <GradientStop Color="#09131C" Offset="0.45" />
        <GradientStop Color="#050A10" Offset="1" />
      </LinearGradientBrush>
    </Setter>
  </Style>

  <Style Selector="Ellipse.SplashAuraPrimary">
    <Setter Property="Fill" Value="#2239D8C8" />
    <Setter Property="Opacity" Value="0.55" />
    <Setter Property="Effect">

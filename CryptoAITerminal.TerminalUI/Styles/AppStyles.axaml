<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Styles.Resources>
    <!-- ============================================================
         ПАЛИТРА — выровнена под референс-дизайн дашборда
         bg #060D14 · карточка #07101A · бордер #152233 · 14px
    ============================================================ -->
    <!-- Цвета фона -->
    <SolidColorBrush x:Key="AppBg" Color="#060D14" />
    <SolidColorBrush x:Key="AppBg2" Color="#07101A" />
    <!-- Уровни поверхностей -->
    <SolidColorBrush x:Key="Surface0" Color="#060D14" />
    <SolidColorBrush x:Key="Surface1" Color="#07101A" />
    <SolidColorBrush x:Key="Surface2" Color="#0A1422" />
    <SolidColorBrush x:Key="Surface3" Color="#0D1828" />
    <!-- Вложенные панели (внутри карточек) -->
    <SolidColorBrush x:Key="SurfaceInner" Color="#060D14" />
    <SolidColorBrush x:Key="SurfaceInner2" Color="#0A131E" />
    <!-- Бордеры -->
    <SolidColorBrush x:Key="PanelStroke" Color="#152233" />
    <SolidColorBrush x:Key="PanelStrokeBright" Color="#22384F" />
    <SolidColorBrush x:Key="PanelStrokeSubtle" Color="#111C28" />
    <!-- Текст -->
    <SolidColorBrush x:Key="TextPrimary" Color="#E8F4FF" />
    <SolidColorBrush x:Key="TextSecondary" Color="#D0E4F4" />
    <SolidColorBrush x:Key="TextMuted" Color="#8FA3B8" />
    <SolidColorBrush x:Key="TextSoft" Color="#5A7A94" />
    <SolidColorBrush x:Key="TextDim" Color="#3D5A72" />
    <!-- Акценты -->
    <SolidColorBrush x:Key="Accent" Color="#21E6C1" />
    <SolidColorBrush x:Key="AccentSoft" Color="#0E2A2A" />
    <SolidColorBrush x:Key="AccentBlue" Color="#5BC0FF" />
    <SolidColorBrush x:Key="AccentPurple" Color="#A78BFA" />
    <!-- Статус -->
    <SolidColorBrush x:Key="Positive" Color="#3DDC84" />
    <SolidColorBrush x:Key="Negative" Color="#FF6B6B" />
    <SolidColorBrush x:Key="Warning" Color="#F4B860" />

    <!-- Устаревшие алиасы (обратная совместимость) -->
    <SolidColorBrush x:Key="PanelBg" Color="#07101A" />
    <SolidColorBrush x:Key="PanelBgAlt" Color="#060D14" />
  </Styles.Resources>

  <!-- ============================================================
       WINDOW
  ============================================================ -->
  <Style Selector="Window">
    <Setter Property="Background" Value="#060D14" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Inter, Arial" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
  </Style>

  <!-- ============================================================
       ПАНЕЛИ — 5 семантических уровней
       Surface0  = самый тёмный, для sink-областей (chart bg, log)
       Surface1  = базовая карточка
       Surface2  = приподнятая карточка
       Surface3  = hero / выделенная секция
       SurfaceChrome = chrome-элементы (TopBar, Sidebar)
  ============================================================ -->

  <Style Selector="Border.Surface0">
    <Setter Property="Background" Value="#060D14" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelStrokeSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="10" />
  </Style>

  <Style Selector="Border.Surface1">
    <Setter Property="Background" Value="{DynamicResource Surface1}" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelStroke}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="14" />
  </Style>

  <Style Selector="Border.Surface2">
    <Setter Property="Background" Value="#07101A" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelStroke}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="16" />
  </Style>

  <Style Selector="Border.Surface3">
    <Setter Property="Background">
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#11242C" Offset="0" />
        <GradientStop Color="#171E30" Offset="0.55" />
        <GradientStop Color="#111824" Offset="1" />
      </LinearGradientBrush>
    </Setter>
    <Setter Property="CornerRadius" Value="22" />
    <Setter Property="BorderBrush" Value="#2F4C58" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="22" />
    <Setter Property="BoxShadow">
      <BoxShadows>0 24 54 0 #44050A14</BoxShadows>
    </Setter>
  </Style>

  <Style Selector="Border.SurfaceChrome">
    <Setter Property="Background">
      <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#08111A" Offset="0" />
        <GradientStop Color="#0A121D" Offset="1" />
      </LinearGradientBrush>
    </Setter>
    <Setter Property="CornerRadius" Value="22" />
    <Setter Property="BorderBrush" Value="#1E2B38" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BoxShadow">
      <BoxShadows>0 18 44 0 #2A02070E</BoxShadows>
    </Setter>
  </Style>

  <!-- Алиасы для обратной совместимости с существующими View-файлами.
       Панель дашборда — плоская карточка в стиле референса. -->
  <Style Selector="Border.Panel">
    <Setter Property="Background" Value="#07101A" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="BorderBrush" Value="#152233" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="14" />
  </Style>

  <Style Selector="Border.HeroPanel">
    <Setter Property="Background">
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#11242C" Offset="0" />
        <GradientStop Color="#171E30" Offset="0.55" />
        <GradientStop Color="#111824" Offset="1" />
      </LinearGradientBrush>
    </Setter>
    <Setter Property="CornerRadius" Value="22" />
    <Setter Property="BorderBrush" Value="#2F4C58" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="22" />
    <Setter Property="BoxShadow">
      <BoxShadows>0 24 54 0 #44050A14</BoxShadows>
    </Setter>
  </Style>

  <Style Selector="Border.SoftPanel">
    <Setter Property="Background" Value="#07101A" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="BorderBrush" Value="#152233" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="14" />
  </Style>

  <Style Selector="Border.SectionPanel">
    <Setter Property="Background">
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#101924" Offset="0" />
        <GradientStop Color="#0C141D" Offset="1" />
      </LinearGradientBrush>
    </Setter>
    <Setter Property="CornerRadius" Value="20" />
    <Setter Property="BorderBrush" Value="#294052" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="16" />
    <Setter Property="BoxShadow">
      <BoxShadows>0 18 42 0 #22040A12</BoxShadows>
    </Setter>
  </Style>

  <Style Selector="Border.SurfaceCard">
    <Setter Property="Background" Value="#07101A" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="BorderBrush" Value="#152233" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="14" />
  </Style>

  <!-- Сайдбар: плоская панель во всю высоту, только правая граница -->
  <Style Selector="Border.SidebarShell">
    <Setter Property="Background" Value="#050C14" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="BorderBrush" Value="#0D1B27" />
    <Setter Property="BorderThickness" Value="0,0,1,0" />
  </Style>

  <!-- Топбар: плоская панель, только нижняя граница -->
  <Style Selector="Border.TopBarShell">
    <Setter Property="Background" Value="#050C14" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="BorderBrush" Value="#0D1B27" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>

  <!-- Групповой заголовок в сайдбаре (TRADING, PORTFOLIO, …) -->
  <Style Selector="TextBlock.SideNavGroup">
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="LetterSpacing" Value="1.4" />
    <Setter Property="Foreground" Value="#4E7A96" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- Тикер-элемент в топбаре -->
  <Style Selector="Border.TickerItem">
    <Setter Property="Padding" Value="12,0" />
  </Style>

  <!-- Пульсирующая точка статуса (CONNECTED / AI ON / сессия) -->
  <Style Selector="Ellipse.PulseDot">
    <Style.Animations>
      <Animation Duration="0:0:1.8" IterationCount="INFINITE" Easing="SineEaseInOut">
        <KeyFrame Cue="0%">   <Setter Property="Opacity" Value="1.0" /></KeyFrame>
        <KeyFrame Cue="50%">  <Setter Property="Opacity" Value="0.3" /></KeyFrame>
        <KeyFrame Cue="100%"> <Setter Property="Opacity" Value="1.0" /></KeyFrame>
      </Animation>
    </Style.Animations>
  </Style>

  <!-- ============================================================
       ТИПОГРАФИКА
  ============================================================ -->
  <Style Selector="TextBlock.H1">
    <Setter Property="FontSize" Value="30" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
  </Style>

  <Style Selector="TextBlock.H2">
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
  </Style>

  <Style Selector="TextBlock.Overline">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextSoft}" />
  </Style>

  <Style Selector="TextBlock.Metric">
    <Setter Property="FontSize" Value="24" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
  </Style>

  <Style Selector="TextBlock.SectionMetric">
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
  </Style>

  <Style Selector="TextBlock.SecondaryCopy">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
  </Style>

  <Style Selector="TextBlock.MicroCopy">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="{DynamicResource TextSoft}" />
  </Style>

  <Style Selector="TextBlock.Value">
    <Setter Property="FontSize" Value="32" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{DynamicResource Accent}" />
  </Style>

  <Style Selector="TextBlock.BrandTitle">
    <Setter Property="FontSize" Value="15" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="LetterSpacing" Value="0.6" />
  </Style>

  <!-- ============================================================
       НАВИГАЦИЯ
  ============================================================ -->
  <Style Selector="Border.BrandGlyph">
    <Setter Property="Width" Value="42" />
    <Setter Property="Height" Value="42" />
    <Setter Property="Background" Value="#0C1824" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="BorderBrush" Value="#1F3D46" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="8" />
  </Style>

  <Style Selector="Border.NavGlyph">
    <Setter Property="Background" Value="#07111A" />
    <Setter Property="BorderBrush" Value="#132335" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
  </Style>

  <!-- Иконка меню: тонкая контурная (line-icon, как в примере).
       Цвет наследуется от Foreground кнопки через привязку на каждой иконке. -->
  <Style Selector="Path.NavIcon">
    <Setter Property="StrokeThickness" Value="1.9" />
    <Setter Property="StrokeLineCap" Value="Round" />
    <Setter Property="StrokeJoin" Value="Round" />
    <Setter Property="Fill" Value="{x:Null}" />
  </Style>

  <Style Selector="Button.SideNavButton">
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="Padding" Value="8,7" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#5A7A94" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="MinHeight" Value="34" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <Style Selector="Button.SideNavButton:pointerover">
    <Setter Property="Background" Value="#0A1826" />
    <Setter Property="Foreground" Value="#C8DCEF" />
  </Style>

  <!-- Активный пункт меню — плоская заливка -->
  <Style Selector="Button.SideNavButton.active">
    <Setter Property="Background" Value="#0B2030" />
    <Setter Property="Foreground" Value="#D4EEFF" />
  </Style>

  <Style Selector="Button.SideUtilityButton">
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Padding" Value="14,10" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Background" Value="#0C151F" />
    <Setter Property="BorderBrush" Value="#1E2A37" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="#8FA3B8" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <Style Selector="Button.TopNavButton">
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button.TopNavButton:pointerover">
    <Setter Property="Background" Value="#0F1823" />
  </Style>

  <Style Selector="Border.StatusPill">
    <Setter Property="Background" Value="#0F1822" />
    <Setter Property="BorderBrush" Value="#213140" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="12,7" />
  </Style>

  <Style Selector="Border.TopIconChip">
    <Setter Property="Width" Value="32" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Background" Value="#0F1822" />
    <Setter Property="BorderBrush" Value="#22303F" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="17" />
  </Style>

  <!-- ============================================================
       КНОПКИ
  ============================================================ -->
  <Style Selector="Button">
    <Setter Property="Padding" Value="14,9" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Background" Value="#121A24" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelStrokeBright}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="MinHeight" Value="36" />
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="#1A2840" />
    <Setter Property="BorderBrush" Value="#4A7AAA" />
  </Style>

  <Style Selector="Button:pressed">
    <Setter Property="RenderTransform">
      <ScaleTransform ScaleX="0.975" ScaleY="0.975" />
    </Setter>
    <Setter Property="Opacity" Value="0.85" />
  </Style>

  <Style Selector="Button:disabled">
    <Setter Property="Opacity" Value="0.4" />
  </Style>

  <Style Selector="Button.PrimaryTradeButton">
    <Setter Property="Background">
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#149B85" Offset="0" />
        <GradientStop Color="#21E6C1" Offset="1" />
      </LinearGradientBrush>
    </Setter>
    <Setter Property="Foreground" Value="#051018" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="FontSize" Value="17" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <!-- AccentButton — стандартная акцентная кнопка для действий в панелях -->
  <Style Selector="Button.AccentButton">
    <Setter Property="Background">
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#149B85" Offset="0" />
        <GradientStop Color="#21E6C1" Offset="1" />
      </LinearGradientBrush>
    </Setter>
    <Setter Property="Foreground" Value="#051018" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="16,8" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="CornerRadius" Value="6" />
  </Style>
  <Style Selector="Button.AccentButton:disabled">
    <Setter Property="Background" Value="#1A2E3A" />
    <Setter Property="Foreground" Value="#3A5570" />
  </Style>

  <Style Selector="Button.TopActionButton">
    <Setter Property="Background">
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#15A58D" Offset="0" />
        <GradientStop Color="#1FE6C2" Offset="1" />
      </LinearGradientBrush>
    </Setter>
    <Setter Property="Foreground" Value="#071018" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="18,10" />
  </Style>

  <Style Selector="Button.BuyButton">
    <Setter Property="Background">
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#18A05D" Offset="0" />
        <GradientStop Color="#31D67C" Offset="1" />
      </LinearGradientBrush>
    </Setter>
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="Button.SellButton">
    <Setter Property="Background">
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#D74D5C" Offset="0" />
        <GradientStop Color="#FF776A" Offset="1" />
      </LinearGradientBrush>
    </Setter>
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="Button.TradeSideButton">
    <Setter Property="Height" Value="48" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <Style Selector="Button.GhostButton">
    <Setter Property="Background" Value="#0F1721" />
    <Setter Property="BorderBrush" Value="#2A3A4B" />
  </Style>

  <!-- Timeframe button: active state (selected) -->
  <Style Selector="Button.GhostButton.active">
    <Setter Property="Background"   Value="#132030" />
    <Setter Property="BorderBrush"  Value="#21E6C1" />
    <Setter Property="Foreground"   Value="#21E6C1" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Button.ChartToolbarButton">
    <Setter Property="MinWidth" Value="62" />
    <Setter Property="Height" Value="42" />
    <Setter Property="Padding" Value="14,0" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Button.AiPromptChip">
    <Setter Property="Background" Value="#101924" />
    <Setter Property="BorderBrush" Value="#294052" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="14,8" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button.SideNavGhost">
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Padding" Value="14,12" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Background" Value="#0D1721" />
    <Setter Property="BorderBrush" Value="#233243" />
  </Style>

  <!-- ============================================================
       ФОРМ-ЭЛЕМЕНТЫ
  ============================================================ -->
  <Style Selector="TextBox">
    <Setter Property="Background" Value="#131F2E" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    <Setter Property="BorderBrush" Value="#445E78" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="MinHeight" Value="42" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden" />
  </Style>

  <Style Selector="TextBox:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    <Setter Property="Background" Value="#152130" />
    <Setter Property="BorderThickness" Value="1.5" />
  </Style>

  <Style Selector="TextBox:pointerover">
    <Setter Property="BorderBrush" Value="#5A7A9A" />
  </Style>

  <Style Selector="TextBox.LogBox">
    <Setter Property="Background" Value="#0B1119" />
    <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
    <Setter Property="FontFamily" Value="Consolas, Cascadia Code, monospace" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="AcceptsReturn" Value="True" />
    <Setter Property="IsReadOnly" Value="True" />
    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    <Setter Property="Padding" Value="14" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="MinHeight" Value="0" />
  </Style>

  <Style Selector="TextBox.BotPromptBox">
    <Setter Property="Background" Value="#0D141D" />
    <Setter Property="BorderBrush" Value="#203040" />
  </Style>

  <Style Selector="NumericUpDown">
    <Setter Property="Background" Value="#131F2E" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    <Setter Property="BorderBrush" Value="#445E78" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="MinHeight" Value="42" />
    <Setter Property="Padding" Value="6,6" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <Style Selector="NumericUpDown:focus-within">
    <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    <Setter Property="Background" Value="#152130" />
  </Style>

  <Style Selector="NumericUpDown:pointerover">
    <Setter Property="BorderBrush" Value="#5A7A9A" />
  </Style>

  <!-- Compact spinner arrows so the number itself stays visible even in
       narrow numeric fields (default chevrons eat most of the width). -->
  <Style Selector="ButtonSpinner /template/ RepeatButton">
    <Setter Property="MinWidth" Value="22" />
    <Setter Property="Width" Value="22" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="Background" Value="#131F2E" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    <Setter Property="BorderBrush" Value="#445E78" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="10,10" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="MinHeight" Value="42" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <Style Selector="ComboBox:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}" />
  </Style>

  <Style Selector="ComboBoxItem">
    <Setter Property="Background" Value="#101821" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    <Setter Property="Padding" Value="12,10" />
  </Style>

  <Style Selector="ComboBoxItem:pointerover">
    <Setter Property="Background" Value="#172230" />
  </Style>

  <Style Selector="Slider.TradeSlider">
    <Setter Property="MinHeight" Value="28" />
  </Style>

  <!-- ============================================================
       ЧЕКБОКСЫ — крупный, выровненный бокс 22px с акцентной галкой
  ============================================================ -->
  <Style Selector="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Template">
      <ControlTemplate>
        <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center" Background="Transparent">
          <Border Name="Box"
                  Grid.Column="0"
                  Width="22" Height="22"
                  CornerRadius="6"
                  Background="#0E151E"
                  BorderBrush="#3C566E"
                  BorderThickness="1.4"
                  VerticalAlignment="Center">
            <Path Name="Check"
                  Stretch="Uniform"
                  Width="12" Height="12"
                  Stroke="#04101A"
                  StrokeThickness="2.4"
                  StrokeJoin="Round"
                  StrokeLineCap="Round"
                  Data="M2,7 L6,11 L13,3"
                  IsVisible="False" />
          </Border>
          <ContentPresenter Name="PART_ContentPresenter"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            RecognizesAccessKey="True" />
        </Grid>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="CheckBox:pointerover /template/ Border#Box">
    <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
  </Style>

  <Style Selector="CheckBox:checked /template/ Border#Box">
    <Setter Property="Background" Value="{DynamicResource Accent}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
  </Style>

  <Style Selector="CheckBox:checked /template/ Path#Check">
    <Setter Property="IsVisible" Value="True" />
  </Style>

  <Style Selector="CheckBox:indeterminate /template/ Border#Box">
    <Setter Property="Background" Value="#173D3D" />
    <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
  </Style>

  <Style Selector="CheckBox:disabled">
    <Setter Property="Opacity" Value="0.45" />
  </Style>

  <!-- ============================================================
       СПИСКИ
  ============================================================ -->
  <Style Selector="ListBox">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="ListBoxItem">
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0,0,0,10" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="ListBoxItem /template/ ContentPresenter">
    <Setter Property="Background" Value="#111924" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="12" />
  </Style>

  <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#172231" />
  </Style>

  <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background">
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#17373B" Offset="0" />
        <GradientStop Color="#1A2540" Offset="1" />
      </LinearGradientBrush>
    </Setter>
    <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <!-- ============================================================
       ТАБЫ
  ============================================================ -->
  <Style Selector="TabControl">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TabControl > TabItem">
    <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="18,10" />
    <Setter Property="Margin" Value="0,0,8,0" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="TabControl > TabItem /template/ ContentPresenter">
    <Setter Property="Background" Value="#101822" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="14,8" />
  </Style>

  <Style Selector="TabControl > TabItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#182333" />
  </Style>

  <Style Selector="TabControl > TabItem:selected">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
  </Style>

  <Style Selector="TabControl > TabItem:selected /template/ ContentPresenter">
    <Setter Property="Background">
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#11323A" Offset="0" />
        <GradientStop Color="#16293A" Offset="1" />
      </LinearGradientBrush>
    </Setter>
    <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="TabControl.PrimaryNavTabs">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TabControl.PrimaryNavTabs > TabItem">
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="Foreground" Value="Transparent" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Opacity" Value="0" />
    <Setter Property="IsHitTestVisible" Value="False" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Height" Value="0" />
  </Style>

  <Style Selector="TabControl.PrimaryNavTabs > TabItem /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Height" Value="0" />
  </Style>

  <Style Selector="TabControl.PrimaryNavTabs > TabItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TabControl.PrimaryNavTabs > TabItem:selected">
    <Setter Property="Foreground" Value="Transparent" />
  </Style>


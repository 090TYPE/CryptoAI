  <!-- ============================================================
       ВИДЖЕТЫ ДАШБОРДА — общие стили в стиле референс-дизайна
       (плоские тёмные карточки, моноширинные числа, бейджи)
  ============================================================ -->

  <!-- Заголовок виджета: мелкий, верхний регистр, приглушённый -->
  <Style Selector="TextBlock.WidgetTitle">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="LetterSpacing" Value="1.2" />
    <Setter Property="Foreground" Value="#8FA3B8" />
  </Style>

  <!-- Микро-подпись (метка над числом) -->
  <Style Selector="TextBlock.StatLabel">
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LetterSpacing" Value="0.8" />
    <Setter Property="Foreground" Value="#5A7A94" />
  </Style>

  <!-- Моноширинное число (цены, объёмы) -->
  <Style Selector="TextBlock.Mono">
    <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
  </Style>

  <!-- Плоская стат-ячейка (внутри виджета) -->
  <Style Selector="Border.StatCell">
    <Setter Property="Background" Value="#060D14" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="BorderBrush" Value="#111C28" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="12,10" />
  </Style>

  <!-- Вложенная панель/таблица -->
  <Style Selector="Border.InnerCard">
    <Setter Property="Background" Value="#060D14" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="BorderBrush" Value="#111C28" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="10" />
  </Style>

  <!-- Бейдж-счётчик (напр. «8 coins») справа в шапке -->
  <Style Selector="Border.CountBadge">
    <Setter Property="Background" Value="#0A1422" />
    <Setter Property="BorderBrush" Value="#152233" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="8,2" />
  </Style>

  <!-- Бейдж LIVE -->
  <Style Selector="Border.LivePill">
    <Setter Property="Background" Value="#0E2A2A" />
    <Setter Property="BorderBrush" Value="#21E6C1" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="10,5" />
  </Style>

  <!-- Строка таблицы виджета (наведение подсвечивает) -->
  <Style Selector="Border.WidgetRow">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="8,6" />
  </Style>
  <Style Selector="Border.WidgetRow:pointerover">
    <Setter Property="Background" Value="#0B1626" />
  </Style>

  <!-- Кнопка таймфрейма графика (компактная) -->
  <Style Selector="Button.TfButton">
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="MinHeight" Value="26" />
    <Setter Property="Height" Value="26" />
    <Setter Property="Padding" Value="10,0" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Background" Value="#0A1422" />
    <Setter Property="BorderBrush" Value="#152233" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="#8FA3B8" />
  </Style>
  <Style Selector="Button.TfButton.active">
    <Setter Property="Background" Value="#0E2A2A" />
    <Setter Property="BorderBrush" Value="#21E6C1" />
    <Setter Property="Foreground" Value="#21E6C1" />
  </Style>

  <!-- Маленькая «таблеточная» кнопка действия в виджете (Trade/Watch) -->
  <Style Selector="Button.MiniPill">
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="Padding" Value="10,3" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Background" Value="#0A1422" />
    <Setter Property="BorderBrush" Value="#22384F" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

</Styles>

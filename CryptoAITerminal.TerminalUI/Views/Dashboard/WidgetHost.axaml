<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vmd="clr-namespace:CryptoAITerminal.TerminalUI.ViewModels.Dashboard"
             xmlns:dash="clr-namespace:CryptoAITerminal.TerminalUI.Views.Dashboard"
             x:Class="CryptoAITerminal.TerminalUI.Views.Dashboard.WidgetHost"
             x:DataType="vmd:DashboardWidget"
             x:CompileBindings="False">
  <Border Classes="Panel" Margin="0">
    <Grid RowDefinitions="Auto,*">
      <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto,Auto" Margin="0,0,0,10">
        <TextBlock Grid.Column="0" x:Name="DragHandle" Text="☰" Margin="0,0,8,0"
                   Foreground="#8FA3B8" Cursor="SizeAll"
                   IsVisible="{Binding $parent[dash:WidgetHost].IsEditMode}" />
        <Border Grid.Column="1" Width="3" Height="13" CornerRadius="2" Background="#21E6C1"
                Margin="0,0,9,0" VerticalAlignment="Center" />
        <TextBlock Grid.Column="2" Text="{Binding Title}" Classes="WidgetTitle" VerticalAlignment="Center" />
        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="3" Margin="0,0,6,0"
                    IsVisible="{Binding $parent[dash:WidgetHost].IsEditMode}">
          <Button Content="W−" FontSize="11" Padding="6,2" ToolTip.Tip="Уже"
                  Command="{Binding $parent[ItemsControl].DataContext.DashboardLayoutVM.NarrowCommand}"
                  CommandParameter="{Binding}" />
          <Button Content="W+" FontSize="11" Padding="6,2" ToolTip.Tip="Шире"
                  Command="{Binding $parent[ItemsControl].DataContext.DashboardLayoutVM.WidenCommand}"
                  CommandParameter="{Binding}" />
          <Button Content="H−" FontSize="11" Padding="6,2" ToolTip.Tip="Ниже"
                  Command="{Binding $parent[ItemsControl].DataContext.DashboardLayoutVM.ShorterCommand}"
                  CommandParameter="{Binding}" />
          <Button Content="H+" FontSize="11" Padding="6,2" ToolTip.Tip="Выше"
                  Command="{Binding $parent[ItemsControl].DataContext.DashboardLayoutVM.TallerCommand}"
                  CommandParameter="{Binding}" />
        </StackPanel>
        <Button Grid.Column="4" Content="✕" Classes="GhostButton"
                IsVisible="{Binding $parent[dash:WidgetHost].IsEditMode}"
                Command="{Binding $parent[ItemsControl].DataContext.DashboardLayoutVM.RemoveWidgetCommand}"
                CommandParameter="{Binding}" />
      </Grid>
      <ContentControl Grid.Row="1" x:Name="Body" />
      <Thumb Grid.Row="1" x:Name="ResizeThumb" Width="16" Height="16"
             HorizontalAlignment="Right" VerticalAlignment="Bottom"
             Background="#7C5CFF" Cursor="BottomRightCorner"
             IsVisible="{Binding $parent[dash:WidgetHost].IsEditMode}" />
    </Grid>
  </Border>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CryptoAITerminal.TerminalUI.ViewModels"
             x:Class="CryptoAITerminal.TerminalUI.Views.Dashboard.Widgets.LiqHeatmapWidget"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">
  <Border Background="#04101A" CornerRadius="6" ClipToBounds="True"
          ToolTip.Tip="Liquidation Heatmap — click 🔥 Liq Map for fullscreen">
    <StackPanel>
      <TextBlock Text="LIQ MAP" Foreground="#4A6070" FontSize="9" FontWeight="Bold"
                 Margin="4,4,0,2" />
      <Viewbox Stretch="Fill">
        <Canvas Width="1200" Height="460">
          <!-- Heat bands — full-width, colour = side, opacity = magnitude -->
          <ItemsControl ItemsSource="{Binding LiquidationHeatmapVM.HeatBands}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <Canvas Width="1200" Height="460" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:HeatBand">
                <Rectangle Width="1200" Height="{Binding Height}" Fill="{Binding Fill}"
                           Canvas.Top="{Binding Y}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <Path Data="{Binding LiquidationHeatmapVM.CurrentPriceGeometry}"
                Stroke="#F4B860" StrokeThickness="2" StrokeDashArray="8,4" />
        </Canvas>
      </Viewbox>
    </StackPanel>
  </Border>
</UserControl>

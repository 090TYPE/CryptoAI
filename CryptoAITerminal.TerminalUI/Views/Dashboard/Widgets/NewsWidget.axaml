<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CryptoAITerminal.TerminalUI.ViewModels"
             x:Class="CryptoAITerminal.TerminalUI.Views.Dashboard.Widgets.NewsWidget"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">
  <StackPanel Spacing="8">

    <!-- AI Market Pulse summary -->
    <Border Background="#060D14" BorderBrush="#111C28" BorderThickness="1"
            CornerRadius="6" Padding="10,8">
      <Grid ColumnDefinitions="Auto,*">
        <Border Grid.Column="0" Background="{Binding NewsFeedVM.PulseBrush}" CornerRadius="3" Padding="6,2">
          <TextBlock Text="{Binding NewsFeedVM.PulseLabel}" Foreground="#06121C" FontSize="11" FontWeight="Bold" />
        </Border>
        <TextBlock Grid.Column="1" Text="{Binding NewsFeedVM.AiDigest}"
                   Foreground="{Binding NewsFeedVM.AiDigestBrush}"
                   FontSize="11" TextWrapping="Wrap" Margin="8,0,0,0" MaxLines="2" />
      </Grid>
    </Border>

    <!-- Status + unread badge -->
    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="{Binding NewsFeedVM.StatusLabel}" Foreground="#4A6880" FontSize="10" VerticalAlignment="Center" />
      <Border IsVisible="{Binding NewsFeedVM.HasUnread}"
              Background="#FF6B6B" CornerRadius="8" Padding="5,1">
        <TextBlock Text="{Binding NewsFeedVM.UnreadBadge, StringFormat='{}{0} new'}"
                   Foreground="White" FontSize="9" FontWeight="Bold" />
      </Border>
    </StackPanel>

    <!-- Loading state -->
    <TextBlock IsVisible="{Binding NewsFeedVM.IsLoading}"
               Text="Fetching news…"
               Foreground="#4A6880" FontSize="11" />

    <!-- News rows -->
    <ScrollViewer IsVisible="{Binding !NewsFeedVM.IsLoading}"
                  VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding NewsFeedVM.Rows}">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type vm:NewsItemRowVM}">
            <Border Background="{Binding SentimentBackground}"
                    CornerRadius="3" Padding="8,5" Margin="0,1"
                    BorderBrush="#17263A" BorderThickness="0,0,0,1">
              <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                <!-- Sentiment badge -->
                <Border Grid.Column="0" CornerRadius="3" Padding="5,2" VerticalAlignment="Top" Margin="0,1,0,0">
                  <Border.Background>
                    <SolidColorBrush Color="{Binding SentimentBrush}" Opacity="0.15" />
                  </Border.Background>
                  <TextBlock Text="{Binding SentimentLabel}"
                             Foreground="{Binding SentimentBrush}"
                             FontSize="9" FontWeight="Bold" />
                </Border>
                <!-- Title + meta -->
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="{Binding Title}" Foreground="#C8D8E8"
                             FontSize="11" TextWrapping="Wrap" />
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding Source}" Foreground="#4A6880" FontSize="9" />
                    <TextBlock Text="·" Foreground="#2D4A5A" FontSize="9" />
                    <TextBlock Text="{Binding AgeLabel}" Foreground="#4A6880" FontSize="9" />
                  </StackPanel>
                </StackPanel>
                <!-- Votes -->
                <TextBlock Grid.Column="2" Text="{Binding VotesLabel}"
                           Foreground="{Binding VotesBrush}"
                           FontSize="10" FontWeight="Bold"
                           VerticalAlignment="Top" Margin="0,1,0,0" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </StackPanel>
</UserControl>

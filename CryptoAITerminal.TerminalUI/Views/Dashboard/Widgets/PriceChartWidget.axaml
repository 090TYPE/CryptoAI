<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CryptoAITerminal.TerminalUI.ViewModels"
             xmlns:ctrl="clr-namespace:CryptoAITerminal.TerminalUI.Controls"
             x:Class="CryptoAITerminal.TerminalUI.Views.Dashboard.Widgets.PriceChartWidget"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">
  <Border Classes="SoftPanel">
    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
      <TextBlock Grid.Row="0" Classes="H2" Text="Live Price Chart" />
      <ctrl:CexPriceChart Grid.Row="1"
                          Height="240"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Points="{Binding SelectedMarket.ChartPoints}"
                          IsPositiveTrend="{Binding SelectedMarket.IsPositiveTrend}" />
      <TextBlock Grid.Row="2"
                 Text="{Binding SelectedMarket.LastUpdated, StringFormat=Last tick: {0:dd.MM.yyyy HH:mm:ss}}"
                 Foreground="#8B949E" />
    </Grid>
  </Border>
</UserControl>

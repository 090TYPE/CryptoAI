<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CryptoAITerminal.TerminalUI.ViewModels"
             x:Class="CryptoAITerminal.TerminalUI.Views.Dashboard.Widgets.PriceStatsWidget"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">
  <Grid ColumnDefinitions="*,*,*,*,*,*,*,*" ColumnSpacing="10">

    <!-- LAST PRICE -->
    <Border Classes="StatCell" Grid.Column="0">
      <StackPanel Spacing="3">
        <TextBlock Classes="StatLabel" Text="LAST PRICE" />
        <TextBlock Classes="Mono" FontSize="17" FontWeight="Bold"
                   Text="{Binding SelectedMarket.LastPrice, StringFormat='{}{0:N2}'}" />
        <TextBlock FontSize="10" FontWeight="SemiBold"
                   Text="{Binding SelectedMarket.ChangePercentLabel}"
                   Foreground="{Binding SelectedMarket.ChangeBrush}" />
      </StackPanel>
    </Border>

    <!-- BEST BID -->
    <Border Classes="StatCell" Grid.Column="1">
      <StackPanel Spacing="3">
        <TextBlock Classes="StatLabel" Text="BEST BID" />
        <TextBlock Classes="Mono" FontSize="17" FontWeight="Bold" Foreground="#3DDC84"
                   Text="{Binding SelectedMarket.BestBid, StringFormat='{}{0:N2}'}" />
        <TextBlock FontSize="10" Foreground="#5A7A94"
                   Text="{Binding SelectedMarket.SpreadPercentLabel, StringFormat='{}{0} spread'}" />
      </StackPanel>
    </Border>

    <!-- BEST ASK -->
    <Border Classes="StatCell" Grid.Column="2">
      <StackPanel Spacing="3">
        <TextBlock Classes="StatLabel" Text="BEST ASK" />
        <TextBlock Classes="Mono" FontSize="17" FontWeight="Bold" Foreground="#FF6B6B"
                   Text="{Binding SelectedMarket.BestAsk, StringFormat='{}{0:N2}'}" />
        <TextBlock FontSize="10" Foreground="#5A7A94"
                   Text="{Binding SelectedMarket.SpreadPercentLabel, StringFormat='{}{0} spread'}" />
      </StackPanel>
    </Border>

    <!-- 24H CHANGE -->
    <Border Classes="StatCell" Grid.Column="3">
      <StackPanel Spacing="3">
        <TextBlock Classes="StatLabel" Text="24H CHANGE" />
        <TextBlock Classes="Mono" FontSize="17" FontWeight="Bold"
                   Text="{Binding SelectedMarket.ChangePercentLabel}"
                   Foreground="{Binding SelectedMarket.ChangeBrush}" />
        <TextBlock FontSize="10"
                   Text="{Binding SelectedMarket.TrendLabel}"
                   Foreground="{Binding SelectedMarket.TrendBrush}" />
      </StackPanel>
    </Border>

    <!-- SESSION HIGH -->
    <Border Classes="StatCell" Grid.Column="4">
      <StackPanel Spacing="3">
        <TextBlock Classes="StatLabel" Text="24H HIGH" />
        <TextBlock Classes="Mono" FontSize="17" FontWeight="Bold"
                   Text="{Binding SelectedMarket.SessionHigh, StringFormat='{}{0:N2}'}" />
        <TextBlock FontSize="10" Foreground="#3DDC84" Text="session peak" />
      </StackPanel>
    </Border>

    <!-- SESSION LOW -->
    <Border Classes="StatCell" Grid.Column="5">
      <StackPanel Spacing="3">
        <TextBlock Classes="StatLabel" Text="24H LOW" />
        <TextBlock Classes="Mono" FontSize="17" FontWeight="Bold"
                   Text="{Binding SelectedMarket.SessionLow, StringFormat='{}{0:N2}'}" />
        <TextBlock FontSize="10" Foreground="#FF6B6B" Text="session floor" />
      </StackPanel>
    </Border>

    <!-- RANGE -->
    <Border Classes="StatCell" Grid.Column="6">
      <StackPanel Spacing="3">
        <TextBlock Classes="StatLabel" Text="SESSION RANGE" />
        <TextBlock Classes="Mono" FontSize="14" FontWeight="Bold" Foreground="#5BC0FF"
                   Text="{Binding SelectedMarket.RangeLabel}" />
        <TextBlock FontSize="10" Foreground="#5A7A94"
                   Text="{Binding SelectedMarket.RangePercent, StringFormat='{}{0:N2}% band'}" />
      </StackPanel>
    </Border>

    <!-- SPREAD -->
    <Border Classes="StatCell" Grid.Column="7">
      <StackPanel Spacing="3">
        <TextBlock Classes="StatLabel" Text="SPREAD" />
        <TextBlock Classes="Mono" FontSize="17" FontWeight="Bold" Foreground="#A78BFA"
                   Text="{Binding SelectedMarket.Spread, StringFormat='{}{0:N2}'}" />
        <TextBlock FontSize="10" Foreground="#5A7A94"
                   Text="{Binding SelectedMarket.UpdatedLabel, StringFormat='upd {0}'}" />
      </StackPanel>
    </Border>

  </Grid>
</UserControl>

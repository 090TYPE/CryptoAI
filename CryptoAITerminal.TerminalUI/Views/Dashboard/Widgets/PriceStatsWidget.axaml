<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CryptoAITerminal.TerminalUI.ViewModels"
             x:Class="CryptoAITerminal.TerminalUI.Views.Dashboard.Widgets.PriceStatsWidget"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">
  <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="16">
    <Border Classes="Panel" Grid.Column="0">
      <StackPanel>
        <TextBlock Text="Last Price" Foreground="#8B949E" />
        <TextBlock Classes="Value"
                   FontSize="24"
                   Text="{Binding SelectedMarket.LastPrice, StringFormat=$ {0:N4}}" />
      </StackPanel>
    </Border>
    <Border Classes="Panel" Grid.Column="1">
      <StackPanel>
        <TextBlock Text="Best Bid" Foreground="#8B949E" />
        <TextBlock Classes="Value"
                   FontSize="24"
                   Text="{Binding SelectedMarket.BestBid, StringFormat=$ {0:N4}}" />
      </StackPanel>
    </Border>
    <Border Classes="Panel" Grid.Column="2">
      <StackPanel>
        <TextBlock Text="Best Ask" Foreground="#8B949E" />
        <TextBlock Classes="Value"
                   FontSize="24"
                   Text="{Binding SelectedMarket.BestAsk, StringFormat=$ {0:N4}}" />
      </StackPanel>
    </Border>
    <Border Classes="Panel" Grid.Column="3">
      <StackPanel>
        <TextBlock Text="Spread" Foreground="#8B949E" />
        <TextBlock Classes="Value"
                   FontSize="24"
                   Text="{Binding SelectedMarket.Spread, StringFormat=$ {0:N6}}" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>

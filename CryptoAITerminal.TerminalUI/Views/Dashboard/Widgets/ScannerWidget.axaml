<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CryptoAITerminal.TerminalUI.ViewModels"
             x:Class="CryptoAITerminal.TerminalUI.Views.Dashboard.Widgets.ScannerWidget"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">
  <StackPanel Spacing="8">

    <!-- KPI strip -->
    <StackPanel Orientation="Horizontal" Spacing="8">
      <Border Background="#0D1B29" CornerRadius="6" Padding="10,5">
        <StackPanel Spacing="1" HorizontalAlignment="Center">
          <TextBlock Text="Total" FontSize="9" Foreground="#3A4F63" HorizontalAlignment="Center" />
          <TextBlock Text="{Binding ScannerVM.TotalSymbols}" FontSize="14" FontWeight="Bold"
                     Foreground="#8FA3B8" HorizontalAlignment="Center" />
        </StackPanel>
      </Border>
      <Border Background="#0A1F16" CornerRadius="6" Padding="10,5">
        <StackPanel Spacing="1" HorizontalAlignment="Center">
          <TextBlock Text="Hot" FontSize="9" Foreground="#3A4F63" HorizontalAlignment="Center" />
          <TextBlock Text="{Binding ScannerVM.HotCount}" FontSize="14" FontWeight="Bold"
                     Foreground="#FF6B00" HorizontalAlignment="Center" />
        </StackPanel>
      </Border>
      <Border Background="#0A1F0A" CornerRadius="6" Padding="10,5">
        <StackPanel Spacing="1" HorizontalAlignment="Center">
          <TextBlock Text="Gainers" FontSize="9" Foreground="#3A4F63" HorizontalAlignment="Center" />
          <TextBlock Text="{Binding ScannerVM.GainersCount}" FontSize="14" FontWeight="Bold"
                     Foreground="#21E6C1" HorizontalAlignment="Center" />
        </StackPanel>
      </Border>
      <Border Background="#1F0A0A" CornerRadius="6" Padding="10,5">
        <StackPanel Spacing="1" HorizontalAlignment="Center">
          <TextBlock Text="Losers" FontSize="9" Foreground="#3A4F63" HorizontalAlignment="Center" />
          <TextBlock Text="{Binding ScannerVM.LosersCount}" FontSize="14" FontWeight="Bold"
                     Foreground="#FF5555" HorizontalAlignment="Center" />
        </StackPanel>
      </Border>
    </StackPanel>

    <!-- Table header -->
    <Grid ColumnDefinitions="20,*,80,70,80,60">
      <TextBlock Grid.Column="0" Text="" FontSize="9" Foreground="#3A4F63" />
      <TextBlock Grid.Column="1" Text="SYMBOL"  Foreground="#3A4F63" FontSize="9" FontWeight="Bold" />
      <TextBlock Grid.Column="2" Text="PRICE"   Foreground="#3A4F63" FontSize="9" FontWeight="Bold" HorizontalAlignment="Right" />
      <TextBlock Grid.Column="3" Text="24h %"   Foreground="#3A4F63" FontSize="9" FontWeight="Bold" HorizontalAlignment="Right" />
      <TextBlock Grid.Column="4" Text="VOLUME"  Foreground="#3A4F63" FontSize="9" FontWeight="Bold" HorizontalAlignment="Right" />
      <TextBlock Grid.Column="5" Text="RSI"     Foreground="#3A4F63" FontSize="9" FontWeight="Bold" HorizontalAlignment="Right" />
    </Grid>
    <Rectangle Height="1" Fill="#1E3A5F" />

    <!-- Scanner rows -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding ScannerVM.Rows}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="{Binding RowBackground}" Margin="0,1" Padding="0">
              <Grid ColumnDefinitions="20,*,80,70,80,60" Margin="2,4">
                <TextBlock Grid.Column="0" Text="{Binding HotBadgeText}"
                           FontSize="11" VerticalAlignment="Center"
                           HorizontalAlignment="Center" />
                <StackPanel Grid.Column="1" Spacing="0" VerticalAlignment="Center">
                  <TextBlock Text="{Binding Symbol}" FontSize="11"
                             FontWeight="SemiBold" Foreground="#E8F0FE" />
                  <TextBlock Text="{Binding Exchange}" FontSize="9"
                             Foreground="#3A4F63" />
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding PriceLabel}"
                           FontFamily="Consolas" FontSize="10"
                           Foreground="#8FA3B8"
                           HorizontalAlignment="Right" VerticalAlignment="Center" />
                <TextBlock Grid.Column="3" Text="{Binding ChangeLabel}"
                           FontFamily="Consolas" FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{Binding ChangeBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Center" />
                <TextBlock Grid.Column="4" Text="{Binding VolumeLabel}"
                           FontFamily="Consolas" FontSize="10"
                           Foreground="#5C6E82"
                           HorizontalAlignment="Right" VerticalAlignment="Center" />
                <TextBlock Grid.Column="5" Text="{Binding RsiLabel}"
                           FontFamily="Consolas" FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{Binding RsiBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Center" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </StackPanel>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CryptoAITerminal.TerminalUI.ViewModels"
             x:Class="CryptoAITerminal.TerminalUI.Views.Dashboard.Widgets.TapeWidget"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">
  <StackPanel Spacing="8">

    <!-- Pressure + status summary -->
    <StackPanel Spacing="3">
      <TextBlock Text="{Binding MarketTapeVM.PressureLabel}" FontWeight="SemiBold"
                 Foreground="{Binding MarketTapeVM.PressureBrush}" FontSize="12" />
      <TextBlock Text="{Binding MarketTapeVM.StatusLabel}" Foreground="#8FA3B8" FontSize="10" />
    </StackPanel>

    <!-- Column headers -->
    <Grid ColumnDefinitions="38,80,50,*,*,70,90" Margin="0,0,0,2">
      <TextBlock Grid.Column="0" Text="Src"    Foreground="#8FA3B8" FontSize="10" />
      <TextBlock Grid.Column="1" Text="Time"   Foreground="#8FA3B8" FontSize="10" />
      <TextBlock Grid.Column="2" Text="Side"   Foreground="#8FA3B8" FontSize="10" />
      <TextBlock Grid.Column="3" Text="Price"  Foreground="#8FA3B8" FontSize="10" />
      <TextBlock Grid.Column="4" Text="Qty"    Foreground="#8FA3B8" FontSize="10" />
      <TextBlock Grid.Column="5" Text="USD"    Foreground="#8FA3B8" FontSize="10" HorizontalAlignment="Right" />
      <TextBlock Grid.Column="6" Text="Wallet" Foreground="#8FA3B8" FontSize="10" />
    </Grid>

    <!-- Trade tape -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding MarketTapeVM.Rows}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="{Binding RowBrush}" CornerRadius="2" Padding="2,1">
              <Grid ColumnDefinitions="38,80,50,*,*,70,90">
                <TextBlock Grid.Column="0" Text="{Binding VenueLabel}"
                           Foreground="{Binding VenueBrush}" FontSize="10" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{Binding TimeLabel}"
                           FontFamily="Cascadia Code,Consolas,monospace" FontSize="11" Foreground="#8FA3B8" />
                <TextBlock Grid.Column="2" Text="{Binding Side}"
                           Foreground="{Binding SideBrush}" FontWeight="{Binding Weight}" FontSize="11" />
                <TextBlock Grid.Column="3" Text="{Binding PriceLabel}"
                           FontFamily="Cascadia Code,Consolas,monospace" FontWeight="{Binding Weight}" FontSize="11" />
                <TextBlock Grid.Column="4" Text="{Binding QtyLabel}"
                           FontFamily="Cascadia Code,Consolas,monospace" FontSize="11" Foreground="#C7D3DF" />
                <TextBlock Grid.Column="5" Text="{Binding QuoteLabel}"
                           FontFamily="Cascadia Code,Consolas,monospace" FontWeight="{Binding Weight}" FontSize="11"
                           HorizontalAlignment="Right" Foreground="#C7D3DF" />
                <TextBlock Grid.Column="6" Text="{Binding TraderLabel}"
                           FontFamily="Cascadia Code,Consolas,monospace" FontSize="10" Foreground="#8FA3B8" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </StackPanel>
</UserControl>

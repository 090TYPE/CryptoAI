<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CryptoAITerminal.TerminalUI.ViewModels"
             xmlns:ctrl="clr-namespace:CryptoAITerminal.TerminalUI.Controls"
             x:Class="CryptoAITerminal.TerminalUI.Views.Dashboard.Widgets.TrackedCoinsWidget"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">
  <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">

    <!-- Count badge + loading -->
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
      <TextBlock Grid.Column="0" Text="Loading markets…" Classes="StatLabel"
                 VerticalAlignment="Center" IsVisible="{Binding IsMarketLoading}" />
      <Border Grid.Column="1" Classes="CountBadge">
        <TextBlock Text="{Binding Markets.Count, StringFormat='{}{0} coins'}"
                   Foreground="#8FA3B8" FontSize="10" FontWeight="SemiBold" />
      </Border>
    </Grid>

    <!-- Column headers -->
    <Grid Grid.Row="1" ColumnDefinitions="34,*,66,Auto" ColumnSpacing="8" Margin="2,0,4,0">
      <TextBlock Grid.Column="1" Text="SYMBOL" Classes="StatLabel" />
      <TextBlock Grid.Column="2" Text="TREND" Classes="StatLabel" HorizontalAlignment="Center" />
      <TextBlock Grid.Column="3" Text="PRICE / 24H" Classes="StatLabel" HorizontalAlignment="Right" />
    </Grid>

    <!-- Rows -->
    <ScrollViewer Grid.Row="2" Classes="PageScroll">
      <ListBox ItemsSource="{Binding Markets}"
               SelectedItem="{Binding SelectedMarket}">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:CexMarketItemViewModel">
            <Grid ColumnDefinitions="34,*,66,Auto" ColumnSpacing="8" VerticalAlignment="Center">
              <!-- Icon -->
              <Border Grid.Column="0" Width="30" Height="30" CornerRadius="8"
                      Background="{Binding LogoBackground}" VerticalAlignment="Center">
                <TextBlock Text="{Binding LogoText}" Foreground="{Binding LogoForeground}"
                           FontWeight="Bold" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <!-- Pair + exchange -->
              <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                <TextBlock Text="{Binding DisplaySymbol}" Foreground="#E8F4FF"
                           FontWeight="Bold" FontSize="12" />
                <TextBlock Text="{Binding Exchange}" Foreground="#5A7A94" FontSize="10" />
              </StackPanel>
              <!-- Sparkline -->
              <ctrl:CexPriceChart Grid.Column="2" Height="26" Width="60"
                                  VerticalAlignment="Center"
                                  Points="{Binding ChartPoints}"
                                  IsPositiveTrend="{Binding IsPositiveTrend}" />
              <!-- Price + change -->
              <StackPanel Grid.Column="3" Spacing="2" VerticalAlignment="Center"
                          HorizontalAlignment="Right">
                <TextBlock Classes="Mono" Text="{Binding LastPrice, StringFormat='{}{0:N2}'}"
                           Foreground="#E8F4FF" FontSize="12" FontWeight="SemiBold"
                           HorizontalAlignment="Right" />
                <TextBlock Text="{Binding ChangePercentLabel}"
                           Foreground="{Binding ChangeBrush}" FontSize="11" FontWeight="SemiBold"
                           HorizontalAlignment="Right" />
              </StackPanel>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </ScrollViewer>
  </Grid>
</UserControl>

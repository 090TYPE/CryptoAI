<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CryptoAITerminal.TerminalUI.ViewModels"
             xmlns:ctrl="clr-namespace:CryptoAITerminal.TerminalUI.Controls"
             x:Class="CryptoAITerminal.TerminalUI.Views.DashboardView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">
        <StackPanel Spacing="16">
        <Border Classes="HeroPanel"
                BorderBrush="{Binding WalletVM.GlobalQuoteAssetModeBrush}"
                BorderThickness="1.5">
          <Grid ColumnDefinitions="1.3*,Auto" ColumnSpacing="18">
            <StackPanel Spacing="6">
              <TextBlock Classes="Overline" Text="MARKET OVERVIEW" />
              <TextBlock Classes="H1" Text="{Binding SelectedMarketTitle}" />
            </StackPanel>

            <WrapPanel Orientation="Horizontal">
              <Border Classes="SoftPanel" MinWidth="150" Margin="0,0,12,0">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Last Price" />
                  <TextBlock FontSize="22" FontWeight="Bold" Foreground="#21E6C1"
                             Text="{Binding SelectedMarket.LastPrice, StringFormat=$ {0:N4}}" />
                </StackPanel>
              </Border>
              <Border Classes="SoftPanel" MinWidth="140">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Spread" />
                  <TextBlock FontSize="22" FontWeight="Bold" Foreground="#21E6C1"
                             Text="{Binding SelectedMarket.Spread, StringFormat=$ {0:N6}}" />
                </StackPanel>
              </Border>
            </WrapPanel>
          </Grid>
        </Border>

        <Border Classes="Panel">
          <Grid ColumnDefinitions="310,*" ColumnSpacing="16">
            <Border Classes="Panel" Grid.Column="0">
              <StackPanel Spacing="12">
                <TextBlock Classes="H2" Text="Tracked Coins" />
                <TextBlock Text="Loading markets…"
                           Foreground="#8B949E"
                           IsVisible="{Binding IsMarketLoading}" />

                <ScrollViewer Classes="PageScroll" MaxHeight="640">
                  <ListBox ItemsSource="{Binding Markets}"
                           SelectedItem="{Binding SelectedMarket}">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:CexMarketItemViewModel">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                          <TextBlock Grid.Row="0" Grid.Column="0"
                                     Text="{Binding DisplaySymbol}"
                                     FontWeight="Bold" />
                          <TextBlock Grid.Row="0" Grid.Column="1"
                                     Text="{Binding LastPrice, StringFormat=$ {0:N4}}"
                                     Foreground="#21E6C1" />
                          <TextBlock Grid.Row="1" Grid.Column="0"
                                     Text="{Binding BestBid, StringFormat=Bid: $ {0:N4}}"
                                     Foreground="#8B949E"
                                     FontSize="12" />
                          <TextBlock Grid.Row="1" Grid.Column="1"
                                     Text="{Binding BestAsk, StringFormat=Ask: $ {0:N4}}"
                                     Foreground="#8B949E"
                                     FontSize="12" />
                          <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                                     Text="{Binding LastUpdated, StringFormat=Updated: {0:HH:mm:ss}}"
                                     Foreground="#6E8196"
                                     FontSize="12" />
                        </Grid>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </ScrollViewer>
              </StackPanel>
            </Border>

            <Border Classes="Panel" Grid.Column="1">
              <StackPanel Spacing="16">
                <StackPanel Spacing="4">
                  <TextBlock Classes="H1" Text="{Binding SelectedMarketTitle}" />
                </StackPanel>

                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="16">
                  <Border Classes="Panel" Grid.Column="0">
                    <StackPanel>
                      <TextBlock Text="Last Price" Foreground="#8B949E" />
                      <TextBlock Classes="Value"
                                 FontSize="24"
                                 Text="{Binding SelectedMarket.LastPrice, StringFormat=$ {0:N4}}" />
                    </StackPanel>
                  </Border>
                  <Border Classes="Panel" Grid.Column="1">
                    <StackPanel>
                      <TextBlock Text="Best Bid" Foreground="#8B949E" />
                      <TextBlock Classes="Value"
                                 FontSize="24"
                                 Text="{Binding SelectedMarket.BestBid, StringFormat=$ {0:N4}}" />
                    </StackPanel>
                  </Border>
                  <Border Classes="Panel" Grid.Column="2">
                    <StackPanel>
                      <TextBlock Text="Best Ask" Foreground="#8B949E" />
                      <TextBlock Classes="Value"
                                 FontSize="24"
                                 Text="{Binding SelectedMarket.BestAsk, StringFormat=$ {0:N4}}" />
                    </StackPanel>
                  </Border>
                  <Border Classes="Panel" Grid.Column="3">
                    <StackPanel>
                      <TextBlock Text="Spread" Foreground="#8B949E" />
                      <TextBlock Classes="Value"
                                 FontSize="24"
                                 Text="{Binding SelectedMarket.Spread, StringFormat=$ {0:N6}}" />
                    </StackPanel>
                  </Border>
                </Grid>

                <Border Classes="SoftPanel">
                  <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <TextBlock Grid.Row="0" Classes="H2" Text="Live Price Chart" />
                    <Grid Grid.Row="1" ColumnDefinitions="*,160" ColumnSpacing="8">
                      <ctrl:CexPriceChart Grid.Column="0"
                                          Height="240"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          Points="{Binding SelectedMarket.ChartPoints}"
                                          IsPositiveTrend="{Binding SelectedMarket.IsPositiveTrend}" />
                      <!-- Mini liquidation heatmap — Viewbox scales 1200×460 → 160×224.
                           Explicit Width+Height on Viewbox gives well-defined ScaleX/ScaleY. -->
                      <Border Grid.Column="1" Background="#04101A" CornerRadius="6" ClipToBounds="True"
                              ToolTip.Tip="Liquidation Heatmap — click 🔥 Liq Map for fullscreen">
                        <StackPanel>
                          <TextBlock Text="LIQ MAP" Foreground="#4A6070" FontSize="9" FontWeight="Bold"
                                     Margin="4,4,0,2" />
                          <Viewbox Width="160" Height="224" Stretch="Fill">
                            <Canvas Width="1200" Height="460">
                              <Path Data="{Binding LiquidationHeatmapVM.LongBarsGeometry}"
                                    Fill="#5521E6C1" Stroke="#21E6C1" StrokeThickness="1" />
                              <Path Data="{Binding LiquidationHeatmapVM.ShortBarsGeometry}"
                                    Fill="#55FF4444" Stroke="#FF4444" StrokeThickness="1" />
                              <Line StartPoint="600,0" EndPoint="600,460"
                                    Stroke="#1E3A50" StrokeThickness="1" />
                              <Path Data="{Binding LiquidationHeatmapVM.CurrentPriceGeometry}"
                                    Stroke="#F4B860" StrokeThickness="2" StrokeDashArray="8,4" />
                            </Canvas>
                          </Viewbox>
                        </StackPanel>
                      </Border>
                    </Grid>
                    <TextBlock Grid.Row="2"
                               Text="{Binding SelectedMarket.LastUpdated, StringFormat=Last tick: {0:dd.MM.yyyy HH:mm:ss}}"
                               Foreground="#8B949E" />
                  </Grid>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                  <Border Classes="Panel" Grid.Column="0">
                    <StackPanel Spacing="8">
                      <TextBlock Classes="H2" Text="Bids" />
                      <ScrollViewer Classes="PageScroll" MaxHeight="240">
                        <ItemsControl ItemsSource="{Binding SelectedMarket.BidLevels}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:OrderBookLevelViewModel">
                              <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Price, StringFormat=$ {0:N4}}"
                                           Foreground="#3DDC84" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Quantity, StringFormat={}{0:N4}}"
                                           Foreground="#8B949E" />
                              </Grid>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </ScrollViewer>
                    </StackPanel>
                  </Border>

                  <Border Classes="Panel" Grid.Column="1">
                    <StackPanel Spacing="8">
                      <TextBlock Classes="H2" Text="Asks" />
                      <ScrollViewer Classes="PageScroll" MaxHeight="240">
                        <ItemsControl ItemsSource="{Binding SelectedMarket.AskLevels}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:OrderBookLevelViewModel">
                              <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Price, StringFormat=$ {0:N4}}"
                                           Foreground="#FF6B6B" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Quantity, StringFormat={}{0:N4}}"
                                           Foreground="#8B949E" />
                              </Grid>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </ScrollViewer>
                    </StackPanel>
                  </Border>
                </Grid>
              </StackPanel>
            </Border>
          </Grid>
        </Border>

        <!-- ── Market Sentiment Widget ──────────────────────────────────────── -->
        <Border Classes="Panel">
          <StackPanel Spacing="12">
            <!-- Header row -->
            <Grid ColumnDefinitions="*,Auto,Auto">
              <TextBlock Grid.Column="0" Classes="H2" Text="MARKET SENTIMENT" />
              <TextBlock Grid.Column="1" Text="{Binding SentimentVM.StatusLabel}"
                         Foreground="#8B949E" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0" />
              <Button Grid.Column="2" Content="🧠 AI Read"
                      Command="{Binding SentimentVM.AnalyzeWithAiCommand}"
                      IsEnabled="{Binding !SentimentVM.InsightRunning}"
                      Foreground="#21E6C1" FontSize="11" />
            </Grid>

            <!-- ── AI Sentiment Insight (#7) ── -->
            <Border Background="#04101A" CornerRadius="6" Padding="12,9"
                    IsVisible="{Binding SentimentVM.HasInsight}">
              <StackPanel Spacing="5">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="{Binding SentimentVM.InsightSignal}"
                             Foreground="{Binding SentimentVM.InsightSignalBrush}" FontWeight="Bold" FontSize="13" />
                  <TextBlock Grid.Column="1" Text="{Binding SentimentVM.InsightSource}"
                             Foreground="#5C6E82" FontSize="10" VerticalAlignment="Center" />
                </Grid>
                <TextBlock Text="{Binding SentimentVM.InsightSummary}" Foreground="#D7E3EE" FontSize="12" TextWrapping="Wrap" />
                <TextBlock Text="{Binding SentimentVM.InsightBullets}" Foreground="#8FA3B8" FontSize="11" TextWrapping="Wrap"
                           IsVisible="{Binding SentimentVM.InsightBullets, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
              </StackPanel>
            </Border>

            <!-- Fear & Greed row -->
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
              <!-- Circle gauge -->
              <Border Grid.Column="0"
                      Width="72" Height="72" CornerRadius="36"
                      BorderThickness="3"
                      BorderBrush="{Binding SentimentVM.FearGreedBrush}"
                      Background="#0D1B2A"
                      VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0">
                  <TextBlock Text="{Binding SentimentVM.FearGreedValue}"
                             FontSize="22" FontWeight="Bold" Foreground="White"
                             HorizontalAlignment="Center" />
                  <TextBlock Text="{Binding SentimentVM.FearGreedLabel}"
                             FontSize="9" Foreground="#8B949E"
                             HorizontalAlignment="Center" />
                </StackPanel>
              </Border>

              <!-- Center info -->
              <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                <TextBlock Classes="Overline" Text="FEAR &amp; GREED INDEX" />

                <!-- Long/Short bar -->
                <StackPanel Spacing="4">
                  <Grid>
                    <!-- Background bar (short = red) -->
                    <Border Width="200" Height="6" Background="#33FF4444"
                            CornerRadius="3" HorizontalAlignment="Left" />
                    <!-- Foreground bar (long = teal) -->
                    <Border Height="6" Background="#21E6C1"
                            CornerRadius="3,0,0,3" HorizontalAlignment="Left"
                            Width="{Binding SentimentVM.LongBarWidth}" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*">
                    <TextBlock Grid.Column="0" Text="{Binding SentimentVM.LongLabel}"
                               Foreground="#21E6C1" FontSize="12" />
                    <TextBlock Grid.Column="1" Text="{Binding SentimentVM.ShortLabel}"
                               Foreground="#FF4444" FontSize="12"
                               HorizontalAlignment="Right" />
                  </Grid>
                </StackPanel>

                <!-- Open Interest -->
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Open Interest:" Foreground="#8B949E" FontSize="12" />
                  <TextBlock Text="{Binding SentimentVM.OpenInterestLabel}"
                             Foreground="White" FontSize="12" FontWeight="Bold" />
                  <TextBlock Text="{Binding SentimentVM.OpenInterestChangeLabel}"
                             Foreground="{Binding SentimentVM.OpenInterestChangeBrush}"
                             FontSize="12" />
                </StackPanel>
              </StackPanel>

              <!-- Change badge -->
              <Border Grid.Column="2" VerticalAlignment="Center" Padding="8,4"
                      Background="#0D1B2A" CornerRadius="6">
                <TextBlock Text="{Binding SentimentVM.FearGreedChangeLabel}"
                           Foreground="{Binding SentimentVM.FearGreedChangeBrush}"
                           FontSize="14" FontWeight="Bold" />
              </Border>
            </Grid>
          </StackPanel>
        </Border>
        <!-- ── End Market Sentiment Widget ──────────────────────────────────── -->

        </StackPanel>
</UserControl>

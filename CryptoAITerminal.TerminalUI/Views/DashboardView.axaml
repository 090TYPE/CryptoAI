<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CryptoAITerminal.TerminalUI.ViewModels"
             xmlns:vmd="clr-namespace:CryptoAITerminal.TerminalUI.ViewModels.Dashboard"
             xmlns:ctrl="clr-namespace:CryptoAITerminal.TerminalUI.Controls"
             xmlns:dash="clr-namespace:CryptoAITerminal.TerminalUI.Views.Dashboard"
             x:Class="CryptoAITerminal.TerminalUI.Views.DashboardView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">
  <DockPanel LastChildFill="True">
    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto,Auto,Auto" Margin="0,0,0,16">
      <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
        <TextBlock Classes="H1" Text="Dashboard" />
        <TextBlock Classes="StatLabel"
                   Text="{Binding DashboardLayoutVM.Widgets.Count, StringFormat='DEFAULT LAYOUT · {0} WIDGETS'}" />
      </StackPanel>

      <!-- LIVE indicator -->
      <Border Grid.Column="1" Classes="LivePill" Margin="0,0,10,0" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <Ellipse Width="7" Height="7" Fill="#21E6C1" VerticalAlignment="Center" />
          <TextBlock Text="LIVE" Foreground="#21E6C1" FontSize="11" FontWeight="Bold" LetterSpacing="0.8" />
        </StackPanel>
      </Border>

      <Button Grid.Column="2" Content="+ Widget" Margin="0,0,8,0" VerticalAlignment="Center">
        <Button.Flyout>
          <Flyout Placement="Bottom">
            <ScrollViewer MaxHeight="360">
              <ItemsControl ItemsSource="{Binding DashboardLayoutVM.AddableCatalog}" Width="240">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vmd:WidgetCatalogEntry">
                    <Button Content="{Binding Title}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Margin="0,0,0,4"
                            Command="{Binding $parent[ItemsControl].DataContext.DashboardLayoutVM.AddWidgetCommand}"
                            CommandParameter="{Binding Key}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Flyout>
        </Button.Flyout>
      </Button>
      <Button Grid.Column="3" Content="↺ Reset" Margin="0,0,8,0" VerticalAlignment="Center"
              IsVisible="{Binding DashboardLayoutVM.IsEditMode}"
              Command="{Binding DashboardLayoutVM.ResetLayoutCommand}" />
      <Button Grid.Column="4" Content="✎ Edit Layout" Classes="AccentButton" VerticalAlignment="Center"
              Command="{Binding DashboardLayoutVM.ToggleEditCommand}" />
    </Grid>

    <ScrollViewer Classes="PageScroll">
      <ItemsControl ItemsSource="{Binding DashboardLayoutVM.Widgets}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <ctrl:WidgetGridPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.Styles>
          <Style Selector="ContentPresenter">
            <Setter Property="(ctrl:WidgetGridPanel.Col)"     Value="{Binding Col}" />
            <Setter Property="(ctrl:WidgetGridPanel.Row)"     Value="{Binding Row}" />
            <Setter Property="(ctrl:WidgetGridPanel.ColSpan)" Value="{Binding ColSpan}" />
            <Setter Property="(ctrl:WidgetGridPanel.RowSpan)" Value="{Binding RowSpan}" />
          </Style>
        </ItemsControl.Styles>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vmd:DashboardWidget">
            <dash:WidgetHost IsEditMode="{Binding $parent[ItemsControl].DataContext.DashboardLayoutVM.IsEditMode}" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CryptoAITerminal.TerminalUI.ViewModels"
             xmlns:ctrl="clr-namespace:CryptoAITerminal.TerminalUI.Controls"
             x:Class="CryptoAITerminal.TerminalUI.Views.FundingArbView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">
          <StackPanel Spacing="16" IsVisible="{Binding IsFundingRateSectionVisible}">

            <!-- Section header -->
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Classes="H1" Text="Funding Rate Arbitrage Bot" />
                <TextBlock Text="{Binding FundingArbitrageVM.StatusLabel}"
                           FontSize="11" Foreground="#8FA3B8" />
              </StackPanel>
              <Button Grid.Column="1" Classes="GhostButton" Content="↺ Refresh"
                      IsEnabled="{Binding !FundingArbitrageVM.IsLoading}"
                      Command="{Binding FundingArbitrageVM.RefreshCommand}" />
            </Grid>

            <!-- Config row -->
            <Border Classes="Panel" Padding="16,12">
              <Grid ColumnDefinitions="Auto,130,Auto,130,Auto,80,*" ColumnSpacing="12" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Text="Min rate (per 8h)%" Classes="Overline"
                           VerticalAlignment="Center" />
                <NumericUpDown Grid.Column="1"
                               Value="{Binding FundingArbitrageVM.ThresholdPct}"
                               Minimum="0.01" Maximum="5" Increment="0.01"
                               FormatString="N2" />

                <TextBlock Grid.Column="2" Text="Notional USD" Classes="Overline"
                           VerticalAlignment="Center" Margin="8,0,0,0" />
                <NumericUpDown Grid.Column="3"
                               Value="{Binding FundingArbitrageVM.NotionalUsd}"
                               Minimum="10" Maximum="1000000" Increment="100"
                               FormatString="N0" />

                <TextBlock Grid.Column="4" Text="Leverage" Classes="Overline"
                           VerticalAlignment="Center" Margin="8,0,0,0" />
                <NumericUpDown Grid.Column="5"
                               Value="{Binding FundingArbitrageVM.Leverage}"
                               Minimum="1" Maximum="10" Increment="1"
                               FormatString="N0" />

                <!-- Risk reminder -->
                <TextBlock Grid.Column="6" FontSize="10" Foreground="#3A4F63"
                           TextWrapping="Wrap" VerticalAlignment="Center" Margin="16,0,0,0"
                           Text="Strategy: long spot + short perp. Delta-neutral. Earns funding payments every 8 h." />
              </Grid>
            </Border>

            <!-- Auto-reinvest row -->
            <Border Classes="Panel" Padding="16,10">
              <Grid ColumnDefinitions="Auto,*,Auto,120,*" ColumnSpacing="16" VerticalAlignment="Center">
                <ToggleSwitch Grid.Column="0" IsChecked="{Binding FundingArbitrageVM.AutoReinvest}"
                              Content="Auto-Reinvest" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" FontSize="11" Foreground="#5C6E82"
                           TextWrapping="Wrap" VerticalAlignment="Center"
                           Text="Compounds collected funding back into position size automatically." />
                <TextBlock Grid.Column="2" Text="Threshold $" Classes="Overline"
                           VerticalAlignment="Center" />
                <NumericUpDown Grid.Column="3"
                               Value="{Binding FundingArbitrageVM.ReinvestThreshold}"
                               Minimum="1" Maximum="10000" Increment="5"
                               FormatString="N0"
                               IsEnabled="{Binding FundingArbitrageVM.AutoReinvest}" />
                <TextBlock Grid.Column="4" FontSize="10" Foreground="#3A4F63"
                           TextWrapping="Wrap" VerticalAlignment="Center" Margin="8,0,0,0"
                           Text="Reinvest fires when funding collected ≥ Threshold USD." />
              </Grid>
            </Border>

            <!-- KPI strip: open positions, total funding, total PnL, best APR, reinvest count -->
            <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="12">
              <Border Grid.Column="0" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="OPEN POSITIONS" />
                  <TextBlock Text="{Binding FundingArbitrageVM.OpenPositionCount}"
                             Classes="Metric" Foreground="#F4B860" />
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="FUNDING EARNED" />
                  <TextBlock Text="{Binding FundingArbitrageVM.TotalFundingLabel}"
                             Classes="Metric" Foreground="#21E6C1" />
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="TOTAL PnL" />
                  <TextBlock Text="{Binding FundingArbitrageVM.TotalPnlLabel}"
                             Classes="Metric" Foreground="{Binding FundingArbitrageVM.TotalPnlBrush}" />
                </StackPanel>
              </Border>
              <Border Grid.Column="3" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="BEST APR" />
                  <TextBlock Text="{Binding FundingArbitrageVM.BestAprLabel}"
                             Classes="Metric" Foreground="#21E6C1" />
                </StackPanel>
              </Border>
              <Border Grid.Column="4" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="REINVESTS" />
                  <TextBlock Text="{Binding FundingArbitrageVM.ReinvestCountLabel}"
                             Classes="Metric" Foreground="#8FA3B8" />
                </StackPanel>
              </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

              <!-- Left: Opportunities table -->
              <Border Grid.Column="0" Classes="Panel">
                <StackPanel Spacing="10">
                  <TextBlock Classes="H2" Text="Live Opportunities" />
                  <TextBlock FontSize="11" Foreground="#5C6E82"
                             Text="Positive funding = longs pay shorts. Long spot + short perp captures this." />

                  <!-- Table header -->
                  <Grid ColumnDefinitions="60,*,80,80,70,60,Auto" ColumnSpacing="8" Margin="0,4,0,0">
                    <TextBlock Grid.Column="0" Text="EXCHANGE" Classes="Overline" />
                    <TextBlock Grid.Column="1" Text="SYMBOL"   Classes="Overline" />
                    <TextBlock Grid.Column="2" Text="RATE/8H"  Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="3" Text="ANNUAL"   Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="4" Text="MARK $"   Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="5" Text="NEXT"     Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="6" Text=""         Classes="Overline" Width="80" />
                  </Grid>

                  <ScrollViewer Classes="PageScroll" MaxHeight="400">
                    <ItemsControl ItemsSource="{Binding FundingArbitrageVM.Opportunities}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:FundingArbOpportunityRowVM">
                          <Border Padding="0,6" BorderBrush="#0D1E2D" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="60,*,80,80,70,60,Auto" ColumnSpacing="8">
                              <!-- Exchange badge -->
                              <Border Grid.Column="0" CornerRadius="4" Padding="5,2"
                                      HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Border.Background>
                                  <SolidColorBrush Color="{Binding ExchangeBadgeColor}" Opacity="0.18" />
                                </Border.Background>
                                <TextBlock Text="{Binding Exchange}"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="{Binding ExchangeBadgeColor}" />
                              </Border>
                              <!-- Symbol -->
                              <TextBlock Grid.Column="1" Text="{Binding Symbol}"
                                         FontWeight="SemiBold" VerticalAlignment="Center" />
                              <!-- Rate/8h -->
                              <TextBlock Grid.Column="2" Text="{Binding RateLabel}"
                                         Foreground="{Binding RateBrush}"
                                         FontWeight="Bold" FontFamily="Consolas"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- Annualised -->
                              <TextBlock Grid.Column="3" Text="{Binding AnnualLabel}"
                                         Foreground="{Binding AnnualBrush}"
                                         FontSize="11"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- Mark price -->
                              <TextBlock Grid.Column="4" Text="{Binding PriceLabel}"
                                         Foreground="#8FA3B8" FontSize="11"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- Next funding -->
                              <TextBlock Grid.Column="5" Text="{Binding NextLabel}"
                                         Foreground="#5C6E82" FontSize="11"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- Open button -->
                              <Button Grid.Column="6"
                                      Classes="BuyButton"
                                      Content="⚡ Open"
                                      Padding="10,4"
                                      FontSize="11"
                                      Width="78"
                                      VerticalAlignment="Center"
                                      Command="{Binding $parent[Window].DataContext.FundingArbitrageVM.OpenCommand}"
                                      CommandParameter="{Binding}" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>

                  <!-- Empty state -->
                  <TextBlock IsVisible="{Binding !FundingArbitrageVM.HasOpportunities}"
                             Text="No opportunities above threshold. Try lowering Min rate or press Refresh."
                             Foreground="#3A4F63" FontSize="12" TextWrapping="Wrap" Margin="0,8" />
                </StackPanel>
              </Border>

              <!-- Right: Open Positions table -->
              <Border Grid.Column="1" Classes="Panel">
                <StackPanel Spacing="10">
                  <TextBlock Classes="H2" Text="Open Arb Positions" />
                  <TextBlock FontSize="11" Foreground="#5C6E82"
                             Text="Each row = long spot + short perp. Funding income accrues every 8 h." />

                  <!-- Table header -->
                  <Grid ColumnDefinitions="55,*,65,55,70,70,70,Auto" ColumnSpacing="6" Margin="0,4,0,0">
                    <TextBlock Grid.Column="0" Text="EXCH"     Classes="Overline" />
                    <TextBlock Grid.Column="1" Text="SYMBOL"   Classes="Overline" />
                    <TextBlock Grid.Column="2" Text="AGE"      Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="3" Text="RATE"     Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="4" Text="FUNDING"  Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="5" Text="BASIS"    Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="6" Text="PnL"      Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="7" Text=""         Classes="Overline" Width="68" />
                  </Grid>

                  <ScrollViewer Classes="PageScroll" MaxHeight="400">
                    <ItemsControl ItemsSource="{Binding FundingArbitrageVM.Positions}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:FundingArbPositionRowVM">
                          <Border Padding="0,6" BorderBrush="#0D1E2D" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="55,*,65,55,70,70,70,Auto" ColumnSpacing="6">
                              <!-- Exchange -->
                              <TextBlock Grid.Column="0" Text="{Binding Exchange}"
                                         FontSize="10" FontWeight="Bold" Foreground="#F4B860"
                                         VerticalAlignment="Center" />
                              <!-- Symbol -->
                              <StackPanel Grid.Column="1" Spacing="1">
                                <TextBlock Text="{Binding Symbol}" FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding NotionalLabel}" FontSize="10"
                                           Foreground="#5C6E82" />
                              </StackPanel>
                              <!-- Age -->
                              <TextBlock Grid.Column="2" Text="{Binding AgeLabel}"
                                         Foreground="#8FA3B8" FontSize="11"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- Entry rate -->
                              <TextBlock Grid.Column="3" Text="{Binding EntryRateLabel}"
                                         Foreground="#21E6C1" FontSize="11" FontFamily="Consolas"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- Funding collected -->
                              <TextBlock Grid.Column="4" Text="{Binding FundingLabel}"
                                         Foreground="#21E6C1" FontSize="11"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- Basis drift -->
                              <TextBlock Grid.Column="5" Text="{Binding BasisLabel}"
                                         Foreground="{Binding BasisBrush}" FontSize="11"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- Total PnL -->
                              <TextBlock Grid.Column="6" Text="{Binding TotalPnlLabel}"
                                         Foreground="{Binding TotalPnlBrush}"
                                         FontWeight="SemiBold" FontSize="11"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- Close button -->
                              <Button Grid.Column="7"
                                      Classes="SellButton"
                                      Content="✕ Close"
                                      Padding="8,4" FontSize="11"
                                      Width="66"
                                      VerticalAlignment="Center"
                                      Command="{Binding $parent[Window].DataContext.FundingArbitrageVM.CloseCommand}"
                                      CommandParameter="{Binding}" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>

                  <!-- Empty state -->
                  <StackPanel IsVisible="{Binding !FundingArbitrageVM.Positions.Count}"
                              Spacing="6" Margin="0,16">
                    <TextBlock Text="No open positions"
                               Foreground="#3A4F63" FontSize="13"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Press ⚡ Open on any opportunity to start earning funding."
                               Foreground="#2A3A4A" FontSize="11"
                               HorizontalAlignment="Center" TextWrapping="Wrap" />
                  </StackPanel>
                </StackPanel>
              </Border>

            </Grid><!-- end opportunities / positions grid -->

            <!-- Explainer / risk notes -->
            <Border Background="#080F18" BorderBrush="#1E3A52" BorderThickness="1"
                    CornerRadius="8" Padding="14,10">
              <Grid ColumnDefinitions="*,*,*" ColumnSpacing="20">
                <StackPanel Grid.Column="0" Spacing="4">
                  <TextBlock Text="How it works" FontWeight="Bold"
                             FontSize="12" Foreground="#21E6C1" />
                  <TextBlock FontSize="11" Foreground="#8FA3B8" TextWrapping="Wrap" LineHeight="18">
                    When funding is positive, perpetual longs pay shorts every 8 hours.
                    Buy spot + short-sell the perp creates a delta-neutral position
                    that collects payments without directional risk.
                  </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                  <TextBlock Text="Basis risk" FontWeight="Bold"
                             FontSize="12" Foreground="#FFAA33" />
                  <TextBlock FontSize="11" Foreground="#8FA3B8" TextWrapping="Wrap" LineHeight="18">
                    Spot and perp usually trade near parity but can diverge briefly.
                    Monitor the Basis column — values above ±0.5 % signal stress.
                    Close positions if basis widens beyond your tolerance.
                  </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                  <TextBlock Text="Exit conditions" FontWeight="Bold"
                             FontSize="12" Foreground="#5C6E82" />
                  <TextBlock FontSize="11" Foreground="#8FA3B8" TextWrapping="Wrap" LineHeight="18">
                    Close when: funding rate drops below threshold, basis drifts > 1 %,
                    funding cycles earned cover expected fees, or manually when done.
                  </TextBlock>
                </StackPanel>
              </Grid>
            </Border>

          </StackPanel>
</UserControl>

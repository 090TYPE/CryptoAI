<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CryptoAITerminal.TerminalUI.ViewModels"
             xmlns:ctrl="clr-namespace:CryptoAITerminal.TerminalUI.Controls"
             x:Class="CryptoAITerminal.TerminalUI.Views.GasView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">
          <StackPanel Spacing="16" IsVisible="{Binding IsGasSectionVisible}">

            <!-- Alert banner -->
            <Border IsVisible="{Binding GasMonitorVM.AlertMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Background="#1A2D1A" BorderBrush="#21E6C1" BorderThickness="0,0,0,1" Padding="14,10">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="⚡" FontSize="16" VerticalAlignment="Center" />
                <TextBlock Text="{Binding GasMonitorVM.AlertMessage}" FontSize="13" FontWeight="SemiBold"
                           Foreground="#21E6C1" VerticalAlignment="Center" TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <!-- Three-column gas cards row -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">

              <!-- Ethereum -->
              <Border Grid.Column="0" Background="#0F1721" CornerRadius="6" Padding="16">
                <StackPanel Spacing="10">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Ξ" FontSize="18" Foreground="#8FA3B8" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Text="Ethereum" Classes="H2" VerticalAlignment="Center" />
                    <Border IsVisible="{Binding GasMonitorVM.IsEthAlertActive}"
                            Background="#163020" CornerRadius="3" Padding="6,2">
                      <TextBlock Text="LOW ⚡" Foreground="#21E6C1" FontSize="10" FontWeight="Bold" />
                    </Border>
                  </StackPanel>
                  <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Slow" Classes="Overline" />
                    <TextBlock Grid.Column="1" Grid.Row="0" Text="Standard" Classes="Overline" />
                    <TextBlock Grid.Column="2" Grid.Row="0" Text="Fast" Classes="Overline" />
                    <TextBlock Grid.Column="0" Grid.Row="1" Text="{Binding GasMonitorVM.EthSlowLabel}"
                               Foreground="{Binding GasMonitorVM.EthSlowColor}" FontSize="15" FontWeight="Bold" />
                    <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding GasMonitorVM.EthStdLabel}"
                               Foreground="{Binding GasMonitorVM.EthStdColor}" FontSize="15" FontWeight="Bold" />
                    <TextBlock Grid.Column="2" Grid.Row="1" Text="{Binding GasMonitorVM.EthFastLabel}"
                               Foreground="{Binding GasMonitorVM.EthFastColor}" FontSize="15" FontWeight="Bold" />
                    <TextBlock Grid.Column="0" Grid.Row="2" Text="{Binding GasMonitorVM.EthSlowTimeLabel}"
                               Foreground="#4A6880" FontSize="10" />
                    <TextBlock Grid.Column="1" Grid.Row="2" Text="{Binding GasMonitorVM.EthStdTimeLabel}"
                               Foreground="#4A6880" FontSize="10" />
                    <TextBlock Grid.Column="2" Grid.Row="2" Text="{Binding GasMonitorVM.EthFastTimeLabel}"
                               Foreground="#4A6880" FontSize="10" />
                  </Grid>
                  <!-- ETH alert threshold -->
                  <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                    <TextBlock Text="Alert below:" Foreground="#4A6880" FontSize="11" VerticalAlignment="Center" />
                    <NumericUpDown Value="{Binding GasMonitorVM.EthAlertGwei}"
                                  Minimum="1" Maximum="200" Increment="1"
                                  FormatString="N0"
                                  Width="80" Height="26" FontSize="11"
                                  Background="#0A1018" Foreground="#C8D8E8" />
                    <TextBlock Text="gwei" Foreground="#4A6880" FontSize="11" VerticalAlignment="Center" />
                  </StackPanel>
                </StackPanel>
              </Border>

              <!-- BSC -->
              <Border Grid.Column="1" Background="#0F1721" CornerRadius="6" Padding="16">
                <StackPanel Spacing="10">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="⬡" FontSize="16" Foreground="#F0B90B" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Text="BNB Chain" Classes="H2" VerticalAlignment="Center" />
                    <Border IsVisible="{Binding GasMonitorVM.IsBscAlertActive}"
                            Background="#163020" CornerRadius="3" Padding="6,2">
                      <TextBlock Text="LOW ⚡" Foreground="#21E6C1" FontSize="10" FontWeight="Bold" />
                    </Border>
                  </StackPanel>
                  <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Slow" Classes="Overline" />
                    <TextBlock Grid.Column="1" Grid.Row="0" Text="Standard" Classes="Overline" />
                    <TextBlock Grid.Column="2" Grid.Row="0" Text="Fast" Classes="Overline" />
                    <TextBlock Grid.Column="0" Grid.Row="1" Text="{Binding GasMonitorVM.BscSlowLabel}"
                               Foreground="{Binding GasMonitorVM.BscSlowColor}" FontSize="15" FontWeight="Bold" />
                    <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding GasMonitorVM.BscStdLabel}"
                               Foreground="{Binding GasMonitorVM.BscStdColor}" FontSize="15" FontWeight="Bold" />
                    <TextBlock Grid.Column="2" Grid.Row="1" Text="{Binding GasMonitorVM.BscFastLabel}"
                               Foreground="{Binding GasMonitorVM.BscFastColor}" FontSize="15" FontWeight="Bold" />
                  </Grid>
                  <!-- BSC alert threshold -->
                  <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                    <TextBlock Text="Alert below:" Foreground="#4A6880" FontSize="11" VerticalAlignment="Center" />
                    <NumericUpDown Value="{Binding GasMonitorVM.BscAlertGwei}"
                                  Minimum="1" Maximum="50" Increment="1"
                                  FormatString="N0"
                                  Width="80" Height="26" FontSize="11"
                                  Background="#0A1018" Foreground="#C8D8E8" />
                    <TextBlock Text="gwei" Foreground="#4A6880" FontSize="11" VerticalAlignment="Center" />
                  </StackPanel>
                </StackPanel>
              </Border>

              <!-- Solana -->
              <Border Grid.Column="2" Background="#0F1721" CornerRadius="6" Padding="16">
                <StackPanel Spacing="10">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="◎" FontSize="16" Foreground="#9B59B6" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Text="Solana" Classes="H2" VerticalAlignment="Center" />
                  </StackPanel>
                  <StackPanel Spacing="4">
                    <TextBlock Text="TPS (avg last 4 samples)" Classes="Overline" />
                    <TextBlock Text="{Binding GasMonitorVM.SolanaTpsLabel}"
                               Foreground="{Binding GasMonitorVM.SolanaColor}"
                               FontSize="22" FontWeight="Bold" />
                    <TextBlock Text="Solana has no gas — congestion is measured by TPS."
                               Foreground="#4A6880" FontSize="10" TextWrapping="Wrap" />
                  </StackPanel>
                </StackPanel>
              </Border>

            </Grid>

            <!-- Last updated / Refresh row -->
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
              <TextBlock Text="{Binding GasMonitorVM.LastUpdatedLabel}"
                         Foreground="#4A6880" FontSize="11" VerticalAlignment="Center" />
              <Button Content="↻  Refresh" Classes="SecondaryAction"
                      Command="{Binding GasMonitorVM.RefreshCommand}"
                      IsEnabled="{Binding !GasMonitorVM.IsLoading}"
                      Padding="12,5" FontSize="12" />
            </StackPanel>

            <!-- Info note -->
            <Border Background="#0A1018" CornerRadius="4" Padding="12,8">
              <TextBlock Foreground="#4A6880" FontSize="11" TextWrapping="Wrap">
                <Run Text="ℹ " />
                <Run Text="Gas prices update every 30 seconds. Powered by Etherscan · BSCScan · Solana RPC.  " />
                <Run Text="Set ETHERSCAN_API_KEY / BSCSCAN_API_KEY environment variables for higher rate limits."
                     Foreground="#2D4A5A" />
              </TextBlock>
            </Border>

          </StackPanel>
</UserControl>

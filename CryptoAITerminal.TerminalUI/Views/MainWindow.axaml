<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CryptoAITerminal.TerminalUI.ViewModels"
        xmlns:ctrl="clr-namespace:CryptoAITerminal.TerminalUI.Controls"
        xmlns:views="clr-namespace:CryptoAITerminal.TerminalUI.Views"
        xmlns:wt="clr-namespace:CryptoAITerminal.WhaleTracker.Models;assembly=CryptoAITerminal.WhaleTracker"
        x:Class="CryptoAITerminal.TerminalUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="RootWindow"
        Title="Crypto AI Terminal"
        Icon="avares://CryptoAITerminal.TerminalUI/Assets/app-icon.png"
        MinWidth="960"
        MinHeight="640"
        WindowDecorations="None"
        WindowState="FullScreen"
        ExtendClientAreaToDecorationsHint="True">

  <!-- Hotkeys: Shift+1…9 apply order templates without clicking -->
  <Window.KeyBindings>
    <KeyBinding Gesture="Shift+D1" Command="{Binding ApplyTemplate1Command}" />
    <KeyBinding Gesture="Shift+D2" Command="{Binding ApplyTemplate2Command}" />
    <KeyBinding Gesture="Shift+D3" Command="{Binding ApplyTemplate3Command}" />
    <KeyBinding Gesture="Shift+D4" Command="{Binding ApplyTemplate4Command}" />
    <KeyBinding Gesture="Shift+D5" Command="{Binding ApplyTemplate5Command}" />
    <KeyBinding Gesture="Shift+D6" Command="{Binding ApplyTemplate6Command}" />
    <KeyBinding Gesture="Shift+D7" Command="{Binding ApplyTemplate7Command}" />
    <KeyBinding Gesture="Shift+D8" Command="{Binding ApplyTemplate8Command}" />
    <KeyBinding Gesture="Shift+D9" Command="{Binding ApplyTemplate9Command}" />
    <!-- Global AI command bar -->
    <KeyBinding Gesture="Ctrl+K" Command="{Binding OpenCommandPaletteCommand}" />
  </Window.KeyBindings>

  <Grid>
    <Grid x:Name="MainContentRoot"
          ColumnDefinitions="184,*"
          RowDefinitions="Auto,*"
          Opacity="0"
          IsHitTestVisible="False">
      <Grid.Transitions>
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.55" />
        </Transitions>
      </Grid.Transitions>
    <Border Grid.Row="0" Grid.ColumnSpan="2" Classes="TopBarShell" Margin="16,16,16,12" Padding="14,10">
      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="20">
        <Grid ColumnDefinitions="40,*" ColumnSpacing="12">
          <Border Grid.Column="0" Classes="BrandGlyph">
            <Grid>
              <Path Data="M 14 2 L 26 26 L 2 26 Z" Fill="#1FE6C2" Stretch="Uniform" />
              <Path Data="M 14 9 L 21 22 L 7 22 Z" Fill="#0A121A" Stretch="Uniform" />
            </Grid>
          </Border>
          <TextBlock Grid.Column="1"
                     Text="CRYPTO AI TERMINAL"
                     Classes="BrandTitle"
                     VerticalAlignment="Center" />
        </Grid>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="28,0,0,0"
                    Spacing="6">
          <TextBlock Text="/" Foreground="#3A4F63" VerticalAlignment="Center" FontSize="16" Margin="0,0,4,0" />
          <TextBlock Text="{Binding CurrentSectionTitle}"
                     Foreground="{DynamicResource Accent}"
                     FontWeight="SemiBold"
                     FontSize="15"
                     VerticalAlignment="Center" />
        </StackPanel>

        <WrapPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <Button x:Name="EnglishLanguageButton"
                  Classes="GhostButton"
                  Content="EN"
                  Padding="12,7"
                  Margin="0,0,10,0"
                  Click="OnSetEnglishLanguageClick" />
          <Button x:Name="RussianLanguageButton"
                  Classes="GhostButton"
                  Content="RU"
                  Padding="12,7"
                  Margin="0,0,10,0"
                  Click="OnSetRussianLanguageClick" />
          <Border Classes="StatusPill" Margin="0,0,10,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Ellipse Width="8" Height="8" Fill="#3DDC84" VerticalAlignment="Center" />
              <TextBlock Text="{Binding ConnectionStateLabel}" />
            </StackPanel>
          </Border>
          <Button Classes="GhostButton"
                  ToolTip.Tip="Settings"
                  Padding="0"
                  Width="32" Height="32"
                  CornerRadius="17"
                  BorderThickness="1"
                  Margin="0,0,10,0"
                  Command="{Binding SelectMainTabCommand}"
                  CommandParameter="settings">
            <TextBlock Text="⚙" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" />
          </Button>
          <Button Classes="GhostButton"
                  ToolTip.Tip="Portfolio / Wallet"
                  Padding="0"
                  Width="32" Height="32"
                  CornerRadius="17"
                  BorderThickness="1"
                  Margin="0,0,10,0"
                  Command="{Binding SelectMainTabCommand}"
                  CommandParameter="portfolio">
            <TextBlock Text="◈" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" />
          </Button>
        </WrapPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1" Grid.Column="0" Classes="SidebarShell" Margin="16,0,12,16" Padding="10">
      <Grid RowDefinitions="*,Auto" RowSpacing="16">
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,4,0">
        <StackPanel Spacing="3">

          <!-- ── Торговля ─────────────────────────────────── -->
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="dashboard" Background="{Binding DashboardNavBackground}" Foreground="{Binding DashboardNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⌂" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" /></Border>
              <TextBlock Grid.Column="1" Text="Dashboard" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="markets" Background="{Binding MarketsNavBackground}" Foreground="{Binding MarketsNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="≋" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Markets" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="trading" Background="{Binding TradingNavBackground}" Foreground="{Binding TradingNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="✦" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Trading" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="ai-signals" Background="{Binding SignalsNavBackground}" Foreground="{Binding SignalsNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="✧" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="AI Signals" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="sniper" Background="{Binding SniperNavBackground}" Foreground="{Binding SniperNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="◎" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Sniper" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>

          <!-- ── Портфель ─────────────────────────────────── -->
          <Border Classes="SideNavDivider" />
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="portfolio" Background="{Binding PortfolioNavBackground}" Foreground="{Binding PortfolioNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="▣" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Portfolio" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="positions" Background="{Binding PositionsNavBackground}" Foreground="{Binding PositionsNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⊞" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Positions" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="risk" Background="{Binding RiskNavBackground}" Foreground="{Binding RiskNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⛨" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Risk" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>

          <!-- ── Автоматизация ────────────────────────────── -->
          <Border Classes="SideNavDivider" />
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="bots" Background="{Binding BotsNavBackground}" Foreground="{Binding BotsNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="◉" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Bots" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="rules" Background="{Binding RulesNavBackground}" Foreground="{Binding RulesNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⚡" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" /></Border>
              <TextBlock Grid.Column="1" Text="Rules" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="backtest" Background="{Binding BacktestNavBackground}" Foreground="{Binding BacktestNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="↗" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Backtest" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="journal" Background="{Binding JournalNavBackground}" Foreground="{Binding JournalNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="📓" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Journal" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>

          <!-- ── Арбитраж / Copy ──────────────────────────── -->
          <Border Classes="SideNavDivider" />
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="funding" Background="{Binding FundingNavBackground}" Foreground="{Binding FundingNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="%" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" /></Border>
              <TextBlock Grid.Column="1" Text="Funding" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="arb" Background="{Binding ArbNavBackground}" Foreground="{Binding ArbNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⇄" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" /></Border>
              <TextBlock Grid.Column="1" Text="Arb" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="copy" Background="{Binding CopyNavBackground}" Foreground="{Binding CopyNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⊕" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" /></Border>
              <TextBlock Grid.Column="1" Text="Copy" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="statarb" Background="{Binding StatArbNavBackground}" Foreground="{Binding StatArbNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="∑" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" /></Border>
              <TextBlock Grid.Column="1" Text="Stat Arb" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>

          <!-- ── Данные / Аналитика ───────────────────────── -->
          <Border Classes="SideNavDivider" />
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="news" Background="{Binding NewsNavBackground}" Foreground="{Binding NewsNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph">
                <Panel>
                  <TextBlock Text="📰" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" />
                  <Border IsVisible="{Binding NewsFeedVM.HasUnread}"
                          Background="#FF6B6B" CornerRadius="6" Width="12" Height="12"
                          HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-3,-3,0">
                    <TextBlock Text="{Binding NewsFeedVM.UnreadBadge}" Foreground="White"
                               FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                </Panel>
              </Border>
              <TextBlock Grid.Column="1" Text="News" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="onchain" Background="{Binding OnChainNavBackground}" Foreground="{Binding OnChainNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⛓" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="On-Chain" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="whale" Background="{Binding WhaleNavBackground}" Foreground="{Binding WhaleNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⬡" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Whales" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="tape" Background="{Binding TapeNavBackground}" Foreground="{Binding TapeNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="🎞" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Live Tape" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="liquidation" Background="{Binding LiquidationNavBackground}" Foreground="{Binding LiquidationNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="🔥" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" /></Border>
              <TextBlock Grid.Column="1" Text="Liq Map" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="analytics" Background="{Binding AnalyticsNavBackground}" Foreground="{Binding AnalyticsNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="≣" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Analytics" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>

          <!-- ── Инфраструктура ───────────────────────────── -->
          <Border Classes="SideNavDivider" />
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="gas" Background="{Binding GasNavBackground}" Foreground="{Binding GasNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⛽" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Gas" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="router" Background="{Binding RouterNavBackground}" Foreground="{Binding RouterNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⟳" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" /></Border>
              <TextBlock Grid.Column="1" Text="Router" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="scanner" Background="{Binding ScannerNavBackground}" Foreground="{Binding ScannerNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⊞" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" /></Border>
              <TextBlock Grid.Column="1" Text="Scanner" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="settings" Background="{Binding SettingsNavBackground}" Foreground="{Binding SettingsNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⚙" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Settings" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
        </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Spacing="10">
          <Button Classes="SideUtilityButton" Content="Help" Command="{Binding SelectMainTabCommand}" CommandParameter="help" Background="{Binding HelpNavBackground}" Foreground="{Binding HelpNavForeground}" />
          <Button Classes="SideUtilityButton" Content="Logout" Command="{Binding SelectMainTabCommand}" CommandParameter="logout" Background="{Binding LogoutNavBackground}" Foreground="{Binding LogoutNavForeground}" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Column="1" Grid.Row="1" Margin="0,0,16,16">
    <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                Classes="PrimaryNavTabs">
      <TabItem Header="Dashboard">
        <ScrollViewer Classes="PageScroll">
        <views:DashboardView />
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Markets">
        <ScrollViewer Classes="PageScroll">
        <views:MarketsView />
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Trading">
        <ScrollViewer Classes="PageScroll">
        <StackPanel Spacing="0">
        <views:TradingDeskView />
        </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Portfolio">
        <ScrollViewer Classes="PageScroll">
        <views:PortfolioView />
        </ScrollViewer>
      </TabItem>
      <TabItem Header="AI Signals">
        <ScrollViewer Classes="PageScroll">
          <views:AiSignalsView />
        </ScrollViewer>
      </TabItem>
<TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Sniper" VerticalAlignment="Center" />
            <Border Background="{Binding WalletVM.GlobalQuoteAssetModeBrush}" CornerRadius="8" Padding="6,1">
              <TextBlock Text="{Binding WalletVM.GlobalQuoteTabBadgeLabel}" Foreground="#081018" FontSize="11" FontWeight="Bold" />
            </Border>
          </StackPanel>
        </TabItem.Header>
        <Grid>
          <ScrollViewer Classes="PageScroll">
            <views:SniperView />
          </ScrollViewer>

        </Grid>
      </TabItem>

      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="DEX" VerticalAlignment="Center" />
            <Border Background="{Binding WalletVM.GlobalQuoteAssetModeBrush}" CornerRadius="8" Padding="6,1">
              <TextBlock Text="{Binding WalletVM.GlobalQuoteTabBadgeLabel}" Foreground="#081018" FontSize="11" FontWeight="Bold" />
            </Border>
          </StackPanel>
        </TabItem.Header>
        <ScrollViewer Classes="PageScroll">
        <Border Classes="Panel">
          <Grid ColumnDefinitions="350,*"
                RowDefinitions="*"
                ColumnSpacing="16"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ClipToBounds="True">
            <Border Classes="Panel" Grid.Column="0" Grid.Row="0" MinHeight="0">
              <StackPanel Spacing="12">
                <TextBlock Classes="H2" Text="DEX Tokens" />
                  <TextBox Text="{Binding DexTradingVM.SearchText}"
                          PlaceholderText="Search by symbol, name or address" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Content="SEARCH" Command="{Binding DexTradingVM.SearchCommand}" Width="110" />
                  <Button Content="REFRESH" Command="{Binding DexTradingVM.RefreshCommand}" Width="110" />
                </StackPanel>
                <TextBlock Text="{Binding DexTradingVM.StatusMessage}"
                           TextWrapping="Wrap"
                           Foreground="#8B949E" />
                <TextBlock Text="{Binding DexTradingVM.LastUpdatedLocal, StringFormat=Updated: {0:HH:mm:ss}}"
                           Foreground="#8B949E" />
                <ListBox ItemsSource="{Binding DexTradingVM.Tokens}"
                         SelectedItem="{Binding DexTradingVM.SelectedToken}"
                         Height="500">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:DexTokenItemViewModel">
                      <Border BorderBrush="#30363D" BorderThickness="0,0,0,1" Padding="0,10">
                        <StackPanel>
                          <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" />
                          <TextBlock Text="{Binding PairLabel}" Foreground="#8B949E" FontSize="12" />
                          <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding PriceUsd, StringFormat=$ {0:N6}}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding PriceChange24h, StringFormat={}{0:+0.##;-0.##;0}%}"
                                       Foreground="#00D4AA" />
                          </Grid>
                          <TextBlock Text="{Binding LiquidityUsd, StringFormat=Liquidity: $ {0:N0}}"
                                     Foreground="#8B949E"
                                     FontSize="12" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </Border>

            <Grid Grid.Column="1"
                  Grid.Row="0"
                  RowDefinitions="*"
                  MinHeight="0"
                  ClipToBounds="True">
              <ScrollViewer Grid.Row="0"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          MaxHeight="{Binding $parent[TabControl].Bounds.Height}"
                          MinHeight="0"
                          ClipToBounds="True"
                          AllowAutoHide="False"
                          VerticalScrollBarVisibility="Visible"
                          HorizontalScrollBarVisibility="Auto">
                <Border Classes="Panel"
                        MinHeight="0">
                  <StackPanel Spacing="14">
                  <TextBlock Classes="H1" Text="{Binding DexTradingVM.SelectedTokenTitle}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding DexTradingVM.SelectedTokenSubtitle}"
                             Foreground="#8B949E"
                             TextWrapping="Wrap" />

                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="16" RowSpacing="16">
                    <Border Classes="Panel" Grid.Row="0" Grid.Column="0">
                      <StackPanel>
                        <TextBlock Text="Price USD" Foreground="#8B949E" />
                        <TextBlock Classes="Value"
                                   FontSize="26"
                                   Text="{Binding DexTradingVM.SelectedToken.PriceUsd, StringFormat=$ {0:N6}}" />
                      </StackPanel>
                    </Border>

                    <Border Classes="Panel" Grid.Row="0" Grid.Column="1">
                      <StackPanel>
                        <TextBlock Text="Price Native" Foreground="#8B949E" />
                        <TextBlock Classes="Value"
                                   FontSize="26"
                                   Text="{Binding DexTradingVM.SelectedToken.PriceNative, StringFormat={}{0:N6}}" />
                      </StackPanel>
                    </Border>

                    <Border Classes="Panel" Grid.Row="1" Grid.Column="0">
                      <StackPanel>
                        <TextBlock Text="24h Volume" Foreground="#8B949E" />
                        <TextBlock Classes="Value"
                                   FontSize="24"
                                   Text="{Binding DexTradingVM.SelectedToken.Volume24h, StringFormat=$ {0:N0}}" />
                      </StackPanel>
                    </Border>

                    <Border Classes="Panel" Grid.Row="1" Grid.Column="1">
                      <StackPanel>
                        <TextBlock Text="Liquidity" Foreground="#8B949E" />
                        <TextBlock Classes="Value"
                                   FontSize="24"
                                   Text="{Binding DexTradingVM.SelectedToken.LiquidityUsd, StringFormat=$ {0:N0}}" />
                      </StackPanel>
                    </Border>

                    <Border Classes="Panel" Grid.Row="2" Grid.ColumnSpan="2" MinHeight="420">
                      <StackPanel Spacing="12">
                        <DockPanel>
                          <TextBlock Classes="H2" Text="Price History" DockPanel.Dock="Left" />
                          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <Button Content="15M"
                                    Command="{Binding DexTradingVM.SelectChartRangeCommand}"
                                    CommandParameter="15M"
                                    Width="72" />
                            <Button Content="1D"
                                    Command="{Binding DexTradingVM.SelectChartRangeCommand}"
                                    CommandParameter="1D"
                                    Width="72" />
                            <Button Content="1W"
                                    Command="{Binding DexTradingVM.SelectChartRangeCommand}"
                                    CommandParameter="1W"
                                    Width="72" />
                          </StackPanel>
                        </DockPanel>

                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="16">
                          <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding DexTradingVM.ChartStatusMessage}" Foreground="#8B949E" />
                            <TextBlock Text="{Binding DexTradingVM.ChartTelemetry}"
                                       Foreground="#14E0C1"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding DexTradingVM.SelectedChartRange, StringFormat=Range: {0}}" Foreground="#8B949E" />
                            <TextBlock Text="{Binding DexTradingVM.ChartSource, StringFormat=Source: {0}}" Foreground="#8B949E" />
                            <TextBlock Text="{Binding DexTradingVM.ChartDiagnostics, StringFormat=Debug: {0}}"
                                       Foreground="#8B949E"
                                       TextWrapping="Wrap"
                                       MaxWidth="520" />
                          </StackPanel>
                          <StackPanel Grid.Column="1">
                            <TextBlock Text="High" Foreground="#8B949E" />
                            <TextBlock Text="{Binding DexTradingVM.ChartHigh, StringFormat=$ {0:N6}}" />
                          </StackPanel>
                          <StackPanel Grid.Column="2">
                            <TextBlock Text="Low" Foreground="#8B949E" />
                            <TextBlock Text="{Binding DexTradingVM.ChartLow, StringFormat=$ {0:N6}}" />
                          </StackPanel>
                          <StackPanel Grid.Column="3">
                            <TextBlock Text="Change" Foreground="#8B949E" />
                            <TextBlock Text="{Binding DexTradingVM.ChartChangePercent, StringFormat={}{0:+0.##;-0.##;0}%}" />
                          </StackPanel>
                        </Grid>

                        <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="10" Padding="12" MinHeight="300">
                          <Grid RowDefinitions="*,Auto">
                            <ctrl:DexPriceChart Grid.Row="0"
                                                Height="300"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                Candles="{Binding DexTradingVM.ChartCandles}" />
                            <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="0,12,0,0">
                              <TextBlock Grid.Column="0" Text="{Binding DexTradingVM.ChartStartLabel}" Foreground="#8B949E" />
                              <TextBlock Grid.Column="2" Text="{Binding DexTradingVM.ChartEndLabel}" Foreground="#8B949E" />
                            </Grid>
                          </Grid>
                        </Border>
                      </StackPanel>
                    </Border>

                    <Border Classes="SectionPanel" Grid.Row="3" Grid.ColumnSpan="2">
                      <StackPanel Spacing="12">
                        <TextBlock Classes="H2" Text="Manual DEX Trade" />
                        <Border Classes="GuardStripCard">
                          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border Classes="GuardChip"
                                    Background="#10251F"
                                    BorderBrush="{Binding DexTradingVM.DexGuardStatusBrush}">
                              <TextBlock Text="{Binding DexTradingVM.DexGuardStatusLabel}"
                                         Foreground="{Binding DexTradingVM.DexGuardStatusBrush}"
                                         FontWeight="Bold" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="4">
                              <TextBlock Text="{Binding DexTradingVM.DexGuardSummary}" FontWeight="SemiBold" TextWrapping="Wrap" />
                              <TextBlock Text="{Binding DexTradingVM.DexGuardDetail}" Foreground="#8B949E" TextWrapping="Wrap" />
                            </StackPanel>
                          </Grid>
                        </Border>
                        <TextBlock Text="{Binding DexTradingVM.WalletTradeStatus}"
                                   Foreground="#8B949E"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding DexTradingVM.WalletSessionSummary, StringFormat=Active wallet: {0}}"
                                   Foreground="#14E0C1"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                          <Border Background="{Binding WalletVM.WalletReadinessBrush}" CornerRadius="10" Padding="10,4">
                            <TextBlock Text="{Binding WalletVM.WalletReadinessLabel}" Foreground="#081018" FontWeight="Bold" />
                          </Border>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding WalletVM.RouteReadinessSummary}"
                                     Foreground="#8B949E"
                                     TextWrapping="Wrap"
                                     VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock Text="{Binding DexTradingVM.WalletBalanceSummary, StringFormat=Native balance: {0}}"
                                   Foreground="#8B949E"
                                   TextWrapping="Wrap" />
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                          <Border Background="{Binding DexTradingVM.QuoteAssetModeBrush}" CornerRadius="10" Padding="10,4">
                            <TextBlock Text="{Binding DexTradingVM.QuoteAssetModeLabel}" Foreground="#081018" FontWeight="Bold" />
                          </Border>
                          <TextBlock Grid.Column="1" Text="{Binding DexTradingVM.QuoteAssetSummary}"
                                     Foreground="#8B949E"
                                     TextWrapping="Wrap"
                                     VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock Text="{Binding DexTradingVM.QuoteAssetBalanceLabel, StringFormat=Quote balance: {0}}"
                                   Foreground="#F4B860"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding DexTradingVM.SpendableQuoteBalanceLabel}"
                                   Foreground="#14E0C1"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding DexTradingVM.PairCompatibilityMessage}"
                                   Foreground="{Binding DexTradingVM.QuoteAssetModeBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding DexTradingVM.BuyAvailabilityMessage}"
                                   Foreground="{Binding DexTradingVM.BuyAvailabilityBrush}"
                                   TextWrapping="Wrap" />
                        <Button Content="OPEN WALLET HUB"
                                Command="{Binding OpenWalletTabCommand}"
                                Width="160" />

                        <Grid ColumnDefinitions="Auto,*,Auto,80" ColumnSpacing="12"
                              IsEnabled="{Binding DexTradingVM.CanTradeSelectedToken}">
                          <TextBlock Grid.Column="0" Text="Quote Asset" VerticalAlignment="Center" />
                          <ComboBox Grid.Column="1"
                                    ItemsSource="{Binding DexTradingVM.QuoteAssetOptions}"
                                    SelectedItem="{Binding DexTradingVM.SelectedQuoteAssetSymbol}" />
                          <TextBlock Grid.Column="2" Text="Slippage %" VerticalAlignment="Center" />
                          <NumericUpDown Grid.Column="3" Value="{Binding DexTradingVM.SlippagePercent}"
                                         Increment="0.5" FormatString="0.#" Minimum="0.1" Maximum="50"
                                         ToolTip.Tip="{Binding DexTradingVM.SlippageSummary}" />
                        </Grid>
                        <TextBlock Classes="Overline" Text="BUY" Margin="0,4,0,0" />
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8"
                              IsEnabled="{Binding DexTradingVM.CanTradeSelectedToken}">
                          <Button Grid.Column="0" Content="25%" Classes="GhostButton" Command="{Binding DexTradingVM.ApplyBuyBalancePresetCommand}" CommandParameter="25" />
                          <Button Grid.Column="1" Content="50%" Classes="GhostButton" Command="{Binding DexTradingVM.ApplyBuyBalancePresetCommand}" CommandParameter="50" />
                          <Button Grid.Column="2" Content="75%" Classes="GhostButton" Command="{Binding DexTradingVM.ApplyBuyBalancePresetCommand}" CommandParameter="75" />
                          <Button Grid.Column="3" Content="100%" Classes="GhostButton" Command="{Binding DexTradingVM.ApplyBuyBalancePresetCommand}" CommandParameter="100" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto" ColumnSpacing="12"
                              IsEnabled="{Binding DexTradingVM.CanTradeSelectedToken}">
                          <TextBlock Grid.Column="0" Text="{Binding DexTradingVM.BuyAmountLabel}" VerticalAlignment="Center" />
                          <NumericUpDown Grid.Column="1"
                                         Value="{Binding DexTradingVM.BuyAmountBnb}"
                                         Increment="0.001"
                                         FormatString="0.0000"
                                         Minimum="0" />
                          <Button Grid.Column="2" Content="MAX"
                                  Classes="GhostButton"
                                  Command="{Binding DexTradingVM.UseMaxBuyAmountCommand}" />
                        </Grid>
                        <TextBlock Text="{Binding DexTradingVM.BuyQuoteLabel}"
                                   Foreground="{Binding DexTradingVM.BuyQuoteBrush}"
                                   IsVisible="{Binding DexTradingVM.HasSelectedToken}"
                                   TextWrapping="Wrap" />

                        <TextBlock Classes="Overline" Text="SELL" Margin="0,4,0,0" />
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                          <TextBlock Grid.Column="0" Text="Balance:" VerticalAlignment="Center" Foreground="#8FA3B8" />
                          <TextBlock Grid.Column="1" Text="{Binding DexTradingVM.TokenBalanceLabel}"
                                     VerticalAlignment="Center" Foreground="#F4B860"
                                     IsVisible="{Binding DexTradingVM.HasSelectedToken}" />
                          <Button Grid.Column="2" Content="↻" Classes="GhostButton" Width="34"
                                  Command="{Binding DexTradingVM.RefreshTokenBalanceCommand}"
                                  ToolTip.Tip="Refresh token balance" />
                          <NumericUpDown Grid.Column="3"
                                         Value="{Binding DexTradingVM.SellAmountTokens}"
                                         Increment="1"
                                         FormatString="0.########"
                                         Minimum="0" Width="160"
                                         IsEnabled="{Binding DexTradingVM.CanTradeSelectedToken}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8"
                              IsEnabled="{Binding DexTradingVM.CanTradeSelectedToken}">
                          <Button Grid.Column="0" Content="25%" Classes="GhostButton" Command="{Binding DexTradingVM.ApplySellBalancePresetCommand}" CommandParameter="25" />
                          <Button Grid.Column="1" Content="50%" Classes="GhostButton" Command="{Binding DexTradingVM.ApplySellBalancePresetCommand}" CommandParameter="50" />
                          <Button Grid.Column="2" Content="75%" Classes="GhostButton" Command="{Binding DexTradingVM.ApplySellBalancePresetCommand}" CommandParameter="75" />
                          <Button Grid.Column="3" Content="100%" Classes="GhostButton" Command="{Binding DexTradingVM.ApplySellBalancePresetCommand}" CommandParameter="100" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="16">
                          <Button Content="BUY TOKEN" Classes="BuyButton" Command="{Binding DexTradingVM.BuyCommand}" Width="140"
                                  IsEnabled="{Binding DexTradingVM.CanBuySelectedTokenLive}"
                                  ToolTip.Tip="{Binding DexTradingVM.ManualBuyBlockedReason}" />
                          <Button Content="SELL TOKEN" Classes="SellButton" Command="{Binding DexTradingVM.SellCommand}" Width="140"
                                  IsEnabled="{Binding DexTradingVM.CanSellSelectedTokenLive}"
                                  ToolTip.Tip="{Binding DexTradingVM.ManualSellBlockedReason}" />
                        </StackPanel>
                        <TextBlock Text="{Binding DexTradingVM.ManualBuyBlockedReason}"
                                   Foreground="#F4B860"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding !DexTradingVM.CanBuySelectedTokenLive}" />

                        <TextBlock Text="{Binding DexTradingVM.SelectedToken.TokenAddress, StringFormat=Token: {0}}"
                                   Foreground="#8B949E"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding DexTradingVM.SelectedToken.Url, StringFormat=DEX: {0}}"
                                   Foreground="#8B949E"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </Grid>
                  </StackPanel>
                </Border>
              </ScrollViewer>
            </Grid>
          </Grid>
        </Border>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Logs">
        <ScrollViewer Classes="PageScroll">
        <StackPanel Spacing="16">
          <Border Classes="HeroPanel">
            <StackPanel Spacing="8">
              <TextBlock Classes="Overline" Text="SYSTEM OUTPUT" />
              <TextBlock Classes="H1" Text="Activity &amp; Logs" />
              <TextBlock Text="All runtime messages in one scrollable surface."
                         Foreground="#8FA3B8"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
          <Border Classes="Panel" Padding="0">
            <TextBox Classes="LogBox"
                     Text="{Binding LogMessages}"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     MinHeight="620" />
          </Border>
        </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>

    <Border IsVisible="{Binding IsPlaceholderSectionVisible}" Classes="Panel" Padding="26" ZIndex="5">
      <ScrollViewer Classes="PageScroll">
        <!-- Spacing intentionally 0: every section UserControl below stays
             always-visible (its inner panel toggles IsVisible), so any Spacing
             here accumulates between ~23 zero-height wrappers and pushes the
             active page down. Title gets its own margin instead. -->
        <StackPanel Spacing="0">
          <TextBlock Classes="H1" Text="{Binding CurrentSectionTitle}" Margin="0,0,0,16" />

          <views:RiskView />

          <!-- ══════════ BACKTEST ENGINE ══════════ -->
          <views:BacktestView />

          <views:BotsView />

          <!-- ═══════════════════════════════════════════════════════════════
               Whale Tracker Section
          ════════════════════════════════════════════════════════════════ -->
          <views:WhaleTrackerView />

          <!-- ═══════════════════════════════════════════════════════════════
               Live Tape — public market trades (time & sales)
          ════════════════════════════════════════════════════════════════ -->
          <views:MarketTapeView />

          <!-- ═══════════════════════════════════════════════════════════════
               Funding Rate Monitor
          ════════════════════════════════════════════════════════════════ -->
          <views:FundingRateView />

          <!-- ═══════════════════════════════════════════════════════════════
               FUNDING RATE ARBITRAGE BOT
          ════════════════════════════════════════════════════════════════ -->
          <views:FundingArbView />
          <!-- ═══ End Funding Rate Arbitrage Bot ═══ -->

          <!-- ═══════════════════════════════════════════════════════════════
               CEX-CEX SPOT ARBITRAGE SCANNER
          ════════════════════════════════════════════════════════════════ -->
          <views:ArbView />
          <!-- ═══ End CEX-CEX Spot Arbitrage ═══ -->

          <!-- ═══════════════════════════════════════════════════════════════
               COPY TRADING
          ════════════════════════════════════════════════════════════════ -->
          <views:CopyTradingView />
          <!-- ═══ End Copy Trading ═══ -->

          <!-- ═══════════════════════════════════════════════════════════════
               STATISTICAL ARBITRAGE (PAIRS TRADING)
          ════════════════════════════════════════════════════════════════ -->
          <views:StatArbView />
          <!-- ═══ End Statistical Arbitrage ═══ -->

          <!-- ═══════════════════════════════════════════════════════════════
               BEST EXECUTION ROUTER
          ════════════════════════════════════════════════════════════════ -->
          <views:RouterView />
          <!-- ═══ End Best Execution Router ═══ -->

          <!-- ═══════════════════════════════════════════════════════════════
               MULTI-MARKET SCANNER
          ════════════════════════════════════════════════════════════════ -->
          <views:ScannerView />
          <!-- ═══ End Multi-Market Scanner ═══ -->

          <!-- ═══════════════════════════════════════════════════════════════
               LIQUIDATION HEATMAP
          ════════════════════════════════════════════════════════════════ -->
          <views:LiquidationView />

          <!-- ═══════════════════════════════════════════════════════════════
               COMPOSITE BOT — Rule Editor
          ════════════════════════════════════════════════════════════════ -->
          <views:RulesView />

          <!-- ═══════════════════════════════════════════════════════════════
               Trade Journal
          ════════════════════════════════════════════════════════════════ -->
          <views:JournalView />

          <!-- ═══════════════════════════════════════════════════════════════
               Gas / Network Fees Monitor (Feature 14)
          ════════════════════════════════════════════════════════════════ -->
          <views:GasView />

          <!-- ═══════════════════════════════════════════════════════════════
               All Positions — unified futures view (Feature 15)
          ════════════════════════════════════════════════════════════════ -->
          <views:PositionsView />

          <!-- ═══════════════════════════════════════════════════════════════
               News Feed with Sentiment (Feature 16)
          ════════════════════════════════════════════════════════════════ -->
          <views:NewsView />

          <!-- ═══════════════════════════════════════════════════════════════
               On-Chain Metrics (Feature 17)
          ════════════════════════════════════════════════════════════════ -->
          <views:OnChainView />

          <!-- ═══════════════════════════════════════════════════════════════
               P&L Dashboard (Analytics section)
          ════════════════════════════════════════════════════════════════ -->
          <views:AnalyticsView />

          <views:SettingsView />

          <views:HelpView />

          <views:LogoutView />
        </StackPanel>
      </ScrollViewer>
    </Border>
    </Grid>
    </Grid>

    <Border x:Name="SplashOverlay" Classes="SplashOverlay" ZIndex="300">
      <Border.Transitions>
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.65" />
        </Transitions>
      </Border.Transitions>
      <Grid RowDefinitions="*,Auto,*" ClipToBounds="True">
        <Canvas IsHitTestVisible="False">
          <Ellipse Width="520" Height="520" Classes="SplashAuraPrimary" Canvas.Left="-80" Canvas.Top="-120" />
          <Ellipse Width="360" Height="360" Classes="SplashAuraSecondary" Canvas.Right="80" Canvas.Top="90" />
          <Ellipse Width="300" Height="300" Classes="SplashAuraTertiary" Canvas.Left="680" Canvas.Top="520" />
        </Canvas>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    Width="640"
                    Spacing="18">
          <Border x:Name="SplashLogoShell" Classes="SplashLogoShell" HorizontalAlignment="Center">
            <Grid>
              <Ellipse Width="214" Height="214" Classes="SplashLogoHalo" />
              <Border Classes="SplashLogoCore">
                <Grid Width="128" Height="128">
                  <Path Data="M 64 12 L 106 108 L 22 108 Z" Fill="#1FE6C2" Stretch="Uniform" />
                  <Path Data="M 64 38 L 86 90 L 42 90 Z" Fill="#071018" Stretch="Uniform" />
                  <Path x:Name="SplashSpinner"
                        Data="M 64 6 A 58 58 0 1 1 63.9 6"
                        Stroke="#6FDFFF"
                        StrokeThickness="4"
                        StrokeLineCap="Round"
                        StrokeDashArray="8,12"
                        Stretch="None"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Grid>
              </Border>
            </Grid>
          </Border>

          <StackPanel Spacing="8">
            <TextBlock Text="CRYPTO AI TERMINAL"
                       Classes="SplashTitle"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Launching the AI-driven trading workspace"
                       Classes="SplashSubtitle"
                       HorizontalAlignment="Center" />
          </StackPanel>

          <Grid Width="420" Height="12" HorizontalAlignment="Center" ClipToBounds="True">
            <Border Classes="SplashProgressTrack" />
            <Border x:Name="SplashProgressFill"
                    Classes="SplashProgressFill"
                    RenderTransformOrigin="0,0.5">
              <Border.RenderTransform>
                <ScaleTransform ScaleX="0.03" ScaleY="1" />
              </Border.RenderTransform>
            </Border>
          </Grid>

          <TextBlock x:Name="SplashStatusText"
                     Text="Syncing market feeds..."
                     Classes="SplashStatus"
                     HorizontalAlignment="Center" />

          <WrapPanel HorizontalAlignment="Center">
            <Border Classes="SplashMetricChip" Margin="0,0,10,0">
              <TextBlock Text="DEX streams" />
            </Border>
            <Border Classes="SplashMetricChip" Margin="0,0,10,0">
              <TextBlock Text="Risk engine" />
            </Border>
            <Border Classes="SplashMetricChip">
              <TextBlock Text="AI signals" />
            </Border>
          </WrapPanel>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Alert toast notification overlay -->
    <Border IsVisible="{Binding IsToastVisible}"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,24,96"
            Padding="16,12"
            Background="#0D2233"
            BorderBrush="#1FE6C2"
            BorderThickness="1"
            CornerRadius="8"
            MaxWidth="380"
            ZIndex="100">
      <Border.Transitions>
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.25" />
        </Transitions>
      </Border.Transitions>
      <StackPanel Spacing="4">
        <TextBlock Text="Alert Fired" Foreground="#1FE6C2" FontSize="11" FontWeight="SemiBold" />
        <TextBlock Text="{Binding ToastMessage}" Foreground="#E0E8F0" TextWrapping="Wrap" FontSize="13" />
      </StackPanel>
    </Border>

    <!-- Update available banner -->
    <Border IsVisible="{Binding IsUpdateAvailable}"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Margin="24,0,0,32"
            Padding="16,12"
            Background="#0D2233"
            BorderBrush="#1FE6C2"
            BorderThickness="1"
            CornerRadius="8"
            MaxWidth="420"
            ZIndex="100">
      <StackPanel Spacing="8">
        <TextBlock Text="⬆ Update available" Foreground="#1FE6C2" FontSize="11" FontWeight="SemiBold" />
        <TextBlock Text="{Binding UpdateBannerText}" Foreground="#E0E8F0" TextWrapping="Wrap" FontSize="13" />
        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
          <Button Content="Later" Command="{Binding DismissUpdateCommand}"
                  Padding="12,5" Background="Transparent" BorderBrush="#2C4257" BorderThickness="1" Foreground="#C5D2DE" />
          <Button Content="Download" Command="{Binding OpenUpdateCommand}"
                  Padding="14,5" Background="#1FE6C2" Foreground="#06121C" FontWeight="Bold" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- License status chip (trial / expired) -->
    <Border IsVisible="{Binding LicenseVM.ShowTrialBanner}"
            HorizontalAlignment="Right" VerticalAlignment="Top"
            Margin="0,16,24,0" Padding="12,7"
            Background="#0D2233" BorderBrush="{Binding LicenseVM.StateBrush}"
            BorderThickness="1" CornerRadius="8" ZIndex="90">
      <StackPanel Orientation="Horizontal" Spacing="10">
        <TextBlock Text="{Binding LicenseVM.StateLabel}" Foreground="{Binding LicenseVM.StateBrush}"
                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
        <Button Content="Activate" Command="{Binding LicenseVM.OpenCommand}"
                Padding="10,3" Background="#1FE6C2" Foreground="#06121C" FontSize="11" FontWeight="Bold" />
      </StackPanel>
    </Border>

    <!-- License activation overlay -->
    <Border IsVisible="{Binding LicenseVM.IsVisible}" Background="#CC050A12" ZIndex="220">
      <Border Width="560" HorizontalAlignment="Center" VerticalAlignment="Center"
              Background="#0B1622" BorderBrush="#1FE6C2" BorderThickness="1"
              CornerRadius="14" Padding="32,28">
        <StackPanel Spacing="16">
          <TextBlock Text="License activation" Foreground="#F0F6FC" FontSize="22" FontWeight="Bold" />
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Border Background="{Binding LicenseVM.StateBrush}" CornerRadius="3" Padding="8,3">
              <TextBlock Text="{Binding LicenseVM.StateLabel}" Foreground="#06121C" FontSize="12" FontWeight="Bold" />
            </Border>
          </StackPanel>
          <TextBlock Text="{Binding LicenseVM.DetailLabel}" Foreground="#9FB2C4" FontSize="13" TextWrapping="Wrap" />
          <TextBox Text="{Binding LicenseVM.KeyInput}" PlaceholderText="Paste license key"
                   Background="#0A1018" Foreground="#C8D8E8" Height="34" AcceptsReturn="False" />
          <TextBlock Text="{Binding LicenseVM.StatusMessage}" Foreground="#F4B860" FontSize="12" TextWrapping="Wrap" />
          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
            <TextBlock Grid.Column="0" Text="{Binding LicenseVM.MachineId, StringFormat='Machine ID: {0}'}"
                       Foreground="#48586A" FontSize="10" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="Close" Command="{Binding LicenseVM.CloseCommand}"
                    Padding="16,9" Background="Transparent" BorderBrush="#2C4257" BorderThickness="1" Foreground="#C5D2DE" />
            <Button Grid.Column="2" Content="Activate" Command="{Binding LicenseVM.ActivateCommand}"
                    Padding="18,9" Background="#1FE6C2" Foreground="#06121C" FontWeight="Bold" />
          </Grid>
        </StackPanel>
      </Border>
    </Border>

    <!-- First-run Welcome / Demo overlay -->
    <Border IsVisible="{Binding IsWelcomeVisible}"
            Background="#CC050A12"
            ZIndex="200">
      <Border Width="560"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Background="#0B1622"
              BorderBrush="#1FE6C2"
              BorderThickness="1"
              CornerRadius="14"
              Padding="32,28">
        <StackPanel Spacing="18">
          <StackPanel Spacing="6">
            <Border Background="#13312C"
                    CornerRadius="4"
                    Padding="8,3"
                    HorizontalAlignment="Left">
              <TextBlock Text="DEMO · NO API KEYS NEEDED"
                         Foreground="#1FE6C2"
                         FontSize="11"
                         FontWeight="Bold" />
            </Border>
            <TextBlock Text="Welcome to Crypto AI Terminal"
                       Foreground="#F0F6FC"
                       FontSize="24"
                       FontWeight="Bold" />
            <TextBlock Foreground="#9FB2C4"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Text="You're starting in Paper (Demo) mode. Every order — spot, futures, DEX, and the sniper — is simulated. No real funds can leave the terminal until you add API keys and switch to Live yourself." />
          </StackPanel>

          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <TextBlock Grid.Column="0" Text="✓" Foreground="#3DDC84" FontWeight="Bold" />
              <TextBlock Grid.Column="1" Foreground="#C5D2DE" FontSize="13" TextWrapping="Wrap"
                         Text="Explore live market data, charts, the DEX sniper and AI verdicts with zero setup." />
            </Grid>
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <TextBlock Grid.Column="0" Text="✓" Foreground="#3DDC84" FontWeight="Bold" />
              <TextBlock Grid.Column="1" Foreground="#C5D2DE" FontSize="13" TextWrapping="Wrap"
                         Text="Run bots, backtests and paper trades — results are tracked in the journal and P&amp;L dashboard." />
            </Grid>
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <TextBlock Grid.Column="0" Text="✓" Foreground="#3DDC84" FontWeight="Bold" />
              <TextBlock Grid.Column="1" Foreground="#C5D2DE" FontSize="13" TextWrapping="Wrap"
                         Text="Add exchange API keys any time from Settings when you're ready to trade live." />
            </Grid>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
            <Button Content="Add API keys"
                    Command="{Binding OpenApiKeysFromWelcomeCommand}"
                    Padding="18,10"
                    Background="Transparent"
                    BorderBrush="#2C4257"
                    BorderThickness="1"
                    Foreground="#C5D2DE" />
            <Button Content="Start exploring in Demo"
                    Command="{Binding StartDemoCommand}"
                    Padding="20,10"
                    Background="#1FE6C2"
                    Foreground="#06121C"
                    FontWeight="Bold" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>

    <!-- Onboarding wizard overlay -->
    <Border IsVisible="{Binding OnboardingVM.IsVisible}"
            Background="#CC050A12"
            ZIndex="210">
      <Border Width="560"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Background="#0B1622"
              BorderBrush="#1FE6C2"
              BorderThickness="1"
              CornerRadius="14"
              Padding="32,28">
        <StackPanel Spacing="18">

          <!-- Step 1: choose exchange -->
          <StackPanel Spacing="16" IsVisible="{Binding OnboardingVM.IsChooseStep}">
            <StackPanel Spacing="6">
              <TextBlock Text="Connect an exchange" Foreground="#F0F6FC" FontSize="22" FontWeight="Bold" />
              <TextBlock Foreground="#9FB2C4" FontSize="13" TextWrapping="Wrap"
                         Text="Pick where you trade. Keys are stored encrypted on this PC only (Windows DPAPI) and never leave the machine." />
            </StackPanel>
            <UniformGrid Columns="2" Margin="0,4,0,0">
              <Button Content="Binance" Command="{Binding OnboardingVM.ChooseExchangeCommand}" CommandParameter="Binance"
                      Margin="0,0,8,8" Height="46" Background="#10202E" Foreground="#E0E8F0" FontWeight="SemiBold" />
              <Button Content="Bybit" Command="{Binding OnboardingVM.ChooseExchangeCommand}" CommandParameter="Bybit"
                      Margin="0,0,0,8" Height="46" Background="#10202E" Foreground="#E0E8F0" FontWeight="SemiBold" />
              <Button Content="OKX" Command="{Binding OnboardingVM.ChooseExchangeCommand}" CommandParameter="OKX"
                      Margin="0,0,8,0" Height="46" Background="#10202E" Foreground="#E0E8F0" FontWeight="SemiBold" />
              <Button Content="KuCoin" Command="{Binding OnboardingVM.ChooseExchangeCommand}" CommandParameter="KuCoin"
                      Height="46" Background="#10202E" Foreground="#E0E8F0" FontWeight="SemiBold" />
            </UniformGrid>
            <Button Content="Skip — I'll explore in Demo first"
                    Command="{Binding OnboardingVM.SkipCommand}"
                    HorizontalAlignment="Center" Background="Transparent" Foreground="#7E93A6" FontSize="12" />
          </StackPanel>

          <!-- Step 2: enter keys -->
          <StackPanel Spacing="12" IsVisible="{Binding OnboardingVM.IsKeysStep}">
            <TextBlock Text="{Binding OnboardingVM.KeysStepTitle}" Foreground="#F0F6FC" FontSize="22" FontWeight="Bold" />
            <TextBlock Foreground="#9FB2C4" FontSize="12" TextWrapping="Wrap"
                       Text="Create an API key with trade permission only (no withdrawals), ideally IP-restricted." />
            <TextBox Text="{Binding OnboardingVM.KeyInput}" PlaceholderText="API key"
                     Background="#0A1018" Foreground="#C8D8E8" Height="34" />
            <TextBox Text="{Binding OnboardingVM.SecretInput}" PlaceholderText="API secret" PasswordChar="•"
                     Background="#0A1018" Foreground="#C8D8E8" Height="34" />
            <TextBox Text="{Binding OnboardingVM.PassphraseInput}" PlaceholderText="Passphrase" PasswordChar="•"
                     IsVisible="{Binding OnboardingVM.NeedsPassphrase}"
                     Background="#0A1018" Foreground="#C8D8E8" Height="34" />
            <TextBlock Text="{Binding OnboardingVM.StatusMessage}" Foreground="#FF8A4C" FontSize="12" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
              <Button Content="Back" Command="{Binding OnboardingVM.BackCommand}"
                      Padding="16,9" Background="Transparent" BorderBrush="#2C4257" BorderThickness="1" Foreground="#C5D2DE" />
              <Button Content="Save securely" Command="{Binding OnboardingVM.SaveKeysCommand}"
                      Padding="18,9" Background="#1FE6C2" Foreground="#06121C" FontWeight="Bold" />
            </StackPanel>
          </StackPanel>

          <!-- Step 3: done -->
          <StackPanel Spacing="16" IsVisible="{Binding OnboardingVM.IsDoneStep}">
            <TextBlock Text="✓ Keys saved" Foreground="#3DDC84" FontSize="22" FontWeight="Bold" />
            <TextBlock Foreground="#9FB2C4" FontSize="13" TextWrapping="Wrap"
                       Text="Your API keys are encrypted on this PC. Restart the terminal to connect them — until then you stay in Demo (paper) mode, so nothing trades live by accident." />
            <Button Content="Done"
                    Command="{Binding OnboardingVM.FinishCommand}"
                    HorizontalAlignment="Right" Padding="22,10"
                    Background="#1FE6C2" Foreground="#06121C" FontWeight="Bold" />
          </StackPanel>

        </StackPanel>
      </Border>
    </Border>

    <!-- Floating "Ask AI" button — opens the global omnibox (same as Ctrl+K) -->
    <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
            Margin="0,0,24,28" ZIndex="95"
            CornerRadius="26"
            BoxShadow="0 6 20 0 #80000000"
            IsVisible="{Binding !IsCommandPaletteOpen}">
      <Button Command="{Binding OpenCommandPaletteCommand}"
              Width="52" Height="52" CornerRadius="26" Padding="0"
              Background="#21E6C1" Foreground="#06121C"
              FontSize="22" Content="🧠"
              HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
              ToolTip.Tip="Ask AI · Ctrl+K">
        <Button.Styles>
          <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3FF0D4" />
          </Style>
          <Style Selector="Button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#15C7A8" />
          </Style>
        </Button.Styles>
      </Button>
    </Border>

    <!-- ═══ Global AI Command Bar (Ctrl+K) ═══ -->
    <Border IsVisible="{Binding IsCommandPaletteOpen}"
            Background="#CC04101A" ZIndex="100">
      <Grid>
        <!-- click-outside to close -->
        <Button Command="{Binding CloseCommandPaletteCommand}"
                Background="Transparent" BorderThickness="0"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

        <Border VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,120,0,0" Width="680" MaxWidth="680"
                Background="#0E1B27" BorderBrush="#21E6C1" BorderThickness="1"
                CornerRadius="12" Padding="18" BoxShadow="0 18 60 0 #99000000">
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="⚡ AI Command" Classes="H2" />
                <TextBlock Text="Navigate or ask anything — Enter to run, Esc to close."
                           Foreground="#8FA3B8" FontSize="12" />
              </StackPanel>
              <Button Grid.Column="1" Content="✕" Command="{Binding CloseCommandPaletteCommand}"
                      Background="Transparent" Foreground="#8FA3B8" FontSize="16"
                      VerticalAlignment="Top" Padding="8,2" />
            </Grid>

            <TextBox x:Name="CommandPaletteBox"
                     Text="{Binding CommandPaletteInput}"
                     FontSize="16" Padding="12,10"
                     PlaceholderText="e.g. “open scanner”, “go to settings”, “what's my biggest risk?”">
              <TextBox.KeyBindings>
                <KeyBinding Gesture="Enter"  Command="{Binding RunCommandPaletteCommand}" />
                <KeyBinding Gesture="Escape" Command="{Binding CloseCommandPaletteCommand}" />
              </TextBox.KeyBindings>
            </TextBox>

            <StackPanel Orientation="Horizontal" Spacing="10">
              <Button Content="Run" Command="{Binding RunCommandPaletteCommand}"
                      Background="#1FE6C2" Foreground="#06121C" FontWeight="Bold" Padding="18,8" />
              <TextBlock Text="Thinking…" Foreground="#21E6C1" VerticalAlignment="Center"
                         IsVisible="{Binding CommandPaletteBusy}" />
            </StackPanel>

            <Border Background="#0A1722" CornerRadius="6" Padding="12"
                    IsVisible="{Binding CommandPaletteResult, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
              <TextBlock Text="{Binding CommandPaletteResult}" Foreground="#D7E3EE"
                         TextWrapping="Wrap" />
            </Border>

            <TextBlock Foreground="#4A6880" FontSize="11" TextWrapping="Wrap"
                       Text="Tip: type a destination (scanner, settings, whales, liquidations…) to jump there, or ask a question to get an AI answer. The command bar never trades — it only advises and navigates." />
          </StackPanel>
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>





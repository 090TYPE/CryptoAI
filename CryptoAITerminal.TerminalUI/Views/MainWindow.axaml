<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CryptoAITerminal.TerminalUI.ViewModels"
        xmlns:ctrl="clr-namespace:CryptoAITerminal.TerminalUI.Controls"
        xmlns:views="clr-namespace:CryptoAITerminal.TerminalUI.Views"
        xmlns:wt="clr-namespace:CryptoAITerminal.WhaleTracker.Models;assembly=CryptoAITerminal.WhaleTracker"
        x:Class="CryptoAITerminal.TerminalUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="RootWindow"
        Title="Crypto AI Terminal"
        Icon="avares://CryptoAITerminal.TerminalUI/Assets/app-icon.png"
        MinWidth="960"
        MinHeight="640"
        WindowDecorations="None"
        WindowState="FullScreen"
        ExtendClientAreaToDecorationsHint="True">

  <!-- Hotkeys: Shift+1…9 apply order templates without clicking -->
  <Window.KeyBindings>
    <KeyBinding Gesture="Shift+D1" Command="{Binding ApplyTemplate1Command}" />
    <KeyBinding Gesture="Shift+D2" Command="{Binding ApplyTemplate2Command}" />
    <KeyBinding Gesture="Shift+D3" Command="{Binding ApplyTemplate3Command}" />
    <KeyBinding Gesture="Shift+D4" Command="{Binding ApplyTemplate4Command}" />
    <KeyBinding Gesture="Shift+D5" Command="{Binding ApplyTemplate5Command}" />
    <KeyBinding Gesture="Shift+D6" Command="{Binding ApplyTemplate6Command}" />
    <KeyBinding Gesture="Shift+D7" Command="{Binding ApplyTemplate7Command}" />
    <KeyBinding Gesture="Shift+D8" Command="{Binding ApplyTemplate8Command}" />
    <KeyBinding Gesture="Shift+D9" Command="{Binding ApplyTemplate9Command}" />
    <!-- Global AI command bar -->
    <KeyBinding Gesture="Ctrl+K" Command="{Binding OpenCommandPaletteCommand}" />
  </Window.KeyBindings>

  <Grid>
    <Grid x:Name="MainContentRoot"
          ColumnDefinitions="184,*"
          RowDefinitions="Auto,*"
          Opacity="0"
          IsHitTestVisible="False">
      <Grid.Transitions>
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.55" />
        </Transitions>
      </Grid.Transitions>
    <Border Grid.Row="0" Grid.ColumnSpan="2" Classes="TopBarShell" Margin="16,16,16,12" Padding="14,10">
      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="20">
        <Grid ColumnDefinitions="40,*" ColumnSpacing="12">
          <Border Grid.Column="0" Classes="BrandGlyph">
            <Grid>
              <Path Data="M 14 2 L 26 26 L 2 26 Z" Fill="#1FE6C2" Stretch="Uniform" />
              <Path Data="M 14 9 L 21 22 L 7 22 Z" Fill="#0A121A" Stretch="Uniform" />
            </Grid>
          </Border>
          <TextBlock Grid.Column="1"
                     Text="CRYPTO AI TERMINAL"
                     Classes="BrandTitle"
                     VerticalAlignment="Center" />
        </Grid>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="28,0,0,0"
                    Spacing="6">
          <TextBlock Text="/" Foreground="#3A4F63" VerticalAlignment="Center" FontSize="16" Margin="0,0,4,0" />
          <TextBlock Text="{Binding CurrentSectionTitle}"
                     Foreground="{DynamicResource Accent}"
                     FontWeight="SemiBold"
                     FontSize="15"
                     VerticalAlignment="Center" />
        </StackPanel>

        <WrapPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <Button x:Name="EnglishLanguageButton"
                  Classes="GhostButton"
                  Content="EN"
                  Padding="12,7"
                  Margin="0,0,10,0"
                  Click="OnSetEnglishLanguageClick" />
          <Button x:Name="RussianLanguageButton"
                  Classes="GhostButton"
                  Content="RU"
                  Padding="12,7"
                  Margin="0,0,10,0"
                  Click="OnSetRussianLanguageClick" />
          <Border Classes="StatusPill" Margin="0,0,10,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Ellipse Width="8" Height="8" Fill="#3DDC84" VerticalAlignment="Center" />
              <TextBlock Text="{Binding ConnectionStateLabel}" />
            </StackPanel>
          </Border>
          <Button Classes="GhostButton"
                  ToolTip.Tip="Settings"
                  Padding="0"
                  Width="32" Height="32"
                  CornerRadius="17"
                  BorderThickness="1"
                  Margin="0,0,10,0"
                  Command="{Binding SelectMainTabCommand}"
                  CommandParameter="settings">
            <TextBlock Text="⚙" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" />
          </Button>
          <Button Classes="GhostButton"
                  ToolTip.Tip="Portfolio / Wallet"
                  Padding="0"
                  Width="32" Height="32"
                  CornerRadius="17"
                  BorderThickness="1"
                  Margin="0,0,10,0"
                  Command="{Binding SelectMainTabCommand}"
                  CommandParameter="portfolio">
            <TextBlock Text="◈" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" />
          </Button>
        </WrapPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1" Grid.Column="0" Classes="SidebarShell" Margin="16,0,12,16" Padding="10">
      <Grid RowDefinitions="*,Auto" RowSpacing="16">
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,4,0">
        <StackPanel Spacing="3">

          <!-- ── Торговля ─────────────────────────────────── -->
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="dashboard" Background="{Binding DashboardNavBackground}" Foreground="{Binding DashboardNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⌂" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" /></Border>
              <TextBlock Grid.Column="1" Text="Dashboard" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="markets" Background="{Binding MarketsNavBackground}" Foreground="{Binding MarketsNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="≋" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Markets" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="trading" Background="{Binding TradingNavBackground}" Foreground="{Binding TradingNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="✦" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Trading" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="ai-signals" Background="{Binding SignalsNavBackground}" Foreground="{Binding SignalsNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="✧" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="AI Signals" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="sniper" Background="{Binding SniperNavBackground}" Foreground="{Binding SniperNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="◎" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Sniper" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>

          <!-- ── Портфель ─────────────────────────────────── -->
          <Border Classes="SideNavDivider" />
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="portfolio" Background="{Binding PortfolioNavBackground}" Foreground="{Binding PortfolioNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="▣" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Portfolio" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="positions" Background="{Binding PositionsNavBackground}" Foreground="{Binding PositionsNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⊞" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Positions" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="risk" Background="{Binding RiskNavBackground}" Foreground="{Binding RiskNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⛨" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Risk" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>

          <!-- ── Автоматизация ────────────────────────────── -->
          <Border Classes="SideNavDivider" />
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="bots" Background="{Binding BotsNavBackground}" Foreground="{Binding BotsNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="◉" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Bots" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="rules" Background="{Binding RulesNavBackground}" Foreground="{Binding RulesNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⚡" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" /></Border>
              <TextBlock Grid.Column="1" Text="Rules" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="backtest" Background="{Binding BacktestNavBackground}" Foreground="{Binding BacktestNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="↗" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Backtest" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="journal" Background="{Binding JournalNavBackground}" Foreground="{Binding JournalNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="📓" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Journal" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>

          <!-- ── Арбитраж / Copy ──────────────────────────── -->
          <Border Classes="SideNavDivider" />
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="funding" Background="{Binding FundingNavBackground}" Foreground="{Binding FundingNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="%" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" /></Border>
              <TextBlock Grid.Column="1" Text="Funding" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="arb" Background="{Binding ArbNavBackground}" Foreground="{Binding ArbNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⇄" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" /></Border>
              <TextBlock Grid.Column="1" Text="Arb" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="copy" Background="{Binding CopyNavBackground}" Foreground="{Binding CopyNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⊕" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" /></Border>
              <TextBlock Grid.Column="1" Text="Copy" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="statarb" Background="{Binding StatArbNavBackground}" Foreground="{Binding StatArbNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="∑" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" /></Border>
              <TextBlock Grid.Column="1" Text="Stat Arb" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>

          <!-- ── Данные / Аналитика ───────────────────────── -->
          <Border Classes="SideNavDivider" />
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="news" Background="{Binding NewsNavBackground}" Foreground="{Binding NewsNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph">
                <Panel>
                  <TextBlock Text="📰" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" />
                  <Border IsVisible="{Binding NewsFeedVM.HasUnread}"
                          Background="#FF6B6B" CornerRadius="6" Width="12" Height="12"
                          HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-3,-3,0">
                    <TextBlock Text="{Binding NewsFeedVM.UnreadBadge}" Foreground="White"
                               FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                </Panel>
              </Border>
              <TextBlock Grid.Column="1" Text="News" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="onchain" Background="{Binding OnChainNavBackground}" Foreground="{Binding OnChainNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⛓" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="On-Chain" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="whale" Background="{Binding WhaleNavBackground}" Foreground="{Binding WhaleNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⬡" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Whales" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="liquidation" Background="{Binding LiquidationNavBackground}" Foreground="{Binding LiquidationNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="🔥" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" /></Border>
              <TextBlock Grid.Column="1" Text="Liq Map" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="analytics" Background="{Binding AnalyticsNavBackground}" Foreground="{Binding AnalyticsNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="≣" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Analytics" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>

          <!-- ── Инфраструктура ───────────────────────────── -->
          <Border Classes="SideNavDivider" />
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="gas" Background="{Binding GasNavBackground}" Foreground="{Binding GasNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⛽" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Gas" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="router" Background="{Binding RouterNavBackground}" Foreground="{Binding RouterNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⟳" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" /></Border>
              <TextBlock Grid.Column="1" Text="Router" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="scanner" Background="{Binding ScannerNavBackground}" Foreground="{Binding ScannerNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⊞" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" /></Border>
              <TextBlock Grid.Column="1" Text="Scanner" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
          <Button Classes="SideNavButton" Command="{Binding SelectMainTabCommand}" CommandParameter="settings" Background="{Binding SettingsNavBackground}" Foreground="{Binding SettingsNavForeground}">
            <Grid ColumnDefinitions="18,*" ColumnSpacing="12">
              <Border Width="18" Height="18" Classes="NavGlyph"><TextBlock Text="⚙" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" /></Border>
              <TextBlock Grid.Column="1" Text="Settings" VerticalAlignment="Center" Foreground="{Binding $parent[Button].Foreground}" />
            </Grid>
          </Button>
        </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Spacing="10">
          <Button Classes="SideUtilityButton" Content="Help" Command="{Binding SelectMainTabCommand}" CommandParameter="help" Background="{Binding HelpNavBackground}" Foreground="{Binding HelpNavForeground}" />
          <Button Classes="SideUtilityButton" Content="Logout" Command="{Binding SelectMainTabCommand}" CommandParameter="logout" Background="{Binding LogoutNavBackground}" Foreground="{Binding LogoutNavForeground}" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Column="1" Grid.Row="1" Margin="0,0,16,16">
    <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                Classes="PrimaryNavTabs">
      <TabItem Header="Dashboard">
        <ScrollViewer Classes="PageScroll">
        <StackPanel Spacing="16">
        <Border Classes="HeroPanel"
                BorderBrush="{Binding WalletVM.GlobalQuoteAssetModeBrush}"
                BorderThickness="1.5">
          <Grid ColumnDefinitions="1.3*,Auto" ColumnSpacing="18">
            <StackPanel Spacing="6">
              <TextBlock Classes="Overline" Text="MARKET OVERVIEW" />
              <TextBlock Classes="H1" Text="{Binding SelectedMarketTitle}" />
            </StackPanel>

            <WrapPanel Orientation="Horizontal">
              <Border Classes="SoftPanel" MinWidth="150" Margin="0,0,12,0">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Last Price" />
                  <TextBlock FontSize="22" FontWeight="Bold" Foreground="#21E6C1"
                             Text="{Binding SelectedMarket.LastPrice, StringFormat=$ {0:N4}}" />
                </StackPanel>
              </Border>
              <Border Classes="SoftPanel" MinWidth="140">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Spread" />
                  <TextBlock FontSize="22" FontWeight="Bold" Foreground="#21E6C1"
                             Text="{Binding SelectedMarket.Spread, StringFormat=$ {0:N6}}" />
                </StackPanel>
              </Border>
            </WrapPanel>
          </Grid>
        </Border>

        <Border Classes="Panel">
          <Grid ColumnDefinitions="310,*" ColumnSpacing="16">
            <Border Classes="Panel" Grid.Column="0">
              <StackPanel Spacing="12">
                <TextBlock Classes="H2" Text="Tracked Coins" />
                <TextBlock Text="Loading markets…"
                           Foreground="#8B949E"
                           IsVisible="{Binding IsMarketLoading}" />

                <ScrollViewer Classes="PageScroll" MaxHeight="640">
                  <ListBox ItemsSource="{Binding Markets}"
                           SelectedItem="{Binding SelectedMarket}">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:CexMarketItemViewModel">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                          <TextBlock Grid.Row="0" Grid.Column="0"
                                     Text="{Binding DisplaySymbol}"
                                     FontWeight="Bold" />
                          <TextBlock Grid.Row="0" Grid.Column="1"
                                     Text="{Binding LastPrice, StringFormat=$ {0:N4}}"
                                     Foreground="#21E6C1" />
                          <TextBlock Grid.Row="1" Grid.Column="0"
                                     Text="{Binding BestBid, StringFormat=Bid: $ {0:N4}}"
                                     Foreground="#8B949E"
                                     FontSize="12" />
                          <TextBlock Grid.Row="1" Grid.Column="1"
                                     Text="{Binding BestAsk, StringFormat=Ask: $ {0:N4}}"
                                     Foreground="#8B949E"
                                     FontSize="12" />
                          <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                                     Text="{Binding LastUpdated, StringFormat=Updated: {0:HH:mm:ss}}"
                                     Foreground="#6E8196"
                                     FontSize="12" />
                        </Grid>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </ScrollViewer>
              </StackPanel>
            </Border>

            <Border Classes="Panel" Grid.Column="1">
              <StackPanel Spacing="16">
                <StackPanel Spacing="4">
                  <TextBlock Classes="H1" Text="{Binding SelectedMarketTitle}" />
                </StackPanel>

                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="16">
                  <Border Classes="Panel" Grid.Column="0">
                    <StackPanel>
                      <TextBlock Text="Last Price" Foreground="#8B949E" />
                      <TextBlock Classes="Value"
                                 FontSize="24"
                                 Text="{Binding SelectedMarket.LastPrice, StringFormat=$ {0:N4}}" />
                    </StackPanel>
                  </Border>
                  <Border Classes="Panel" Grid.Column="1">
                    <StackPanel>
                      <TextBlock Text="Best Bid" Foreground="#8B949E" />
                      <TextBlock Classes="Value"
                                 FontSize="24"
                                 Text="{Binding SelectedMarket.BestBid, StringFormat=$ {0:N4}}" />
                    </StackPanel>
                  </Border>
                  <Border Classes="Panel" Grid.Column="2">
                    <StackPanel>
                      <TextBlock Text="Best Ask" Foreground="#8B949E" />
                      <TextBlock Classes="Value"
                                 FontSize="24"
                                 Text="{Binding SelectedMarket.BestAsk, StringFormat=$ {0:N4}}" />
                    </StackPanel>
                  </Border>
                  <Border Classes="Panel" Grid.Column="3">
                    <StackPanel>
                      <TextBlock Text="Spread" Foreground="#8B949E" />
                      <TextBlock Classes="Value"
                                 FontSize="24"
                                 Text="{Binding SelectedMarket.Spread, StringFormat=$ {0:N6}}" />
                    </StackPanel>
                  </Border>
                </Grid>

                <Border Classes="SoftPanel">
                  <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <TextBlock Grid.Row="0" Classes="H2" Text="Live Price Chart" />
                    <Grid Grid.Row="1" ColumnDefinitions="*,160" ColumnSpacing="8">
                      <ctrl:CexPriceChart Grid.Column="0"
                                          Height="240"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          Points="{Binding SelectedMarket.ChartPoints}"
                                          IsPositiveTrend="{Binding SelectedMarket.IsPositiveTrend}" />
                      <!-- Mini liquidation heatmap — Viewbox scales 1200×460 → 160×224.
                           Explicit Width+Height on Viewbox gives well-defined ScaleX/ScaleY. -->
                      <Border Grid.Column="1" Background="#04101A" CornerRadius="6" ClipToBounds="True"
                              ToolTip.Tip="Liquidation Heatmap — click 🔥 Liq Map for fullscreen">
                        <StackPanel>
                          <TextBlock Text="LIQ MAP" Foreground="#4A6070" FontSize="9" FontWeight="Bold"
                                     Margin="4,4,0,2" />
                          <Viewbox Width="160" Height="224" Stretch="Fill">
                            <Canvas Width="1200" Height="460">
                              <Path Data="{Binding LiquidationHeatmapVM.LongBarsGeometry}"
                                    Fill="#5521E6C1" Stroke="#21E6C1" StrokeThickness="1" />
                              <Path Data="{Binding LiquidationHeatmapVM.ShortBarsGeometry}"
                                    Fill="#55FF4444" Stroke="#FF4444" StrokeThickness="1" />
                              <Line StartPoint="600,0" EndPoint="600,460"
                                    Stroke="#1E3A50" StrokeThickness="1" />
                              <Path Data="{Binding LiquidationHeatmapVM.CurrentPriceGeometry}"
                                    Stroke="#F4B860" StrokeThickness="2" StrokeDashArray="8,4" />
                            </Canvas>
                          </Viewbox>
                        </StackPanel>
                      </Border>
                    </Grid>
                    <TextBlock Grid.Row="2"
                               Text="{Binding SelectedMarket.LastUpdated, StringFormat=Last tick: {0:dd.MM.yyyy HH:mm:ss}}"
                               Foreground="#8B949E" />
                  </Grid>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                  <Border Classes="Panel" Grid.Column="0">
                    <StackPanel Spacing="8">
                      <TextBlock Classes="H2" Text="Bids" />
                      <ScrollViewer Classes="PageScroll" MaxHeight="240">
                        <ItemsControl ItemsSource="{Binding SelectedMarket.BidLevels}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:OrderBookLevelViewModel">
                              <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Price, StringFormat=$ {0:N4}}"
                                           Foreground="#3DDC84" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Quantity, StringFormat={}{0:N4}}"
                                           Foreground="#8B949E" />
                              </Grid>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </ScrollViewer>
                    </StackPanel>
                  </Border>

                  <Border Classes="Panel" Grid.Column="1">
                    <StackPanel Spacing="8">
                      <TextBlock Classes="H2" Text="Asks" />
                      <ScrollViewer Classes="PageScroll" MaxHeight="240">
                        <ItemsControl ItemsSource="{Binding SelectedMarket.AskLevels}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:OrderBookLevelViewModel">
                              <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Price, StringFormat=$ {0:N4}}"
                                           Foreground="#FF6B6B" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Quantity, StringFormat={}{0:N4}}"
                                           Foreground="#8B949E" />
                              </Grid>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </ScrollViewer>
                    </StackPanel>
                  </Border>
                </Grid>
              </StackPanel>
            </Border>
          </Grid>
        </Border>

        <!-- ── Market Sentiment Widget ──────────────────────────────────────── -->
        <Border Classes="Panel">
          <StackPanel Spacing="12">
            <!-- Header row -->
            <Grid ColumnDefinitions="*,Auto,Auto">
              <TextBlock Grid.Column="0" Classes="H2" Text="MARKET SENTIMENT" />
              <TextBlock Grid.Column="1" Text="{Binding SentimentVM.StatusLabel}"
                         Foreground="#8B949E" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0" />
              <Button Grid.Column="2" Content="🧠 AI Read"
                      Command="{Binding SentimentVM.AnalyzeWithAiCommand}"
                      IsEnabled="{Binding !SentimentVM.InsightRunning}"
                      Foreground="#21E6C1" FontSize="11" />
            </Grid>

            <!-- ── AI Sentiment Insight (#7) ── -->
            <Border Background="#04101A" CornerRadius="6" Padding="12,9"
                    IsVisible="{Binding SentimentVM.HasInsight}">
              <StackPanel Spacing="5">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="{Binding SentimentVM.InsightSignal}"
                             Foreground="{Binding SentimentVM.InsightSignalBrush}" FontWeight="Bold" FontSize="13" />
                  <TextBlock Grid.Column="1" Text="{Binding SentimentVM.InsightSource}"
                             Foreground="#5C6E82" FontSize="10" VerticalAlignment="Center" />
                </Grid>
                <TextBlock Text="{Binding SentimentVM.InsightSummary}" Foreground="#D7E3EE" FontSize="12" TextWrapping="Wrap" />
                <TextBlock Text="{Binding SentimentVM.InsightBullets}" Foreground="#8FA3B8" FontSize="11" TextWrapping="Wrap"
                           IsVisible="{Binding SentimentVM.InsightBullets, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
              </StackPanel>
            </Border>

            <!-- Fear & Greed row -->
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
              <!-- Circle gauge -->
              <Border Grid.Column="0"
                      Width="72" Height="72" CornerRadius="36"
                      BorderThickness="3"
                      BorderBrush="{Binding SentimentVM.FearGreedBrush}"
                      Background="#0D1B2A"
                      VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0">
                  <TextBlock Text="{Binding SentimentVM.FearGreedValue}"
                             FontSize="22" FontWeight="Bold" Foreground="White"
                             HorizontalAlignment="Center" />
                  <TextBlock Text="{Binding SentimentVM.FearGreedLabel}"
                             FontSize="9" Foreground="#8B949E"
                             HorizontalAlignment="Center" />
                </StackPanel>
              </Border>

              <!-- Center info -->
              <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                <TextBlock Classes="Overline" Text="FEAR &amp; GREED INDEX" />

                <!-- Long/Short bar -->
                <StackPanel Spacing="4">
                  <Grid>
                    <!-- Background bar (short = red) -->
                    <Border Width="200" Height="6" Background="#33FF4444"
                            CornerRadius="3" HorizontalAlignment="Left" />
                    <!-- Foreground bar (long = teal) -->
                    <Border Height="6" Background="#21E6C1"
                            CornerRadius="3,0,0,3" HorizontalAlignment="Left"
                            Width="{Binding SentimentVM.LongBarWidth}" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*">
                    <TextBlock Grid.Column="0" Text="{Binding SentimentVM.LongLabel}"
                               Foreground="#21E6C1" FontSize="12" />
                    <TextBlock Grid.Column="1" Text="{Binding SentimentVM.ShortLabel}"
                               Foreground="#FF4444" FontSize="12"
                               HorizontalAlignment="Right" />
                  </Grid>
                </StackPanel>

                <!-- Open Interest -->
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Open Interest:" Foreground="#8B949E" FontSize="12" />
                  <TextBlock Text="{Binding SentimentVM.OpenInterestLabel}"
                             Foreground="White" FontSize="12" FontWeight="Bold" />
                  <TextBlock Text="{Binding SentimentVM.OpenInterestChangeLabel}"
                             Foreground="{Binding SentimentVM.OpenInterestChangeBrush}"
                             FontSize="12" />
                </StackPanel>
              </StackPanel>

              <!-- Change badge -->
              <Border Grid.Column="2" VerticalAlignment="Center" Padding="8,4"
                      Background="#0D1B2A" CornerRadius="6">
                <TextBlock Text="{Binding SentimentVM.FearGreedChangeLabel}"
                           Foreground="{Binding SentimentVM.FearGreedChangeBrush}"
                           FontSize="14" FontWeight="Bold" />
              </Border>
            </Grid>
          </StackPanel>
        </Border>
        <!-- ── End Market Sentiment Widget ──────────────────────────────────── -->

        </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Markets">
        <ScrollViewer Classes="PageScroll">
        <StackPanel Spacing="16">
          <Border Classes="HeroPanel">
            <Grid ColumnDefinitions="1.35*,Auto" ColumnSpacing="18">
              <StackPanel Spacing="6">
                <TextBlock Classes="Overline" Text="MARKET EXPLORER" />
                <TextBlock Classes="H1" Text="Live Spot Radar" />
                <TextBlock Text="{Binding MarketsScreenSummary}"
                           Foreground="#8FA3B8"
                           TextWrapping="Wrap"
                           MaxWidth="760" />
              </StackPanel>

              <WrapPanel Orientation="Horizontal">
                <Border Classes="SoftPanel" MinWidth="140" Margin="0,0,12,0">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="Overline" Text="Tracked" />
                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="#21E6C1"
                               Text="{Binding TrackedMarketsCount}" />
                  </StackPanel>
                </Border>
                <Border Classes="SoftPanel" MinWidth="140" Margin="0,0,12,0">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="Overline" Text="Visible" />
                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="#F4F7FB"
                               Text="{Binding VisibleMarketsCount}" />
                  </StackPanel>
                </Border>
                <Border Classes="SoftPanel" MinWidth="140" Margin="0,0,12,0">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="Overline" Text="Favorites" />
                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="#F4B860"
                               Text="{Binding FavoriteMarketsCount}" />
                  </StackPanel>
                </Border>
                <Border Classes="SoftPanel" MinWidth="180">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="Overline" Text="Breadth" />
                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="#F4F7FB"
                               Text="{Binding MarketBreadthLabel}" />
                  </StackPanel>
                </Border>
              </WrapPanel>
            </Grid>
          </Border>

          <Grid ColumnDefinitions="320,*" ColumnSpacing="16">
            <Border Classes="Panel" Grid.Column="0">
              <StackPanel Spacing="14">
                <TextBlock Classes="H2" Text="Scanner Controls" />

                <StackPanel Spacing="6">
                  <TextBlock Classes="Overline" Text="Search" />
                  <TextBox Text="{Binding MarketsSearchText}"
                           PlaceholderText="BTC, ETH, BNB..." />
                </StackPanel>

                <StackPanel Spacing="6">
                  <TextBlock Classes="Overline" Text="Sort" />
                  <ComboBox ItemsSource="{Binding MarketSortOptions}"
                            SelectedItem="{Binding SelectedMarketSortMode}" />
                </StackPanel>

                <CheckBox Content="Show favorites only"
                          IsChecked="{Binding ShowFavoriteMarketsOnly}" />

                <WrapPanel Orientation="Horizontal">
                  <Button Content="REFRESH"
                          Command="{Binding RefreshMarketsCommand}"
                          Width="120"
                          Margin="0,0,10,0" />
                  <Button Content="OPEN TRADING"
                          Command="{Binding OpenMarketInTradingCommand}"
                          CommandParameter="{Binding SelectedMarket}"
                          Width="150"
                          Classes="GhostButton" />
                </WrapPanel>

                <Border Classes="SoftPanel">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="Overline" Text="Selection" />
                    <TextBlock Text="{Binding MarketsSelectionSummary}"
                               Foreground="#D7E3EE"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Border Classes="SoftPanel">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="Overline" Text="Leaders" />
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                      <TextBlock Grid.Row="0" Text="Strongest" Foreground="#8FA3B8" />
                      <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding StrongestMarketLabel}" FontWeight="SemiBold" />
                      <TextBlock Grid.Row="1" Text="Weakest" Foreground="#8FA3B8" />
                      <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding WeakestMarketLabel}" FontWeight="SemiBold" />
                      <TextBlock Grid.Row="2" Text="Tightest" Foreground="#8FA3B8" />
                      <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TightestSpreadMarketLabel}" FontWeight="SemiBold" />
                      <TextBlock Grid.Row="3" Text="Active" Foreground="#8FA3B8" />
                      <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding MostActiveMarketLabel}" FontWeight="SemiBold" />
                    </Grid>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>

            <StackPanel Grid.Column="1" Spacing="16">
              <Border Classes="Panel">
                <StackPanel Spacing="12">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <TextBlock Classes="H2" Text="Heatmap" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ConnectionStateLabel}"
                               Foreground="#8FA3B8"
                               VerticalAlignment="Center" />
                  </Grid>
                  <ItemsControl ItemsSource="{Binding MarketHeatmapMarkets}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:CexMarketItemViewModel">
                        <Button Width="170"
                                Margin="0,0,12,12"
                                Padding="12"
                                HorizontalContentAlignment="Stretch"
                                Command="{Binding $parent[Window].DataContext.FocusMarketCommand}"
                                CommandParameter="{Binding .}"
                                Background="{Binding LogoBackground}">
                          <StackPanel Spacing="4">
                            <Grid ColumnDefinitions="*,Auto">
                              <TextBlock Grid.Column="0"
                                         Text="{Binding BaseAssetSymbol}"
                                         FontWeight="Bold"
                                         Foreground="{Binding LogoForeground}" />
                              <TextBlock Grid.Column="1"
                                         Text="{Binding ChangePercentLabel}"
                                         Foreground="{Binding LogoForeground}" />
                            </Grid>
                            <TextBlock Text="{Binding LastPrice, StringFormat=$ {0:N4}}"
                                       Foreground="{Binding LogoForeground}"
                                       FontSize="18"
                                       FontWeight="Bold" />
                            <TextBlock Text="{Binding TrendLabel}"
                                       Foreground="{Binding LogoForeground}" />
                          </StackPanel>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>

              <Grid ColumnDefinitions="0.95*,1.05*" ColumnSpacing="16">
                <Border Classes="Panel" Grid.Column="0">
                  <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                      <TextBlock Classes="H2" Text="Market Board" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding VisibleMarketsCount, StringFormat=Rows: {0}}"
                                 Foreground="#8FA3B8"
                                 VerticalAlignment="Center" />
                    </Grid>

                    <ListBox ItemsSource="{Binding VisibleMarkets}"
                             SelectedItem="{Binding SelectedMarket}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:CexMarketItemViewModel">
                          <Border Classes="SoftPanel" Margin="0,0,0,10">
                            <StackPanel Spacing="8">
                              <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Border Grid.Column="0"
                                        Width="34"
                                        Height="34"
                                        Background="{Binding LogoBackground}"
                                        CornerRadius="17">
                                  <TextBlock Text="{Binding LogoText}"
                                             Foreground="{Binding LogoForeground}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             FontWeight="Bold" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2">
                                  <TextBlock Text="{Binding DisplaySymbol}" FontWeight="Bold" />
                                  <TextBlock Text="{Binding TrendLabel}"
                                             Foreground="{Binding TrendBrush}" />
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Content="{Binding FavoriteGlyph}"
                                        Command="{Binding $parent[Window].DataContext.ToggleMarketFavoriteCommand}"
                                        CommandParameter="{Binding .}"
                                        Classes="GhostButton"
                                        Foreground="{Binding FavoriteBrush}"
                                        MinWidth="70" />
                              </Grid>

                              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="6">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding LastPrice, StringFormat=Last: $ {0:N4}}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ChangePercentLabel}" Foreground="{Binding ChangeBrush}" HorizontalAlignment="Right" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding SpreadPercentLabel, StringFormat=Spread: {0}}" Foreground="#8FA3B8" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UpdatedLabel, StringFormat=Updated: {0}}" Foreground="#8FA3B8" HorizontalAlignment="Right" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding RangeLabel, StringFormat=Range: {0}}" Foreground="#8FA3B8" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ActivityScoreLabel, StringFormat=Score: {0}}" Foreground="#8FA3B8" HorizontalAlignment="Right" />
                              </Grid>

                              <Button Content="OPEN IN TRADING"
                                      Command="{Binding $parent[Window].DataContext.OpenMarketInTradingCommand}"
                                      CommandParameter="{Binding .}"
                                      Classes="GhostButton"
                                      HorizontalAlignment="Left" />
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>
                </Border>

                <Border Classes="Panel" Grid.Column="1">
                  <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="H2" Text="{Binding SelectedMarketTitle}" />
                        <TextBlock Text="{Binding MarketsSelectionSummary}"
                                   Foreground="#8FA3B8"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                      <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button Content="TRADING"
                                Command="{Binding OpenMarketInTradingCommand}"
                                CommandParameter="{Binding SelectedMarket}"
                                Width="110"
                                Margin="0,0,10,0" />
                        <Button Content="FAVORITE"
                                Command="{Binding ToggleMarketFavoriteCommand}"
                                CommandParameter="{Binding SelectedMarket}"
                                Width="110"
                                Classes="GhostButton" />
                      </WrapPanel>
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                      <Border Classes="SurfaceCard" Grid.Column="0">
                        <StackPanel Spacing="4">
                          <TextBlock Classes="Overline" Text="Last" />
                          <TextBlock Classes="Metric" FontSize="22"
                                     Text="{Binding SelectedMarket.LastPrice, StringFormat=$ {0:N4}}" />
                        </StackPanel>
                      </Border>
                      <Border Classes="SurfaceCard" Grid.Column="1">
                        <StackPanel Spacing="4">
                          <TextBlock Classes="Overline" Text="Change" />
                          <TextBlock Classes="Metric" FontSize="22"
                                     Text="{Binding SelectedMarket.ChangePercentLabel}"
                                     Foreground="{Binding SelectedMarket.ChangeBrush}" />
                        </StackPanel>
                      </Border>
                      <Border Classes="SurfaceCard" Grid.Column="2">
                        <StackPanel Spacing="4">
                          <TextBlock Classes="Overline" Text="Spread" />
                          <TextBlock Classes="Metric" FontSize="22"
                                     Text="{Binding SelectedMarket.SpreadPercentLabel}" />
                        </StackPanel>
                      </Border>
                      <Border Classes="SurfaceCard" Grid.Column="3">
                        <StackPanel Spacing="4">
                          <TextBlock Classes="Overline" Text="Activity" />
                          <TextBlock Classes="Metric" FontSize="22"
                                     Text="{Binding SelectedMarket.ActivityScoreLabel}" />
                        </StackPanel>
                      </Border>
                    </Grid>

                    <Border Classes="SoftPanel">
                      <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                        <TextBlock Grid.Row="0" Classes="H2" Text="Micro Trend" />
                        <ctrl:CexPriceChart Grid.Row="1"
                                            Height="220"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            Points="{Binding SelectedMarket.ChartPoints}"
                                            IsPositiveTrend="{Binding SelectedMarket.IsPositiveTrend}" />
                        <TextBlock Grid.Row="2"
                                   Text="{Binding SelectedMarket.RangeLabel, StringFormat=Observed range: {0}}"
                                   Foreground="#8FA3B8" />
                      </Grid>
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                      <Border Classes="SurfaceCard" Grid.Column="0">
                        <StackPanel Spacing="8">
                          <TextBlock Classes="H2" Text="Bids" />
                          <ScrollViewer Classes="PageScroll" MaxHeight="240">
                            <ItemsControl ItemsSource="{Binding SelectedMarket.BidLevels}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:OrderBookLevelViewModel">
                                  <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Price, StringFormat=$ {0:N4}}"
                                               Foreground="#3DDC84" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Quantity, StringFormat={}{0:N4}}"
                                               Foreground="#8B949E" />
                                  </Grid>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </ScrollViewer>
                        </StackPanel>
                      </Border>

                      <Border Classes="SurfaceCard" Grid.Column="1">
                        <StackPanel Spacing="8">
                          <TextBlock Classes="H2" Text="Asks" />
                          <ScrollViewer Classes="PageScroll" MaxHeight="240">
                            <ItemsControl ItemsSource="{Binding SelectedMarket.AskLevels}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:OrderBookLevelViewModel">
                                  <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Price, StringFormat=$ {0:N4}}"
                                               Foreground="#FF6B6B" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Quantity, StringFormat={}{0:N4}}"
                                               Foreground="#8B949E" />
                                  </Grid>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </ScrollViewer>
                        </StackPanel>
                      </Border>
                    </Grid>
                  </StackPanel>
                </Border>
              </Grid>
            </StackPanel>
          </Grid>
        </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Trading">
        <ScrollViewer Classes="PageScroll">
        <StackPanel Spacing="0">
        <views:TradingDeskView />
        </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Portfolio">
        <ScrollViewer Classes="PageScroll">
        <Border Classes="Panel">
          <Grid ColumnDefinitions="360,*" ColumnSpacing="16">
            <Border Classes="Panel" Grid.Column="0">
              <StackPanel Spacing="14">
                <TextBlock Classes="H2" Text="Wallet Hub" />
                <TextBlock Text="Connect a wallet once and reuse the same identity across DEX trading, monitoring and future portfolio modules."
                           Foreground="#8B949E"
                           TextWrapping="Wrap" />

                <!-- License activation -->
                <Border Background="#0A1622" BorderBrush="#1A3A50" BorderThickness="1" CornerRadius="8" Padding="12">
                  <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Grid.Column="0" Text="License" FontWeight="Bold" Foreground="#E0E8F0" VerticalAlignment="Center" />
                      <Border Grid.Column="1" Background="{Binding LicenseVM.StateBrush}" CornerRadius="3" Padding="7,2">
                        <TextBlock Text="{Binding LicenseVM.StateLabel}" Foreground="#06121C" FontSize="11" FontWeight="Bold" />
                      </Border>
                    </Grid>
                    <TextBox Text="{Binding LicenseVM.KeyInput}" PlaceholderText="Paste activation key" />
                    <Button Content="Activate" Command="{Binding LicenseVM.ActivateCommand}"
                            HorizontalAlignment="Stretch" Background="#1FE6C2" Foreground="#06121C" FontWeight="Bold" />
                    <TextBlock Text="{Binding LicenseVM.StatusMessage}" Foreground="#F4B860" FontSize="11" TextWrapping="Wrap" />
                    <TextBlock Foreground="#4A6880" FontSize="10" TextWrapping="Wrap"
                               Text="Get a key from the Telegram bot. Your Machine ID is in Settings → License. No key? You stay in Demo mode." />
                  </StackPanel>
                </Border>

                <Expander IsExpanded="True">
                  <Expander.Header>
                    <TextBlock Text="Connection Studio" FontWeight="Bold" />
                  </Expander.Header>
                  <StackPanel Spacing="12" Margin="8,12,8,4">
                    <StackPanel Spacing="8">
                      <TextBlock Text="Wallet Provider" Foreground="#8B949E" />
                      <WrapPanel Orientation="Horizontal">
                        <Button Content="METAMASK"
                                Command="{Binding WalletVM.SelectProviderCommand}"
                                CommandParameter="MetaMask"
                                Width="110"
                                Margin="0,0,8,8" />
                        <Button Content="TRUST"
                                Command="{Binding WalletVM.SelectProviderCommand}"
                                CommandParameter="Trust Wallet"
                                Width="110"
                                Margin="0,0,8,8" />
                        <Button Content="PHANTOM"
                                Command="{Binding WalletVM.SelectProviderCommand}"
                                CommandParameter="Phantom"
                                Width="110"
                                Margin="0,0,8,8" />
                        <Button Content="TRONLINK"
                                Command="{Binding WalletVM.SelectProviderCommand}"
                                CommandParameter="TronLink"
                                Width="110"
                                Margin="0,0,8,8" />
                      </WrapPanel>
                      <TextBlock Text="{Binding WalletVM.SelectedProvider, StringFormat=Focused provider: {0}}"
                                 Foreground="#21E6C1"
                                 FontWeight="SemiBold" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                      <TextBlock Text="Network" Foreground="#8B949E" />
                      <ComboBox ItemsSource="{Binding WalletVM.AvailableNetworks}"
                                SelectedItem="{Binding WalletVM.SelectedNetwork}" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                      <TextBlock Text="Wallet Address" Foreground="#8B949E" />
                      <TextBox Text="{Binding WalletVM.WalletAddressInput}"
                               PlaceholderText="Paste wallet address for shared watch mode" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                      <TextBlock Text="Private Key" Foreground="#8B949E" />
                      <TextBox Text="{Binding WalletVM.PrivateKeyInput}"
                               PlaceholderText="EVM private key, Solana 64-byte keypair / 32-byte seed, or Tron 32-byte private key" />
                    </StackPanel>

                    <WrapPanel Orientation="Horizontal">
                      <Button Content="CONNECT WATCH"
                              Command="{Binding WalletVM.ConnectWatchCommand}"
                              Width="150"
                              Margin="0,0,8,8" />
                      <Button Content="IMPORT FOR TRADING"
                              Command="{Binding WalletVM.ImportPrivateKeyCommand}"
                              Width="170"
                              Margin="0,0,8,8" />
                      <Button Content="REFRESH"
                              Command="{Binding WalletVM.RefreshWalletCommand}"
                              Width="120"
                              Margin="0,0,8,8" />
                      <Button Content="OPEN PROVIDER"
                              Command="{Binding WalletVM.OpenProviderCommand}"
                              Width="140"
                              Margin="0,0,8,8" />
                      <Button Content="DISCONNECT"
                              Command="{Binding WalletVM.DisconnectWalletCommand}"
                              Width="130"
                              Margin="0,0,8,8" />
                    </WrapPanel>

                    <Border Classes="SoftPanel">
                      <StackPanel Spacing="8">
                        <TextBlock Classes="Overline" Text="Solana Self-Test" />
                        <TextBlock Text="Run a safe end-to-end probe for the armed Solana session: wallet, RPC, blockhash, signing, memo simulation, Jupiter quote and signed swap simulation."
                                   Foreground="#8B949E"
                                   TextWrapping="Wrap" />
                        <Button Content="RUN SOLANA SELF-TEST"
                                Command="{Binding WalletVM.RunSolanaDiagnosticsCommand}"
                                IsEnabled="{Binding WalletVM.CanRunSolanaDiagnostics}"
                                Width="220" />
                        <TextBlock Text="{Binding WalletVM.SolanaDiagnosticsSummary}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>

                    <Border Classes="SoftPanel"
                            IsVisible="{Binding WalletVM.IsTronNetworkSelected}">
                      <StackPanel Spacing="8">
                        <TextBlock Classes="Overline" Text="Tron Self-Test" />
                        <TextBlock Text="Run a safe Tron smoke-check for the armed session: wallet, RPC, TRC20 metadata, SunSwap quote and unsigned swap preview without broadcasting a trade."
                                   Foreground="#8B949E"
                                   TextWrapping="Wrap" />
                        <Button Content="RUN TRON SELF-TEST"
                                Command="{Binding WalletVM.RunTronDiagnosticsCommand}"
                                IsEnabled="{Binding WalletVM.CanRunTronDiagnostics}"
                                Width="220" />
                        <TextBlock Text="{Binding WalletVM.TronDiagnosticsSummary}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>

                    <Border Classes="SoftPanel"
                            IsVisible="{Binding WalletVM.IsTronNetworkSelected}">
                      <StackPanel Spacing="10">
                        <TextBlock Classes="Overline" Text="Tron TRC20 Payments" />
                        <TextBlock Text="Send a real TRC20 transfer from the armed Tron session. The app creates the transaction, signs it locally, and broadcasts it through Tron RPC."
                                   Foreground="#8B949E"
                                   TextWrapping="Wrap" />
                        <WrapPanel Orientation="Horizontal">
                          <Button Content="USE USDC"
                                  Command="{Binding WalletVM.ApplyTronTokenPresetCommand}"
                                  CommandParameter="USDC"
                                  Background="{Binding WalletVM.TronUsdcPresetBackground}"
                                  Foreground="{Binding WalletVM.TronUsdcPresetForeground}"
                                  Width="120"
                                  Margin="0,0,8,8" />
                          <Button Content="USE USDT"
                                  Command="{Binding WalletVM.ApplyTronTokenPresetCommand}"
                                  CommandParameter="USDT"
                                  Background="{Binding WalletVM.TronUsdtPresetBackground}"
                                  Foreground="{Binding WalletVM.TronUsdtPresetForeground}"
                                  Width="120"
                                  Margin="0,0,8,8" />
                        </WrapPanel>
                        <TextBlock Text="{Binding WalletVM.TronTrc20BalanceLabel, StringFormat=Tracked token balance: {0}}"
                                   FontWeight="SemiBold"
                                   Foreground="#21E6C1" />
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                          <TextBlock Grid.Row="0" Grid.Column="0" Text="Symbol" VerticalAlignment="Center" />
                          <TextBox Grid.Row="0" Grid.Column="1"
                                   Text="{Binding WalletVM.TronTrc20Symbol}"
                                   PlaceholderText="USDT" />

                          <TextBlock Grid.Row="1" Grid.Column="0" Text="Contract" VerticalAlignment="Center" />
                          <TextBox Grid.Row="1" Grid.Column="1"
                                   Text="{Binding WalletVM.TronTrc20ContractAddress}"
                                   PlaceholderText="TRC20 contract address" />

                          <TextBlock Grid.Row="2" Grid.Column="0" Text="Recipient" VerticalAlignment="Center" />
                          <TextBox Grid.Row="2" Grid.Column="1"
                                   Text="{Binding WalletVM.TronPaymentRecipient}"
                                   PlaceholderText="Recipient Tron address" />

                          <TextBlock Grid.Row="3" Grid.Column="0" Text="Amount" VerticalAlignment="Center" />
                          <NumericUpDown Grid.Row="3" Grid.Column="1"
                                         Value="{Binding WalletVM.TronTrc20Amount}"
                                         Increment="0.1"
                                         Minimum="0"
                                         FormatString="0.######" />

                          <TextBlock Grid.Row="4" Grid.Column="0" Text="Fee Limit (TRX)" VerticalAlignment="Center" />
                          <NumericUpDown Grid.Row="4" Grid.Column="1"
                                         Value="{Binding WalletVM.TronFeeLimitTrx}"
                                         Increment="1"
                                         Minimum="1"
                                         FormatString="0.##" />
                        </Grid>
                        <Button Content="SEND TRC20"
                                Command="{Binding WalletVM.SendTronPaymentCommand}"
                                IsEnabled="{Binding WalletVM.CanSendTronPaymentLive}"
                                ToolTip.Tip="{Binding WalletVM.TronPaymentBlockedReason}"
                                Width="160" />
                        <TextBlock Text="{Binding WalletVM.TronPaymentBlockedReason}"
                                   Foreground="#F4B860"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding !WalletVM.CanSendTronPaymentLive}" />
                        <TextBlock Text="{Binding WalletVM.TronPaymentStatus}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Expander>

                  <Expander IsExpanded="True">
                    <Expander.Header>
                      <TextBlock Text="Security Notes" FontWeight="Bold" />
                  </Expander.Header>
                  <StackPanel Spacing="8" Margin="8,12,8,4">
                    <TextBlock Text="The key stays only in memory for this desktop session."
                               Foreground="#F4B860"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="Use watch mode for analytics and monitoring. Enable a trading session only when you are ready to execute on-chain actions."
                               Foreground="#8B949E"
                               TextWrapping="Wrap" />
                    </StackPanel>
                  </Expander>

                  <Expander IsExpanded="True">
                    <Expander.Header>
                      <TextBlock Text="Saved Wallets" FontWeight="Bold" />
                    </Expander.Header>
                    <StackPanel Spacing="10" Margin="8,12,8,4">
                      <Border Classes="SoftPanel">
                        <StackPanel Spacing="8">
                          <TextBlock Classes="Overline" Text="Execution Matrix" />
                          <TextBlock Text="{Binding WalletVM.NetworkExecutionMatrix}"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                      <ScrollViewer Classes="PageScroll" MaxHeight="260">
                        <ItemsControl ItemsSource="{Binding WalletVM.SavedWallets}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SavedWalletViewModel">
                              <Border Classes="SoftPanel" Margin="0,0,0,8">
                                <StackPanel Spacing="8">
                                  <TextBlock Text="{Binding DisplayAddress}" FontWeight="Bold" />
                                  <TextBlock Text="{Binding Summary}" Foreground="#8B949E" TextWrapping="Wrap" />
                                  <TextBlock Text="{Binding Note}" Foreground="#6E8196" TextWrapping="Wrap" />
                                  <WrapPanel Orientation="Horizontal">
                                    <Button Content="LOAD"
                                            Command="{Binding $parent[Window].DataContext.WalletVM.LoadSavedWalletCommand}"
                                            CommandParameter="{Binding .}"
                                            Width="110"
                                            Margin="0,0,10,0" />
                                    <Button Content="DELETE"
                                            Command="{Binding $parent[Window].DataContext.WalletVM.DeleteSavedWalletCommand}"
                                            CommandParameter="{Binding .}"
                                            Width="110"
                                            Classes="GhostButton" />
                                  </WrapPanel>
                                </StackPanel>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </ScrollViewer>
                    </StackPanel>
                  </Expander>

                  <Border Classes="SoftPanel">
                  <StackPanel Spacing="6">
                      <TextBlock Text="Session Status" Foreground="#8B949E" />
                    <TextBlock Text="{Binding WalletVM.StatusMessage}"
                               TextWrapping="Wrap"
                               FontWeight="SemiBold" />
                  </StackPanel>
                </Border>

                <Border Classes="SoftPanel">
                  <StackPanel Spacing="10">
                    <TextBlock Text="Solana Diagnostic Trace" Foreground="#8B949E" />
                    <ScrollViewer Classes="PageScroll" MaxHeight="240">
                      <ItemsControl ItemsSource="{Binding WalletVM.SolanaDiagnosticSteps}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Background="#0D1117"
                                    BorderBrush="#30363D"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12"
                                    Margin="0,0,0,8">
                              <TextBlock Text="{Binding .}" TextWrapping="Wrap" />
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </StackPanel>
                </Border>

                <Border Classes="SoftPanel"
                        IsVisible="{Binding WalletVM.IsTronNetworkSelected}">
                  <StackPanel Spacing="10">
                    <TextBlock Text="Tron Diagnostic Trace" Foreground="#8B949E" />
                    <ScrollViewer Classes="PageScroll" MaxHeight="240">
                      <ItemsControl ItemsSource="{Binding WalletVM.TronDiagnosticSteps}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Background="#0D1117"
                                    BorderBrush="#30363D"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12"
                                    Margin="0,0,0,8">
                              <TextBlock Text="{Binding .}" TextWrapping="Wrap" />
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>

            <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,*" ColumnDefinitions="*,*" ColumnSpacing="16" RowSpacing="16">
              <Border Classes="Panel" Grid.Row="0" Grid.Column="0">
                <StackPanel Spacing="6">
                  <TextBlock Text="Active Session" Foreground="#8B949E" />
                  <TextBlock Classes="H2" Text="{Binding WalletVM.ActiveWalletBanner}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding WalletVM.WalletReadinessLabel}"
                             Foreground="{Binding WalletVM.WalletReadinessBrush}"
                             FontWeight="Bold" />
                  <TextBlock Text="{Binding WalletVM.ConnectionSummary}" Foreground="#8B949E" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding WalletVM.WalletReadinessSummary}"
                             Foreground="#8FA3B8"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Classes="Panel" Grid.Row="0" Grid.Column="1">
                <StackPanel Spacing="6">
                  <TextBlock Text="Live Route" Foreground="#8B949E" />
                  <TextBlock Classes="H2" Text="{Binding WalletVM.NativeBalanceLabel}" />
                  <TextBlock Text="{Binding WalletVM.RouteReadinessLabel}"
                             Foreground="{Binding WalletVM.RouteReadinessBrush}"
                             FontWeight="Bold" />
                  <TextBlock Text="{Binding WalletVM.ExplorerUrl}" Foreground="#8B949E" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding WalletVM.RouteReadinessSummary}"
                             Foreground="#8FA3B8"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Classes="Panel" Grid.Row="1" Grid.ColumnSpan="2">
                <StackPanel Spacing="12">
                  <TextBlock Classes="H2" Text="Portfolio Lens" />
                  <ItemsControl ItemsSource="{Binding WalletVM.Assets}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:WalletAssetViewModel">
                        <Border Background="#0D1117"
                                BorderBrush="#30363D"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14"
                                Width="250"
                                Margin="0,0,12,12">
                          <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Title}" Foreground="#8B949E" />
                            <TextBlock Text="{Binding Value}" FontSize="22" FontWeight="Bold" Foreground="#14E0C1" />
                            <TextBlock Text="{Binding Subtitle}" Foreground="#8B949E" TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>

              <!-- ═══ PORTFOLIO REBALANCER ═══ -->
              <Border Classes="Panel" Grid.Row="2" Grid.ColumnSpan="2" x:DataType="vm:MainWindowViewModel">
                <StackPanel Spacing="12">

                  <!-- Header row -->
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                      <TextBlock Classes="H2" Text="Portfolio Rebalancer" />
                      <!-- Total value badge -->
                      <Border Background="#0D1826" CornerRadius="8" Padding="8,2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PortfolioRebalanceVM.TotalValueLabel}"
                                   Foreground="#21E6C1" FontSize="12" FontWeight="Bold" />
                      </Border>
                      <!-- Alert badge -->
                      <Border Background="#3A1010" CornerRadius="8" Padding="8,2" VerticalAlignment="Center"
                              IsVisible="{Binding PortfolioRebalanceVM.HasAlerts}">
                        <TextBlock Text="⚠ Drift detected"
                                   Foreground="#FF5555" FontSize="11" FontWeight="Bold" />
                      </Border>
                    </StackPanel>

                    <!-- Alert threshold setting -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center" Margin="8,0">
                      <TextBlock Text="Alert when deviation ≥" FontSize="12" Foreground="#8FA3B8"
                                 VerticalAlignment="Center" />
                      <NumericUpDown Value="{Binding PortfolioRebalanceVM.GlobalAlertThresholdPct}"
                                     Minimum="0.5" Maximum="50" Increment="0.5"
                                     Width="120" FontSize="12" />
                      <TextBlock Text="%" FontSize="12" Foreground="#8FA3B8" VerticalAlignment="Center" />

                      <!-- Target sum validator -->
                      <Border Background="#0D1826" CornerRadius="6" Padding="8,2" Margin="8,0,0,0"
                              VerticalAlignment="Center">
                        <TextBlock Text="{Binding PortfolioRebalanceVM.TargetSumLabel}"
                                   Foreground="{Binding PortfolioRebalanceVM.TargetSumBrush}"
                                   FontSize="11" FontFamily="Consolas" />
                      </Border>
                    </StackPanel>

                    <!-- Refresh button -->
                    <Button Grid.Column="2"
                            Content="⟳ Refresh"
                            Classes="GhostButton" FontSize="12" Padding="10,4"
                            Command="{Binding PortfolioRebalanceVM.RefreshCommand}"
                            VerticalAlignment="Center" />

                    <!-- Loading indicator -->
                    <TextBlock Grid.Column="3"
                               Text="Fetching…" FontSize="11" Foreground="#8FA3B8"
                               IsVisible="{Binding PortfolioRebalanceVM.IsLoading}"
                               VerticalAlignment="Center" />
                  </Grid>

                  <!-- Alert summary banner -->
                  <Border Background="#200A0A" CornerRadius="6" Padding="12,8"
                          IsVisible="{Binding PortfolioRebalanceVM.HasAlerts}">
                    <TextBlock Text="{Binding PortfolioRebalanceVM.AlertSummary}"
                               Foreground="#FF8888" FontSize="12"
                               FontFamily="Consolas" TextWrapping="Wrap" />
                  </Border>

                  <!-- ── AI rebalance (#5) ── -->
                  <Border Background="#0D1826" CornerRadius="8" Padding="12,10" Margin="0,0,0,4">
                    <StackPanel Spacing="8">
                      <Grid ColumnDefinitions="Auto,160,Auto,*,Auto">
                        <TextBlock Grid.Column="0" Text="🧠 AI target weights"
                                   FontWeight="SemiBold" Foreground="#E8F0FE" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding PortfolioRebalanceVM.AvailableRiskProfiles}"
                                  SelectedItem="{Binding PortfolioRebalanceVM.SelectedRiskProfile}"
                                  HorizontalAlignment="Stretch" />
                        <Button Grid.Column="2" Content="Suggest" Margin="10,0,0,0"
                                Command="{Binding PortfolioRebalanceVM.SuggestWithAiCommand}"
                                IsEnabled="{Binding !PortfolioRebalanceVM.AiRunning}"
                                Foreground="#21E6C1" />
                        <TextBlock Grid.Column="4" Text="{Binding PortfolioRebalanceVM.AiSource}"
                                   Foreground="#5C6E82" FontSize="10" VerticalAlignment="Center" />
                      </Grid>
                      <TextBlock Text="{Binding PortfolioRebalanceVM.AiCommentary}"
                                 Foreground="#8FA3B8" FontSize="11" TextWrapping="Wrap"
                                 IsVisible="{Binding PortfolioRebalanceVM.AiCommentary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                  </Border>

                  <!-- Column headers -->
                  <Grid ColumnDefinitions="32,70,55,55,80,70,55,*,Auto,Auto"
                        ColumnSpacing="6" Margin="4,0">
                    <TextBlock Grid.Column="0" Text=""         FontSize="11" Foreground="#5C6E82" />
                    <TextBlock Grid.Column="1" Text="ASSET"    FontSize="11" Foreground="#5C6E82" FontWeight="Bold" />
                    <TextBlock Grid.Column="2" Text="BALANCE"  FontSize="11" Foreground="#5C6E82" FontWeight="Bold" />
                    <TextBlock Grid.Column="3" Text="PRICE"    FontSize="11" Foreground="#5C6E82" FontWeight="Bold" />
                    <TextBlock Grid.Column="4" Text="VALUE"    FontSize="11" Foreground="#5C6E82" FontWeight="Bold" />
                    <TextBlock Grid.Column="5" Text="TARGET %" FontSize="11" Foreground="#5C6E82" FontWeight="Bold" />
                    <TextBlock Grid.Column="6" Text="ACTUAL"   FontSize="11" Foreground="#5C6E82" FontWeight="Bold" />
                    <TextBlock Grid.Column="7" Text="REBALANCE ORDER" FontSize="11" Foreground="#5C6E82" FontWeight="Bold" />
                    <TextBlock Grid.Column="8" Text=""         FontSize="11" Foreground="#5C6E82" />
                    <TextBlock Grid.Column="9" Text=""         FontSize="11" Foreground="#5C6E82" />
                  </Grid>

                  <!-- Allocation rows -->
                  <ItemsControl ItemsSource="{Binding PortfolioRebalanceVM.Allocations}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:PortfolioAllocationRowViewModel">
                        <Border Background="#0A1520" CornerRadius="5"
                                Padding="4,6" Margin="0,1">
                          <Grid ColumnDefinitions="32,70,55,55,80,70,55,*,Auto,Auto"
                                ColumnSpacing="6" VerticalAlignment="Center">

                            <!-- Status icon (▲ / ▼ / ✓) -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding StatusIcon}"
                                       Foreground="{Binding StatusBrush}"
                                       FontSize="13" FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />

                            <!-- Symbol + sources tooltip -->
                            <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                              <TextBlock Text="{Binding Symbol}"
                                         FontSize="13" FontWeight="Bold"
                                         ToolTip.Tip="{Binding SourcesLabel}" />
                              <TextBlock Text="{Binding SourcesLabel}"
                                         FontSize="9" Foreground="#4A6070"
                                         TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <!-- Balance -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding BalanceLabel}"
                                       FontSize="11" Foreground="#C8D6E5"
                                       VerticalAlignment="Center" />

                            <!-- Price -->
                            <TextBlock Grid.Column="3"
                                       Text="{Binding PriceLabel}"
                                       FontSize="11" Foreground="#C8D6E5"
                                       VerticalAlignment="Center" />

                            <!-- USD value -->
                            <TextBlock Grid.Column="4"
                                       Text="{Binding ValueLabel}"
                                       FontSize="12" FontWeight="Bold" Foreground="#E0EAF4"
                                       VerticalAlignment="Center" />

                            <!-- Target % (editable) -->
                            <NumericUpDown Grid.Column="5"
                                           Value="{Binding TargetPct}"
                                           Minimum="0" Maximum="100" Increment="1"
                                           FormatString="F1"
                                           FontSize="11" Padding="4,2"
                                           VerticalAlignment="Center" />

                            <!-- Actual % + deviation -->
                            <StackPanel Grid.Column="6" Spacing="1" VerticalAlignment="Center">
                              <TextBlock Text="{Binding ActualPctLabel}"
                                         FontSize="11" FontWeight="Bold" />
                              <TextBlock Text="{Binding DeviationLabel}"
                                         FontSize="10"
                                         Foreground="{Binding DeviationBrush}" />
                            </StackPanel>

                            <!-- Rebalance order suggestion -->
                            <TextBlock Grid.Column="7"
                                       Text="{Binding RebalanceOrderLabel}"
                                       Foreground="{Binding RebalanceOrderBrush}"
                                       FontSize="11" FontFamily="Consolas"
                                       VerticalAlignment="Center" />

                            <!-- Move up/down -->
                            <StackPanel Grid.Column="8" Orientation="Horizontal" Spacing="2">
                              <Button Content="↑" Padding="4,2" FontSize="11" Classes="GhostButton"
                                      Command="{Binding $parent[Window].DataContext.PortfolioRebalanceVM.MoveUpCommand}"
                                      CommandParameter="{Binding}" />
                              <Button Content="↓" Padding="4,2" FontSize="11" Classes="GhostButton"
                                      Command="{Binding $parent[Window].DataContext.PortfolioRebalanceVM.MoveDownCommand}"
                                      CommandParameter="{Binding}" />
                            </StackPanel>

                            <!-- Remove -->
                            <Button Grid.Column="9"
                                    Content="✕" Padding="6,2" FontSize="11" Classes="GhostButton"
                                    Foreground="#FF5555"
                                    Command="{Binding $parent[Window].DataContext.PortfolioRebalanceVM.RemoveAssetCommand}"
                                    CommandParameter="{Binding}" />

                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <!-- Add asset row -->
                  <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8"
                        Margin="0,4,0,0">
                    <TextBlock Grid.Column="0" Text="Add asset:"
                               FontSize="12" Foreground="#8FA3B8" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding PortfolioRebalanceVM.NewAssetSymbol}"
                             Width="110" FontSize="12" PlaceholderText="BTC" />
                    <NumericUpDown Grid.Column="2"
                                   Value="{Binding PortfolioRebalanceVM.NewAssetTargetPct}"
                                   Minimum="0.1" Maximum="100" Increment="5"
                                   FormatString="F1"
                                   Width="120" FontSize="12" />
                    <TextBlock Grid.Column="3" Text="%" FontSize="12" Foreground="#8FA3B8"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="4"
                            Content="+ Add"
                            Classes="GhostButton" FontSize="12" Padding="10,4"
                            Command="{Binding PortfolioRebalanceVM.AddAssetCommand}" />
                  </Grid>

                  <!-- Status bar -->
                  <TextBlock Text="{Binding PortfolioRebalanceVM.StatusLabel}"
                             Foreground="#4A6070" FontSize="11" />

                </StackPanel>
              </Border>
              <!-- ═══ END PORTFOLIO REBALANCER ═══ -->

              <Border Classes="Panel" Grid.Row="3" Grid.ColumnSpan="2">
                <Grid ColumnDefinitions="1.2*,*" ColumnSpacing="16">
                  <StackPanel Grid.Column="0" Spacing="10">
                    <TextBlock Classes="H2" Text="Wallet Capability" />
                    <TextBlock Text="{Binding WalletVM.WalletCapabilityText}"
                               Foreground="#14E0C1"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                  </StackPanel>

                  <StackPanel Grid.Column="1" Spacing="10">
                    <TextBlock Classes="H2" Text="Recent Activity" />
                    <Expander IsExpanded="True">
                      <Expander.Header>
                        <TextBlock Text="Session Feed" FontWeight="Bold" />
                      </Expander.Header>
                      <ItemsControl ItemsSource="{Binding WalletVM.RecentActivity}" Margin="8,12,8,4">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Background="#0D1117"
                                    BorderBrush="#30363D"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12"
                                    Margin="0,0,0,8">
                              <TextBlock Text="{Binding .}" TextWrapping="Wrap" />
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Expander>
                  </StackPanel>
                </Grid>
              </Border>
            </Grid>
          </Grid>
        </Border>
        </ScrollViewer>
      </TabItem>
      <TabItem Header="AI Signals">
        <ScrollViewer Classes="PageScroll">
          <Border Classes="Panel">
            <StackPanel Spacing="18">
              <Border Classes="HeroPanel">
                <Grid ColumnDefinitions="1.2*,Auto" ColumnSpacing="18">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="Overline" Text="AI SIGNAL STUDIO" />
                    <TextBlock Classes="H1" Text="Crypto Copilot Workspace" />
                    <TextBlock Text="A focused signal desk with local crypto chat, visual review, route context, and quick action prompts built around the live terminal state."
                               Foreground="#8FA3B8"
                               MaxWidth="940"
                               TextWrapping="Wrap" />
                  </StackPanel>
                  <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Classes="SurfaceCard" MinWidth="148" Margin="0,0,12,0">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="Overline" Text="Status" />
                        <TextBlock Text="{Binding AiAssistantStatusLabel}" FontWeight="Bold" Foreground="{Binding AiAssistantStatusBrush}" />
                      </StackPanel>
                    </Border>
                    <Border Classes="SurfaceCard" MinWidth="136" Margin="0,0,12,0">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="Overline" Text="Chat" />
                        <TextBlock Text="{Binding AiConversationCountLabel}" FontWeight="Bold" />
                      </StackPanel>
                    </Border>
                    <Border Classes="SurfaceCard" MinWidth="136" Margin="0,0,12,0">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="Overline" Text="Visuals" />
                        <TextBlock Text="{Binding AiVisualCountLabel}" FontWeight="Bold" />
                      </StackPanel>
                    </Border>
                    <Border Classes="SurfaceCard" MinWidth="170">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="Overline" Text="Engine" />
                        <TextBlock Text="{Binding AiEngineAvailabilityLabel}" FontWeight="Bold" Foreground="{Binding AiEngineAvailabilityBrush}" />
                      </StackPanel>
                    </Border>
                  </WrapPanel>
                </Grid>
              </Border>

              <Grid ColumnDefinitions="480,1.1*,540" ColumnSpacing="24" MinHeight="980">
                <Border Grid.Column="0" Classes="SectionPanel" Padding="20" MinHeight="980">
                  <Grid RowDefinitions="Auto,*" RowSpacing="12">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="H2" Text="Prompt Library" />
                      <TextBlock Text="{Binding AiWorkspaceSubheadline}" Classes="SecondaryCopy" TextWrapping="Wrap" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" MaxHeight="880" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                      <StackPanel Spacing="14">
                        <Border Classes="AiPromptCard">
                          <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                              <TextBlock Classes="H2" Text="Prompt Builder" />
                              <Button Grid.Column="1"
                                      Content="BUILD PROMPT"
                                      Classes="GhostButton"
                                      Command="{Binding GenerateAiPresetPromptCommand}" />
                            </Grid>
                            <TextBlock Text="Assemble a focused AI question from the active context, trade style, horizon, risk, and analysis goal." Classes="SecondaryCopy" TextWrapping="Wrap" />

                            <StackPanel Spacing="6">
                              <TextBlock Classes="Overline" Text="Asset" />
                              <TextBox Text="{Binding AiPromptPresetAsset}" />
                            </StackPanel>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                              <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Classes="Overline" Text="Trade Style" />
                                <ComboBox ItemsSource="{Binding AiPromptTradeStyleOptions}"
                                          SelectedItem="{Binding SelectedAiPromptTradeStyle}" />
                              </StackPanel>
                              <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Classes="Overline" Text="Horizon" />
                                <ComboBox ItemsSource="{Binding AiPromptHorizonOptions}"
                                          SelectedItem="{Binding SelectedAiPromptHorizon}" />
                              </StackPanel>
                            </Grid>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                              <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Classes="Overline" Text="Risk Profile" />
                                <ComboBox ItemsSource="{Binding AiPromptRiskProfileOptions}"
                                          SelectedItem="{Binding SelectedAiPromptRiskProfile}" />
                              </StackPanel>
                              <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Classes="Overline" Text="Focus" />
                                <ComboBox ItemsSource="{Binding AiPromptFocusOptions}"
                                          SelectedItem="{Binding SelectedAiPromptFocus}" />
                              </StackPanel>
                            </Grid>

                            <Border Classes="InfoBand">
                              <StackPanel Spacing="4">
                                <TextBlock Classes="Overline" Text="Preset Summary" />
                                <TextBlock Text="{Binding AiPromptPresetSummary}" FontWeight="SemiBold" TextWrapping="Wrap" />
                              </StackPanel>
                            </Border>

                            <Border Classes="AiFactCard">
                              <StackPanel Spacing="4">
                                <TextBlock Classes="Overline" Text="Prompt Preview" />
                                <TextBlock Text="{Binding AiPromptPresetPreview}" Classes="SecondaryCopy" TextWrapping="Wrap" />
                              </StackPanel>
                            </Border>

                            <StackPanel Spacing="6">
                              <TextBlock Classes="Overline" Text="My Preset Name" />
                              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <TextBox Text="{Binding AiCustomPresetName}" />
                                <Button Grid.Column="1"
                                        Content="SAVE MY PRESET"
                                        Classes="GhostButton"
                                        Command="{Binding SaveAiCustomPromptPresetCommand}"
                                        IsEnabled="{Binding CanSaveAiCustomPromptPreset}" />
                              </Grid>
                            </StackPanel>
                          </StackPanel>
                        </Border>

                        <Border Classes="AiPromptCard">
                          <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                              <TextBlock Classes="H2" Text="Saved Presets" />
                              <TextBlock Grid.Column="1" Text="{Binding AiSavedPresetCountLabel}" Classes="MicroCopy" VerticalAlignment="Center" />
                            </Grid>
                            <TextBlock Text="One-click tactical profiles for scalp, swing, DEX, sniper, and risk review workflows." Classes="SecondaryCopy" TextWrapping="Wrap" />
                            <ItemsControl ItemsSource="{Binding AiSavedPromptPresets}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:AiPromptPresetViewModel">
                                  <Border Classes="AiFactCard" Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                      <StackPanel Spacing="4">
                                        <DockPanel LastChildFill="True">
                                          <TextBlock DockPanel.Dock="Left" Text="{Binding Label}" FontWeight="Bold" />
                                          <TextBlock DockPanel.Dock="Right" Text="{Binding Asset}" Classes="MicroCopy" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding Summary}" Classes="SecondaryCopy" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding TradeStyle}" Foreground="#6FDBFF" FontWeight="SemiBold" />
                                      </StackPanel>
                                      <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                                        <Button Content="LOAD"
                                                Classes="GhostButton"
                                                Command="{Binding #RootWindow.DataContext.LoadAiSavedPromptPresetCommand}"
                                                CommandParameter="{Binding .}" />
                                        <Button Content="BUILD"
                                                Classes="GhostButton"
                                                Command="{Binding #RootWindow.DataContext.BuildAiSavedPromptPresetCommand}"
                                                CommandParameter="{Binding .}" />
                                        <Button Content="SEND NOW"
                                                Classes="GhostButton"
                                                Command="{Binding #RootWindow.DataContext.SendAiSavedPromptPresetCommand}"
                                                CommandParameter="{Binding .}" />
                                      </StackPanel>
                                    </Grid>
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>

                        <Border Classes="AiPromptCard">
                          <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                              <TextBlock Classes="H2" Text="My Presets" />
                              <TextBlock Grid.Column="1" Text="{Binding AiCustomPresetCountLabel}" Classes="MicroCopy" VerticalAlignment="Center" />
                            </Grid>
                            <TextBlock Text="Your own saved prompt profiles live here and persist between terminal restarts." Classes="SecondaryCopy" TextWrapping="Wrap" />
                            <ItemsControl ItemsSource="{Binding AiCustomPromptPresets}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:AiPromptPresetViewModel">
                                  <Border Classes="AiFactCard" Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                      <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Label}" FontWeight="Bold" />
                                        <TextBlock Text="{Binding Summary}" Classes="SecondaryCopy" TextWrapping="Wrap" />
                                      </StackPanel>
                                      <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                                        <Button Content="LOAD"
                                                Classes="GhostButton"
                                                Command="{Binding #RootWindow.DataContext.LoadAiSavedPromptPresetCommand}"
                                                CommandParameter="{Binding .}" />
                                        <Button Content="BUILD"
                                                Classes="GhostButton"
                                                Command="{Binding #RootWindow.DataContext.BuildAiSavedPromptPresetCommand}"
                                                CommandParameter="{Binding .}" />
                                        <Button Content="SEND NOW"
                                                Classes="GhostButton"
                                                Command="{Binding #RootWindow.DataContext.SendAiSavedPromptPresetCommand}"
                                                CommandParameter="{Binding .}" />
                                        <Button Content="DELETE"
                                                Classes="GhostButton"
                                                Command="{Binding #RootWindow.DataContext.DeleteAiCustomPromptPresetCommand}"
                                                CommandParameter="{Binding .}" />
                                      </StackPanel>
                                    </Grid>
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>

                        <Border Classes="AiPromptCard">
                          <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                              <TextBlock Classes="H2" Text="Prompt Library" />
                              <TextBlock Grid.Column="1" Text="{Binding AiQuickPromptCountLabel}" Classes="MicroCopy" VerticalAlignment="Center" />
                            </Grid>
                            <TextBlock Text="{Binding AiWorkspaceSubheadline}" Classes="SecondaryCopy" TextWrapping="Wrap" />

                            <StackPanel Spacing="10">
                              <TextBlock Classes="Overline" Text="ENTRY" />
                              <ItemsControl ItemsSource="{Binding AiEntryPrompts}">
                                <ItemsControl.ItemsPanel>
                                  <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                  </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:AiAssistantQuickPromptViewModel">
                                    <Button Classes="AiPromptChip"
                                            Content="{Binding Label}"
                                            Command="{Binding #RootWindow.DataContext.UseAiAssistantQuickPromptCommand}"
                                            CommandParameter="{Binding .}"
                                            Margin="0,0,10,10" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>

                            <StackPanel Spacing="10">
                              <TextBlock Classes="Overline" Text="EXIT" />
                              <ItemsControl ItemsSource="{Binding AiExitPrompts}">
                                <ItemsControl.ItemsPanel>
                                  <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                  </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:AiAssistantQuickPromptViewModel">
                                    <Button Classes="AiPromptChip"
                                            Content="{Binding Label}"
                                            Command="{Binding #RootWindow.DataContext.UseAiAssistantQuickPromptCommand}"
                                            CommandParameter="{Binding .}"
                                            Margin="0,0,10,10" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>

                            <StackPanel Spacing="10">
                              <TextBlock Classes="Overline" Text="RISK" />
                              <ItemsControl ItemsSource="{Binding AiRiskPrompts}">
                                <ItemsControl.ItemsPanel>
                                  <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                  </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:AiAssistantQuickPromptViewModel">
                                    <Button Classes="AiPromptChip"
                                            Content="{Binding Label}"
                                            Command="{Binding #RootWindow.DataContext.UseAiAssistantQuickPromptCommand}"
                                            CommandParameter="{Binding .}"
                                            Margin="0,0,10,10" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>

                            <StackPanel Spacing="10">
                              <TextBlock Classes="Overline" Text="DEX" />
                              <ItemsControl ItemsSource="{Binding AiDexPrompts}">
                                <ItemsControl.ItemsPanel>
                                  <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                  </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:AiAssistantQuickPromptViewModel">
                                    <Button Classes="AiPromptChip"
                                            Content="{Binding Label}"
                                            Command="{Binding #RootWindow.DataContext.UseAiAssistantQuickPromptCommand}"
                                            CommandParameter="{Binding .}"
                                            Margin="0,0,10,10" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>

                            <StackPanel Spacing="10">
                              <TextBlock Classes="Overline" Text="SNIPER" />
                              <ItemsControl ItemsSource="{Binding AiSniperPrompts}">
                                <ItemsControl.ItemsPanel>
                                  <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                  </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:AiAssistantQuickPromptViewModel">
                                    <Button Classes="AiPromptChip"
                                            Content="{Binding Label}"
                                            Command="{Binding #RootWindow.DataContext.UseAiAssistantQuickPromptCommand}"
                                            CommandParameter="{Binding .}"
                                            Margin="0,0,10,10" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>

                            <StackPanel Spacing="10">
                              <TextBlock Classes="Overline" Text="VISUAL" />
                              <ItemsControl ItemsSource="{Binding AiVisualPrompts}">
                                <ItemsControl.ItemsPanel>
                                  <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                  </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:AiAssistantQuickPromptViewModel">
                                    <Button Classes="AiPromptChip"
                                            Content="{Binding Label}"
                                            Command="{Binding #RootWindow.DataContext.UseAiAssistantQuickPromptCommand}"
                                            CommandParameter="{Binding .}"
                                            Margin="0,0,10,10" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </StackPanel>
                        </Border>

                        <Border Classes="AiPromptCard">
                          <StackPanel Spacing="10">
                            <TextBlock Classes="Overline" Text="Context Venue" />
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                              <Button Grid.Column="0"
                                      Content="AUTO"
                                      Classes="GhostButton"
                                      Command="{Binding SelectAiContextVenueModeCommand}"
                                      CommandParameter="AUTO"
                                      Background="{Binding AiContextAutoBackground}"
                                      Foreground="{Binding AiContextAutoForeground}" />
                              <Button Grid.Column="1"
                                      Content="CEX"
                                      Classes="GhostButton"
                                      Command="{Binding SelectAiContextVenueModeCommand}"
                                      CommandParameter="CEX"
                                      Background="{Binding AiContextCexBackground}"
                                      Foreground="{Binding AiContextCexForeground}" />
                              <Button Grid.Column="2"
                                      Content="DEX"
                                      Classes="GhostButton"
                                      Command="{Binding SelectAiContextVenueModeCommand}"
                                      CommandParameter="DEX"
                                      Background="{Binding AiContextDexBackground}"
                                      Foreground="{Binding AiContextDexForeground}" />
                            </Grid>
                            <TextBlock Text="{Binding AiContextVenueLabel}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding AiContextVenueSummary}" Classes="SecondaryCopy" TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>

                        <Border Classes="AiPromptCard">
                          <StackPanel Spacing="10">
                            <TextBlock Classes="Overline" Text="Context Sources" />
                            <WrapPanel Orientation="Horizontal">
                              <Button Content="MARKET"
                                      Classes="GhostButton"
                                      Command="{Binding ToggleAiContextSourceCommand}"
                                      CommandParameter="MARKET"
                                      Background="{Binding AiMarketChipBackground}"
                                      Foreground="{Binding AiMarketChipForeground}"
                                      Margin="0,0,8,8" />
                              <Button Content="RISK"
                                      Classes="GhostButton"
                                      Command="{Binding ToggleAiContextSourceCommand}"
                                      CommandParameter="RISK"
                                      Background="{Binding AiRiskChipBackground}"
                                      Foreground="{Binding AiRiskChipForeground}"
                                      Margin="0,0,8,8" />
                              <Button Content="DEX"
                                      Classes="GhostButton"
                                      Command="{Binding ToggleAiContextSourceCommand}"
                                      CommandParameter="DEX"
                                      Background="{Binding AiDexChipBackground}"
                                      Foreground="{Binding AiDexChipForeground}"
                                      Margin="0,0,8,8" />
                              <Button Content="SNIPER"
                                      Classes="GhostButton"
                                      Command="{Binding ToggleAiContextSourceCommand}"
                                      CommandParameter="SNIPER"
                                      Background="{Binding AiSniperChipBackground}"
                                      Foreground="{Binding AiSniperChipForeground}"
                                      Margin="0,0,8,8" />
                              <Button Content="VISUAL"
                                      Classes="GhostButton"
                                      Command="{Binding ToggleAiContextSourceCommand}"
                                      CommandParameter="VISUAL"
                                      Background="{Binding AiVisualChipBackground}"
                                      Foreground="{Binding AiVisualChipForeground}"
                                      Margin="0,0,8,8" />
                            </WrapPanel>
                            <TextBlock Text="{Binding AiContextSourcesSummary}" Classes="SecondaryCopy" TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>

                        <Border Classes="AiPromptCard">
                          <StackPanel Spacing="8">
                            <TextBlock Classes="Overline" Text="Scope" />
                            <TextBlock Text="{Binding AiAssistantScopeLabel}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding AiAssistantModeSummary}" Classes="SecondaryCopy" TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>

                        <Border Classes="AiPromptCard">
                          <StackPanel Spacing="8">
                            <TextBlock Classes="Overline" Text="Model Slot" />
                            <TextBlock Text="{Binding AiEngineAvailabilityLabel}" FontWeight="Bold" Foreground="{Binding AiEngineAvailabilityBrush}" />
                            <TextBlock Text="{Binding AiEngineAvailabilitySummary}" Classes="SecondaryCopy" TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>

                        <Border Classes="AiPromptCard">
                          <StackPanel Spacing="8">
                            <TextBlock Classes="Overline" Text="Image Window" />
                            <TextBlock Text="{Binding AiAttachmentStatusLabel}" FontWeight="Bold" />
                            <TextBlock Text="{Binding AiAttachmentStatusSummary}" Classes="SecondaryCopy" TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>

                        <StackPanel Spacing="10">
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Classes="H2" Text="Live Context" />
                            <TextBlock Grid.Column="1" Text="{Binding AiQuickPromptCountLabel}" Classes="MicroCopy" VerticalAlignment="Center" />
                          </Grid>
                          <ItemsControl ItemsSource="{Binding AiAssistantContextCards}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:AiContextCardViewModel">
                                <Border Classes="AiFactCard" Margin="0,0,0,10">
                                  <StackPanel Spacing="4">
                                    <TextBlock Classes="Overline" Text="{Binding Overline}" />
                                    <TextBlock Text="{Binding Value}" FontSize="17" FontWeight="Bold" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Caption}" Classes="SecondaryCopy" TextWrapping="Wrap" />
                                  </StackPanel>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>

                        <StackPanel Spacing="10">
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Classes="H2" Text="Knowledge Base" />
                            <TextBlock Grid.Column="1" Text="{Binding AiKnowledgeCountLabel}" Classes="MicroCopy" VerticalAlignment="Center" />
                          </Grid>
                          <TextBlock Text="{Binding AiKnowledgeSummary}" Classes="SecondaryCopy" TextWrapping="Wrap" />
                          <ItemsControl ItemsSource="{Binding AiAssistantKnowledgeTopics}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:AiKnowledgeTopicViewModel">
                                <Button Command="{Binding #RootWindow.DataContext.ExplainAiKnowledgeTopicCommand}"
                                        CommandParameter="{Binding .}"
                                        Padding="0"
                                        Margin="0,0,0,10"
                                        Background="Transparent"
                                        BorderThickness="0">
                                  <Border Classes="AiFactCard">
                                    <StackPanel Spacing="4">
                                      <DockPanel LastChildFill="True">
                                        <TextBlock DockPanel.Dock="Left" Text="{Binding Label}" FontWeight="Bold" />
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Category}" Classes="MicroCopy" />
                                      </DockPanel>
                                      <TextBlock Text="{Binding Question}" Classes="SecondaryCopy" TextWrapping="Wrap" />
                                    </StackPanel>
                                  </Border>
                                </Button>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </StackPanel>
                    </ScrollViewer>
                  </Grid>
                </Border>

                <Border Grid.Column="1" Classes="SectionPanel" Padding="20" MinHeight="980">
                  <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="H2" Text="Conversation" />
                      <TextBlock Text="Use this desk like an execution copilot: ask for setup, invalidation, route checks, sniper pressure, glossary topics, or a concrete next action." Classes="SecondaryCopy" TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Row="1" Classes="AiPromptCard" Padding="14">
                        <ItemsControl ItemsSource="{Binding AiAssistantMessages}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:AiAssistantMessageViewModel">
                              <Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
                                <Border Grid.Column="{Binding ColumnIndex}"
                                        HorizontalAlignment="{Binding BubbleAlignment}"
                                        Background="{Binding BubbleBackground}"
                                        BorderBrush="{Binding BubbleBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="14,12"
                                        MaxWidth="560">
                                  <StackPanel Spacing="6">
                                    <DockPanel LastChildFill="True">
                                      <TextBlock DockPanel.Dock="Left" Text="{Binding Title}" FontWeight="Bold" Foreground="{Binding TitleBrush}" />
                                      <TextBlock DockPanel.Dock="Right" Text="{Binding Meta}" Foreground="{Binding MetaBrush}" FontSize="11" HorizontalAlignment="Right" />
                                    </DockPanel>
                                    <TextBlock Text="{Binding Body}" TextWrapping="Wrap" LineHeight="20" />
                                  </StackPanel>
                                </Border>
                              </Grid>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <StackPanel Grid.Row="2" Spacing="10">
                      <TextBox Text="{Binding AiAssistantDraftPrompt}"
                               AcceptsReturn="True"
                               TextWrapping="Wrap"
                               Height="126"
                               PlaceholderText="{Binding AiAssistantComposerPlaceholder}" />
                      <WrapPanel Orientation="Horizontal">
                        <Button Content="SEND"
                                Width="124"
                                Command="{Binding SendAiAssistantPromptCommand}"
                                IsEnabled="{Binding CanSendAiAssistantPrompt}"
                                Margin="0,0,10,0" />
                        <Button Content="SYNC CONTEXT"
                                Width="136"
                                Classes="GhostButton"
                                Command="{Binding InjectAiMarketContextCommand}"
                                Margin="0,0,10,0" />
                        <Button Content="BUILD PLAN"
                                Width="136"
                                Classes="GhostButton"
                                Command="{Binding BuildAiTradePlanCommand}"
                                Margin="0,0,10,0" />
                        <Button Content="ANALYZE VISUAL"
                                Width="156"
                                Classes="GhostButton"
                                Command="{Binding AnalyzeSelectedAiVisualCommand}"
                                Margin="0,0,10,0" />
                        <Button Content="CLEAR"
                                Width="112"
                                Classes="GhostButton"
                                Command="{Binding ClearAiAssistantConversationCommand}" />
                      </WrapPanel>
                    </StackPanel>
                  </Grid>
                </Border>

                <Border Grid.Column="2" Classes="SectionPanel" Padding="20" MinHeight="980">
                  <Grid RowDefinitions="Auto,Auto,*" RowSpacing="16">
                    <Border Classes="AiStudioStage">
                      <Grid RowDefinitions="420,Auto,Auto" RowSpacing="12">
                        <Border CornerRadius="14" ClipToBounds="True">
                          <Image Source="{Binding AiSelectedVisualImage}" Stretch="UniformToFill" />
                        </Border>
                        <StackPanel Grid.Row="1" Spacing="6">
                          <TextBlock Classes="Overline" Text="Pinned Visual" />
                          <TextBlock Text="{Binding AiSelectedVisualTitle}" FontSize="22" FontWeight="Bold" />
                          <TextBlock Text="{Binding AiSelectedVisualCaption}" Classes="SecondaryCopy" TextWrapping="Wrap" />
                        </StackPanel>
                        <Border Grid.Row="2" Classes="InfoBand">
                          <StackPanel Spacing="4">
                            <TextBlock Classes="Overline" Text="Signal Metric" />
                            <TextBlock Text="{Binding AiSelectedVisualMetric}" FontWeight="Bold" />
                          </StackPanel>
                        </Border>
                      </Grid>
                    </Border>

                    <Border Grid.Row="1" Classes="AiPromptCard">
                      <StackPanel Spacing="8">
                        <TextBlock Classes="Overline" Text="Visual Usage" />
                        <TextBlock Text="Use the gallery below to pin a chart-style image, then run visual analysis to get a local explanation tied to current market and route state." Classes="SecondaryCopy" TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2" Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                          <TextBlock Classes="H2" Text="Visual Rail" />
                          <TextBlock Grid.Column="1" Text="tap to focus" Classes="MicroCopy" VerticalAlignment="Center" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding AiAssistantVisuals}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:AiVisualCardViewModel">
                              <Button Command="{Binding #RootWindow.DataContext.SelectAiVisualCommand}"
                                      CommandParameter="{Binding .}"
                                      Padding="0"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Margin="0,0,0,10">
                                <Border Classes="AiThumbCard"
                                        Background="{Binding CardBackground}"
                                        BorderBrush="{Binding CardBorderBrush}">
                                  <Grid ColumnDefinitions="118,*" ColumnSpacing="12">
                                    <Border Grid.Column="0" CornerRadius="10" ClipToBounds="True" Height="82">
                                      <Image Source="{Binding Image}" Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                      <TextBlock Text="{Binding Title}" FontWeight="Bold" />
                                      <TextBlock Text="{Binding Caption}" Classes="SecondaryCopy" TextWrapping="Wrap" MaxHeight="40" />
                                      <TextBlock Text="{Binding Metric}" Foreground="{Binding MetricBrush}" FontWeight="SemiBold" />
                                    </StackPanel>
                                  </Grid>
                                </Border>
                              </Button>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                  </Grid>
                </Border>
              </Grid>
            </StackPanel>
          </Border>
        </ScrollViewer>
      </TabItem>
<TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Sniper" VerticalAlignment="Center" />
            <Border Background="{Binding WalletVM.GlobalQuoteAssetModeBrush}" CornerRadius="8" Padding="6,1">
              <TextBlock Text="{Binding WalletVM.GlobalQuoteTabBadgeLabel}" Foreground="#081018" FontSize="11" FontWeight="Bold" />
            </Border>
          </StackPanel>
        </TabItem.Header>
        <Grid>
          <ScrollViewer Classes="PageScroll">
            <views:SniperView />
          </ScrollViewer>

        </Grid>
      </TabItem>

      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="DEX" VerticalAlignment="Center" />
            <Border Background="{Binding WalletVM.GlobalQuoteAssetModeBrush}" CornerRadius="8" Padding="6,1">
              <TextBlock Text="{Binding WalletVM.GlobalQuoteTabBadgeLabel}" Foreground="#081018" FontSize="11" FontWeight="Bold" />
            </Border>
          </StackPanel>
        </TabItem.Header>
        <ScrollViewer Classes="PageScroll">
        <Border Classes="Panel">
          <Grid ColumnDefinitions="350,*"
                RowDefinitions="*"
                ColumnSpacing="16"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ClipToBounds="True">
            <Border Classes="Panel" Grid.Column="0" Grid.Row="0" MinHeight="0">
              <StackPanel Spacing="12">
                <TextBlock Classes="H2" Text="DEX Tokens" />
                  <TextBox Text="{Binding DexTradingVM.SearchText}"
                          PlaceholderText="Search by symbol, name or address" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Content="SEARCH" Command="{Binding DexTradingVM.SearchCommand}" Width="110" />
                  <Button Content="REFRESH" Command="{Binding DexTradingVM.RefreshCommand}" Width="110" />
                </StackPanel>
                <TextBlock Text="{Binding DexTradingVM.StatusMessage}"
                           TextWrapping="Wrap"
                           Foreground="#8B949E" />
                <TextBlock Text="{Binding DexTradingVM.LastUpdatedLocal, StringFormat=Updated: {0:HH:mm:ss}}"
                           Foreground="#8B949E" />
                <ListBox ItemsSource="{Binding DexTradingVM.Tokens}"
                         SelectedItem="{Binding DexTradingVM.SelectedToken}"
                         Height="500">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:DexTokenItemViewModel">
                      <Border BorderBrush="#30363D" BorderThickness="0,0,0,1" Padding="0,10">
                        <StackPanel>
                          <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" />
                          <TextBlock Text="{Binding PairLabel}" Foreground="#8B949E" FontSize="12" />
                          <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding PriceUsd, StringFormat=$ {0:N6}}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding PriceChange24h, StringFormat={}{0:+0.##;-0.##;0}%}"
                                       Foreground="#00D4AA" />
                          </Grid>
                          <TextBlock Text="{Binding LiquidityUsd, StringFormat=Liquidity: $ {0:N0}}"
                                     Foreground="#8B949E"
                                     FontSize="12" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </Border>

            <Grid Grid.Column="1"
                  Grid.Row="0"
                  RowDefinitions="*"
                  MinHeight="0"
                  ClipToBounds="True">
              <ScrollViewer Grid.Row="0"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          MaxHeight="{Binding $parent[TabControl].Bounds.Height}"
                          MinHeight="0"
                          ClipToBounds="True"
                          AllowAutoHide="False"
                          VerticalScrollBarVisibility="Visible"
                          HorizontalScrollBarVisibility="Auto">
                <Border Classes="Panel"
                        MinHeight="0">
                  <StackPanel Spacing="14">
                  <TextBlock Classes="H1" Text="{Binding DexTradingVM.SelectedTokenTitle}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding DexTradingVM.SelectedTokenSubtitle}"
                             Foreground="#8B949E"
                             TextWrapping="Wrap" />

                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="16" RowSpacing="16">
                    <Border Classes="Panel" Grid.Row="0" Grid.Column="0">
                      <StackPanel>
                        <TextBlock Text="Price USD" Foreground="#8B949E" />
                        <TextBlock Classes="Value"
                                   FontSize="26"
                                   Text="{Binding DexTradingVM.SelectedToken.PriceUsd, StringFormat=$ {0:N6}}" />
                      </StackPanel>
                    </Border>

                    <Border Classes="Panel" Grid.Row="0" Grid.Column="1">
                      <StackPanel>
                        <TextBlock Text="Price Native" Foreground="#8B949E" />
                        <TextBlock Classes="Value"
                                   FontSize="26"
                                   Text="{Binding DexTradingVM.SelectedToken.PriceNative, StringFormat={}{0:N6}}" />
                      </StackPanel>
                    </Border>

                    <Border Classes="Panel" Grid.Row="1" Grid.Column="0">
                      <StackPanel>
                        <TextBlock Text="24h Volume" Foreground="#8B949E" />
                        <TextBlock Classes="Value"
                                   FontSize="24"
                                   Text="{Binding DexTradingVM.SelectedToken.Volume24h, StringFormat=$ {0:N0}}" />
                      </StackPanel>
                    </Border>

                    <Border Classes="Panel" Grid.Row="1" Grid.Column="1">
                      <StackPanel>
                        <TextBlock Text="Liquidity" Foreground="#8B949E" />
                        <TextBlock Classes="Value"
                                   FontSize="24"
                                   Text="{Binding DexTradingVM.SelectedToken.LiquidityUsd, StringFormat=$ {0:N0}}" />
                      </StackPanel>
                    </Border>

                    <Border Classes="Panel" Grid.Row="2" Grid.ColumnSpan="2" MinHeight="420">
                      <StackPanel Spacing="12">
                        <DockPanel>
                          <TextBlock Classes="H2" Text="Price History" DockPanel.Dock="Left" />
                          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <Button Content="15M"
                                    Command="{Binding DexTradingVM.SelectChartRangeCommand}"
                                    CommandParameter="15M"
                                    Width="72" />
                            <Button Content="1D"
                                    Command="{Binding DexTradingVM.SelectChartRangeCommand}"
                                    CommandParameter="1D"
                                    Width="72" />
                            <Button Content="1W"
                                    Command="{Binding DexTradingVM.SelectChartRangeCommand}"
                                    CommandParameter="1W"
                                    Width="72" />
                          </StackPanel>
                        </DockPanel>

                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="16">
                          <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding DexTradingVM.ChartStatusMessage}" Foreground="#8B949E" />
                            <TextBlock Text="{Binding DexTradingVM.ChartTelemetry}"
                                       Foreground="#14E0C1"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding DexTradingVM.SelectedChartRange, StringFormat=Range: {0}}" Foreground="#8B949E" />
                            <TextBlock Text="{Binding DexTradingVM.ChartSource, StringFormat=Source: {0}}" Foreground="#8B949E" />
                            <TextBlock Text="{Binding DexTradingVM.ChartDiagnostics, StringFormat=Debug: {0}}"
                                       Foreground="#8B949E"
                                       TextWrapping="Wrap"
                                       MaxWidth="520" />
                          </StackPanel>
                          <StackPanel Grid.Column="1">
                            <TextBlock Text="High" Foreground="#8B949E" />
                            <TextBlock Text="{Binding DexTradingVM.ChartHigh, StringFormat=$ {0:N6}}" />
                          </StackPanel>
                          <StackPanel Grid.Column="2">
                            <TextBlock Text="Low" Foreground="#8B949E" />
                            <TextBlock Text="{Binding DexTradingVM.ChartLow, StringFormat=$ {0:N6}}" />
                          </StackPanel>
                          <StackPanel Grid.Column="3">
                            <TextBlock Text="Change" Foreground="#8B949E" />
                            <TextBlock Text="{Binding DexTradingVM.ChartChangePercent, StringFormat={}{0:+0.##;-0.##;0}%}" />
                          </StackPanel>
                        </Grid>

                        <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="10" Padding="12" MinHeight="300">
                          <Grid RowDefinitions="*,Auto">
                            <ctrl:DexPriceChart Grid.Row="0"
                                                Height="300"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                Candles="{Binding DexTradingVM.ChartCandles}" />
                            <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="0,12,0,0">
                              <TextBlock Grid.Column="0" Text="{Binding DexTradingVM.ChartStartLabel}" Foreground="#8B949E" />
                              <TextBlock Grid.Column="2" Text="{Binding DexTradingVM.ChartEndLabel}" Foreground="#8B949E" />
                            </Grid>
                          </Grid>
                        </Border>
                      </StackPanel>
                    </Border>

                    <Border Classes="SectionPanel" Grid.Row="3" Grid.ColumnSpan="2">
                      <StackPanel Spacing="12">
                        <TextBlock Classes="H2" Text="Manual DEX Trade" />
                        <Border Classes="GuardStripCard">
                          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border Classes="GuardChip"
                                    Background="#10251F"
                                    BorderBrush="{Binding DexTradingVM.DexGuardStatusBrush}">
                              <TextBlock Text="{Binding DexTradingVM.DexGuardStatusLabel}"
                                         Foreground="{Binding DexTradingVM.DexGuardStatusBrush}"
                                         FontWeight="Bold" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="4">
                              <TextBlock Text="{Binding DexTradingVM.DexGuardSummary}" FontWeight="SemiBold" TextWrapping="Wrap" />
                              <TextBlock Text="{Binding DexTradingVM.DexGuardDetail}" Foreground="#8B949E" TextWrapping="Wrap" />
                            </StackPanel>
                          </Grid>
                        </Border>
                        <TextBlock Text="{Binding DexTradingVM.WalletTradeStatus}"
                                   Foreground="#8B949E"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding DexTradingVM.WalletSessionSummary, StringFormat=Active wallet: {0}}"
                                   Foreground="#14E0C1"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                          <Border Background="{Binding WalletVM.WalletReadinessBrush}" CornerRadius="10" Padding="10,4">
                            <TextBlock Text="{Binding WalletVM.WalletReadinessLabel}" Foreground="#081018" FontWeight="Bold" />
                          </Border>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding WalletVM.RouteReadinessSummary}"
                                     Foreground="#8B949E"
                                     TextWrapping="Wrap"
                                     VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock Text="{Binding DexTradingVM.WalletBalanceSummary, StringFormat=Native balance: {0}}"
                                   Foreground="#8B949E"
                                   TextWrapping="Wrap" />
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                          <Border Background="{Binding DexTradingVM.QuoteAssetModeBrush}" CornerRadius="10" Padding="10,4">
                            <TextBlock Text="{Binding DexTradingVM.QuoteAssetModeLabel}" Foreground="#081018" FontWeight="Bold" />
                          </Border>
                          <TextBlock Grid.Column="1" Text="{Binding DexTradingVM.QuoteAssetSummary}"
                                     Foreground="#8B949E"
                                     TextWrapping="Wrap"
                                     VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock Text="{Binding DexTradingVM.QuoteAssetBalanceLabel, StringFormat=Quote balance: {0}}"
                                   Foreground="#F4B860"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding DexTradingVM.SpendableQuoteBalanceLabel}"
                                   Foreground="#14E0C1"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding DexTradingVM.PairCompatibilityMessage}"
                                   Foreground="{Binding DexTradingVM.QuoteAssetModeBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding DexTradingVM.BuyAvailabilityMessage}"
                                   Foreground="{Binding DexTradingVM.BuyAvailabilityBrush}"
                                   TextWrapping="Wrap" />
                        <Button Content="OPEN WALLET HUB"
                                Command="{Binding OpenWalletTabCommand}"
                                Width="160" />

                        <Grid ColumnDefinitions="Auto,*,Auto,80" ColumnSpacing="12"
                              IsEnabled="{Binding DexTradingVM.CanTradeSelectedToken}">
                          <TextBlock Grid.Column="0" Text="Quote Asset" VerticalAlignment="Center" />
                          <ComboBox Grid.Column="1"
                                    ItemsSource="{Binding DexTradingVM.QuoteAssetOptions}"
                                    SelectedItem="{Binding DexTradingVM.SelectedQuoteAssetSymbol}" />
                          <TextBlock Grid.Column="2" Text="Slippage %" VerticalAlignment="Center" />
                          <NumericUpDown Grid.Column="3" Value="{Binding DexTradingVM.SlippagePercent}"
                                         Increment="0.5" FormatString="0.#" Minimum="0.1" Maximum="50"
                                         ToolTip.Tip="{Binding DexTradingVM.SlippageSummary}" />
                        </Grid>
                        <TextBlock Classes="Overline" Text="BUY" Margin="0,4,0,0" />
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8"
                              IsEnabled="{Binding DexTradingVM.CanTradeSelectedToken}">
                          <Button Grid.Column="0" Content="25%" Classes="GhostButton" Command="{Binding DexTradingVM.ApplyBuyBalancePresetCommand}" CommandParameter="25" />
                          <Button Grid.Column="1" Content="50%" Classes="GhostButton" Command="{Binding DexTradingVM.ApplyBuyBalancePresetCommand}" CommandParameter="50" />
                          <Button Grid.Column="2" Content="75%" Classes="GhostButton" Command="{Binding DexTradingVM.ApplyBuyBalancePresetCommand}" CommandParameter="75" />
                          <Button Grid.Column="3" Content="100%" Classes="GhostButton" Command="{Binding DexTradingVM.ApplyBuyBalancePresetCommand}" CommandParameter="100" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto" ColumnSpacing="12"
                              IsEnabled="{Binding DexTradingVM.CanTradeSelectedToken}">
                          <TextBlock Grid.Column="0" Text="{Binding DexTradingVM.BuyAmountLabel}" VerticalAlignment="Center" />
                          <NumericUpDown Grid.Column="1"
                                         Value="{Binding DexTradingVM.BuyAmountBnb}"
                                         Increment="0.001"
                                         FormatString="0.0000"
                                         Minimum="0" />
                          <Button Grid.Column="2" Content="MAX"
                                  Classes="GhostButton"
                                  Command="{Binding DexTradingVM.UseMaxBuyAmountCommand}" />
                        </Grid>
                        <TextBlock Text="{Binding DexTradingVM.BuyQuoteLabel}"
                                   Foreground="{Binding DexTradingVM.BuyQuoteBrush}"
                                   IsVisible="{Binding DexTradingVM.HasSelectedToken}"
                                   TextWrapping="Wrap" />

                        <TextBlock Classes="Overline" Text="SELL" Margin="0,4,0,0" />
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                          <TextBlock Grid.Column="0" Text="Balance:" VerticalAlignment="Center" Foreground="#8FA3B8" />
                          <TextBlock Grid.Column="1" Text="{Binding DexTradingVM.TokenBalanceLabel}"
                                     VerticalAlignment="Center" Foreground="#F4B860"
                                     IsVisible="{Binding DexTradingVM.HasSelectedToken}" />
                          <Button Grid.Column="2" Content="↻" Classes="GhostButton" Width="34"
                                  Command="{Binding DexTradingVM.RefreshTokenBalanceCommand}"
                                  ToolTip.Tip="Refresh token balance" />
                          <NumericUpDown Grid.Column="3"
                                         Value="{Binding DexTradingVM.SellAmountTokens}"
                                         Increment="1"
                                         FormatString="0.########"
                                         Minimum="0" Width="160"
                                         IsEnabled="{Binding DexTradingVM.CanTradeSelectedToken}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8"
                              IsEnabled="{Binding DexTradingVM.CanTradeSelectedToken}">
                          <Button Grid.Column="0" Content="25%" Classes="GhostButton" Command="{Binding DexTradingVM.ApplySellBalancePresetCommand}" CommandParameter="25" />
                          <Button Grid.Column="1" Content="50%" Classes="GhostButton" Command="{Binding DexTradingVM.ApplySellBalancePresetCommand}" CommandParameter="50" />
                          <Button Grid.Column="2" Content="75%" Classes="GhostButton" Command="{Binding DexTradingVM.ApplySellBalancePresetCommand}" CommandParameter="75" />
                          <Button Grid.Column="3" Content="100%" Classes="GhostButton" Command="{Binding DexTradingVM.ApplySellBalancePresetCommand}" CommandParameter="100" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="16">
                          <Button Content="BUY TOKEN" Classes="BuyButton" Command="{Binding DexTradingVM.BuyCommand}" Width="140"
                                  IsEnabled="{Binding DexTradingVM.CanBuySelectedTokenLive}"
                                  ToolTip.Tip="{Binding DexTradingVM.ManualBuyBlockedReason}" />
                          <Button Content="SELL TOKEN" Classes="SellButton" Command="{Binding DexTradingVM.SellCommand}" Width="140"
                                  IsEnabled="{Binding DexTradingVM.CanSellSelectedTokenLive}"
                                  ToolTip.Tip="{Binding DexTradingVM.ManualSellBlockedReason}" />
                        </StackPanel>
                        <TextBlock Text="{Binding DexTradingVM.ManualBuyBlockedReason}"
                                   Foreground="#F4B860"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding !DexTradingVM.CanBuySelectedTokenLive}" />

                        <TextBlock Text="{Binding DexTradingVM.SelectedToken.TokenAddress, StringFormat=Token: {0}}"
                                   Foreground="#8B949E"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding DexTradingVM.SelectedToken.Url, StringFormat=DEX: {0}}"
                                   Foreground="#8B949E"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </Grid>
                  </StackPanel>
                </Border>
              </ScrollViewer>
            </Grid>
          </Grid>
        </Border>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Logs">
        <ScrollViewer Classes="PageScroll">
        <StackPanel Spacing="16">
          <Border Classes="HeroPanel">
            <StackPanel Spacing="8">
              <TextBlock Classes="Overline" Text="SYSTEM OUTPUT" />
              <TextBlock Classes="H1" Text="Activity &amp; Logs" />
              <TextBlock Text="All runtime messages in one scrollable surface."
                         Foreground="#8FA3B8"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
          <Border Classes="Panel" Padding="0">
            <TextBox Classes="LogBox"
                     Text="{Binding LogMessages}"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     MinHeight="620" />
          </Border>
        </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>

    <Border IsVisible="{Binding IsPlaceholderSectionVisible}" Classes="Panel" Padding="26" ZIndex="5">
      <ScrollViewer Classes="PageScroll">
        <StackPanel Spacing="18">
          <TextBlock Classes="H1" Text="{Binding CurrentSectionTitle}" />

          <StackPanel Spacing="16" IsVisible="{Binding IsRiskSectionVisible}">
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">
              <Border Grid.Column="0" Classes="SurfaceCard">
                <StackPanel Spacing="6">
                  <TextBlock Classes="Overline" Text="Execution Guard" />
                  <TextBlock Classes="Metric" Text="{Binding WalletVM.GlobalExecutionModeLabel}" />
                  <TextBlock Text="{Binding WalletVM.GlobalExecutionGuardStatusLabel}"
                             Foreground="{Binding RiskRuntimeStatusBrush}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Classes="SurfaceCard">
                <StackPanel Spacing="6">
                  <TextBlock Classes="Overline" Text="Risk Budget" />
                  <TextBlock Text="{Binding RiskRuntimeSummary}" FontWeight="SemiBold" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding RiskCexExposureSummary}" Foreground="#8FA3B8" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Classes="SurfaceCard">
                <StackPanel Spacing="6">
                  <TextBlock Classes="Overline" Text="Sniper Safety" />
                  <TextBlock Text="{Binding RiskSniperGuardSummary}" FontWeight="SemiBold" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding SniperVM.StatusMessage}" Foreground="#8FA3B8" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </Grid>

            <!-- ── Live risk metrics ── -->
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="16">
              <Border Grid.Column="0" Classes="SurfaceCard">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Realized P&amp;L" />
                  <TextBlock Classes="Metric" Text="{Binding PnlDashboardVM.TotalPnlLabel}"
                             Foreground="{Binding PnlDashboardVM.TotalPnlBrush}" />
                  <TextBlock Text="{Binding PnlDashboardVM.TradeCountLabel}" Foreground="#8FA3B8" FontSize="11" />
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Classes="SurfaceCard">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Open P&amp;L (unrealized)" />
                  <TextBlock Classes="Metric" Text="{Binding AllPositionsVM.TotalPnlLabel}"
                             Foreground="{Binding AllPositionsVM.TotalPnlBrush}" />
                  <TextBlock Text="{Binding AllPositionsVM.StatusLabel}" Foreground="#8FA3B8" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Classes="SurfaceCard">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Open Positions" />
                  <TextBlock Classes="Metric" Text="{Binding AllPositionsVM.PositionCount}" />
                  <TextBlock Text="{Binding AllPositionsVM.TotalSizeLabel}" Foreground="#8FA3B8" FontSize="11" />
                </StackPanel>
              </Border>
              <Border Grid.Column="3" Classes="SurfaceCard">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Win Rate / PF" />
                  <TextBlock Classes="Metric" Text="{Binding PnlDashboardVM.WinRateLabel}" />
                  <TextBlock Text="{Binding PnlDashboardVM.ProfitFactorLabel, StringFormat='PF {0}'}" Foreground="#8FA3B8" FontSize="11" />
                  <TextBlock Text="{Binding PnlDashboardVM.MaxDrawdownLabel, StringFormat='Max DD {0}'}" Foreground="#8FA3B8" FontSize="11" />
                </StackPanel>
              </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
              <Border Grid.Column="0" Classes="Panel">
                <StackPanel Spacing="10">
                  <TextBlock Classes="H2" Text="Quick Controls" />
                  <WrapPanel Orientation="Horizontal">
                    <Button Classes="GhostButton"
                            Content="Paper Mode"
                            Margin="0,0,10,10"
                            Command="{Binding WalletVM.ApplyGlobalExecutionModeCommand}"
                            CommandParameter="PAPER" />
                    <Button Classes="GhostButton"
                            Content="Live Allowed"
                            Margin="0,0,10,10"
                            Command="{Binding WalletVM.ApplyGlobalExecutionModeCommand}"
                            CommandParameter="LIVE" />
                    <Button Classes="GhostButton"
                            Content="Refresh Wallet"
                            Margin="0,0,10,10"
                            Command="{Binding WalletVM.RefreshWalletCommand}" />
                    <Button Classes="GhostButton"
                            Content="Open Logs"
                            Margin="0,0,10,10"
                            Command="{Binding SelectMainTabCommand}"
                            CommandParameter="logs" />
                  </WrapPanel>
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Classes="Panel">
                <StackPanel Spacing="10">
                  <TextBlock Classes="H2" Text="Readiness Notes" />
                  <TextBlock Text="{Binding WalletVM.GlobalExecutionSummary}" Foreground="#8FA3B8" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding WalletVM.GlobalQuoteAssetSummary}" Foreground="#8FA3B8" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding FuturesPrivateApiStatusLabel}" Foreground="{Binding FuturesPrivateApiStatusBrush}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>

          <!-- ══════════ BACKTEST ENGINE ══════════ -->
          <StackPanel Spacing="16" IsVisible="{Binding IsBacktestSectionVisible}">

            <!-- ── Configuration ── -->
            <Border Classes="Panel">
              <StackPanel Spacing="14">
                <TextBlock Classes="H2" Text="Backtest Configuration" />

                <!-- Row 1: symbol · timeframe · commission · strategy · date toggle · run -->
                <Grid ColumnDefinitions="*,110,110,*,Auto,Auto" ColumnSpacing="12">
                  <StackPanel Grid.Column="0" Spacing="5">
                    <TextBlock Classes="Overline" Text="Symbol" />
                    <TextBox Text="{Binding BacktestVM.Symbol}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="5">
                    <TextBlock Classes="Overline" Text="Timeframe" />
                    <ComboBox ItemsSource="{Binding BacktestVM.AvailableTimeframes}"
                              SelectedItem="{Binding BacktestVM.SelectedTimeframe}" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="5">
                    <TextBlock Classes="Overline" Text="Commission %" />
                    <NumericUpDown Value="{Binding BacktestVM.Commission}"
                                   Increment="0.05" Minimum="0" Maximum="5" FormatString="0.00" />
                  </StackPanel>
                  <StackPanel Grid.Column="3" Spacing="5">
                    <TextBlock Classes="Overline" Text="Strategy" />
                    <ComboBox ItemsSource="{Binding BacktestVM.AvailableStrategies}"
                              SelectedItem="{Binding BacktestVM.SelectedStrategy}" />
                  </StackPanel>
                  <StackPanel Grid.Column="4" Spacing="5" VerticalAlignment="Bottom">
                    <CheckBox Content="By Date Range" IsChecked="{Binding BacktestVM.UseCustomDateRange}" />
                  </StackPanel>
                  <StackPanel Grid.Column="5" Spacing="5" VerticalAlignment="Bottom">
                    <Button Command="{Binding BacktestVM.RunCommand}"
                            IsEnabled="{Binding BacktestVM.CanRun}"
                            Content="▶  Run" Classes="AccentButton" />
                  </StackPanel>
                </Grid>

                <!-- Row 2a: last N candles (no date range) -->
                <StackPanel IsVisible="{Binding BacktestVM.UseCustomDateRange, Converter={x:Static BoolConverters.Not}}">
                  <StackPanel Spacing="5" MaxWidth="200" HorizontalAlignment="Left">
                    <TextBlock Classes="Overline" Text="Candles (max 3000)" />
                    <NumericUpDown Value="{Binding BacktestVM.CandleLimit}"
                                   Increment="100" Minimum="50" Maximum="3000" />
                  </StackPanel>
                </StackPanel>

                <!-- Row 2b: date range -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12"
                      IsVisible="{Binding BacktestVM.UseCustomDateRange}">
                  <StackPanel Grid.Column="0" Spacing="5">
                    <TextBlock Classes="Overline" Text="Start Date" />
                    <CalendarDatePicker SelectedDate="{Binding BacktestVM.StartDate}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="5">
                    <TextBlock Classes="Overline" Text="End Date" />
                    <CalendarDatePicker SelectedDate="{Binding BacktestVM.EndDate}" />
                  </StackPanel>
                </Grid>

                <!-- Row 3a: MA Crossover params -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12"
                      IsVisible="{Binding BacktestVM.IsMAStrategy}">
                  <Border Grid.Column="0" Grid.ColumnSpan="3" Background="#091520" CornerRadius="4" Padding="12,8">
                    <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="12">
                      <TextBlock Grid.Column="0" Text="Fast Period" Classes="Overline" VerticalAlignment="Center" />
                      <NumericUpDown Grid.Column="1" Value="{Binding BacktestVM.MaFastPeriod}"
                                     Increment="1" Minimum="2" Maximum="200" />
                      <TextBlock Grid.Column="2" Text="Slow Period" Classes="Overline" VerticalAlignment="Center" Margin="8,0,0,0" />
                      <NumericUpDown Grid.Column="3" Value="{Binding BacktestVM.MaSlowPeriod}"
                                     Increment="1" Minimum="3" Maximum="500" />
                    </Grid>
                  </Border>
                </Grid>

                <!-- Row 3b: RSI params -->
                <Border Background="#091520" CornerRadius="4" Padding="12,8"
                        IsVisible="{Binding BacktestVM.IsRsiStrategy}">
                  <Grid ColumnDefinitions="Auto,100,Auto,120,Auto,120" ColumnSpacing="12">
                    <TextBlock Grid.Column="0" Text="Period" Classes="Overline" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Column="1" Value="{Binding BacktestVM.RsiPeriod}"
                                   Increment="1" Minimum="2" Maximum="100" />
                    <TextBlock Grid.Column="2" Text="Overbought" Classes="Overline" VerticalAlignment="Center" Margin="8,0,0,0" />
                    <NumericUpDown Grid.Column="3" Value="{Binding BacktestVM.RsiOverbought}"
                                   Increment="1" Minimum="51" Maximum="99" FormatString="0" />
                    <TextBlock Grid.Column="4" Text="Oversold" Classes="Overline" VerticalAlignment="Center" Margin="8,0,0,0" />
                    <NumericUpDown Grid.Column="5" Value="{Binding BacktestVM.RsiOversold}"
                                   Increment="1" Minimum="1" Maximum="49" FormatString="0" />
                  </Grid>
                </Border>

                <!-- Row 3c: Bollinger Bands params -->
                <Border Background="#091520" CornerRadius="4" Padding="12,8"
                        IsVisible="{Binding BacktestVM.IsBBStrategy}">
                  <Grid ColumnDefinitions="Auto,100,Auto,120" ColumnSpacing="12">
                    <TextBlock Grid.Column="0" Text="Period" Classes="Overline" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Column="1" Value="{Binding BacktestVM.BbPeriod}"
                                   Increment="1" Minimum="2" Maximum="200" />
                    <TextBlock Grid.Column="2" Text="Multiplier (σ)" Classes="Overline" VerticalAlignment="Center" Margin="8,0,0,0" />
                    <NumericUpDown Grid.Column="3" Value="{Binding BacktestVM.BbMultiplier}"
                                   Increment="0.1" Minimum="0.5" Maximum="5" FormatString="0.0" />
                  </Grid>
                </Border>

                <!-- Row 3d: Breakout params -->
                <Border Background="#091520" CornerRadius="4" Padding="12,8"
                        IsVisible="{Binding BacktestVM.IsBreakoutStrategy}">
                  <Grid ColumnDefinitions="Auto,100" ColumnSpacing="12">
                    <TextBlock Grid.Column="0" Text="Lookback Period" Classes="Overline" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Column="1" Value="{Binding BacktestVM.BreakoutPeriod}"
                                   Increment="1" Minimum="2" Maximum="300" />
                  </Grid>
                </Border>

              </StackPanel>
            </Border>

            <!-- Метрики главной стратегии -->
            <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="12">
              <Border Classes="SurfaceCard">
                <StackPanel Spacing="5">
                  <TextBlock Classes="Overline" Text="Status" />
                  <TextBlock Classes="Metric" Text="{Binding BacktestVM.StatusLabel}" />
                  <TextBlock Text="{Binding BacktestVM.WindowLabel}"
                             Foreground="{Binding BacktestVM.StatusBrush}"
                             TextWrapping="Wrap" FontSize="11" />
                </StackPanel>
              </Border>
              <Border Classes="SurfaceCard">
                <StackPanel Spacing="5">
                  <TextBlock Classes="Overline" Text="Trades / Win Rate" />
                  <TextBlock Classes="Metric" Text="{Binding BacktestVM.TradeCountLabel}" />
                  <TextBlock Text="{Binding BacktestVM.WinRateLabel}" Foreground="#8FA3B8" />
                </StackPanel>
              </Border>
              <Border Classes="SurfaceCard">
                <StackPanel Spacing="5">
                  <TextBlock Classes="Overline" Text="Net Return" />
                  <TextBlock Classes="Metric"
                             Text="{Binding BacktestVM.NetReturnLabel}"
                             Foreground="{Binding BacktestVM.NetReturnColor}" />
                  <TextBlock Text="{Binding BacktestVM.DrawdownLabel, StringFormat='Max DD {0}'}"
                             Foreground="#8FA3B8" />
                </StackPanel>
              </Border>
              <Border Classes="SurfaceCard">
                <StackPanel Spacing="5">
                  <TextBlock Classes="Overline" Text="Sharpe / Bias" />
                  <TextBlock Classes="Metric" Text="{Binding BacktestVM.SharpeLabel}" />
                  <TextBlock Text="{Binding BacktestVM.BiasLabel}" Foreground="#8FA3B8" />
                </StackPanel>
              </Border>
              <Border Classes="SurfaceCard">
                <StackPanel Spacing="5">
                  <TextBlock Classes="Overline" Text="Best / Worst Trade" />
                  <TextBlock Classes="Metric" Text="{Binding BacktestVM.BestTradeLabel}" Foreground="#3DDC84" />
                  <TextBlock Text="{Binding BacktestVM.WorstTradeLabel}" Foreground="#FF5D73" />
                </StackPanel>
              </Border>
            </Grid>

            <!-- ГРАФИК ЭКВИТИ -->
            <Border Classes="Panel" IsVisible="{Binding BacktestVM.EquityGeometry, Converter={x:Static ObjectConverters.IsNotNull}}">
              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Classes="H2" Text="Equity Curve" VerticalAlignment="Center" />
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Border Width="18" Height="2" Background="#1FE0B3" VerticalAlignment="Center" />
                      <TextBlock Text="Strategy" Foreground="#8FA3B8" FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Border Width="18" Height="2" Background="#F4B860" VerticalAlignment="Center" />
                      <TextBlock Text="Buy &amp; Hold" Foreground="#8FA3B8" FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding BacktestVM.EquityDateRange}" Foreground="#4A6880" FontSize="11" VerticalAlignment="Center" />
                  </StackPanel>
                </Grid>

                <!-- SVG-график через Viewbox + Path -->
                <Grid>
                  <!-- Ось Y: мин/макс -->
                  <StackPanel HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="36">
                    <TextBlock Text="{Binding BacktestVM.EquityMaxLabel}" FontSize="10" Foreground="#4A6880" />
                    <TextBlock Text="{Binding BacktestVM.EquityMinLabel}" FontSize="10" Foreground="#4A6880"
                               VerticalAlignment="Bottom" Margin="0,110,0,0" />
                  </StackPanel>
                  <Border Background="#07131C" CornerRadius="6" Height="130" Margin="40,0,0,0" ClipToBounds="True">
                    <Viewbox Stretch="Fill">
                      <Canvas Width="700" Height="130">
                        <!-- Нулевая линия (equity = 100) -->
                        <Line StartPoint="0,65" EndPoint="700,65"
                              Stroke="#1A2E3A" StrokeThickness="1" StrokeDashArray="4,4" />
                        <!-- Buy & Hold -->
                        <Path Data="{Binding BacktestVM.BuyHoldGeometry}"
                              Stroke="#F4B860" StrokeThickness="1.2"
                              Opacity="0.55" Fill="Transparent" />
                        <!-- Стратегия -->
                        <Path Data="{Binding BacktestVM.EquityGeometry}"
                              Stroke="#1FE0B3" StrokeThickness="1.8"
                              Fill="Transparent" />
                      </Canvas>
                    </Viewbox>
                  </Border>
                </Grid>
                <TextBlock Text="{Binding BacktestVM.Narrative}"
                           Foreground="#8FA3B8" FontSize="11" TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <!-- ── Walk-Forward Optimizer ── -->
            <Border Classes="Panel">
              <StackPanel Spacing="12">
                <!-- Header row -->
                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12">
                  <StackPanel Grid.Column="0">
                    <TextBlock Classes="H2" Text="Walk-Forward Optimizer" />
                    <TextBlock Text="Splits data into IS/OOS folds · sweeps all parameter combinations · ranks by OOS WF Score"
                               Foreground="#4A6880" FontSize="11" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Classes="Overline" Text="Folds" />
                    <NumericUpDown Value="{Binding BacktestVM.WfFolds}"
                                   Increment="1" Minimum="2" Maximum="10" Width="70" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Classes="Overline" Text="In-Sample %" />
                    <NumericUpDown Value="{Binding BacktestVM.WfInSamplePct}"
                                   Increment="5" Minimum="40" Maximum="90" Width="80" />
                  </StackPanel>
                  <StackPanel Grid.Column="3" Spacing="4" VerticalAlignment="Bottom">
                    <Button Command="{Binding BacktestVM.OptimizeCommand}"
                            IsEnabled="{Binding BacktestVM.CanOptimize}"
                            Classes="AccentButton">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="⚙" />
                        <TextBlock Text="Optimize" />
                      </StackPanel>
                    </Button>
                  </StackPanel>
                </Grid>

                <!-- Best params label -->
                <Border Background="#091520" CornerRadius="4" Padding="10,6"
                        IsVisible="{Binding BacktestVM.BestParamsLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                  <TextBlock Text="{Binding BacktestVM.BestParamsLabel}"
                             Foreground="#F4B860" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                </Border>

                <!-- Results table -->
                <StackPanel IsVisible="{Binding BacktestVM.OptimizerRows.Count, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Spacing="6">

                  <!-- Column headers -->
                  <Grid ColumnDefinitions="180,70,80,70,80,70,70,70,60,Auto" ColumnSpacing="6">
                    <TextBlock Grid.Column="0" Classes="Overline" Text="Params" />
                    <TextBlock Grid.Column="1" Classes="Overline" Text="IS Sharpe" />
                    <TextBlock Grid.Column="2" Classes="Overline" Text="IS Return" />
                    <TextBlock Grid.Column="3" Classes="Overline" Text="OOS Sharpe" />
                    <TextBlock Grid.Column="4" Classes="Overline" Text="OOS Return" />
                    <TextBlock Grid.Column="5" Classes="Overline" Text="OOS DD" />
                    <TextBlock Grid.Column="6" Classes="Overline" Text="Efficiency" />
                    <TextBlock Grid.Column="7" Classes="Overline" Text="WF Score" />
                    <TextBlock Grid.Column="8" Classes="Overline" Text="Times #1" />
                    <TextBlock Grid.Column="9" Classes="Overline" Text="" />
                  </Grid>
                  <Border Height="1" Background="#0E2030" />

                  <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding BacktestVM.OptimizerRows}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:WfResultRowVM">
                          <Border Padding="0,3" BorderBrush="#1A3A50" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="180,70,80,70,80,70,70,70,60,Auto" ColumnSpacing="6">
                              <TextBlock Grid.Column="0" Text="{Binding Params}"
                                         Foreground="{Binding NameColor}" FontSize="11" VerticalAlignment="Center"
                                         TextTrimming="CharacterEllipsis" />
                              <TextBlock Grid.Column="1" Text="{Binding IsSharpe}"
                                         Foreground="#8FA3B8" FontSize="11" VerticalAlignment="Center" />
                              <TextBlock Grid.Column="2" Text="{Binding IsReturn}"
                                         Foreground="#8FA3B8" FontSize="11" VerticalAlignment="Center" />
                              <TextBlock Grid.Column="3" Text="{Binding OosSharpe}"
                                         Foreground="{Binding EffColor}" FontSize="11" VerticalAlignment="Center" />
                              <TextBlock Grid.Column="4" Text="{Binding OosReturn}"
                                         Foreground="{Binding ReturnColor}" FontWeight="SemiBold"
                                         FontSize="11" VerticalAlignment="Center" />
                              <TextBlock Grid.Column="5" Text="{Binding OosMaxDD}"
                                         Foreground="#FF8A4C" FontSize="11" VerticalAlignment="Center" />
                              <TextBlock Grid.Column="6" Text="{Binding Efficiency}"
                                         Foreground="{Binding EffColor}" FontSize="11" VerticalAlignment="Center" />
                              <TextBlock Grid.Column="7" Text="{Binding WfScore}"
                                         Foreground="{Binding ScoreColor}" FontWeight="SemiBold"
                                         FontSize="11" VerticalAlignment="Center" />
                              <TextBlock Grid.Column="8" Text="{Binding TimesLabel}"
                                         Foreground="#21E6C1" FontSize="11" VerticalAlignment="Center" />
                              <Button Grid.Column="9"
                                      Command="{Binding $parent[ItemsControl].((vm:BacktestViewModel)DataContext).ApplyCommand}"
                                      CommandParameter="{Binding}"
                                      Content="Apply" FontSize="10" Padding="6,2"
                                      Classes="SecondaryButton" VerticalAlignment="Center" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- ── Monte Carlo Simulator ── -->
            <Border Classes="Panel">
              <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                  <StackPanel Grid.Column="0">
                    <TextBlock Classes="H2" Text="Monte Carlo Simulator" />
                    <TextBlock Text="Runs the selected strategy N times on random candle subsets · reports mean, median, σ, and a 90% confidence interval"
                               Foreground="#4A6880" FontSize="11" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Classes="Overline" Text="Runs" />
                    <NumericUpDown Value="{Binding BacktestVM.MonteCarloRuns}"
                                   Increment="10" Minimum="10" Maximum="5000" Width="90" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Classes="Overline" Text="Subsample %" />
                    <NumericUpDown Value="{Binding BacktestVM.MonteCarloSubsamplePercent}"
                                   Increment="5" Minimum="10" Maximum="100" Width="90" />
                  </StackPanel>
                  <StackPanel Grid.Column="3" Spacing="4" VerticalAlignment="Bottom">
                    <Button Command="{Binding BacktestVM.MonteCarloCommand}"
                            IsEnabled="{Binding BacktestVM.CanMonteCarlo}"
                            Classes="AccentButton">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="🎲" />
                        <TextBlock Text="Run Monte Carlo" />
                      </StackPanel>
                    </Button>
                  </StackPanel>
                </Grid>

                <Border Background="#091520" CornerRadius="4" Padding="10,8">
                  <TextBlock Text="{Binding BacktestVM.MonteCarloSummary}"
                             Foreground="#D7E3EE" FontSize="12" TextWrapping="Wrap"
                             FontFamily="Consolas,Menlo,monospace" />
                </Border>

                <!-- ── Export ── -->
                <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10">
                  <Button Grid.Column="0"
                          Command="{Binding BacktestVM.ExportCsvCommand}"
                          Classes="SecondaryButton">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="💾" />
                      <TextBlock Text="Export CSV" />
                    </StackPanel>
                  </Button>
                  <Button Grid.Column="1"
                          Command="{Binding BacktestVM.ExportReportCommand}"
                          Classes="SecondaryButton">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="📄" />
                      <TextBlock Text="Export Report" />
                    </StackPanel>
                  </Button>
                  <TextBlock Grid.Column="2"
                             Text="{Binding BacktestVM.ExportStatus}"
                             Foreground="#8FA3B8" FontSize="11"
                             VerticalAlignment="Center" TextWrapping="Wrap" />
                </Grid>
              </StackPanel>
            </Border>

            <!-- ── AI Backtest Review (#2) ── -->
            <Border Classes="Panel">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <StackPanel Grid.Column="0">
                    <TextBlock Classes="H2" Text="🧠 AI Review" />
                    <TextBlock Text="Robust or overfit? An AI read of this backtest."
                               Foreground="#4A6880" FontSize="11" />
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="{Binding BacktestVM.AiReviewSource}"
                             Foreground="#5C6E82" FontSize="10" VerticalAlignment="Center" Margin="0,0,10,0" />
                  <Button Grid.Column="2" Content="Review with AI"
                          Command="{Binding BacktestVM.ReviewWithAiCommand}"
                          IsEnabled="{Binding !BacktestVM.AiReviewRunning}" />
                </Grid>
                <StackPanel Spacing="8" IsVisible="{Binding BacktestVM.HasAiReview}">
                  <Border CornerRadius="6" Padding="10,7" Background="#04101A">
                    <StackPanel Spacing="4">
                      <TextBlock Text="{Binding BacktestVM.AiReviewVerdict}"
                                 Foreground="{Binding BacktestVM.AiVerdictBrush}"
                                 FontWeight="Bold" FontSize="14" />
                      <TextBlock Text="{Binding BacktestVM.AiReviewSummary}"
                                 Foreground="#D7E3EE" FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                  <TextBlock Text="{Binding BacktestVM.AiReviewRisks}"
                             Foreground="#F4B860" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- ── Strategy Comparison (all types, same candles) ── -->
            <Border Classes="Panel"
                    IsVisible="{Binding BacktestVM.ComparisonRows.Count, Converter={x:Static ObjectConverters.IsNotNull}}">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0">
                    <TextBlock Classes="H2" Text="Strategy Comparison" />
                    <TextBlock Text="MA · RSI · BB · Breakout presets on the same dataset. Sorted by net return."
                               Foreground="#4A6880" FontSize="11" />
                  </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="180,55,70,90,70,70,90" ColumnSpacing="8">
                  <TextBlock Grid.Column="0" Classes="Overline" Text="Strategy" />
                  <TextBlock Grid.Column="1" Classes="Overline" Text="Trades" />
                  <TextBlock Grid.Column="2" Classes="Overline" Text="Win Rate" />
                  <TextBlock Grid.Column="3" Classes="Overline" Text="Net Return" />
                  <TextBlock Grid.Column="4" Classes="Overline" Text="Max DD" />
                  <TextBlock Grid.Column="5" Classes="Overline" Text="Sharpe" />
                  <TextBlock Grid.Column="6" Classes="Overline" Text="Best Trade" />
                </Grid>
                <Border Height="1" Background="#0E2030" />

                <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                  <ListBox ItemsSource="{Binding BacktestVM.ComparisonRows}"
                           Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:StrategyComparisonRow">
                        <Grid ColumnDefinitions="180,55,70,90,70,70,90" ColumnSpacing="8" Margin="0,3">
                          <TextBlock Grid.Column="0" Text="{Binding Name}"
                                     Foreground="{Binding NameColor}" FontSize="12" VerticalAlignment="Center"
                                     TextTrimming="CharacterEllipsis" />
                          <TextBlock Grid.Column="1" Text="{Binding TradeCount}"
                                     Foreground="#8FA3B8" FontSize="12" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="2" Text="{Binding WinRate}"
                                     Foreground="#8FA3B8" FontSize="12" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="3" Text="{Binding NetReturn}"
                                     Foreground="{Binding ReturnColor}" FontWeight="SemiBold"
                                     FontSize="12" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="4" Text="{Binding MaxDD}"
                                     Foreground="#FF8A4C" FontSize="12" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="5" Text="{Binding Sharpe}"
                                     Foreground="#8FA3B8" FontSize="12" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="6" Text="{Binding BestTrade}"
                                     Foreground="#3DDC84" FontSize="12" VerticalAlignment="Center" />
                        </Grid>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </ScrollViewer>
              </StackPanel>
            </Border>

            <!-- ── Trade History ── -->
            <Border Classes="Panel">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Classes="H2" Text="Trades" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding BacktestVM.TradeCountLabel, StringFormat='Total: {0}'}"
                             Foreground="#4A6880" VerticalAlignment="Center" />
                </Grid>
                <Grid ColumnDefinitions="110,80,80,110,60,50" ColumnSpacing="8">
                  <TextBlock Grid.Column="0" Classes="Overline" Text="Opened" />
                  <TextBlock Grid.Column="1" Classes="Overline" Text="Entry" />
                  <TextBlock Grid.Column="2" Classes="Overline" Text="Exit" />
                  <TextBlock Grid.Column="3" Classes="Overline" Text="Closed" />
                  <TextBlock Grid.Column="4" Classes="Overline" Text="Duration" />
                  <TextBlock Grid.Column="5" Classes="Overline" Text="P&amp;L" />
                </Grid>
                <Border Height="1" Background="#0E2030" />
                <ListBox ItemsSource="{Binding BacktestVM.TradeRows}"
                         MaxHeight="280" Background="Transparent">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:BacktestTradeRow">
                      <Grid ColumnDefinitions="110,80,80,110,60,50" ColumnSpacing="8" Margin="0,2">
                        <TextBlock Grid.Column="0" Text="{Binding OpenTime}"
                                   Foreground="#8FA3B8" FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding EntryPrice}"
                                   FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding ExitPrice}"
                                   FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="{Binding CloseTime}"
                                   Foreground="#8FA3B8" FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="4" Text="{Binding Duration}"
                                   Foreground="#4A6880" FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="5" Text="{Binding ReturnLabel}"
                                   Foreground="{Binding ReturnColor}"
                                   FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" />
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </Border>

          </StackPanel>

          <StackPanel Spacing="16" IsVisible="{Binding IsBotsSectionVisible}">

            <!-- ── Daily AI Briefing (morning read: book + news + sentiment + scanner) ── -->
            <Border Classes="Panel">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Classes="H2" Text="🗞️ Daily AI Briefing" />
                  </StackPanel>
                  <Border Grid.Column="1" CornerRadius="6" Padding="10,4" VerticalAlignment="Center" Margin="0,0,10,0"
                          Background="#04101A" IsVisible="{Binding BriefingVM.HasSignal}">
                    <TextBlock Text="{Binding BriefingVM.SignalLabel}"
                               Foreground="{Binding BriefingVM.SignalBrush}"
                               FontWeight="SemiBold" FontSize="12" />
                  </Border>
                  <Button Grid.Column="2" Content="↻ Generate" Command="{Binding BriefingVM.RefreshCommand}"
                          IsEnabled="{Binding !BriefingVM.Running}" VerticalAlignment="Center" />
                </Grid>

                <TextBlock Text="{Binding BriefingVM.Summary}" Foreground="#E8F0FE" FontSize="13"
                           TextWrapping="Wrap" />

                <ItemsControl ItemsSource="{Binding BriefingVM.Bullets}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                        <TextBlock Text="•" Foreground="#21E6C1" />
                        <TextBlock Text="{Binding}" Foreground="#A8B6C6" FontSize="12" TextWrapping="Wrap" />
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Orientation="Horizontal" Spacing="10">
                  <TextBlock Text="{Binding BriefingVM.Source}" Foreground="#4D5F70" FontSize="10" />
                  <TextBlock Text="{Binding BriefingVM.GeneratedAt, StringFormat='· {0}'}"
                             Foreground="#4D5F70" FontSize="10" />
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- ── AI Risk Check (holistic pre-trade assessment) ── -->
            <Border Classes="Panel">
              <StackPanel Spacing="10">
                <StackPanel Spacing="2">
                  <TextBlock Classes="H2" Text="🛡️ AI Risk Check" />
                </StackPanel>

                <!-- Order form -->
                <Grid ColumnDefinitions="2*,*,*,*,Auto" ColumnSpacing="10">
                  <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Classes="Overline" Text="Symbol" />
                    <TextBox Text="{Binding RiskCheckVM.Symbol}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Classes="Overline" Text="Side" />
                    <ComboBox ItemsSource="{Binding RiskCheckVM.AvailableSides}"
                              SelectedItem="{Binding RiskCheckVM.Side}" HorizontalAlignment="Stretch" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Classes="Overline" Text="Order $" />
                    <NumericUpDown Value="{Binding RiskCheckVM.OrderUsd}" Minimum="0" Increment="10" FormatString="N0" />
                  </StackPanel>
                  <StackPanel Grid.Column="3" Spacing="4">
                    <TextBlock Classes="Overline" Text="Leverage" />
                    <NumericUpDown Value="{Binding RiskCheckVM.Leverage}" Minimum="1" Maximum="125" Increment="1" FormatString="N0" />
                  </StackPanel>
                  <Button Grid.Column="4" Content="Check" VerticalAlignment="Bottom"
                          Command="{Binding RiskCheckVM.CheckCommand}"
                          IsEnabled="{Binding !RiskCheckVM.Running}" />
                </Grid>

                <!-- Verdict -->
                <StackPanel Orientation="Horizontal" Spacing="12" IsVisible="{Binding RiskCheckVM.HasVerdict}">
                  <Border CornerRadius="6" Padding="12,5" Background="#04101A" VerticalAlignment="Center">
                    <TextBlock Text="{Binding RiskCheckVM.Verdict}"
                               Foreground="{Binding RiskCheckVM.VerdictBrush}"
                               FontWeight="Bold" FontSize="14" />
                  </Border>
                  <TextBlock Text="{Binding RiskCheckVM.ScoreLabel, StringFormat='Risk {0}'}"
                             Foreground="#8FA3B8" FontSize="13" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Text="{Binding RiskCheckVM.Rationale}" Foreground="#E8F0FE" FontSize="13"
                           TextWrapping="Wrap" />

                <ItemsControl ItemsSource="{Binding RiskCheckVM.Reasons}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                        <TextBlock Text="•" Foreground="#F4B860" />
                        <TextBlock Text="{Binding}" Foreground="#A8B6C6" FontSize="12" TextWrapping="Wrap" />
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{Binding RiskCheckVM.Source}" Foreground="#4D5F70" FontSize="10"
                           IsVisible="{Binding RiskCheckVM.HasVerdict}" />
              </StackPanel>
            </Border>

            <!-- ── AI Correlation Insight (diversification posture across the book) ── -->
            <Border Classes="Panel">
              <StackPanel Spacing="10">
                <StackPanel Spacing="2">
                  <TextBlock Classes="H2" Text="🔗 AI Correlation Insight" />
                </StackPanel>

                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                  <TextBox Grid.Column="0" Text="{Binding CorrelationInsightVM.Symbols}"
                           PlaceholderText="BTCUSDT, ETHUSDT, SOLUSDT…" />
                  <Border Grid.Column="1" CornerRadius="6" Padding="10,4" VerticalAlignment="Center"
                          Background="#04101A" IsVisible="{Binding CorrelationInsightVM.HasSignal}">
                    <TextBlock Text="{Binding CorrelationInsightVM.SignalLabel}"
                               Foreground="{Binding CorrelationInsightVM.SignalBrush}"
                               FontWeight="SemiBold" FontSize="12" />
                  </Border>
                  <Button Grid.Column="2" Content="Analyze" Command="{Binding CorrelationInsightVM.AnalyzeCommand}"
                          IsEnabled="{Binding !CorrelationInsightVM.Running}" />
                </Grid>

                <TextBlock Text="{Binding CorrelationInsightVM.Summary}" Foreground="#E8F0FE" FontSize="13"
                           TextWrapping="Wrap" />

                <ItemsControl ItemsSource="{Binding CorrelationInsightVM.Bullets}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                        <TextBlock Text="•" Foreground="#21E6C1" />
                        <TextBlock Text="{Binding}" Foreground="#A8B6C6" FontSize="12" TextWrapping="Wrap" />
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{Binding CorrelationInsightVM.Source}" Foreground="#4D5F70" FontSize="10"
                           IsVisible="{Binding CorrelationInsightVM.HasSignal}" />
              </StackPanel>
            </Border>

            <!-- ── AI Options Advisor (strategy from Deribit IV/skew/PCR + view) ── -->
            <Border Classes="Panel">
              <StackPanel Spacing="10">
                <StackPanel Spacing="2">
                  <TextBlock Classes="H2" Text="📐 AI Options Advisor" />
                </StackPanel>

                <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="10">
                  <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Classes="Overline" Text="Asset" />
                    <ComboBox ItemsSource="{Binding OptionsStrategyVM.AvailableAssets}"
                              SelectedItem="{Binding OptionsStrategyVM.Asset}" HorizontalAlignment="Stretch" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Classes="Overline" Text="View" />
                    <ComboBox ItemsSource="{Binding OptionsStrategyVM.AvailableDirections}"
                              SelectedItem="{Binding OptionsStrategyVM.Direction}" HorizontalAlignment="Stretch" />
                  </StackPanel>
                  <Button Grid.Column="2" Content="Suggest" VerticalAlignment="Bottom"
                          Command="{Binding OptionsStrategyVM.SuggestCommand}"
                          IsEnabled="{Binding !OptionsStrategyVM.Running}" />
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="12" IsVisible="{Binding OptionsStrategyVM.HasResult}">
                  <Border CornerRadius="6" Padding="12,5" Background="#04101A" VerticalAlignment="Center">
                    <TextBlock Text="{Binding OptionsStrategyVM.Strategy}" Foreground="#E8F0FE"
                               FontWeight="Bold" FontSize="14" />
                  </Border>
                  <TextBlock Text="{Binding OptionsStrategyVM.IvRegime, StringFormat='{}{0} IV'}"
                             Foreground="{Binding OptionsStrategyVM.IvRegimeBrush}"
                             FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Text="{Binding OptionsStrategyVM.Rationale}" Foreground="#E8F0FE" FontSize="13"
                           TextWrapping="Wrap" />

                <ItemsControl ItemsSource="{Binding OptionsStrategyVM.Considerations}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                        <TextBlock Text="•" Foreground="#21E6C1" />
                        <TextBlock Text="{Binding}" Foreground="#A8B6C6" FontSize="12" TextWrapping="Wrap" />
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{Binding OptionsStrategyVM.Source}" Foreground="#4D5F70" FontSize="10"
                           IsVisible="{Binding OptionsStrategyVM.HasResult}" />
              </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,260" ColumnSpacing="16">

              <!-- ── Left: Rule Bot Controls ── -->
              <Border Grid.Column="0" Classes="Panel">
                <StackPanel Spacing="12">
                  <TextBlock Classes="H2" Text="Rule Bot Controls" />
                  <TextBlock Text="{Binding BotsRuntimeStatusLabel}" Foreground="{Binding BotsRuntimeStatusBrush}" />

                  <!-- Row 1: Symbol · Quantity · Exchange · Risk Cap -->
                  <Grid ColumnDefinitions="2*,*,*,*" ColumnSpacing="10">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Classes="Overline" Text="Symbol" />
                      <TextBox Text="{Binding AIBotVM.Symbol}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                      <TextBlock Classes="Overline" Text="Quantity" />
                      <NumericUpDown Value="{Binding AIBotVM.Quantity}"
                                     Increment="0.001" Minimum="0.001" FormatString="N4" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Classes="Overline" Text="Exchange" />
                      <ComboBox ItemsSource="{Binding AIBotVM.AvailableExchanges}"
                                SelectedItem="{Binding AIBotVM.SelectedExchange}"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Spacing="4">
                      <TextBlock Classes="Overline" Text="Risk Cap $" />
                      <NumericUpDown Value="{Binding AIBotVM.MaxRiskPerTrade}"
                                     Increment="10" Minimum="10" FormatString="N0" />
                    </StackPanel>
                  </Grid>

                  <!-- Row 2: Market Mode · Margin · Bias · Leverage (futures only) -->
                  <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Classes="Overline" Text="Market Mode" />
                      <ComboBox ItemsSource="{Binding AIBotVM.AvailableMarketModes}"
                                SelectedItem="{Binding AIBotVM.SelectedMarketMode}"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                      <TextBlock Classes="Overline" Text="Margin" />
                      <ComboBox ItemsSource="{Binding AIBotVM.AvailableFuturesMarginModes}"
                                SelectedItem="{Binding AIBotVM.SelectedFuturesMarginMode}"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Classes="Overline" Text="Bias" />
                      <ComboBox ItemsSource="{Binding AIBotVM.AvailableFuturesBiasModes}"
                                SelectedItem="{Binding AIBotVM.SelectedFuturesBias}"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Spacing="4"
                                IsVisible="{Binding AIBotVM.IsFuturesMode}">
                      <TextBlock Classes="Overline" Text="Leverage ×" />
                      <NumericUpDown Value="{Binding AIBotVM.FuturesLeverage}"
                                     Increment="1" Minimum="1" Maximum="125" />
                    </StackPanel>
                  </Grid>

                  <!-- Row 2b: Strategy selector -->
                  <Grid ColumnDefinitions="Auto,180,*" ColumnSpacing="10">
                    <TextBlock Grid.Column="0" Classes="Overline" Text="Strategy" VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding AIBotVM.AvailableStrategies}"
                              SelectedItem="{Binding AIBotVM.SelectedStrategy}"
                              HorizontalAlignment="Stretch" />
                    <TextBlock Grid.Column="2" Text="{Binding AIBotVM.StrategySummary}"
                               Foreground="#21E6C1" FontSize="11"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                  </Grid>

                  <!-- Row 2c: MA Cross parameters (used when Strategy = MA Cross) -->
                  <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="10">
                    <TextBlock Grid.Column="0" Classes="Overline" Text="Fast MA" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Column="1" Value="{Binding AIBotVM.MaFastPeriod}"
                                   Increment="1" Minimum="2" Maximum="200" />
                    <TextBlock Grid.Column="2" Classes="Overline" Text="Slow MA"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                    <NumericUpDown Grid.Column="3" Value="{Binding AIBotVM.MaSlowPeriod}"
                                   Increment="1" Minimum="3" Maximum="500" />
                  </Grid>

                  <!-- Row 2d: RSI parameters -->
                  <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" Classes="Overline" Text="RSI Period" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Column="1" Value="{Binding AIBotVM.RsiPeriod}"
                                   Increment="1" Minimum="2" Maximum="100" />
                    <TextBlock Grid.Column="2" Classes="Overline" Text="Oversold"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                    <NumericUpDown Grid.Column="3" Value="{Binding AIBotVM.RsiOversold}"
                                   Increment="1" Minimum="1" Maximum="50" />
                    <TextBlock Grid.Column="4" Classes="Overline" Text="Overbought"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                    <NumericUpDown Grid.Column="5" Value="{Binding AIBotVM.RsiOverbought}"
                                   Increment="1" Minimum="50" Maximum="99" />
                  </Grid>

                  <!-- Row 2e: Bollinger parameters -->
                  <Grid ColumnDefinitions="Auto,*,Auto,*,Auto" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" Classes="Overline" Text="BB Period" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Column="1" Value="{Binding AIBotVM.BbPeriod}"
                                   Increment="1" Minimum="2" Maximum="200" />
                    <TextBlock Grid.Column="2" Classes="Overline" Text="BB σ"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                    <NumericUpDown Grid.Column="3" Value="{Binding AIBotVM.BbDeviation}"
                                   Increment="0.1" Minimum="0.5" Maximum="5" />
                    <TextBlock Grid.Column="4" Classes="Overline" Text="Breakout Period"
                               VerticalAlignment="Center" Margin="14,0,0,0" />
                  </Grid>

                  <!-- Row 2f: Breakout + MACD parameters -->
                  <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*,Auto,*" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" Classes="Overline" Text="Breakout N" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Column="1" Value="{Binding AIBotVM.BreakoutPeriod}"
                                   Increment="1" Minimum="2" Maximum="200" />
                    <TextBlock Grid.Column="2" Classes="Overline" Text="MACD Fast"
                               VerticalAlignment="Center" Margin="14,0,0,0" />
                    <NumericUpDown Grid.Column="3" Value="{Binding AIBotVM.MacdFast}"
                                   Increment="1" Minimum="2" Maximum="100" />
                    <TextBlock Grid.Column="4" Classes="Overline" Text="MACD Slow"
                               VerticalAlignment="Center" Margin="6,0,0,0" />
                    <NumericUpDown Grid.Column="5" Value="{Binding AIBotVM.MacdSlow}"
                                   Increment="1" Minimum="3" Maximum="200" />
                    <TextBlock Grid.Column="6" Classes="Overline" Text="MACD Sig"
                               VerticalAlignment="Center" Margin="6,0,0,0" />
                    <NumericUpDown Grid.Column="7" Value="{Binding AIBotVM.MacdSignal}"
                                   Increment="1" Minimum="2" Maximum="50" />
                  </Grid>

                  <!-- Row 2f-vwap: VWAP parameters -->
                  <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" Classes="Overline" Text="VWAP Band %"
                               VerticalAlignment="Center" />
                    <NumericUpDown Grid.Column="1" Value="{Binding AIBotVM.VwapBandPct}"
                                   Increment="0.01" Minimum="0" Maximum="5" />
                  </Grid>

                  <!-- Row 2g: Claude (AI) parameters -->
                  <Grid ColumnDefinitions="Auto,*,Auto,200,Auto,130" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" Classes="Overline" Text="Claude Key" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" PasswordChar="•"
                             PlaceholderText="sk-ant-…"
                             Text="{Binding AIBotVM.ClaudeApiKey}"
                             UseFloatingPlaceholder="False" />
                    <TextBlock Grid.Column="2" Classes="Overline" Text="Model"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                    <TextBox Grid.Column="3" Text="{Binding AIBotVM.ClaudeModel}" />
                    <TextBlock Grid.Column="4" Classes="Overline" Text="Poll sec"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                    <NumericUpDown Grid.Column="5" Value="{Binding AIBotVM.ClaudePollSeconds}"
                                   Increment="15" Minimum="15" Maximum="3600" />
                  </Grid>

                  <!-- Row 3: Buttons + mode summary -->
                  <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10">
                    <Button Grid.Column="0" Classes="GhostButton" Content="▶ Start Bot"
                            Command="{Binding AIBotVM.StartBotCommand}" />
                    <Button Grid.Column="1" Classes="GhostButton" Content="■ Stop Bot"
                            Command="{Binding AIBotVM.StopBotCommand}" />
                    <TextBlock Grid.Column="2" Text="{Binding AIBotVM.BotModeSummary}"
                               Foreground="#1FE6C2" FontSize="11"
                               VerticalAlignment="Center" TextWrapping="Wrap" />
                  </Grid>

                  <!-- Bot Activity Log (monospace terminal) -->
                  <Border Background="#04101A" CornerRadius="4" Padding="10,8" MaxHeight="140">
                    <ScrollViewer x:Name="BotLogScrollViewer" VerticalScrollBarVisibility="Auto">
                      <TextBlock Text="{Binding AIBotVM.BotLog}"
                                 FontFamily="Consolas,Courier New,monospace"
                                 FontSize="11" Foreground="#21E6C1"
                                 TextWrapping="Wrap" />
                    </ScrollViewer>
                  </Border>
                </StackPanel>
              </Border>

              <!-- ── Right: Runtime status card ── -->
              <Border Grid.Column="1" Classes="SurfaceCard" VerticalAlignment="Top">
                <StackPanel Spacing="8">
                  <TextBlock Classes="Overline" Text="Runtime" />
                  <TextBlock Text="{Binding WalletVM.GlobalExecutionSummary}"
                             Foreground="#8FA3B8" TextWrapping="Wrap" FontSize="11" />
                  <TextBlock Text="{Binding FuturesPrivateApiStatusLabel}"
                             Foreground="{Binding FuturesPrivateApiStatusBrush}"
                             TextWrapping="Wrap" FontSize="11" />
                </StackPanel>
              </Border>

            </Grid>

            <!-- TP / SL configuration -->
            <Border Classes="Panel">
              <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                  <TextBlock Classes="H2" Text="Take Profit / Stop Loss" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Text="{Binding AIBotVM.TpSlSummary}" Foreground="#1FE6C2" FontSize="11" VerticalAlignment="Center" />
                  <Button Grid.Column="2" Content="🧠 AI Suggest"
                          Command="{Binding AIBotVM.SuggestTpSlCommand}"
                          IsEnabled="{Binding !AIBotVM.TpSlSuggestRunning}"
                          Foreground="#21E6C1" FontSize="11" />
                </Grid>
                <TextBlock Text="{Binding AIBotVM.TpSlSuggestNote}" Foreground="#6A8FA8" FontSize="11" TextWrapping="Wrap"
                           IsVisible="{Binding AIBotVM.TpSlSuggestNote, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                <!-- TP row -->
                <Grid ColumnDefinitions="Auto,*,Auto,*,*,Auto,*,Auto,Auto" ColumnSpacing="12">
                  <CheckBox Grid.Column="0" IsChecked="{Binding AIBotVM.TpEnabled}" VerticalAlignment="Center" />
                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Classes="Overline" Text="Take Profit %" />
                    <NumericUpDown Value="{Binding AIBotVM.TpPercent}" Increment="0.1" Minimum="0.1" Maximum="100" FormatString="N1" />
                  </StackPanel>

                  <CheckBox Grid.Column="2" IsChecked="{Binding AIBotVM.PartialTp}" VerticalAlignment="Center" Margin="8,0,0,0" />
                  <StackPanel Grid.Column="3" Spacing="4">
                    <TextBlock Classes="Overline" Text="TP1 Close %" />
                    <NumericUpDown Value="{Binding AIBotVM.PartialTpClosePercent}" Increment="5" Minimum="1" Maximum="99" FormatString="N0" IsEnabled="{Binding AIBotVM.PartialTp}" />
                  </StackPanel>
                  <StackPanel Grid.Column="4" Spacing="4" Margin="0,0,0,0">
                    <TextBlock Classes="Overline" Text="TP2 %" />
                    <NumericUpDown Value="{Binding AIBotVM.PartialTp2Percent}" Increment="0.1" Minimum="0.1" Maximum="100" FormatString="N1" IsEnabled="{Binding AIBotVM.PartialTp}" />
                  </StackPanel>

                  <CheckBox Grid.Column="5" IsChecked="{Binding AIBotVM.SlEnabled}" VerticalAlignment="Center" Margin="16,0,0,0" />
                  <StackPanel Grid.Column="6" Spacing="4">
                    <TextBlock Classes="Overline" Text="Stop Loss %" />
                    <NumericUpDown Value="{Binding AIBotVM.SlPercent}" Increment="0.1" Minimum="0.1" Maximum="100" FormatString="N1" />
                  </StackPanel>

                  <CheckBox Grid.Column="7" IsChecked="{Binding AIBotVM.TrailingStop}" VerticalAlignment="Center" Margin="8,0,0,0" />
                  <StackPanel Grid.Column="8" Spacing="4">
                    <TextBlock Classes="Overline" Text="Trailing SL" />
                    <TextBlock Text="{Binding AIBotVM.TrailingStop, StringFormat={}{0}}" Foreground="#8FA3B8" FontSize="11" VerticalAlignment="Center" />
                  </StackPanel>
                </Grid>

                <TextBlock Text="Futures: TP/SL placed as exchange orders (TakeProfitMarket / StopMarket) with ReduceOnly. Trailing SL replaces SL order on each new peak. Spot: monitored in-process." Foreground="#4A6070" FontSize="11" TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <!-- ═══════════════ GRID TRADING BOT ═══════════════ -->
            <Border Classes="Panel">
              <StackPanel Spacing="14">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                  <TextBlock Classes="H2" Text="Grid Trading Bot" VerticalAlignment="Center" />
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Border Background="{Binding GridBotVM.StatusColor}" CornerRadius="4" Padding="8,3">
                      <TextBlock Text="{Binding GridBotVM.StatusLabel}" FontSize="11" FontWeight="SemiBold" Foreground="#0A1628" />
                    </Border>
                  </StackPanel>
                </Grid>

                <!-- ── AI grid parameters (#8) ── -->
                <Border Background="#04101A" CornerRadius="6" Padding="10,8">
                  <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                      <TextBlock Grid.Column="0" Text="🧠 Let AI suggest grid bounds &amp; levels"
                                 Foreground="#8FA3B8" FontSize="12" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1" Text="{Binding GridBotVM.AiParamsSource}"
                                 Foreground="#5C6E82" FontSize="10" VerticalAlignment="Center" Margin="0,0,10,0" />
                      <Button Grid.Column="2" Content="AI Suggest"
                              Command="{Binding GridBotVM.SuggestParamsCommand}"
                              IsEnabled="{Binding !GridBotVM.AiParamsRunning}" Foreground="#21E6C1" />
                    </Grid>
                    <TextBlock Text="{Binding GridBotVM.AiParamsRationale}"
                               Foreground="#6A8FA8" FontSize="11" TextWrapping="Wrap"
                               IsVisible="{Binding GridBotVM.AiParamsRationale, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                  </StackPanel>
                </Border>

                <!-- Row 1: Symbol · Lower Price · Upper Price · Grid Levels · Qty/Grid -->
                <Grid ColumnDefinitions="2*,*,*,*,*" ColumnSpacing="12">
                  <StackPanel Grid.Column="0" Spacing="5">
                    <TextBlock Classes="Overline" Text="Symbol" />
                    <TextBox Text="{Binding GridBotVM.Symbol}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="5">
                    <TextBlock Classes="Overline" Text="Lower Price" />
                    <NumericUpDown Value="{Binding GridBotVM.LowerPrice}" Increment="100" Minimum="0" FormatString="N2" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="5">
                    <TextBlock Classes="Overline" Text="Upper Price" />
                    <NumericUpDown Value="{Binding GridBotVM.UpperPrice}" Increment="100" Minimum="0" FormatString="N2" />
                  </StackPanel>
                  <StackPanel Grid.Column="3" Spacing="5">
                    <TextBlock Classes="Overline" Text="Grid Levels" />
                    <NumericUpDown Value="{Binding GridBotVM.GridLevels}" Increment="1" Minimum="2" Maximum="100" />
                  </StackPanel>
                  <StackPanel Grid.Column="4" Spacing="5">
                    <TextBlock Classes="Overline" Text="Qty / Grid" />
                    <NumericUpDown Value="{Binding GridBotVM.QuantityPerGrid}" Increment="0.001" Minimum="0.0001" FormatString="N4" />
                  </StackPanel>
                </Grid>

                <!-- Row 2: Market Mode · Margin · Leverage (futures only) -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                  <StackPanel Grid.Column="0" Spacing="5">
                    <TextBlock Classes="Overline" Text="Market Mode" />
                    <ComboBox ItemsSource="{Binding GridBotVM.AvailableMarketModes}"
                              SelectedItem="{Binding GridBotVM.SelectedMarketMode}"
                              HorizontalAlignment="Stretch" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="5" IsVisible="{Binding GridBotVM.IsFuturesMode}">
                    <TextBlock Classes="Overline" Text="Margin" />
                    <ComboBox ItemsSource="{Binding GridBotVM.AvailableMarginModes}"
                              SelectedItem="{Binding GridBotVM.SelectedMarginMode}"
                              HorizontalAlignment="Stretch" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="5" IsVisible="{Binding GridBotVM.IsFuturesMode}">
                    <TextBlock Classes="Overline" Text="Leverage" />
                    <NumericUpDown Value="{Binding GridBotVM.Leverage}" Increment="1" Minimum="1" Maximum="25" />
                  </StackPanel>
                </Grid>

                <!-- Grid preview info -->
                <TextBlock Text="{Binding GridBotVM.GridSummary}" Foreground="#8FA3B8" FontSize="12" />

                <!-- Controls -->
                <WrapPanel Orientation="Horizontal">
                  <Button Content="Start Grid"
                          Classes="AccentButton"
                          Margin="0,0,10,0"
                          IsEnabled="{Binding GridBotVM.CanStart}"
                          Command="{Binding GridBotVM.StartCommand}" />
                  <Button Content="Pause"
                          Classes="GhostButton"
                          Margin="0,0,10,0"
                          IsEnabled="{Binding GridBotVM.CanPause}"
                          Command="{Binding GridBotVM.PauseCommand}" />
                  <Button Content="Resume"
                          Classes="GhostButton"
                          Margin="0,0,10,0"
                          IsEnabled="{Binding GridBotVM.CanResume}"
                          Command="{Binding GridBotVM.ResumeCommand}" />
                  <Button Content="Stop Grid"
                          Classes="GhostButton"
                          IsEnabled="{Binding GridBotVM.CanStop}"
                          Command="{Binding GridBotVM.StopCommand}" />
                </WrapPanel>

                <!-- Stats row -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                  <Border Grid.Column="0" Classes="SurfaceCard">
                    <StackPanel Spacing="4">
                      <TextBlock Classes="Overline" Text="Cycles Completed" />
                      <TextBlock Classes="Metric" Text="{Binding GridBotVM.CyclesCompleted}" />
                    </StackPanel>
                  </Border>
                  <Border Grid.Column="1" Classes="SurfaceCard">
                    <StackPanel Spacing="4">
                      <TextBlock Classes="Overline" Text="Grid P&amp;L" />
                      <TextBlock Classes="Metric"
                                 Text="{Binding GridBotVM.GridPnLLabel}"
                                 Foreground="{Binding GridBotVM.GridPnLColor}" />
                    </StackPanel>
                  </Border>
                  <Border Grid.Column="2" Classes="SurfaceCard">
                    <StackPanel Spacing="4">
                      <TextBlock Classes="Overline" Text="Grid Spacing" />
                      <TextBlock Classes="Metric" Text="{Binding GridBotVM.GridSpacing, StringFormat={}{0:N2}}" />
                    </StackPanel>
                  </Border>
                </Grid>

                <!-- Log -->
                <Border Background="#04101A" CornerRadius="6" Padding="10,8" MaxHeight="120">
                  <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding GridBotVM.BotLog}"
                               Foreground="#6A8FA8" FontFamily="Courier New" FontSize="11"
                               TextWrapping="Wrap" />
                  </ScrollViewer>
                </Border>
              </StackPanel>
            </Border>

            <!-- ═══════════════ DCA BOT ═══════════════ -->
            <Border Classes="Panel">
              <StackPanel Spacing="14">

                <!-- Header + status -->
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                  <TextBlock Classes="H2" Text="DCA Bot" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Text="{Binding DcaBotVM.CountdownLabel}"
                             Foreground="#F4B860" FontSize="12" VerticalAlignment="Center"
                             IsVisible="{Binding DcaBotVM.IsRunning}" />
                  <TextBlock Grid.Column="2" Text="{Binding DcaBotVM.NextExecutionLabel}"
                             Foreground="#8FA3B8" FontSize="11" VerticalAlignment="Center"
                             IsVisible="{Binding DcaBotVM.IsRunning}" />
                </Grid>

                <!-- Schedule row: Interval · Period · Budget · Checkbox -->
                <Grid ColumnDefinitions="*,*,*,2*" ColumnSpacing="12">
                  <StackPanel Grid.Column="0" Spacing="5">
                    <TextBlock Classes="Overline" Text="Interval" />
                    <NumericUpDown Value="{Binding DcaBotVM.IntervalValue}" Increment="1" Minimum="1" Maximum="999" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="5">
                    <TextBlock Classes="Overline" Text="Period" />
                    <ComboBox ItemsSource="{Binding DcaBotVM.IntervalTypes}"
                              SelectedItem="{Binding DcaBotVM.SelectedIntervalType}"
                              HorizontalAlignment="Stretch" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="5">
                    <TextBlock Classes="Overline" Text="Budget USDT" />
                    <NumericUpDown Value="{Binding DcaBotVM.TotalBudget}" Increment="10" Minimum="1" FormatString="N0" />
                  </StackPanel>
                  <StackPanel Grid.Column="3" Spacing="5" VerticalAlignment="Bottom" Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <CheckBox IsChecked="{Binding DcaBotVM.ExecuteImmediately}" VerticalAlignment="Center" />
                      <TextBlock Text="Run immediately on start" Foreground="#8FA3B8" FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                  </StackPanel>
                </Grid>

                <!-- Exchange selector -->
                <Grid ColumnDefinitions="Auto,200,*" ColumnSpacing="10">
                  <TextBlock Grid.Column="0" Classes="Overline" Text="Exchange"
                             VerticalAlignment="Center" />
                  <ComboBox Grid.Column="1"
                            ItemsSource="{Binding DcaBotVM.AvailableExchanges}"
                            SelectedItem="{Binding DcaBotVM.SelectedExchange}"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{Binding !DcaBotVM.IsRunning}" />
                  <TextBlock Grid.Column="2" Text="Spot-only: by design DCA does not trade futures."
                             Foreground="#6A8FA8" FontSize="11" VerticalAlignment="Center" />
                </Grid>

                <!-- Coin list header -->
                <Grid ColumnDefinitions="2*,120,40,120,*,32" ColumnSpacing="10">
                  <TextBlock Grid.Column="0" Classes="Overline" Text="Symbol" />
                  <TextBlock Grid.Column="1" Classes="Overline" Text="Weight %" />
                  <TextBlock Grid.Column="2" Classes="Overline" Text="MA" />
                  <TextBlock Grid.Column="3" Classes="Overline" Text="MA Days" />
                  <TextBlock Grid.Column="4" Classes="Overline" Text="Avg Price / Held" />
                  <TextBlock Grid.Column="5" Classes="Overline" Text="" />
                </Grid>

                <!-- Coin list -->
                <ItemsControl ItemsSource="{Binding DcaBotVM.Coins}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DcaCoinRowViewModel">
                      <Grid ColumnDefinitions="2*,120,40,120,*,32" ColumnSpacing="10" Margin="0,3">
                        <TextBox Grid.Column="0" Text="{Binding Symbol}" />
                        <NumericUpDown Grid.Column="1" Value="{Binding WeightPercent}" Increment="5" Minimum="1" Maximum="100" />
                        <CheckBox Grid.Column="2" IsChecked="{Binding ConditionalBuy}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        <NumericUpDown Grid.Column="3" Value="{Binding MaPeriod}" Increment="10" Minimum="10" Maximum="500"
                                       IsEnabled="{Binding ConditionalBuy}" />
                        <TextBlock Grid.Column="4" Text="{Binding StatsLabel}" Foreground="#8FA3B8"
                                   FontSize="12" VerticalAlignment="Center" />
                        <Button Grid.Column="5" Content="✕" FontSize="11" Padding="4,2"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Command="{Binding $parent[Window].DataContext.DcaBotVM.RemoveCoinCommand}"
                                CommandParameter="{Binding Id}" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add coin form -->
                <Grid ColumnDefinitions="2*,120,40,120,Auto,Auto" ColumnSpacing="10">
                  <TextBox Grid.Column="0" Text="{Binding DcaBotVM.NewCoinSymbol}" PlaceholderText="SOLUSDT" />
                  <NumericUpDown Grid.Column="1" Value="{Binding DcaBotVM.NewCoinWeight}" Increment="5" Minimum="1" Maximum="100" />
                  <CheckBox Grid.Column="2" IsChecked="{Binding DcaBotVM.NewCoinConditional}"
                            VerticalAlignment="Center" HorizontalAlignment="Center" />
                  <NumericUpDown Grid.Column="3" Value="{Binding DcaBotVM.NewCoinMaPeriod}" Increment="10" Minimum="10" Maximum="500"
                                 IsEnabled="{Binding DcaBotVM.NewCoinConditional}" />
                  <Button Grid.Column="4" Content="+ Add Coin" Margin="4,0,0,0"
                          Command="{Binding DcaBotVM.AddCoinCommand}" />
                  <TextBlock Grid.Column="5" Text="{Binding DcaBotVM.WeightSumLabel}"
                             Foreground="{Binding DcaBotVM.WeightSumColor}"
                             FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" />
                </Grid>

                <!-- Controls -->
                <WrapPanel Orientation="Horizontal">
                  <Button Content="Start DCA" Classes="AccentButton" Margin="0,0,10,0"
                          IsEnabled="{Binding DcaBotVM.CanStart}"
                          Command="{Binding DcaBotVM.StartCommand}" />
                  <Button Content="Run Now" Classes="GhostButton" Margin="0,0,10,0"
                          IsEnabled="{Binding DcaBotVM.IsRunning}"
                          Command="{Binding DcaBotVM.RunNowCommand}" />
                  <Button Content="Stop DCA" Classes="GhostButton"
                          IsEnabled="{Binding DcaBotVM.CanStop}"
                          Command="{Binding DcaBotVM.StopCommand}" />
                </WrapPanel>

                <!-- Execution history -->
                <TextBlock Classes="Overline" Text="Execution History" Margin="0,6,0,0" />
                <Grid ColumnDefinitions="70,*,90,80,80,70" ColumnSpacing="8">
                  <TextBlock Grid.Column="0" Classes="Overline" Text="Time" />
                  <TextBlock Grid.Column="1" Classes="Overline" Text="Symbol" />
                  <TextBlock Grid.Column="2" Classes="Overline" Text="Price" />
                  <TextBlock Grid.Column="3" Classes="Overline" Text="Qty" />
                  <TextBlock Grid.Column="4" Classes="Overline" Text="Total USDT" />
                  <TextBlock Grid.Column="5" Classes="Overline" Text="Status" />
                </Grid>
                <ListBox ItemsSource="{Binding DcaBotVM.Executions}"
                         MaxHeight="200" Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:DcaExecutionRowViewModel">
                      <Grid ColumnDefinitions="70,*,90,80,80,70" ColumnSpacing="8" Margin="0,2">
                        <TextBlock Grid.Column="0" Text="{Binding TimeLabel}" Foreground="#4A6880" FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding Symbol}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding PriceLabel}" Foreground="#D7E3EE" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="{Binding QtyLabel}" Foreground="#8FA3B8" FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="4" Text="{Binding TotalLabel}" Foreground="#8FA3B8" FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="5" Text="{Binding StatusLabel}" Foreground="{Binding StatusColor}"
                                   FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <!-- Bot log -->
                <Border Background="#04101A" CornerRadius="6" Padding="10,8" MaxHeight="100">
                  <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding DcaBotVM.BotLog}"
                               Foreground="#6A8FA8" FontFamily="Courier New" FontSize="11"
                               TextWrapping="Wrap" />
                  </ScrollViewer>
                </Border>

              </StackPanel>
            </Border>

            <!-- ── Autonomous AI Trader (Claude tool-use agent) ── -->
            <Border Classes="Panel">
              <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Classes="H2" Text="🤖 AI Trader (Autonomous)" />
                    <TextBlock Text="Claude inspects the market and places its own orders via tool use."
                               Foreground="#8FA3B8" FontSize="11" TextWrapping="Wrap" />
                  </StackPanel>
                  <Border Grid.Column="1" CornerRadius="6" Padding="10,4" VerticalAlignment="Center"
                          Background="#04101A">
                    <TextBlock Text="{Binding AiTraderVM.ModeLabel}"
                               Foreground="{Binding AiTraderVM.ModeBrush}"
                               FontWeight="SemiBold" FontSize="12" />
                  </Border>
                </Grid>

                <TextBlock Text="{Binding AiTraderVM.StatusLabel}"
                           Foreground="{Binding AiTraderVM.StatusBrush}" FontSize="12" />

                <!-- Venue · Exchange · Interval · Live toggle -->
                <Grid ColumnDefinitions="*,*,*,Auto" ColumnSpacing="10">
                  <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Classes="Overline" Text="Venue" />
                    <ComboBox ItemsSource="{Binding AiTraderVM.AvailableVenues}"
                              SelectedItem="{Binding AiTraderVM.SelectedVenue}"
                              HorizontalAlignment="Stretch" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="4" IsVisible="{Binding AiTraderVM.IsCexVenue}">
                    <TextBlock Classes="Overline" Text="Exchange" />
                    <ComboBox ItemsSource="{Binding AiTraderVM.AvailableExchanges}"
                              SelectedItem="{Binding AiTraderVM.SelectedExchange}"
                              HorizontalAlignment="Stretch" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="4" IsVisible="{Binding AiTraderVM.IsDexVenue}">
                    <TextBlock Classes="Overline" Text="Network" />
                    <TextBlock Text="Active DEX wallet" Foreground="#8FA3B8" FontSize="12" VerticalAlignment="Center" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Classes="Overline" Text="Interval (sec)" />
                    <NumericUpDown Value="{Binding AiTraderVM.IntervalSeconds}"
                                   Minimum="30" Maximum="3600" Increment="30" FormatString="N0" />
                  </StackPanel>
                  <StackPanel Grid.Column="3" Spacing="4" VerticalAlignment="Bottom">
                    <TextBlock Classes="Overline" Text="Live trading" />
                    <CheckBox IsChecked="{Binding AiTraderVM.LiveEnabled}"
                              Content="Real orders" Foreground="#FF6B6B" />
                  </StackPanel>
                </Grid>

                <!-- CEX: Market mode · Leverage · Margin -->
                <Grid ColumnDefinitions="*,*,*,Auto" ColumnSpacing="10"
                      IsVisible="{Binding AiTraderVM.IsCexVenue}">
                  <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Classes="Overline" Text="Market" />
                    <ComboBox ItemsSource="{Binding AiTraderVM.AvailableMarketModes}"
                              SelectedItem="{Binding AiTraderVM.SelectedMarketMode}"
                              HorizontalAlignment="Stretch" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="4" IsVisible="{Binding AiTraderVM.IsFuturesMode}">
                    <TextBlock Classes="Overline" Text="Leverage" />
                    <NumericUpDown Value="{Binding AiTraderVM.Leverage}" Minimum="1" Maximum="125" Increment="1" FormatString="N0" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="4" IsVisible="{Binding AiTraderVM.IsFuturesMode}">
                    <TextBlock Classes="Overline" Text="Margin" />
                    <ComboBox ItemsSource="{Binding AiTraderVM.AvailableMarginModes}"
                              SelectedItem="{Binding AiTraderVM.SelectedMarginMode}"
                              HorizontalAlignment="Stretch" />
                  </StackPanel>
                  <TextBlock Grid.Column="3" Text="{Binding AiTraderVM.MarketSummary}"
                             Foreground="#1FE6C2" FontSize="11" VerticalAlignment="Bottom" Margin="0,0,0,8" />
                </Grid>

                <!-- DEX: slippage · max native/trade · paper native start -->
                <Grid ColumnDefinitions="*,*,*,Auto" ColumnSpacing="10"
                      IsVisible="{Binding AiTraderVM.IsDexVenue}">
                  <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Classes="Overline" Text="Slippage %" />
                    <NumericUpDown Value="{Binding AiTraderVM.DexSlippagePercent}" Minimum="0.1" Maximum="50" Increment="0.5" FormatString="N1" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Classes="Overline" Text="Max native / trade" />
                    <NumericUpDown Value="{Binding AiTraderVM.MaxNativePerTrade}" Minimum="0.0000001" Increment="0.01" FormatString="N4" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Classes="Overline" Text="Paper native start" />
                    <NumericUpDown Value="{Binding AiTraderVM.VirtualNativeStart}" Minimum="0.0000001" Increment="0.1" FormatString="N4" />
                  </StackPanel>
                  <StackPanel Grid.Column="3" Spacing="4">
                    <TextBlock Classes="Overline" Text="Max positions" />
                    <NumericUpDown Value="{Binding AiTraderVM.MaxOpenPositions}" Minimum="1" Maximum="20" Increment="1" FormatString="N0" Width="90" />
                  </StackPanel>
                </Grid>

                <!-- Hard limits (CEX, USD-denominated) -->
                <TextBlock Classes="Overline" Text="Risk limits (enforced in paper AND live)" Margin="0,4,0,0"
                           IsVisible="{Binding AiTraderVM.IsCexVenue}" />
                <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="10"
                      IsVisible="{Binding AiTraderVM.IsCexVenue}">
                  <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Classes="Overline" Text="Max order $" />
                    <NumericUpDown Value="{Binding AiTraderVM.MaxOrderUsd}" Minimum="1" Increment="10" FormatString="N0" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Classes="Overline" Text="Max exposure $" />
                    <NumericUpDown Value="{Binding AiTraderVM.MaxTotalExposureUsd}" Minimum="1" Increment="50" FormatString="N0" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Classes="Overline" Text="Max positions" />
                    <NumericUpDown Value="{Binding AiTraderVM.MaxOpenPositions}" Minimum="1" Maximum="20" Increment="1" FormatString="N0" />
                  </StackPanel>
                  <StackPanel Grid.Column="3" Spacing="4">
                    <TextBlock Classes="Overline" Text="Max daily loss $" />
                    <NumericUpDown Value="{Binding AiTraderVM.MaxDailyLossUsd}" Minimum="1" Increment="25" FormatString="N0" />
                  </StackPanel>
                  <StackPanel Grid.Column="4" Spacing="4">
                    <TextBlock Classes="Overline" Text="Paper start $" />
                    <NumericUpDown Value="{Binding AiTraderVM.VirtualStartUsd}" Minimum="10" Increment="100" FormatString="N0" />
                  </StackPanel>
                </Grid>

                <!-- Controls -->
                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10">
                  <Button Grid.Column="0" Content="▶ Run once" Command="{Binding AiTraderVM.RunOnceCommand}" />
                  <Button Grid.Column="1" Content="🔁 Start loop" Command="{Binding AiTraderVM.StartLoopCommand}" />
                  <Button Grid.Column="2" Content="■ Stop" Command="{Binding AiTraderVM.StopCommand}" />
                  <Button Grid.Column="3" Content="⛔ Kill" Command="{Binding AiTraderVM.KillCommand}"
                          Foreground="#FF6B6B" />
                </Grid>

                <!-- Agent log -->
                <TextBlock Classes="Overline" Text="Agent activity" Margin="0,4,0,0" />
                <Border Background="#04101A" CornerRadius="6" Padding="10,8" MaxHeight="220">
                  <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding AiTraderVM.AgentLog}"
                               Foreground="#6A8FA8" FontFamily="Courier New" FontSize="11"
                               TextWrapping="Wrap" />
                  </ScrollViewer>
                </Border>
              </StackPanel>
            </Border>

            <!-- ── AI Copilot (read-only conversational assistant) ── -->
            <Border Classes="Panel">
              <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Classes="H2" Text="💬 AI Copilot" />
                    <TextBlock Text="Ask about your balance, positions, P&amp;L, risk or the market. Read-only — it never trades."
                               Foreground="#8FA3B8" FontSize="11" TextWrapping="Wrap" />
                  </StackPanel>
                  <Border Grid.Column="1" CornerRadius="6" Padding="10,4" VerticalAlignment="Center"
                          Background="#04101A">
                    <TextBlock Text="{Binding CopilotVM.ModeLabel}"
                               Foreground="{Binding CopilotVM.ModeBrush}"
                               FontWeight="SemiBold" FontSize="12" />
                  </Border>
                </Grid>

                <!-- Transcript -->
                <Border Background="#04101A" CornerRadius="6" Padding="10,8" MinHeight="160" MaxHeight="320">
                  <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding CopilotVM.Messages}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <StackPanel Spacing="2" Margin="0,0,0,10" HorizontalAlignment="{Binding Align}">
                            <TextBlock Text="{Binding RoleLabel}" Foreground="{Binding RoleBrush}"
                                       FontSize="10" FontWeight="SemiBold" />
                            <Border Background="#08161F" CornerRadius="6" Padding="10,7" MaxWidth="520">
                              <TextBlock Text="{Binding Text}" Foreground="#E8F0FE" FontSize="12"
                                         TextWrapping="Wrap" />
                            </Border>
                            <TextBlock Text="{Binding Source}" Foreground="#4D5F70" FontSize="9"
                                       IsVisible="{Binding HasSource}" />
                          </StackPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Border>

                <!-- Suggestion chips -->
                <ItemsControl ItemsSource="{Binding CopilotVM.Suggestions}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Classes="LinkButton" Content="{Binding}" Margin="0,0,8,6"
                              Command="{Binding $parent[ItemsControl].DataContext.CopilotVM.AskSuggestionCommand}"
                              CommandParameter="{Binding}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Input -->
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                  <TextBox Grid.Column="0" Text="{Binding CopilotVM.Question}"
                           PlaceholderText="Ask the copilot…" />
                  <Button Grid.Column="1" Content="Ask" Command="{Binding CopilotVM.AskCommand}"
                          IsEnabled="{Binding !CopilotVM.IsBusy}" />
                  <Button Grid.Column="2" Content="Clear" Classes="LinkButton"
                          Command="{Binding CopilotVM.ClearCommand}" />
                </Grid>
                <TextBlock Text="{Binding CopilotVM.StatusLabel}" Foreground="#5C6E82" FontSize="11" />
              </StackPanel>
            </Border>

          </StackPanel>

          <!-- ═══════════════════════════════════════════════════════════════
               Whale Tracker Section
          ════════════════════════════════════════════════════════════════ -->
          <StackPanel Spacing="16" IsVisible="{Binding IsWhaleTrackerSectionVisible}">

            <!-- Header stats + controls -->
            <Grid ColumnDefinitions="*,*,*,Auto,Auto" ColumnSpacing="12">
              <Border Grid.Column="0" Classes="SurfaceCard">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Min Transfer" />
                  <TextBlock Text="{Binding WhaleTrackerVM.MinUsdValue, StringFormat='${0:N0}'}" Foreground="#21E6C1" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Classes="SurfaceCard">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Alerts Captured" />
                  <TextBlock Text="{Binding WhaleTrackerVM.TotalAlertsCount}" Foreground="#21E6C1" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Classes="SurfaceCard">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Labeled Wallet Alerts" />
                  <TextBlock Text="{Binding WhaleTrackerVM.LabeledAlertsCount}" Foreground="#F4B860" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Button Grid.Column="3" Classes="BuyButton" Command="{Binding WhaleTrackerVM.StartCommand}" Width="110" IsVisible="{Binding !WhaleTrackerVM.IsTracking}">Start Tracking</Button>
              <Button Grid.Column="4" Classes="SellButton" Command="{Binding WhaleTrackerVM.StopCommand}" Width="110" IsVisible="{Binding WhaleTrackerVM.IsTracking}">Stop Tracking</Button>
            </Grid>

            <!-- Status bar -->
            <Border Classes="Panel" Padding="12,8">
              <StackPanel Orientation="Horizontal" Spacing="16">
                <Ellipse Width="8" Height="8" Fill="{Binding WhaleTrackerVM.IsTracking, Converter={StaticResource BoolToColorConverter}}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding WhaleTrackerVM.KnownWalletCount, StringFormat='{}Polling ETH · BSC · Solana  ·  {0} known wallets tracked'}" Foreground="#8FA3B8" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Text="·  ETHERSCAN_API_KEY / BSCSCAN_API_KEY env vars for higher rate limits" Foreground="#4D5F70" FontSize="11" VerticalAlignment="Center" />
                <Button Classes="LinkButton" Command="{Binding WhaleTrackerVM.ClearCommand}" HorizontalAlignment="Right">Clear</Button>
              </StackPanel>
            </Border>

            <!-- ── AI Flow Insight (#6) ── -->
            <Border Classes="Panel" Padding="14,12">
              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <StackPanel Grid.Column="0">
                    <TextBlock Text="🧠 AI Flow Insight" FontWeight="SemiBold" Foreground="#E8F0FE" FontSize="13" />
                    <TextBlock Text="Accumulation or distribution? AI reads recent whale flows."
                               Foreground="#5C6E82" FontSize="11" />
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="{Binding WhaleTrackerVM.InsightSource}"
                             Foreground="#5C6E82" FontSize="10" VerticalAlignment="Center" Margin="0,0,10,0" />
                  <Button Grid.Column="2" Content="Analyze with AI"
                          Command="{Binding WhaleTrackerVM.AnalyzeWithAiCommand}"
                          IsEnabled="{Binding !WhaleTrackerVM.InsightRunning}" Foreground="#21E6C1" />
                </Grid>
                <StackPanel Spacing="5" IsVisible="{Binding WhaleTrackerVM.HasInsight}">
                  <TextBlock Text="{Binding WhaleTrackerVM.InsightSignal}"
                             Foreground="{Binding WhaleTrackerVM.InsightSignalBrush}" FontWeight="Bold" FontSize="13" />
                  <TextBlock Text="{Binding WhaleTrackerVM.InsightSummary}" Foreground="#D7E3EE" FontSize="12" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding WhaleTrackerVM.InsightBullets}" Foreground="#8FA3B8" FontSize="11" TextWrapping="Wrap"
                             IsVisible="{Binding WhaleTrackerVM.InsightBullets, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Main split: alerts list + known wallets sidebar -->
            <Grid ColumnDefinitions="*,280" ColumnSpacing="16">

              <!-- Alerts feed -->
              <Border Grid.Column="0" Classes="Panel" Padding="0">
                <StackPanel>
                  <Border Padding="16,12" BorderBrush="#1A2E3A" BorderThickness="0,0,0,1">
                    <TextBlock Classes="H2" Text="Live Whale Alerts" />
                  </Border>
                  <ScrollViewer MaxHeight="520" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding WhaleTrackerVM.RecentAlerts}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:WhaleAlertViewModel">
                          <Border Padding="16,10" BorderBrush="#1A2E3A" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" ColumnSpacing="10">

                              <!-- Chain badge -->
                              <Border Grid.Column="0" CornerRadius="3" Padding="5,2" Background="#0D1E2A" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ChainBadge}" Foreground="{Binding ChainBrush}" FontSize="10" FontWeight="Bold" />
                              </Border>

                              <!-- Alert type -->
                              <Border Grid.Column="1" CornerRadius="3" Padding="5,2" Background="#0D1E2A" VerticalAlignment="Center">
                                <TextBlock Text="{Binding AlertBadge}" Foreground="{Binding AlertBrush}" FontSize="10" FontWeight="Bold" />
                              </Border>

                              <!-- Main info -->
                              <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                  <TextBlock Text="{Binding AmountLabel}" Foreground="#E8F4FF" FontWeight="SemiBold" />
                                  <TextBlock Text="{Binding TokenSymbol}" Foreground="#8FA3B8" FontSize="12" />
                                </StackPanel>
                                <TextBlock Text="{Binding Description}" Foreground="#8FA3B8" FontSize="11" />
                                <TextBlock Text="{Binding ActiveWalletLabel}" Foreground="#F4B860" FontSize="11" IsVisible="{Binding HasLabel}" />
                              </StackPanel>

                              <!-- Time -->
                              <TextBlock Grid.Column="3" Text="{Binding TimeLabel}" Foreground="#4D5F70" FontSize="11" VerticalAlignment="Center" />

                              <!-- 1h price trend (Alchemy-enriched, appears asynchronously) -->
                              <Border Grid.Column="4" CornerRadius="3" Padding="6,2"
                                      Background="#0D1E2A" VerticalAlignment="Center"
                                      IsVisible="{Binding HasPriceTrend}">
                                <TextBlock Text="{Binding PriceTrendLabel}"
                                           Foreground="{Binding PriceTrendBrush}"
                                           FontSize="10" FontWeight="SemiBold" />
                              </Border>

                              <!-- Snipe button -->
                              <Button Grid.Column="5" Classes="BuyButton" Command="{Binding SniperBuyCommand}"
                                      IsVisible="{Binding CanSnipe}" Padding="8,4" FontSize="11" VerticalAlignment="Center">
                                ⚡ Snipe
                              </Button>

                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </StackPanel>
              </Border>

              <!-- Known wallets sidebar -->
              <StackPanel Grid.Column="1" Spacing="12">
                <Border Classes="Panel" Padding="0">
                  <StackPanel>
                    <Border Padding="14,10" BorderBrush="#1A2E3A" BorderThickness="0,0,0,1">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Classes="H2" Text="Tracked Wallets" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding WhaleTrackerVM.KnownWalletCount}" Foreground="#21E6C1" FontSize="12" VerticalAlignment="Center" />
                      </StackPanel>
                    </Border>
                    <ScrollViewer MaxHeight="480" VerticalScrollBarVisibility="Auto">
                      <ItemsControl ItemsSource="{Binding WhaleTrackerVM.KnownWallets}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="wt:LabeledWallet">
                            <Border Padding="14,8" BorderBrush="#1A2E3A" BorderThickness="0,0,0,1">
                              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Border Grid.Column="0" CornerRadius="3" Padding="4,2" Background="#0D1E2A" VerticalAlignment="Top">
                                  <TextBlock Text="{Binding Chain}" FontSize="9" Foreground="#8FA3B8" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="1">
                                  <TextBlock Text="{Binding Label}" Foreground="#C8D8E8" FontSize="12" />
                                  <TextBlock Text="{Binding Category}" Foreground="#4D7EA8" FontSize="10" />
                                </StackPanel>
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </StackPanel>
                </Border>

                <!-- API keys note -->
                <Border Classes="Panel">
                  <StackPanel Spacing="6">
                    <TextBlock Classes="H2" Text="API Keys" />
                    <TextBlock Text="ETHERSCAN_API_KEY" Foreground="#21E6C1" FontFamily="Consolas" FontSize="11" />
                    <TextBlock Text="BSCSCAN_API_KEY" Foreground="#21E6C1" FontFamily="Consolas" FontSize="11" />
                    <TextBlock Text="Free keys increase rate limits from 1 req/5s to 5 req/s. Solscan uses public API." Foreground="#4D5F70" FontSize="11" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </StackPanel>

            </Grid>
          </StackPanel>

          <!-- ═══════════════════════════════════════════════════════════════
               Funding Rate Monitor
          ════════════════════════════════════════════════════════════════ -->
          <StackPanel Spacing="16" IsVisible="{Binding IsFundingRateSectionVisible}">

            <!-- ── Control bar ── -->
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" ColumnSpacing="10">
              <TextBox Grid.Column="0"
                       Width="180"
                       Text="{Binding FundingRateVM.FilterText}"
                       PlaceholderText="Filter symbol…"
                       Classes="DarkInput" />
              <CheckBox Grid.Column="1"
                        Content="Extremes only"
                        IsChecked="{Binding FundingRateVM.ShowOnlyExtremes}" />
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="{Binding FundingRateVM.StatusMessage}"
                           Foreground="#8B949E" FontSize="12" VerticalAlignment="Center" />
              </StackPanel>
              <Button Grid.Column="3" Classes="GhostButton"
                      Command="{Binding FundingRateVM.RefreshCommand}">Refresh</Button>
              <Button Grid.Column="4" Classes="BuyButton" Width="110"
                      Command="{Binding FundingRateVM.StartTrackingCommand}"
                      IsVisible="{Binding !FundingRateVM.IsTracking}">Start</Button>
              <Button Grid.Column="5" Classes="SellButton" Width="110"
                      Command="{Binding FundingRateVM.StopTrackingCommand}"
                      IsVisible="{Binding FundingRateVM.IsTracking}">Stop</Button>
            </Grid>

            <!-- ── Summary KPI strip ── -->
            <Border Classes="Panel" Padding="16,10">
              <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="16">
                <StackPanel Grid.Column="0" Spacing="2">
                  <TextBlock Classes="Overline" Text="AVG FUNDING" />
                  <TextBlock Text="{Binding FundingRateVM.AvgRateLabel}"
                             FontSize="18" FontWeight="Bold" Foreground="#8B949E" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Classes="Overline" Text="EXTREME INSTRUMENTS" />
                  <TextBlock Text="{Binding FundingRateVM.ExtremeCount}"
                             FontSize="18" FontWeight="Bold" Foreground="#F4B860" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="2">
                  <TextBlock Classes="Overline" Text="TOP LONG FUNDING (best short)" />
                  <TextBlock Text="{Binding FundingRateVM.TopBearishLabel}"
                             FontSize="13" FontWeight="SemiBold" Foreground="#FF5D73" />
                </StackPanel>
                <StackPanel Grid.Column="3" Spacing="2">
                  <TextBlock Classes="Overline" Text="TOP SHORT FUNDING (best long)" />
                  <TextBlock Text="{Binding FundingRateVM.TopBullishLabel}"
                             FontSize="13" FontWeight="SemiBold" Foreground="#3DDC84" />
                </StackPanel>
              </Grid>
            </Border>

            <!-- ── Main content: table + history chart + alerts ── -->
            <Grid ColumnDefinitions="*,320" ColumnSpacing="12">

              <!-- Left: rates table -->
              <Border Classes="Panel" Grid.Column="0">
                <StackPanel Spacing="8">
                  <TextBlock Classes="H2" Text="All Instruments" />

                  <!-- Table header -->
                  <Grid ColumnDefinitions="*,90,90,80,90" ColumnSpacing="8"
                        Margin="0,0,0,4">
                    <TextBlock Grid.Column="0" Text="SYMBOL"   Classes="Overline" />
                    <TextBlock Grid.Column="1" Text="RATE"     Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="2" Text="ANNL."    Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="3" Text="MARK $"   Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="4" Text="NEXT"     Classes="Overline" HorizontalAlignment="Right" />
                  </Grid>

                  <ScrollViewer Classes="PageScroll" MaxHeight="460">
                    <ItemsControl ItemsSource="{Binding FundingRateVM.DisplayRates}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:FundingRateRowViewModel">
                          <Border Padding="0,5"
                                  BorderBrush="#12283A"
                                  BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,90,90,80,90" ColumnSpacing="8">
                              <!-- Symbol + extreme tag — click to load history -->
                              <Button Grid.Column="0"
                                      Classes="LinkButton"
                                      HorizontalAlignment="Left"
                                      Command="{Binding $parent[Window].DataContext.FundingRateVM.SelectSymbolCommand}"
                                      CommandParameter="{Binding Symbol}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                  <TextBlock Text="{Binding Symbol}"
                                             FontWeight="SemiBold"
                                             VerticalAlignment="Center" />
                                  <TextBlock Text="{Binding ExtremeTag}"
                                             FontSize="10"
                                             VerticalAlignment="Center" />
                                </StackPanel>
                              </Button>
                              <!-- Rate -->
                              <TextBlock Grid.Column="1"
                                         Text="{Binding FundingRatePct}"
                                         Foreground="{Binding RateColor}"
                                         FontWeight="Bold"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Center" />
                              <!-- Annualised -->
                              <TextBlock Grid.Column="2"
                                         Text="{Binding AnnualizedLabel}"
                                         Foreground="{Binding RateColor}"
                                         FontSize="11"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Center" />
                              <!-- Mark price -->
                              <TextBlock Grid.Column="3"
                                         Text="{Binding MarkPriceLabel}"
                                         Foreground="#8B949E"
                                         FontSize="11"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Center" />
                              <!-- Countdown -->
                              <TextBlock Grid.Column="4"
                                         Text="{Binding NextFundingLabel}"
                                         Foreground="#5A7080"
                                         FontSize="11"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Center" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </StackPanel>
              </Border>

              <!-- Right: history chart + alert feed -->
              <StackPanel Grid.Column="1" Spacing="12">

                <!-- History chart -->
                <Border Classes="Panel">
                  <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Grid.Column="0" Classes="H2"
                                 Text="{Binding FundingRateVM.HistorySymbolLabel,
                                        StringFormat='Funding History — {0}'}" />
                      <TextBlock Grid.Column="1"
                                 Text="(click row to switch)"
                                 Foreground="#3A5A70" FontSize="10"
                                 VerticalAlignment="Center" />
                    </Grid>

                    <!-- SVG chart canvas -->
                    <Grid IsVisible="{Binding FundingRateVM.HistoryHasData}">
                      <Canvas Width="300" Height="130" ClipToBounds="True">
                        <!-- Zero line -->
                        <Line StartPoint="0,0" EndPoint="300,0"
                              Stroke="#1A3A50" StrokeThickness="1">
                          <Line.RenderTransform>
                            <TranslateTransform Y="{Binding FundingRateVM.HistoryZeroLineY}" />
                          </Line.RenderTransform>
                        </Line>
                        <!-- Rate path -->
                        <Path Stroke="#21E6C1"
                              StrokeThickness="1.5"
                              Fill="Transparent"
                              Data="{Binding FundingRateVM.HistoryPathData}" />
                      </Canvas>
                      <!-- Y-axis labels -->
                      <Grid VerticalAlignment="Stretch">
                        <TextBlock Text="{Binding FundingRateVM.HistoryMaxLabel}"
                                   Foreground="#5A7080" FontSize="9"
                                   VerticalAlignment="Top" HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding FundingRateVM.HistoryMinLabel}"
                                   Foreground="#5A7080" FontSize="9"
                                   VerticalAlignment="Bottom" HorizontalAlignment="Right" />
                      </Grid>
                    </Grid>
                    <TextBlock Text="No history data — select a symbol or refresh"
                               Foreground="#3A5A70" FontSize="11"
                               IsVisible="{Binding FundingRateVM.HistoryIsEmpty}" />
                  </StackPanel>
                </Border>

                <!-- Extreme alerts feed -->
                <Border Classes="Panel">
                  <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Grid.Column="0" Classes="H2" Text="Extreme Rate Alerts" />
                      <Button Grid.Column="1" Classes="LinkButton"
                              Command="{Binding FundingRateVM.ClearAlertsCommand}">Clear</Button>
                    </Grid>
                    <TextBlock Text="No extreme rates detected yet."
                               Foreground="#3A5A70" FontSize="11"
                               IsVisible="{Binding !FundingRateVM.Alerts.Count}" />
                    <ScrollViewer Classes="PageScroll" MaxHeight="280">
                      <ItemsControl ItemsSource="{Binding FundingRateVM.Alerts}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:FundingAlertViewModel">
                            <Border Padding="0,4"
                                    BorderBrush="#12283A"
                                    BorderThickness="0,0,0,1">
                              <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding TimeLabel}"
                                           Foreground="#3A5A70" FontSize="11"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DisplayLabel}"
                                           Foreground="{Binding Color}"
                                           FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Border Grid.Column="2"
                                        Background="{Binding Color}"
                                        CornerRadius="2" Padding="5,1">
                                  <TextBlock Text="{Binding Direction}"
                                             Foreground="White"
                                             FontSize="10" FontWeight="Bold" />
                                </Border>
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </StackPanel>
                </Border>

              </StackPanel>
            </Grid>

          </StackPanel>

          <!-- ═══════════════════════════════════════════════════════════════
               FUNDING RATE ARBITRAGE BOT
          ════════════════════════════════════════════════════════════════ -->
          <StackPanel Spacing="16" IsVisible="{Binding IsFundingRateSectionVisible}">

            <!-- Section header -->
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Classes="H1" Text="Funding Rate Arbitrage Bot" />
                <TextBlock Text="{Binding FundingArbitrageVM.StatusLabel}"
                           FontSize="11" Foreground="#8FA3B8" />
              </StackPanel>
              <Button Grid.Column="1" Classes="GhostButton" Content="↺ Refresh"
                      IsEnabled="{Binding !FundingArbitrageVM.IsLoading}"
                      Command="{Binding FundingArbitrageVM.RefreshCommand}" />
            </Grid>

            <!-- Config row -->
            <Border Classes="Panel" Padding="16,12">
              <Grid ColumnDefinitions="Auto,130,Auto,130,Auto,80,*" ColumnSpacing="12" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Text="Min rate (per 8h)%" Classes="Overline"
                           VerticalAlignment="Center" />
                <NumericUpDown Grid.Column="1"
                               Value="{Binding FundingArbitrageVM.ThresholdPct}"
                               Minimum="0.01" Maximum="5" Increment="0.01"
                               FormatString="N2" />

                <TextBlock Grid.Column="2" Text="Notional USD" Classes="Overline"
                           VerticalAlignment="Center" Margin="8,0,0,0" />
                <NumericUpDown Grid.Column="3"
                               Value="{Binding FundingArbitrageVM.NotionalUsd}"
                               Minimum="10" Maximum="1000000" Increment="100"
                               FormatString="N0" />

                <TextBlock Grid.Column="4" Text="Leverage" Classes="Overline"
                           VerticalAlignment="Center" Margin="8,0,0,0" />
                <NumericUpDown Grid.Column="5"
                               Value="{Binding FundingArbitrageVM.Leverage}"
                               Minimum="1" Maximum="10" Increment="1"
                               FormatString="N0" />

                <!-- Risk reminder -->
                <TextBlock Grid.Column="6" FontSize="10" Foreground="#3A4F63"
                           TextWrapping="Wrap" VerticalAlignment="Center" Margin="16,0,0,0"
                           Text="Strategy: long spot + short perp. Delta-neutral. Earns funding payments every 8 h." />
              </Grid>
            </Border>

            <!-- Auto-reinvest row -->
            <Border Classes="Panel" Padding="16,10">
              <Grid ColumnDefinitions="Auto,*,Auto,120,*" ColumnSpacing="16" VerticalAlignment="Center">
                <ToggleSwitch Grid.Column="0" IsChecked="{Binding FundingArbitrageVM.AutoReinvest}"
                              Content="Auto-Reinvest" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" FontSize="11" Foreground="#5C6E82"
                           TextWrapping="Wrap" VerticalAlignment="Center"
                           Text="Compounds collected funding back into position size automatically." />
                <TextBlock Grid.Column="2" Text="Threshold $" Classes="Overline"
                           VerticalAlignment="Center" />
                <NumericUpDown Grid.Column="3"
                               Value="{Binding FundingArbitrageVM.ReinvestThreshold}"
                               Minimum="1" Maximum="10000" Increment="5"
                               FormatString="N0"
                               IsEnabled="{Binding FundingArbitrageVM.AutoReinvest}" />
                <TextBlock Grid.Column="4" FontSize="10" Foreground="#3A4F63"
                           TextWrapping="Wrap" VerticalAlignment="Center" Margin="8,0,0,0"
                           Text="Reinvest fires when funding collected ≥ Threshold USD." />
              </Grid>
            </Border>

            <!-- KPI strip: open positions, total funding, total PnL, best APR, reinvest count -->
            <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="12">
              <Border Grid.Column="0" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="OPEN POSITIONS" />
                  <TextBlock Text="{Binding FundingArbitrageVM.OpenPositionCount}"
                             Classes="Metric" Foreground="#F4B860" />
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="FUNDING EARNED" />
                  <TextBlock Text="{Binding FundingArbitrageVM.TotalFundingLabel}"
                             Classes="Metric" Foreground="#21E6C1" />
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="TOTAL PnL" />
                  <TextBlock Text="{Binding FundingArbitrageVM.TotalPnlLabel}"
                             Classes="Metric" Foreground="{Binding FundingArbitrageVM.TotalPnlBrush}" />
                </StackPanel>
              </Border>
              <Border Grid.Column="3" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="BEST APR" />
                  <TextBlock Text="{Binding FundingArbitrageVM.BestAprLabel}"
                             Classes="Metric" Foreground="#21E6C1" />
                </StackPanel>
              </Border>
              <Border Grid.Column="4" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="REINVESTS" />
                  <TextBlock Text="{Binding FundingArbitrageVM.ReinvestCountLabel}"
                             Classes="Metric" Foreground="#8FA3B8" />
                </StackPanel>
              </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

              <!-- Left: Opportunities table -->
              <Border Grid.Column="0" Classes="Panel">
                <StackPanel Spacing="10">
                  <TextBlock Classes="H2" Text="Live Opportunities" />
                  <TextBlock FontSize="11" Foreground="#5C6E82"
                             Text="Positive funding = longs pay shorts. Long spot + short perp captures this." />

                  <!-- Table header -->
                  <Grid ColumnDefinitions="60,*,80,80,70,60,Auto" ColumnSpacing="8" Margin="0,4,0,0">
                    <TextBlock Grid.Column="0" Text="EXCHANGE" Classes="Overline" />
                    <TextBlock Grid.Column="1" Text="SYMBOL"   Classes="Overline" />
                    <TextBlock Grid.Column="2" Text="RATE/8H"  Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="3" Text="ANNUAL"   Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="4" Text="MARK $"   Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="5" Text="NEXT"     Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="6" Text=""         Classes="Overline" Width="80" />
                  </Grid>

                  <ScrollViewer Classes="PageScroll" MaxHeight="400">
                    <ItemsControl ItemsSource="{Binding FundingArbitrageVM.Opportunities}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:FundingArbOpportunityRowVM">
                          <Border Padding="0,6" BorderBrush="#0D1E2D" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="60,*,80,80,70,60,Auto" ColumnSpacing="8">
                              <!-- Exchange badge -->
                              <Border Grid.Column="0" CornerRadius="4" Padding="5,2"
                                      HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Border.Background>
                                  <SolidColorBrush Color="{Binding ExchangeBadgeColor}" Opacity="0.18" />
                                </Border.Background>
                                <TextBlock Text="{Binding Exchange}"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="{Binding ExchangeBadgeColor}" />
                              </Border>
                              <!-- Symbol -->
                              <TextBlock Grid.Column="1" Text="{Binding Symbol}"
                                         FontWeight="SemiBold" VerticalAlignment="Center" />
                              <!-- Rate/8h -->
                              <TextBlock Grid.Column="2" Text="{Binding RateLabel}"
                                         Foreground="{Binding RateBrush}"
                                         FontWeight="Bold" FontFamily="Consolas"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- Annualised -->
                              <TextBlock Grid.Column="3" Text="{Binding AnnualLabel}"
                                         Foreground="{Binding AnnualBrush}"
                                         FontSize="11"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- Mark price -->
                              <TextBlock Grid.Column="4" Text="{Binding PriceLabel}"
                                         Foreground="#8FA3B8" FontSize="11"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- Next funding -->
                              <TextBlock Grid.Column="5" Text="{Binding NextLabel}"
                                         Foreground="#5C6E82" FontSize="11"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- Open button -->
                              <Button Grid.Column="6"
                                      Classes="BuyButton"
                                      Content="⚡ Open"
                                      Padding="10,4"
                                      FontSize="11"
                                      Width="78"
                                      VerticalAlignment="Center"
                                      Command="{Binding $parent[Window].DataContext.FundingArbitrageVM.OpenCommand}"
                                      CommandParameter="{Binding}" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>

                  <!-- Empty state -->
                  <TextBlock IsVisible="{Binding !FundingArbitrageVM.HasOpportunities}"
                             Text="No opportunities above threshold. Try lowering Min rate or press Refresh."
                             Foreground="#3A4F63" FontSize="12" TextWrapping="Wrap" Margin="0,8" />
                </StackPanel>
              </Border>

              <!-- Right: Open Positions table -->
              <Border Grid.Column="1" Classes="Panel">
                <StackPanel Spacing="10">
                  <TextBlock Classes="H2" Text="Open Arb Positions" />
                  <TextBlock FontSize="11" Foreground="#5C6E82"
                             Text="Each row = long spot + short perp. Funding income accrues every 8 h." />

                  <!-- Table header -->
                  <Grid ColumnDefinitions="55,*,65,55,70,70,70,Auto" ColumnSpacing="6" Margin="0,4,0,0">
                    <TextBlock Grid.Column="0" Text="EXCH"     Classes="Overline" />
                    <TextBlock Grid.Column="1" Text="SYMBOL"   Classes="Overline" />
                    <TextBlock Grid.Column="2" Text="AGE"      Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="3" Text="RATE"     Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="4" Text="FUNDING"  Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="5" Text="BASIS"    Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="6" Text="PnL"      Classes="Overline" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="7" Text=""         Classes="Overline" Width="68" />
                  </Grid>

                  <ScrollViewer Classes="PageScroll" MaxHeight="400">
                    <ItemsControl ItemsSource="{Binding FundingArbitrageVM.Positions}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:FundingArbPositionRowVM">
                          <Border Padding="0,6" BorderBrush="#0D1E2D" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="55,*,65,55,70,70,70,Auto" ColumnSpacing="6">
                              <!-- Exchange -->
                              <TextBlock Grid.Column="0" Text="{Binding Exchange}"
                                         FontSize="10" FontWeight="Bold" Foreground="#F4B860"
                                         VerticalAlignment="Center" />
                              <!-- Symbol -->
                              <StackPanel Grid.Column="1" Spacing="1">
                                <TextBlock Text="{Binding Symbol}" FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding NotionalLabel}" FontSize="10"
                                           Foreground="#5C6E82" />
                              </StackPanel>
                              <!-- Age -->
                              <TextBlock Grid.Column="2" Text="{Binding AgeLabel}"
                                         Foreground="#8FA3B8" FontSize="11"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- Entry rate -->
                              <TextBlock Grid.Column="3" Text="{Binding EntryRateLabel}"
                                         Foreground="#21E6C1" FontSize="11" FontFamily="Consolas"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- Funding collected -->
                              <TextBlock Grid.Column="4" Text="{Binding FundingLabel}"
                                         Foreground="#21E6C1" FontSize="11"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- Basis drift -->
                              <TextBlock Grid.Column="5" Text="{Binding BasisLabel}"
                                         Foreground="{Binding BasisBrush}" FontSize="11"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- Total PnL -->
                              <TextBlock Grid.Column="6" Text="{Binding TotalPnlLabel}"
                                         Foreground="{Binding TotalPnlBrush}"
                                         FontWeight="SemiBold" FontSize="11"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- Close button -->
                              <Button Grid.Column="7"
                                      Classes="SellButton"
                                      Content="✕ Close"
                                      Padding="8,4" FontSize="11"
                                      Width="66"
                                      VerticalAlignment="Center"
                                      Command="{Binding $parent[Window].DataContext.FundingArbitrageVM.CloseCommand}"
                                      CommandParameter="{Binding}" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>

                  <!-- Empty state -->
                  <StackPanel IsVisible="{Binding !FundingArbitrageVM.Positions.Count}"
                              Spacing="6" Margin="0,16">
                    <TextBlock Text="No open positions"
                               Foreground="#3A4F63" FontSize="13"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Press ⚡ Open on any opportunity to start earning funding."
                               Foreground="#2A3A4A" FontSize="11"
                               HorizontalAlignment="Center" TextWrapping="Wrap" />
                  </StackPanel>
                </StackPanel>
              </Border>

            </Grid><!-- end opportunities / positions grid -->

            <!-- Explainer / risk notes -->
            <Border Background="#080F18" BorderBrush="#1E3A52" BorderThickness="1"
                    CornerRadius="8" Padding="14,10">
              <Grid ColumnDefinitions="*,*,*" ColumnSpacing="20">
                <StackPanel Grid.Column="0" Spacing="4">
                  <TextBlock Text="How it works" FontWeight="Bold"
                             FontSize="12" Foreground="#21E6C1" />
                  <TextBlock FontSize="11" Foreground="#8FA3B8" TextWrapping="Wrap" LineHeight="18">
                    When funding is positive, perpetual longs pay shorts every 8 hours.
                    Buy spot + short-sell the perp creates a delta-neutral position
                    that collects payments without directional risk.
                  </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                  <TextBlock Text="Basis risk" FontWeight="Bold"
                             FontSize="12" Foreground="#FFAA33" />
                  <TextBlock FontSize="11" Foreground="#8FA3B8" TextWrapping="Wrap" LineHeight="18">
                    Spot and perp usually trade near parity but can diverge briefly.
                    Monitor the Basis column — values above ±0.5 % signal stress.
                    Close positions if basis widens beyond your tolerance.
                  </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                  <TextBlock Text="Exit conditions" FontWeight="Bold"
                             FontSize="12" Foreground="#5C6E82" />
                  <TextBlock FontSize="11" Foreground="#8FA3B8" TextWrapping="Wrap" LineHeight="18">
                    Close when: funding rate drops below threshold, basis drifts > 1 %,
                    funding cycles earned cover expected fees, or manually when done.
                  </TextBlock>
                </StackPanel>
              </Grid>
            </Border>

          </StackPanel>
          <!-- ═══ End Funding Rate Arbitrage Bot ═══ -->

          <!-- ═══════════════════════════════════════════════════════════════
               CEX-CEX SPOT ARBITRAGE SCANNER
          ════════════════════════════════════════════════════════════════ -->
          <StackPanel Spacing="16" IsVisible="{Binding IsArbSectionVisible}">

            <!-- Header + status -->
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Classes="H1" Text="CEX-CEX Spot Arbitrage" />
                <TextBlock Text="{Binding CrossExchangeArbVM.StatusLabel}"
                           FontSize="11" Foreground="#8FA3B8" />
              </StackPanel>
              <!-- Auto-execute toggle -->
              <Border Grid.Column="1" CornerRadius="6" Padding="10,5" VerticalAlignment="Center"
                      Background="{Binding CrossExchangeArbVM.AutoExecute,
                        FallbackValue=#0D1E2D}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <ToggleSwitch IsChecked="{Binding CrossExchangeArbVM.AutoExecute}"
                                OffContent="" OnContent="" Margin="0,-2,0,0" />
                  <TextBlock Text="Auto-Execute" FontSize="11" FontWeight="SemiBold"
                             Foreground="#F4B860" VerticalAlignment="Center" />
                </StackPanel>
              </Border>
              <!-- Warning badge when auto-execute is on -->
              <Border Grid.Column="2" CornerRadius="6" Padding="8,5"
                      Background="#2A1500" VerticalAlignment="Center"
                      IsVisible="{Binding CrossExchangeArbVM.AutoExecute}">
                <TextBlock Text="⚠ LIVE ORDERS" FontSize="10" FontWeight="Bold"
                           Foreground="#FFAA33" />
              </Border>
            </Grid>

            <!-- Config bar -->
            <Border Classes="Panel" Padding="14,10">
              <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*,2*" ColumnSpacing="10" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Text="Min net spread %" Classes="Overline" VerticalAlignment="Center" />
                <NumericUpDown Grid.Column="1"
                               Value="{Binding CrossExchangeArbVM.MinNetSpreadPct}"
                               Minimum="0.01" Maximum="5" Increment="0.01" FormatString="N2" />

                <TextBlock Grid.Column="2" Text="Notional $" Classes="Overline"
                           VerticalAlignment="Center" Margin="8,0,0,0" />
                <NumericUpDown Grid.Column="3"
                               Value="{Binding CrossExchangeArbVM.NotionalUsd}"
                               Minimum="10" Maximum="1000000" Increment="100" FormatString="N0" />

                <TextBlock Grid.Column="4" Text="Taker fee %" Classes="Overline"
                           VerticalAlignment="Center" Margin="8,0,0,0" />
                <NumericUpDown Grid.Column="5"
                               Value="{Binding CrossExchangeArbVM.TakerFeePct}"
                               Minimum="0.01" Maximum="1" Increment="0.01" FormatString="N2" />

                <TextBlock Grid.Column="6" FontSize="10" Foreground="#3A4F63"
                           VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"
                           Text="Round-trip fee = Taker × 2. Net spread = Gross − Round-trip. Opportunities refresh every second." />
              </Grid>
            </Border>

            <!-- KPI strip -->
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
              <Border Grid.Column="0" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="TRACKED SYMBOLS" />
                  <TextBlock Text="{Binding CrossExchangeArbVM.TotalSymbols}"
                             Classes="Metric" Foreground="#8FA3B8" />
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="PROFITABLE NOW" />
                  <TextBlock Text="{Binding CrossExchangeArbVM.ProfitableCount}"
                             Classes="Metric" Foreground="#21E6C1" />
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="BEST SPREAD" />
                  <TextBlock Text="{Binding CrossExchangeArbVM.BestSpreadLabel}"
                             FontSize="11" FontWeight="SemiBold" Foreground="#F4B860"
                             VerticalAlignment="Center" />
                </StackPanel>
              </Border>
              <Border Grid.Column="3" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="SESSION PROFIT" />
                  <TextBlock Text="{Binding CrossExchangeArbVM.TotalProfitLabel}"
                             Classes="Metric" Foreground="#21E6C1" />
                </StackPanel>
              </Border>
            </Grid>

            <!-- Main price comparison table -->
            <Border Classes="Panel">
              <StackPanel Spacing="10">
                <TextBlock Classes="H2" Text="Live Price Comparison — All Symbols" />
                <TextBlock FontSize="11" Foreground="#5C6E82"
                           Text="Best buy price highlighted in teal. Best sell price highlighted in amber. Net spread = gross − round-trip fees." />

                <!-- Table header -->
                <Grid ColumnDefinitions="*,70,70,70,70,70,70,110,110,70,70,Auto"
                      ColumnSpacing="6" Margin="0,4,0,0">
                  <TextBlock Grid.Column="0"  Text="SYMBOL"   Classes="Overline" />
                  <TextBlock Grid.Column="1"  Text="BIN Bid"  Classes="Overline" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="2"  Text="BIN Ask"  Classes="Overline" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="3"  Text="BYB Bid"  Classes="Overline" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="4"  Text="BYB Ask"  Classes="Overline" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="5"  Text="OKX Bid"  Classes="Overline" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="6"  Text="OKX Ask"  Classes="Overline" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="7"  Text="BEST BUY"  Classes="Overline" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="8"  Text="BEST SELL" Classes="Overline" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="9"  Text="GROSS"    Classes="Overline" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="10" Text="NET"      Classes="Overline" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="11" Text=""         Classes="Overline" Width="82" />
                </Grid>

                <ScrollViewer Classes="PageScroll" MaxHeight="500">
                  <ItemsControl ItemsSource="{Binding CrossExchangeArbVM.SpreadRows}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:CrossExchangeSpreadRowVM">
                        <Border Padding="0,5" BorderBrush="#0D1E2D" BorderThickness="0,0,0,1">
                          <Grid ColumnDefinitions="*,70,70,70,70,70,70,110,110,70,70,Auto"
                                ColumnSpacing="6">
                            <!-- Symbol -->
                            <TextBlock Grid.Column="0" Text="{Binding Symbol}"
                                       FontWeight="SemiBold" VerticalAlignment="Center" />

                            <!-- Binance Bid / Ask — amber if best sell, teal if best buy -->
                            <TextBlock Grid.Column="1" Text="{Binding BinanceBidLabel}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="{Binding BinanceBidBrush}" />
                            <TextBlock Grid.Column="2" Text="{Binding BinanceAskLabel}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="{Binding BinanceAskBrush}" />

                            <!-- Bybit Bid / Ask -->
                            <TextBlock Grid.Column="3" Text="{Binding BybitBidLabel}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="{Binding BybitBidBrush}" />
                            <TextBlock Grid.Column="4" Text="{Binding BybitAskLabel}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="{Binding BybitAskBrush}" />

                            <!-- OKX Bid / Ask -->
                            <TextBlock Grid.Column="5" Text="{Binding OkxBidLabel}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="{Binding OkxBidBrush}" />
                            <TextBlock Grid.Column="6" Text="{Binding OkxAskLabel}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="{Binding OkxAskBrush}" />

                            <!-- Best buy direction -->
                            <TextBlock Grid.Column="7" Text="{Binding BestBuyLabel}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontSize="11" Foreground="#21E6C1" />

                            <!-- Best sell direction -->
                            <TextBlock Grid.Column="8" Text="{Binding BestSellLabel}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontSize="11" Foreground="#F4B860" />

                            <!-- Gross spread -->
                            <TextBlock Grid.Column="9" Text="{Binding GrossSpreadLabel}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontSize="11" Foreground="#5C6E82" />

                            <!-- Net spread (colored by profitability) -->
                            <TextBlock Grid.Column="10" Text="{Binding NetSpreadLabel}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{Binding NetSpreadBrush}" />

                            <!-- Execute button -->
                            <Button Grid.Column="11"
                                    Classes="BuyButton"
                                    Content="⚡ Execute"
                                    Padding="8,3" FontSize="11"
                                    Width="80"
                                    IsEnabled="{Binding IsProfitable}"
                                    VerticalAlignment="Center"
                                    Command="{Binding $parent[Window].DataContext.CrossExchangeArbVM.ExecuteCommand}"
                                    CommandParameter="{Binding}" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </StackPanel>
            </Border>

            <!-- Execution History -->
            <Border Classes="Panel">
              <StackPanel Spacing="10">
                <TextBlock Classes="H2" Text="Execution History" />

                <!-- Table header -->
                <Grid ColumnDefinitions="70,*,120,70,70,70,70,*" ColumnSpacing="8" Margin="0,4,0,0">
                  <TextBlock Grid.Column="0" Text="TIME"    Classes="Overline" />
                  <TextBlock Grid.Column="1" Text="SYMBOL"  Classes="Overline" />
                  <TextBlock Grid.Column="2" Text="ROUTE"   Classes="Overline" />
                  <TextBlock Grid.Column="3" Text="BUY $"   Classes="Overline" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="4" Text="SELL $"  Classes="Overline" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="5" Text="SPREAD"  Classes="Overline" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="6" Text="PROFIT"  Classes="Overline" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="7" Text="STATUS"  Classes="Overline" />
                </Grid>

                <ScrollViewer Classes="PageScroll" MaxHeight="250">
                  <ItemsControl ItemsSource="{Binding CrossExchangeArbVM.History}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:ArbExecutionRowVM">
                        <Border Padding="0,5" BorderBrush="#0D1E2D" BorderThickness="0,0,0,1">
                          <Grid ColumnDefinitions="70,*,120,70,70,70,70,*" ColumnSpacing="8">
                            <TextBlock Grid.Column="0" Text="{Binding TimeLabel}"
                                       FontFamily="Consolas" FontSize="11" Foreground="#5C6E82"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding Symbol}"
                                       FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding RouteLabel}"
                                       FontSize="11" Foreground="#8FA3B8" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="{Binding BuyLabel}"
                                       FontFamily="Consolas" FontSize="11"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="{Binding SellLabel}"
                                       FontFamily="Consolas" FontSize="11"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="5" Text="{Binding SpreadLabel}"
                                       FontSize="11" Foreground="#5C6E82"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="6" Text="{Binding ProfitLabel}"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{Binding ProfitBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="7" Text="{Binding StatusLabel}"
                                       FontSize="11" Foreground="{Binding StatusBrush}"
                                       VerticalAlignment="Center" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>

                <!-- Empty history -->
                <TextBlock IsVisible="{Binding !CrossExchangeArbVM.History.Count}"
                           Text="No executions yet. Click ⚡ Execute on a profitable row, or enable Auto-Execute."
                           Foreground="#3A4F63" FontSize="12" TextWrapping="Wrap" Margin="0,8" />
              </StackPanel>
            </Border>

          </StackPanel>
          <!-- ═══ End CEX-CEX Spot Arbitrage ═══ -->

          <!-- ═══════════════════════════════════════════════════════════════
               COPY TRADING
          ════════════════════════════════════════════════════════════════ -->
          <StackPanel Spacing="16" IsVisible="{Binding IsCopySectionVisible}">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Classes="H1" Text="Copy Trading" />
                <TextBlock Text="{Binding CopyTradingVM.ModeLabel}"
                           FontSize="11" Foreground="#8FA3B8" />
              </StackPanel>
              <Button Grid.Column="1" Classes="GhostButton" Content="Leader"
                      Command="{Binding CopyTradingVM.SetLeaderCommand}" />
              <Button Grid.Column="2" Classes="GhostButton" Content="Follower"
                      Command="{Binding CopyTradingVM.SetFollowerCommand}" />
              <Button Grid.Column="3" Classes="GhostButton" Content="Off"
                      Command="{Binding CopyTradingVM.SetOffCommand}" />
            </Grid>

            <!-- KPI strip -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
              <Border Grid.Column="0" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="PUBLISHED" />
                  <TextBlock Text="{Binding CopyTradingVM.TotalPublished}"
                             Classes="Metric" Foreground="#21E6C1" />
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="COPIED" />
                  <TextBlock Text="{Binding CopyTradingVM.TotalCopied}"
                             Classes="Metric" Foreground="#F4B860" />
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="EST. PERF FEE" />
                  <TextBlock Text="{Binding CopyTradingVM.FeeLabel}"
                             Classes="Metric" Foreground="#21E6C1" />
                </StackPanel>
              </Border>
            </Grid>

            <!-- Follower config (shown when Follower mode active) -->
            <Border Classes="Panel" Padding="16,12"
                    IsVisible="{Binding CopyTradingVM.IsFollower}">
              <Grid ColumnDefinitions="Auto,*,Auto,120,Auto,100" ColumnSpacing="12" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Text="Leader URL" Classes="Overline" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" Text="{Binding CopyTradingVM.LeaderUrl}"
                         PlaceholderText="http://leader-ip:5180"
                         FontFamily="Consolas" FontSize="12" />
                <TextBlock Grid.Column="2" Text="Scale" Classes="Overline"
                           VerticalAlignment="Center" Margin="8,0,0,0" />
                <NumericUpDown Grid.Column="3"
                               Value="{Binding CopyTradingVM.ScaleRatio}"
                               Minimum="0.01" Maximum="10" Increment="0.1"
                               FormatString="N2" />
                <TextBlock Grid.Column="4" Text="Perf fee %" Classes="Overline"
                           VerticalAlignment="Center" Margin="8,0,0,0" />
                <NumericUpDown Grid.Column="5"
                               Value="{Binding CopyTradingVM.PerformanceFeePct}"
                               Minimum="0" Maximum="50" Increment="1"
                               FormatString="N0" />
              </Grid>
            </Border>

            <!-- Activity log -->
            <Border Classes="Panel" Padding="16,12">
              <StackPanel Spacing="8">
                <TextBlock Classes="H2" Text="Activity Log" />
                <ScrollViewer Classes="PageScroll" MaxHeight="300">
                  <ItemsControl ItemsSource="{Binding CopyTradingVM.Log}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:CopyTradeLogEntry">
                        <Grid ColumnDefinitions="70,*" ColumnSpacing="8" Margin="0,2">
                          <TextBlock Grid.Column="0" Text="{Binding Time}"
                                     FontFamily="Consolas" FontSize="10"
                                     Foreground="#5C6E82" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="1" Text="{Binding Message}"
                                     FontSize="11" Foreground="#8FA3B8"
                                     TextWrapping="Wrap" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
                <TextBlock Text="No activity yet. Switch to Leader or Follower mode to start."
                           Foreground="#3A4F63" FontSize="11"
                           IsVisible="{Binding !CopyTradingVM.Log.Count}" />
              </StackPanel>
            </Border>

            <!-- Info box -->
            <Border Background="#080F18" BorderBrush="#1E3A52" BorderThickness="1"
                    CornerRadius="8" Padding="14,10">
              <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                <StackPanel Grid.Column="0" Spacing="4">
                  <TextBlock Text="Leader mode" FontWeight="Bold" FontSize="12" Foreground="#21E6C1" />
                  <TextBlock FontSize="11" Foreground="#8FA3B8" TextWrapping="Wrap" LineHeight="18">
                    Every trade closed by AI Bot or Grid Bot is published to
                    %APPDATA%/CryptoAITerminal/webapi/copy-trades.json and served at
                    /api/copy-trades. Followers poll this endpoint and mirror trades.
                  </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                  <TextBlock Text="Follower mode" FontWeight="Bold" FontSize="12" Foreground="#F4B860" />
                  <TextBlock FontSize="11" Foreground="#8FA3B8" TextWrapping="Wrap" LineHeight="18">
                    Polls the leader every 2 seconds. New trade IDs are mirrored with
                    quantity × ScaleRatio. Performance fee (default 20 %) is tracked
                    locally — charge your subscribers manually.
                  </TextBlock>
                </StackPanel>
              </Grid>
            </Border>

          </StackPanel>
          <!-- ═══ End Copy Trading ═══ -->

          <!-- ═══════════════════════════════════════════════════════════════
               STATISTICAL ARBITRAGE (PAIRS TRADING)
          ════════════════════════════════════════════════════════════════ -->
          <StackPanel Spacing="16" IsVisible="{Binding IsStatArbSectionVisible}">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Classes="H1" Text="Statistical Arbitrage" />
                <TextBlock Text="{Binding StatArbVM.StatusLabel}"
                           FontSize="11" Foreground="#8FA3B8" />
              </StackPanel>
              <Button Grid.Column="1" Classes="GhostButton" Content="▶ Start"
                      IsEnabled="{Binding !StatArbVM.IsRunning}"
                      Command="{Binding StatArbVM.StartCommand}" />
              <Button Grid.Column="2" Classes="GhostButton" Content="⏹ Stop"
                      IsEnabled="{Binding StatArbVM.IsRunning}"
                      Command="{Binding StatArbVM.StopCommand}" />
            </Grid>

            <!-- ── AI pair verdict (#11) ── -->
            <Border Classes="Panel" Padding="14,12">
              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <StackPanel Grid.Column="0">
                    <TextBlock Text="🧠 AI Pair Verdict" FontWeight="SemiBold" Foreground="#E8F0FE" FontSize="13" />
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="{Binding StatArbVM.PairSource}"
                             Foreground="#5C6E82" FontSize="10" VerticalAlignment="Center" Margin="0,0,10,0" />
                  <Button Grid.Column="2" Content="Evaluate with AI"
                          Command="{Binding StatArbVM.EvaluatePairCommand}"
                          IsEnabled="{Binding !StatArbVM.PairRunning}" Foreground="#21E6C1" />
                </Grid>
                <StackPanel Spacing="5" IsVisible="{Binding StatArbVM.HasPairVerdict}">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="{Binding StatArbVM.PairSignal}"
                               Foreground="{Binding StatArbVM.PairSignalBrush}" FontWeight="Bold" FontSize="13" />
                    <TextBlock Text="{Binding StatArbVM.PairScore, StringFormat='score {0}/100'}"
                               Foreground="#8FA3B8" FontSize="12" VerticalAlignment="Center" />
                  </StackPanel>
                  <TextBlock Text="{Binding StatArbVM.PairReason}" Foreground="#D7E3EE" FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Config row -->
            <Border Classes="Panel" Padding="16,12">
              <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*,Auto,*,Auto,*,Auto,*"
                    ColumnSpacing="10" VerticalAlignment="Center">
                <TextBlock Grid.Column="0"  Text="Symbol A" Classes="Overline" VerticalAlignment="Center" />
                <TextBox   Grid.Column="1"  Text="{Binding StatArbVM.SymbolA}" FontFamily="Consolas" FontSize="12" />
                <TextBlock Grid.Column="2"  Text="Symbol B" Classes="Overline" VerticalAlignment="Center" Margin="8,0,0,0" />
                <TextBox   Grid.Column="3"  Text="{Binding StatArbVM.SymbolB}" FontFamily="Consolas" FontSize="12" />
                <TextBlock Grid.Column="4"  Text="Window"   Classes="Overline" VerticalAlignment="Center" Margin="8,0,0,0" />
                <NumericUpDown Grid.Column="5" Value="{Binding StatArbVM.Window}"
                               Minimum="10" Maximum="500" Increment="10" FormatString="N0" />
                <TextBlock Grid.Column="6"  Text="Entry Z"  Classes="Overline" VerticalAlignment="Center" Margin="8,0,0,0" />
                <NumericUpDown Grid.Column="7" Value="{Binding StatArbVM.EntryZScore}"
                               Minimum="0.5" Maximum="5" Increment="0.1" FormatString="N1" />
                <TextBlock Grid.Column="8"  Text="Exit Z"   Classes="Overline" VerticalAlignment="Center" Margin="8,0,0,0" />
                <NumericUpDown Grid.Column="9" Value="{Binding StatArbVM.ExitZScore}"
                               Minimum="0.1" Maximum="2" Increment="0.1" FormatString="N1" />
                <TextBlock Grid.Column="10" Text="Notional $" Classes="Overline" VerticalAlignment="Center" Margin="8,0,0,0" />
                <NumericUpDown Grid.Column="11" Value="{Binding StatArbVM.NotionalUsd}"
                               Minimum="10" Maximum="1000000" Increment="100" FormatString="N0" />
              </Grid>
            </Border>

            <!-- KPI strip -->
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
              <Border Grid.Column="0" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="Z-SCORE" />
                  <TextBlock Text="{Binding StatArbVM.ZScoreLabel}"
                             Classes="Metric" Foreground="{Binding StatArbVM.ZScoreBrush}" />
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="POSITION" />
                  <TextBlock Text="{Binding StatArbVM.PositionLabel}"
                             Classes="Metric" Foreground="#F4B860" />
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="SPREAD" />
                  <TextBlock Text="{Binding StatArbVM.SpreadLabel}"
                             Classes="Metric" Foreground="#8FA3B8" />
                </StackPanel>
              </Border>
              <Border Grid.Column="3" Classes="SurfaceCard">
                <StackPanel Spacing="3">
                  <TextBlock Classes="Overline" Text="TOTAL PNL" />
                  <TextBlock Text="{Binding StatArbVM.PnlLabel}"
                             Classes="Metric" Foreground="#21E6C1" />
                </StackPanel>
              </Border>
            </Grid>

            <!-- Log -->
            <Border Classes="Panel" Padding="16,12">
              <StackPanel Spacing="8">
                <TextBlock Classes="H2" Text="Engine Log" />
                <ScrollViewer Classes="PageScroll" MaxHeight="300">
                  <ItemsControl ItemsSource="{Binding StatArbVM.LogLines}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   FontFamily="Consolas" FontSize="10"
                                   Foreground="#8FA3B8" TextWrapping="Wrap"
                                   Margin="0,1" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
                <TextBlock Text="Engine not started. Click ▶ Start to begin."
                           Foreground="#3A4F63" FontSize="11"
                           IsVisible="{Binding !StatArbVM.IsRunning}" />
              </StackPanel>
            </Border>

            <!-- Info box -->
            <Border Background="#080F18" BorderBrush="#1E3A52" BorderThickness="1"
                    CornerRadius="8" Padding="14,10">
              <Grid ColumnDefinitions="*,*,*" ColumnSpacing="20">
                <StackPanel Grid.Column="0" Spacing="4">
                  <TextBlock Text="Strategy" FontWeight="Bold" FontSize="12" Foreground="#21E6C1" />
                  <TextBlock FontSize="11" Foreground="#8FA3B8" TextWrapping="Wrap" LineHeight="18">
                    Computes spread = ln(A) − β·ln(B) and z-score over a rolling window.
                    Opens delta-neutral pairs trade when |z| exceeds EntryZ.
                    Closes when |z| drops below ExitZ.
                  </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                  <TextBlock Text="Hedge ratio" FontWeight="Bold" FontSize="12" Foreground="#F4B860" />
                  <TextBlock FontSize="11" Foreground="#8FA3B8" TextWrapping="Wrap" LineHeight="18">
                    β is estimated via OLS regression on historical 1h candles (Window×2 bars).
                    Recalculated on each Start. Default pair BTC/ETH is historically cointegrated.
                  </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                  <TextBlock Text="Risk" FontWeight="Bold" FontSize="12" Foreground="#5C6E82" />
                  <TextBlock FontSize="11" Foreground="#8FA3B8" TextWrapping="Wrap" LineHeight="18">
                    Cointegration can break during structural market shifts.
                    Always size Notional conservatively and monitor basis.
                    Stop the engine immediately if z-score remains elevated.
                  </TextBlock>
                </StackPanel>
              </Grid>
            </Border>

          </StackPanel>
          <!-- ═══ End Statistical Arbitrage ═══ -->

          <!-- ═══════════════════════════════════════════════════════════════
               BEST EXECUTION ROUTER
          ════════════════════════════════════════════════════════════════ -->
          <Border IsVisible="{Binding IsRouterSectionVisible}">
          <StackPanel Spacing="16"
                      DataContext="{Binding BestExecutionVM}">

            <!-- Header ─────────────────────────────────────────────────── -->
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="4">
                <TextBlock Text="Smart Order Router"
                           FontSize="20" FontWeight="Bold" Foreground="#E8F0FE" />
                <TextBlock Text="Finds the best price across Binance / Bybit / OKX including fees. Large orders are automatically split across exchanges."
                           FontSize="12" Foreground="#5C6E82" TextWrapping="Wrap" />
              </StackPanel>
              <!-- Status badge -->
              <Border Grid.Column="1" CornerRadius="6" Padding="10,4"
                      Background="#0E1E2E" VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusText}" FontSize="11"
                           Foreground="#8FA3B8" TextWrapping="Wrap" MaxWidth="280" />
              </Border>
            </Grid>

            <!-- ── AI Slice Planner (#12) ── -->
            <Border Background="#0D1B29" CornerRadius="10" Padding="14,12">
              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto,140,Auto">
                  <StackPanel Grid.Column="0">
                    <TextBlock Text="🧠 AI Slice Planner" FontWeight="SemiBold" Foreground="#E8F0FE" FontSize="13" />
                    <TextBlock Text="Break a large order into impact-aware slices." Foreground="#5C6E82" FontSize="11" />
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="Urgency" Foreground="#8FA3B8" FontSize="11"
                             VerticalAlignment="Center" Margin="0,0,8,0" />
                  <ComboBox Grid.Column="2" ItemsSource="{Binding UrgencyOptions}"
                            SelectedItem="{Binding SelectedUrgency}" HorizontalAlignment="Stretch" />
                  <Button Grid.Column="3" Content="Plan with AI" Margin="10,0,0,0"
                          Command="{Binding PlanSlicesCommand}"
                          IsEnabled="{Binding !PlanRunning}" Foreground="#21E6C1" />
                </Grid>
                <TextBlock Text="{Binding PlanRationale}" Foreground="#D7E3EE" FontSize="12" TextWrapping="Wrap"
                           IsVisible="{Binding HasSlicePlan}" />
                <TextBlock Text="{Binding PlanSource}" Foreground="#5C6E82" FontSize="10"
                           IsVisible="{Binding HasSlicePlan}" />
              </StackPanel>
            </Border>

            <!-- Input bar ───────────────────────────────────────────────── -->
            <Border Background="#0D1B29" CornerRadius="10" Padding="16,12">
              <Grid ColumnDefinitions="Auto,12,160,12,Auto,8,130,12,Auto,12,Auto,*,Auto"
                    VerticalAlignment="Center">

                <!-- Symbol label + input -->
                <TextBlock Grid.Column="0" Text="Symbol" FontSize="11"
                           Foreground="#5C6E82" VerticalAlignment="Center" />
                <TextBox Grid.Column="2"
                         Text="{Binding Symbol, Mode=TwoWay}"
                         PlaceholderText="BTCUSDT"
                         FontFamily="Consolas" FontSize="13"
                         Background="#0A1520" Foreground="#E8F0FE"
                         BorderBrush="#1E3A5F" CornerRadius="6"
                         Padding="8,6" VerticalAlignment="Center" />

                <!-- USD notional -->
                <TextBlock Grid.Column="4" Text="Size ($)" FontSize="11"
                           Foreground="#5C6E82" VerticalAlignment="Center" />
                <NumericUpDown Grid.Column="6" Value="{Binding NotionalUsd, Mode=TwoWay}"
                               Minimum="10" Maximum="10000000" Increment="100"
                               FormatString="N0"
                               Background="#0A1520" Foreground="#E8F0FE"
                               BorderBrush="#1E3A5F" CornerRadius="6"
                               Padding="8,6" VerticalAlignment="Center" />

                <!-- Buy / Sell toggle -->
                <StackPanel Grid.Column="8" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <Border CornerRadius="6" Padding="10,5"
                          Background="#1A3A28"
                          IsVisible="{Binding IsBuySide}">
                    <TextBlock Text="▲ BUY" FontSize="12" FontWeight="Bold"
                               Foreground="#21E6C1" />
                  </Border>
                  <Border CornerRadius="6" Padding="10,5"
                          Background="#3A1A1A"
                          IsVisible="{Binding !IsBuySide}">
                    <TextBlock Text="▼ SELL" FontSize="12" FontWeight="Bold"
                               Foreground="#FF6B6B" />
                  </Border>
                  <ToggleSwitch IsChecked="{Binding IsBuySide, Mode=TwoWay}"
                               OnContent="" OffContent=""
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Compute button -->
                <Button Grid.Column="10"
                        Command="{Binding ComputeCommand}"
                        IsEnabled="{Binding !IsBusy}"
                        Background="#1A3A5C" Foreground="#21E6C1"
                        CornerRadius="7" Padding="14,7"
                        FontWeight="SemiBold" FontSize="12"
                        VerticalAlignment="Center">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="⟳" FontSize="13" VerticalAlignment="Center" />
                    <TextBlock Text="Compute route" VerticalAlignment="Center" />
                  </StackPanel>
                </Button>

                <!-- Execute button (right-aligned) -->
                <Button Grid.Column="12"
                        Command="{Binding ExecuteCommand}"
                        IsEnabled="{Binding HasPlan}"
                        Background="#0D2A1A" Foreground="#21E6C1"
                        CornerRadius="7" Padding="14,7"
                        FontWeight="Bold" FontSize="12"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="⚡" FontSize="13" VerticalAlignment="Center" />
                    <TextBlock Text="Execute" VerticalAlignment="Center" />
                  </StackPanel>
                </Button>
              </Grid>
            </Border>

            <!-- Exchange quotes ─────────────────────────────────────────── -->
            <Border Background="#0D1B29" CornerRadius="10" Padding="16,12">
              <StackPanel Spacing="10">
                <TextBlock Text="Exchange Quotes" FontSize="13" FontWeight="SemiBold"
                           Foreground="#8FA3B8" />

                <!-- Column headers -->
                <Grid ColumnDefinitions="120,*,*,*,100">
                  <TextBlock Grid.Column="0" Text="Exchange" FontSize="10" Foreground="#3A4F63" />
                  <TextBlock Grid.Column="1" Text="Price (raw)" FontSize="10" Foreground="#3A4F63" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="2" Text="Fee" FontSize="10" Foreground="#3A4F63" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="3" Text="Eff. price" FontSize="10" Foreground="#3A4F63" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="4" Text="Liquidity" FontSize="10" Foreground="#3A4F63" HorizontalAlignment="Right" />
                </Grid>
                <Rectangle Height="1" Fill="#1E3A5F" />

                <!-- Quote rows -->
                <ItemsControl ItemsSource="{Binding Quotes}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border CornerRadius="6" Padding="8,6" Margin="0,1"
                              Background="{Binding RowBrush}">
                        <Grid ColumnDefinitions="120,*,*,*,100">
                          <!-- Exchange name + best badge -->
                          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding Exchange}" FontSize="12"
                                       FontWeight="SemiBold" Foreground="#8FA3B8"
                                       VerticalAlignment="Center" />
                            <Border CornerRadius="4" Padding="4,2"
                                    Background="#0D2A1A"
                                    IsVisible="{Binding IsBest}">
                              <TextBlock Text="{Binding BestBadge}" FontSize="9"
                                         FontWeight="Bold" Foreground="#21E6C1" />
                            </Border>
                          </StackPanel>
                          <TextBlock Grid.Column="1" Text="{Binding RawLabel}"
                                     FontFamily="Consolas" FontSize="12"
                                     Foreground="#8FA3B8"
                                     HorizontalAlignment="Right" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="2" Text="{Binding FeeLabel}"
                                     FontFamily="Consolas" FontSize="12"
                                     Foreground="#5C6E82"
                                     HorizontalAlignment="Right" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="3" Text="{Binding EffLabel}"
                                     FontFamily="Consolas" FontSize="12"
                                     Foreground="{Binding PriceBrush}"
                                     HorizontalAlignment="Right" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="4" Text="{Binding LiqLabel}"
                                     FontFamily="Consolas" FontSize="11"
                                     Foreground="#3A4F63"
                                     HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <!-- Routing plan ─────────────────────────────────────────────── -->
            <Border Background="#0D1B29" CornerRadius="10" Padding="16,12"
                    IsVisible="{Binding HasPlan}">
              <StackPanel Spacing="10">
                <!-- Plan header with split badge -->
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Execution Plan" FontSize="13" FontWeight="SemiBold"
                               Foreground="#8FA3B8" VerticalAlignment="Center" />
                    <Border CornerRadius="5" Padding="7,3"
                            Background="#1A2A3A"
                            IsVisible="{Binding IsSplit}">
                      <TextBlock Text="SPLIT ORDER" FontSize="10" FontWeight="Bold"
                                 Foreground="#F4B860" />
                    </Border>
                  </StackPanel>
                  <!-- Summary stats -->
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20">
                    <StackPanel Spacing="1" HorizontalAlignment="Right">
                      <TextBlock Text="Average price" FontSize="10" Foreground="#3A4F63" />
                      <TextBlock Text="{Binding WavgLabel}" FontFamily="Consolas"
                                 FontSize="13" FontWeight="SemiBold" Foreground="#E8F0FE" />
                    </StackPanel>
                    <StackPanel Spacing="1" HorizontalAlignment="Right">
                      <TextBlock Text="Savings vs worst" FontSize="10" Foreground="#3A4F63" />
                      <TextBlock Text="{Binding SavingsLabel}" FontFamily="Consolas"
                                 FontSize="13" FontWeight="Bold"
                                 Foreground="{Binding SavingsBrush}" />
                    </StackPanel>
                    <StackPanel Spacing="1" HorizontalAlignment="Right">
                      <TextBlock Text="Size" FontSize="10" Foreground="#3A4F63" />
                      <TextBlock Text="{Binding TotalLabel}" FontFamily="Consolas"
                                 FontSize="13" Foreground="#8FA3B8" />
                    </StackPanel>
                  </StackPanel>
                </Grid>

                <Rectangle Height="1" Fill="#1E3A5F" />

                <!-- Column headers -->
                <Grid ColumnDefinitions="120,*,*,*,*,80">
                  <TextBlock Grid.Column="0" Text="Exchange" FontSize="10" Foreground="#3A4F63" />
                  <TextBlock Grid.Column="1" Text="Quantity" FontSize="10" Foreground="#3A4F63" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="2" Text="Avg price" FontSize="10" Foreground="#3A4F63" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="3" Text="Fee" FontSize="10" Foreground="#3A4F63" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="4" Text="Cost" FontSize="10" Foreground="#3A4F63" HorizontalAlignment="Right" />
                  <TextBlock Grid.Column="5" Text="Share" FontSize="10" Foreground="#3A4F63" HorizontalAlignment="Right" />
                </Grid>

                <!-- Leg rows -->
                <ItemsControl ItemsSource="{Binding Legs}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Padding="8,6" Margin="0,1">
                        <Grid ColumnDefinitions="120,*,*,*,*,80">
                          <!-- Exchange with rank color -->
                          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <Border Width="4" CornerRadius="2"
                                    Background="{Binding ExchangeBrush}" />
                            <TextBlock Text="{Binding Exchange}" FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding ExchangeBrush}"
                                       VerticalAlignment="Center" />
                          </StackPanel>
                          <TextBlock Grid.Column="1" Text="{Binding QtyLabel}"
                                     FontFamily="Consolas" FontSize="12"
                                     Foreground="#8FA3B8"
                                     HorizontalAlignment="Right" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="2" Text="{Binding PriceLabel}"
                                     FontFamily="Consolas" FontSize="12"
                                     Foreground="#E8F0FE"
                                     HorizontalAlignment="Right" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="3" Text="{Binding FeeLabel}"
                                     FontFamily="Consolas" FontSize="12"
                                     Foreground="#5C6E82"
                                     HorizontalAlignment="Right" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="4" Text="{Binding ValueLabel}"
                                     FontFamily="Consolas" FontSize="12"
                                     Foreground="#E8F0FE"
                                     FontWeight="SemiBold"
                                     HorizontalAlignment="Right" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="5" Text="{Binding ShareLabel}"
                                     FontFamily="Consolas" FontSize="12"
                                     Foreground="#5C6E82"
                                     HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

          </StackPanel>
          </Border>
          <!-- ═══ End Best Execution Router ═══ -->

          <!-- ═══════════════════════════════════════════════════════════════
               MULTI-MARKET SCANNER
          ════════════════════════════════════════════════════════════════ -->
          <Border IsVisible="{Binding IsScannerSectionVisible}">
          <StackPanel Spacing="16" DataContext="{Binding ScannerVM}">

            <!-- Header + KPI strip ──────────────────────────────────────── -->
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="4">
                <TextBlock Text="Real-time Market Scanner"
                           FontSize="20" FontWeight="Bold" Foreground="#E8F0FE" />
                <TextBlock Text="Filter by RSI, change, volume and activity. Click a row → trading screen."
                           FontSize="12" Foreground="#5C6E82" />
              </StackPanel>
              <!-- KPI cards -->
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Border Background="#0D1B29" CornerRadius="8" Padding="14,8">
                  <StackPanel Spacing="1" HorizontalAlignment="Center">
                    <TextBlock Text="Total" FontSize="9" Foreground="#3A4F63" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding TotalSymbols}" FontSize="16" FontWeight="Bold"
                               Foreground="#8FA3B8" HorizontalAlignment="Center" />
                  </StackPanel>
                </Border>
                <Border Background="#0A1F16" CornerRadius="8" Padding="14,8">
                  <StackPanel Spacing="1" HorizontalAlignment="Center">
                    <TextBlock Text="🔥 Hot" FontSize="9" Foreground="#3A4F63" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding HotCount}" FontSize="16" FontWeight="Bold"
                               Foreground="#FF6B00" HorizontalAlignment="Center" />
                  </StackPanel>
                </Border>
                <Border Background="#0A1F0A" CornerRadius="8" Padding="14,8">
                  <StackPanel Spacing="1" HorizontalAlignment="Center">
                    <TextBlock Text="▲ Gainers" FontSize="9" Foreground="#3A4F63" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding GainersCount}" FontSize="16" FontWeight="Bold"
                               Foreground="#21E6C1" HorizontalAlignment="Center" />
                  </StackPanel>
                </Border>
                <Border Background="#1F0A0A" CornerRadius="8" Padding="14,8">
                  <StackPanel Spacing="1" HorizontalAlignment="Center">
                    <TextBlock Text="▼ Losers" FontSize="9" Foreground="#3A4F63" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding LosersCount}" FontSize="16" FontWeight="Bold"
                               Foreground="#FF5555" HorizontalAlignment="Center" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </Grid>

            <!-- ── AI Picks (#1) ──────────────────────────────────────────── -->
            <Border Background="#0D1B29" CornerRadius="10" Padding="14,12">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <StackPanel Grid.Column="0" Spacing="1">
                    <TextBlock Text="🧠 AI Picks" FontSize="14" FontWeight="Bold" Foreground="#E8F0FE" />
                    <TextBlock Text="Top opportunities ranked from the live scan." FontSize="11" Foreground="#5C6E82" />
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="{Binding AiSource}" Foreground="#5C6E82"
                             FontSize="10" VerticalAlignment="Center" Margin="0,0,10,0" />
                  <Button Grid.Column="2" Content="Rank with AI"
                          Command="{Binding RankWithAiCommand}" IsEnabled="{Binding !AiRunning}" />
                </Grid>
                <ItemsControl ItemsSource="{Binding AiPicks}" IsVisible="{Binding HasAiPicks}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:AiPickVM">
                      <Border Background="#0A1622" CornerRadius="6" Padding="10,7" Margin="0,2">
                        <Grid ColumnDefinitions="Auto,90,*">
                          <Border Grid.Column="0" CornerRadius="4" Padding="6,2" Background="#04101A" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ScoreLabel}" FontWeight="Bold" Foreground="#21E6C1" FontSize="13" />
                          </Border>
                          <StackPanel Grid.Column="1" Spacing="0" Margin="8,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Symbol}" FontWeight="SemiBold" Foreground="#E8F0FE" FontSize="13" />
                            <TextBlock Text="{Binding Bias}" Foreground="{Binding BiasBrush}" FontSize="11" FontWeight="Bold" />
                          </StackPanel>
                          <TextBlock Grid.Column="2" Text="{Binding Reason}" Foreground="#8FA3B8"
                                     FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <!-- Filter bar ──────────────────────────────────────────────── -->
            <Border Background="#0D1B29" CornerRadius="10" Padding="14,10">
              <StackPanel Spacing="10">

                <!-- Preset buttons -->
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Preset:" FontSize="11" Foreground="#5C6E82" VerticalAlignment="Center" />
                  <Button Classes="FilterChip" Command="{Binding SetPresetCommand}" CommandParameter="All">All</Button>
                  <Button Classes="FilterChip" Command="{Binding SetPresetCommand}" CommandParameter="Hot">🔥 Hot</Button>
                  <Button Classes="FilterChip" Command="{Binding SetPresetCommand}" CommandParameter="Gainers">📈 Gainers</Button>
                  <Button Classes="FilterChip" Command="{Binding SetPresetCommand}" CommandParameter="Losers">📉 Losers</Button>
                  <Button Classes="FilterChip" Command="{Binding SetPresetCommand}" CommandParameter="Oversold">💎 Oversold</Button>
                  <Button Classes="FilterChip" Command="{Binding SetPresetCommand}" CommandParameter="Overbought">⚡ Overbought</Button>
                </StackPanel>

                <!-- Custom filters row -->
                <Grid ColumnDefinitions="Auto,8,*,16,Auto,8,*,8,*,16,Auto,8,*,8,*,16,Auto,8,*">
                  <TextBlock Grid.Column="0" Text="Symbol" FontSize="10" Foreground="#5C6E82" VerticalAlignment="Center" />
                  <TextBox Grid.Column="2" Text="{Binding SymbolSearch, Mode=TwoWay}"
                           PlaceholderText="BTC, ETH…"
                           FontSize="12" Background="#131F2E" Foreground="#E8F0FE"
                           BorderBrush="#445E78" CornerRadius="8" Padding="10,8" MinHeight="38" />

                  <TextBlock Grid.Column="4" Text="Change %" FontSize="10" Foreground="#5C6E82" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="6" Value="{Binding MinChange, Mode=TwoWay}"
                                 FormatString="F1" Increment="0.5"
                                 Background="#131F2E" Foreground="#E8F0FE"
                                 BorderBrush="#445E78" CornerRadius="8" Padding="8,6" MinHeight="38" />
                  <TextBlock Grid.Column="7" Text="…" FontSize="11" Foreground="#3A4F63" VerticalAlignment="Center" HorizontalAlignment="Center" />
                  <NumericUpDown Grid.Column="8" Value="{Binding MaxChange, Mode=TwoWay}"
                                 FormatString="F1" Increment="0.5"
                                 Background="#131F2E" Foreground="#E8F0FE"
                                 BorderBrush="#445E78" CornerRadius="8" Padding="8,6" MinHeight="38" />

                  <TextBlock Grid.Column="10" Text="RSI" FontSize="10" Foreground="#5C6E82" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="12" Value="{Binding MinRsi, Mode=TwoWay}"
                                 Minimum="0" Maximum="100" Increment="5"
                                 FormatString="F0"
                                 Background="#131F2E" Foreground="#E8F0FE"
                                 BorderBrush="#445E78" CornerRadius="8" Padding="8,6" MinHeight="38" />
                  <TextBlock Grid.Column="13" Text="…" FontSize="11" Foreground="#3A4F63" VerticalAlignment="Center" HorizontalAlignment="Center" />
                  <NumericUpDown Grid.Column="14" Value="{Binding MaxRsi, Mode=TwoWay}"
                                 Minimum="0" Maximum="100" Increment="5"
                                 FormatString="F0"
                                 Background="#131F2E" Foreground="#E8F0FE"
                                 BorderBrush="#445E78" CornerRadius="8" Padding="8,6" MinHeight="38" />

                  <TextBlock Grid.Column="16" Text="Volume min $" FontSize="10" Foreground="#5C6E82" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="18" Value="{Binding MinVolume, Mode=TwoWay}"
                                 Minimum="0" Increment="1000000" FormatString="N0"
                                 Background="#131F2E" Foreground="#E8F0FE"
                                 BorderBrush="#445E78" CornerRadius="8" Padding="8,6" MinHeight="38" />
                </Grid>
              </StackPanel>
            </Border>

            <!-- Main table + Alerts (side-by-side) ──────────────────────── -->
            <Grid ColumnDefinitions="*,12,300">

              <!-- Scanner table -->
              <Border Background="#0D1B29" CornerRadius="10" Padding="14,12">
                <StackPanel Spacing="8">

                  <!-- Column headers (sortable) -->
                  <Grid ColumnDefinitions="30,*,90,80,90,80,70,70">
                    <TextBlock Grid.Column="0" Text="" FontSize="10" Foreground="#3A4F63" />
                    <Button Grid.Column="1" Classes="SortHeader"
                            Command="{Binding SortByCommand}" CommandParameter="symbol">
                      Symbol</Button>
                    <Button Grid.Column="2" Classes="SortHeader"
                            Command="{Binding SortByCommand}" CommandParameter="price"
                            HorizontalAlignment="Right">Price</Button>
                    <Button Grid.Column="3" Classes="SortHeader"
                            Command="{Binding SortByCommand}" CommandParameter="change"
                            HorizontalAlignment="Right">24h %</Button>
                    <Button Grid.Column="4" Classes="SortHeader"
                            Command="{Binding SortByCommand}" CommandParameter="volume"
                            HorizontalAlignment="Right">Volume</Button>
                    <Button Grid.Column="5" Classes="SortHeader"
                            Command="{Binding SortByCommand}" CommandParameter="rsi"
                            HorizontalAlignment="Right">RSI</Button>
                    <Button Grid.Column="6" Classes="SortHeader"
                            Command="{Binding SortByCommand}" CommandParameter="activity"
                            HorizontalAlignment="Right">Act.</Button>
                    <TextBlock Grid.Column="7" Text="H/L" FontSize="10"
                               Foreground="#3A4F63" HorizontalAlignment="Right" VerticalAlignment="Center" />
                  </Grid>

                  <Rectangle Height="1" Fill="#1E3A5F" />

                  <!-- Rows -->
                  <ScrollViewer MaxHeight="520" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Rows}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Button Background="{Binding RowBackground}"
                                  Command="{Binding $parent[ItemsControl].DataContext.GoToTradingCommand}"
                                  CommandParameter="{Binding}"
                                  Padding="0" Margin="0,1"
                                  HorizontalContentAlignment="Stretch">
                            <Grid ColumnDefinitions="30,*,90,80,90,80,70,70" Margin="4,5">
                              <!-- Hot badge / glyph -->
                              <TextBlock Grid.Column="0" Text="{Binding HotBadgeText}"
                                         FontSize="13" VerticalAlignment="Center"
                                         HorizontalAlignment="Center" />
                              <!-- Symbol + exchange -->
                              <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Symbol}" FontSize="12"
                                           FontWeight="SemiBold" Foreground="#E8F0FE" />
                                <TextBlock Text="{Binding Exchange}" FontSize="9"
                                           Foreground="#3A4F63" />
                              </StackPanel>
                              <!-- Price -->
                              <TextBlock Grid.Column="2" Text="{Binding PriceLabel}"
                                         FontFamily="Consolas" FontSize="11"
                                         Foreground="#8FA3B8"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- 24h % change (colored) -->
                              <TextBlock Grid.Column="3" Text="{Binding ChangeLabel}"
                                         FontFamily="Consolas" FontSize="12"
                                         FontWeight="SemiBold"
                                         Foreground="{Binding ChangeBrush}"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- Volume -->
                              <TextBlock Grid.Column="4" Text="{Binding VolumeLabel}"
                                         FontFamily="Consolas" FontSize="11"
                                         Foreground="#5C6E82"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- RSI (colored) -->
                              <TextBlock Grid.Column="5" Text="{Binding RsiLabel}"
                                         FontFamily="Consolas" FontSize="12"
                                         FontWeight="SemiBold"
                                         Foreground="{Binding RsiBrush}"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- Activity -->
                              <TextBlock Grid.Column="6" Text="{Binding ActivityLabel}"
                                         FontFamily="Consolas" FontSize="11"
                                         Foreground="#5C6E82"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                              <!-- High / Low -->
                              <TextBlock Grid.Column="7" Text="{Binding HighLowLabel}"
                                         FontFamily="Consolas" FontSize="9"
                                         Foreground="#3A4F63"
                                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </StackPanel>
              </Border>

              <!-- Right column: Alerts + Price Levels ──────────────────── -->
              <StackPanel Grid.Column="2" Spacing="10">

                <!-- Alerts -->
                <Border Background="#0D1B29" CornerRadius="10" Padding="14,12">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Alerts" FontSize="13" FontWeight="SemiBold"
                               Foreground="#8FA3B8" />
                    <Rectangle Height="1" Fill="#1E3A5F" />
                    <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                      <ItemsControl ItemsSource="{Binding Alerts}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Padding="6,5" Margin="0,1">
                              <Grid ColumnDefinitions="12,*,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding SeverityDot}"
                                           Foreground="{Binding SeverityBrush}"
                                           FontSize="10" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Spacing="1" Margin="6,0,0,0">
                                  <TextBlock Text="{Binding Symbol}" FontSize="11"
                                             FontWeight="Bold" Foreground="#E8F0FE" />
                                  <TextBlock Text="{Binding Message}" FontSize="10"
                                             Foreground="#8FA3B8" TextWrapping="Wrap" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding TimeLabel}"
                                           FontSize="9" Foreground="#3A4F63"
                                           VerticalAlignment="Top" />
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </StackPanel>
                </Border>

                <!-- Price Levels -->
                <Border Background="#0D1B29" CornerRadius="10" Padding="14,12">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Price Levels" FontSize="13" FontWeight="SemiBold"
                               Foreground="#8FA3B8" />

                    <!-- Add level form -->
                    <Grid ColumnDefinitions="*,6,*,6,Auto">
                      <TextBox Grid.Column="0" Text="{Binding LevelSymbol, Mode=TwoWay}"
                               PlaceholderText="BTCUSDT" FontSize="12"
                               Background="#131F2E" Foreground="#E8F0FE"
                               BorderBrush="#445E78" CornerRadius="8" Padding="10,8" MinHeight="38" />
                      <NumericUpDown Grid.Column="2" Value="{Binding LevelPrice, Mode=TwoWay}"
                                     Minimum="0" FormatString="N2" Increment="100"
                                     Background="#131F2E" Foreground="#E8F0FE"
                                     BorderBrush="#445E78" CornerRadius="8" Padding="8,6" MinHeight="38" />
                      <Button Grid.Column="4" Command="{Binding AddLevelCommand}"
                              Background="#1A3A5C" Foreground="#21E6C1"
                              CornerRadius="8" Padding="12,8" FontSize="12" MinHeight="38">
                        + Add
                      </Button>
                    </Grid>
                    <!-- Resistance / Support toggle -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="Type:" FontSize="10" Foreground="#5C6E82" VerticalAlignment="Center" />
                      <ToggleSwitch IsChecked="{Binding LevelIsResistance, Mode=TwoWay}"
                                   OnContent="Resistance" OffContent="Support"
                                   FontSize="10" VerticalAlignment="Center" />
                    </StackPanel>

                    <Rectangle Height="1" Fill="#1E3A5F" />

                    <!-- Level list -->
                    <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                      <ItemsControl ItemsSource="{Binding Levels}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="*,60,50,24" Margin="0,3">
                              <StackPanel Grid.Column="0" Spacing="0">
                                <TextBlock Text="{Binding Symbol}" FontSize="11"
                                           FontWeight="SemiBold" Foreground="#E8F0FE" />
                                <TextBlock Text="{Binding Note}" FontSize="9"
                                           Foreground="#3A4F63" />
                              </StackPanel>
                              <TextBlock Grid.Column="1" Text="{Binding PriceLabel}"
                                         FontFamily="Consolas" FontSize="11"
                                         Foreground="#8FA3B8"
                                         VerticalAlignment="Center" HorizontalAlignment="Right" />
                              <Border Grid.Column="2" CornerRadius="4" Padding="5,2"
                                      Background="#0A1520" HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                                <TextBlock Text="{Binding KindLabel}" FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="{Binding KindBrush}" />
                              </Border>
                              <Button Grid.Column="3"
                                      Command="{Binding $parent[ItemsControl].DataContext.RemoveLevelCommand}"
                                      CommandParameter="{Binding}"
                                      Background="Transparent" Foreground="#3A4F63"
                                      FontSize="12" Padding="2,0"
                                      VerticalAlignment="Center">×</Button>
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </StackPanel>
                </Border>

              </StackPanel>
            </Grid>

            <!-- ══════════════════════════════════════════════════════════════
                 DEX TRADING STATION  (visible only when DEX mode active)
            ══════════════════════════════════════════════════════════════ -->
            <Border Background="#070E17" CornerRadius="10" Padding="0"
                    IsVisible="{Binding $parent[Window].DataContext.IsDexTradingMode}">

              <!-- Inner panel re-binds to DexTradingVM so all children use short paths -->
              <StackPanel Spacing="16" Margin="16,14"
                          DataContext="{Binding $parent[Window].DataContext.DexTradingVM}">

                <!-- ── Station header ──────────────────────────────────────── -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                  <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="DEX Trading Station"
                               FontSize="18" FontWeight="Bold" Foreground="#E8F0FE" />
                    <TextBlock Text="{Binding WalletSessionSummary}"
                               Foreground="#8FA3B8" FontSize="12" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding WalletBalanceSummary}"
                               Foreground="#21E6C1" FontWeight="Bold"
                               HorizontalAlignment="Right" />
                    <TextBlock Text="{Binding WalletTradeStatus}"
                               Foreground="#8FA3B8" FontSize="11"
                               HorizontalAlignment="Right" />
                  </StackPanel>
                </Grid>

                <Rectangle Height="1" Fill="#1E3A5F" />

                <!-- ── Two-column layout: chart left, trading right ─────────── -->
                <Grid ColumnDefinitions="1.5*,*" ColumnSpacing="16">

                  <!-- ── LEFT: Chart Desk ──────────────────────────────────── -->
                  <Border Classes="Panel" Grid.Column="0">
                    <StackPanel Spacing="12">

                      <!-- Title + timeframe row -->
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="H2" Text="Price History" />
                        <WrapPanel Grid.Column="1" Orientation="Horizontal"
                                   VerticalAlignment="Center">
                          <Button Content="15M"
                                  Command="{Binding SelectChartRangeCommand}"
                                  CommandParameter="15M"
                                  Classes="GhostButton" Width="52" Margin="0,0,6,0"
                                  Background="{Binding SelectedChartRange, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                          <Button Content="4H"
                                  Command="{Binding SelectChartRangeCommand}"
                                  CommandParameter="4H"
                                  Classes="GhostButton" Width="52" Margin="0,0,6,0" />
                          <Button Content="12H"
                                  Command="{Binding SelectChartRangeCommand}"
                                  CommandParameter="12H"
                                  Classes="GhostButton" Width="52" Margin="0,0,6,0" />
                          <Button Content="1D"
                                  Command="{Binding SelectChartRangeCommand}"
                                  CommandParameter="1D"
                                  Classes="GhostButton" Width="52" Margin="0,0,6,0" />
                          <Button Content="1W"
                                  Command="{Binding SelectChartRangeCommand}"
                                  CommandParameter="1W"
                                  Classes="GhostButton" Width="52" />
                        </WrapPanel>
                      </Grid>

                      <!-- Price stat KPIs (mirror CEX: Last / High / Low / Change) -->
                      <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                        <Border Classes="SurfaceCard" Grid.Column="0">
                          <StackPanel Spacing="4">
                            <TextBlock Classes="Overline" Text="Last Price" />
                            <TextBlock Classes="Metric" FontSize="20"
                                       Text="{Binding SelectedToken.PriceUsd, StringFormat=\${0:N6}}" />
                          </StackPanel>
                        </Border>
                        <Border Classes="SurfaceCard" Grid.Column="1">
                          <StackPanel Spacing="4">
                            <TextBlock Classes="Overline" Text="High" />
                            <TextBlock Classes="Metric" FontSize="20" Foreground="#21E6C1"
                                       Text="{Binding ChartHigh, StringFormat=\${0:N6}}" />
                          </StackPanel>
                        </Border>
                        <Border Classes="SurfaceCard" Grid.Column="2">
                          <StackPanel Spacing="4">
                            <TextBlock Classes="Overline" Text="Low" />
                            <TextBlock Classes="Metric" FontSize="20" Foreground="#FF6B6B"
                                       Text="{Binding ChartLow, StringFormat=\${0:N6}}" />
                          </StackPanel>
                        </Border>
                        <Border Classes="SurfaceCard" Grid.Column="3">
                          <StackPanel Spacing="4">
                            <TextBlock Classes="Overline" Text="Change" />
                            <TextBlock Classes="Metric" FontSize="20"
                                       Text="{Binding ChartChangePercent, StringFormat={}{0:+0.##;-0.##;0}%}" />
                          </StackPanel>
                        </Border>
                      </Grid>

                      <!-- Chart canvas -->
                      <Border Classes="SoftPanel">
                        <StackPanel Spacing="8">
                          <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding ChartStatusMessage}"
                                       Foreground="#8B949E" TextWrapping="Wrap" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ChartTelemetry}"
                                       Foreground="#14E0C1" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding ChartSource, StringFormat=src: {0}}"
                                       Foreground="#8B949E" FontSize="11" />
                            <TextBlock Grid.Column="3"
                                       Text="{Binding SelectedChartRange, StringFormat=range: {0}}"
                                       Foreground="#8B949E" FontSize="11" />
                          </Grid>

                          <Border Background="#0D1117"
                                  BorderBrush="#30363D" BorderThickness="1"
                                  CornerRadius="10" Padding="12" MinHeight="300">
                            <Grid RowDefinitions="*,Auto">
                              <ctrl:DexPriceChart Grid.Row="0"
                                                  Height="320"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch"
                                                  Candles="{Binding ChartCandles}" />
                              <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding ChartStartLabel}"
                                           Foreground="#8B949E" FontSize="11" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding ChartEndLabel}"
                                           Foreground="#8B949E" FontSize="11" />
                              </Grid>
                            </Grid>
                          </Border>
                        </StackPanel>
                      </Border>

                      <!-- Secondary KPIs: Volume / Liquidity / 24h change -->
                      <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <Border Classes="SoftPanel" Grid.Column="0" Padding="10">
                          <StackPanel Spacing="4">
                            <TextBlock Classes="Overline" Text="24h Volume" />
                            <TextBlock FontSize="16" FontWeight="Bold"
                                       Text="{Binding SelectedToken.Volume24h, StringFormat=\${0:N0}}" />
                          </StackPanel>
                        </Border>
                        <Border Classes="SoftPanel" Grid.Column="1" Padding="10">
                          <StackPanel Spacing="4">
                            <TextBlock Classes="Overline" Text="Liquidity" />
                            <TextBlock FontSize="16" FontWeight="Bold"
                                       Text="{Binding SelectedToken.LiquidityUsd, StringFormat=\${0:N0}}" />
                          </StackPanel>
                        </Border>
                        <Border Classes="SoftPanel" Grid.Column="2" Padding="10">
                          <StackPanel Spacing="4">
                            <TextBlock Classes="Overline" Text="24h Change" />
                            <TextBlock FontSize="16" FontWeight="Bold"
                                       Text="{Binding SelectedToken.PriceChange24h, StringFormat={}{0:+0.##;-0.##;0}%}" />
                          </StackPanel>
                        </Border>
                      </Grid>

                    </StackPanel>
                  </Border>

                  <!-- ── RIGHT: Trading Module ──────────────────────────────── -->
                  <Border Classes="Panel" Grid.Column="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                      <TextBlock Classes="H2" Text="Trading Module" />

                      <!-- Token search / selector -->
                      <Border Classes="SoftPanel">
                        <StackPanel Spacing="10">
                          <TextBlock Classes="Overline" Text="Token" />
                          <TextBox Text="{Binding SearchText}"
                                   PlaceholderText="Symbol, name or address" />
                          <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" Content="SEARCH"
                                    Classes="GhostButton"
                                    Command="{Binding SearchCommand}" />
                            <Button Grid.Column="1" Content="REFRESH"
                                    Classes="GhostButton"
                                    Command="{Binding RefreshCommand}" />
                          </Grid>
                          <ComboBox ItemsSource="{Binding Tokens}"
                                    SelectedItem="{Binding SelectedToken}"
                                    HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                              <DataTemplate x:DataType="vm:DexTokenItemViewModel">
                                <TextBlock Text="{Binding DisplayName}" />
                              </DataTemplate>
                            </ComboBox.ItemTemplate>
                          </ComboBox>
                          <TextBlock Text="{Binding SelectedTokenSubtitle}"
                                     Foreground="#8FA3B8" TextWrapping="Wrap" FontSize="11" />
                        </StackPanel>
                      </Border>

                      <!-- Guard status strip -->
                      <Border Classes="GuardStripCard">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                          <Border Classes="GuardChip"
                                  Background="#10251F"
                                  BorderBrush="{Binding DexGuardStatusBrush}">
                            <TextBlock Text="{Binding DexGuardStatusLabel}"
                                       Foreground="{Binding DexGuardStatusBrush}"
                                       FontWeight="Bold" />
                          </Border>
                          <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="{Binding DexGuardSummary}"
                                       FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding DexGuardDetail}"
                                       Foreground="#8B949E" TextWrapping="Wrap" FontSize="11" />
                          </StackPanel>
                        </Grid>
                      </Border>

                      <!-- Wallet balance KPIs -->
                      <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Border Classes="SurfaceCard" Grid.Column="0">
                          <StackPanel Spacing="4">
                            <TextBlock Classes="Overline" Text="Native" />
                            <TextBlock FontSize="15" FontWeight="Bold" Foreground="#21E6C1"
                                       Text="{Binding WalletBalanceSummary}" TextTrimming="CharacterEllipsis" />
                          </StackPanel>
                        </Border>
                        <Border Classes="SurfaceCard" Grid.Column="1">
                          <StackPanel Spacing="4">
                            <TextBlock Classes="Overline" Text="Quote" />
                            <TextBlock FontSize="15" FontWeight="Bold" Foreground="#F4B860"
                                       Text="{Binding QuoteAssetBalanceLabel}" TextTrimming="CharacterEllipsis" />
                          </StackPanel>
                        </Border>
                      </Grid>

                      <!-- Spendable + pair compat -->
                      <TextBlock Text="{Binding SpendableQuoteBalanceLabel}"
                                 Foreground="#14E0C1" FontSize="11" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding PairCompatibilityMessage}"
                                 Foreground="{Binding QuoteAssetModeBrush}"
                                 FontSize="11" TextWrapping="Wrap" />

                      <!-- Quote asset + slippage -->
                      <Grid ColumnDefinitions="Auto,*,Auto,74" ColumnSpacing="8"
                            IsEnabled="{Binding CanTradeSelectedToken}">
                        <TextBlock Grid.Column="0" Text="Quote" VerticalAlignment="Center" Foreground="#8FA3B8" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding QuoteAssetOptions}"
                                  SelectedItem="{Binding SelectedQuoteAssetSymbol}" />
                        <TextBlock Grid.Column="2" Text="Slip%" VerticalAlignment="Center" Foreground="#8FA3B8" />
                        <NumericUpDown Grid.Column="3"
                                       Value="{Binding SlippagePercent}"
                                       Increment="0.5" FormatString="0.#"
                                       Minimum="0.1" Maximum="50"
                                       ToolTip.Tip="{Binding SlippageSummary}" />
                      </Grid>

                      <!-- ── BUY ── -->
                      <TextBlock Classes="Overline" Text="BUY" Margin="0,4,0,0" />
                      <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="6"
                            IsEnabled="{Binding CanTradeSelectedToken}">
                        <Button Grid.Column="0" Content="25%" Classes="GhostButton"
                                Command="{Binding ApplyBuyBalancePresetCommand}" CommandParameter="25" />
                        <Button Grid.Column="1" Content="50%" Classes="GhostButton"
                                Command="{Binding ApplyBuyBalancePresetCommand}" CommandParameter="50" />
                        <Button Grid.Column="2" Content="75%" Classes="GhostButton"
                                Command="{Binding ApplyBuyBalancePresetCommand}" CommandParameter="75" />
                        <Button Grid.Column="3" Content="100%" Classes="GhostButton"
                                Command="{Binding ApplyBuyBalancePresetCommand}" CommandParameter="100" />
                      </Grid>
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8"
                            IsEnabled="{Binding CanTradeSelectedToken}">
                        <NumericUpDown Grid.Column="0"
                                       Value="{Binding BuyAmountBnb}"
                                       Increment="0.001" FormatString="0.0000" Minimum="0"
                                       HorizontalAlignment="Stretch" />
                        <Button Grid.Column="1" Content="MAX" Classes="GhostButton"
                                Command="{Binding UseMaxBuyAmountCommand}" />
                      </Grid>
                      <TextBlock Text="{Binding BuyQuoteLabel}"
                                 Foreground="{Binding BuyQuoteBrush}"
                                 FontWeight="SemiBold"
                                 IsVisible="{Binding HasSelectedToken}" />

                      <!-- ── SELL ── -->
                      <TextBlock Classes="Overline" Text="SELL" Margin="0,4,0,0" />
                      <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="Bal:" VerticalAlignment="Center" Foreground="#8FA3B8" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding TokenBalanceLabel}"
                                   VerticalAlignment="Center" Foreground="#F4B860"
                                   IsVisible="{Binding HasSelectedToken}" />
                        <Button Grid.Column="2" Content="↻" Classes="GhostButton" Width="34"
                                Command="{Binding RefreshTokenBalanceCommand}"
                                ToolTip.Tip="Refresh token balance" />
                        <NumericUpDown Grid.Column="3"
                                       Value="{Binding SellAmountTokens}"
                                       Increment="1" FormatString="0.########" Minimum="0" Width="130"
                                       IsEnabled="{Binding CanTradeSelectedToken}" />
                      </Grid>
                      <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="6"
                            IsEnabled="{Binding CanTradeSelectedToken}">
                        <Button Grid.Column="0" Content="25%" Classes="GhostButton"
                                Command="{Binding ApplySellBalancePresetCommand}" CommandParameter="25" />
                        <Button Grid.Column="1" Content="50%" Classes="GhostButton"
                                Command="{Binding ApplySellBalancePresetCommand}" CommandParameter="50" />
                        <Button Grid.Column="2" Content="75%" Classes="GhostButton"
                                Command="{Binding ApplySellBalancePresetCommand}" CommandParameter="75" />
                        <Button Grid.Column="3" Content="100%" Classes="GhostButton"
                                Command="{Binding ApplySellBalancePresetCommand}" CommandParameter="100" />
                      </Grid>

                      <!-- Execute -->
                      <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Grid.Column="0" Content="BUY TOKEN" Classes="BuyButton"
                                Command="{Binding BuyCommand}"
                                HorizontalAlignment="Stretch"
                                IsEnabled="{Binding CanBuySelectedTokenLive}"
                                ToolTip.Tip="{Binding ManualBuyBlockedReason}" />
                        <Button Grid.Column="1" Content="SELL TOKEN" Classes="SellButton"
                                Command="{Binding SellCommand}"
                                HorizontalAlignment="Stretch"
                                IsEnabled="{Binding CanSellSelectedTokenLive}"
                                ToolTip.Tip="{Binding ManualSellBlockedReason}" />
                      </Grid>

                      <!-- Status -->
                      <TextBlock Text="{Binding ManualBuyBlockedReason}"
                                 Foreground="#F4B860" TextWrapping="Wrap" FontSize="11"
                                 IsVisible="{Binding !CanBuySelectedTokenLive}" />
                      <TextBlock Text="{Binding StatusMessage}"
                                 Foreground="#8FA3B8" TextWrapping="Wrap" FontSize="12"
                                 IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                      <!-- Token links -->
                      <TextBlock Text="{Binding SelectedToken.TokenAddress, StringFormat=Token: {0}}"
                                 Foreground="#3A4F63" TextWrapping="Wrap" FontSize="10"
                                 IsVisible="{Binding HasSelectedToken}" />
                    </StackPanel>
                    </ScrollViewer>
                  </Border>

                </Grid>
              </StackPanel>
            </Border>

          </StackPanel>
          </Border>
          <!-- ═══ End Multi-Market Scanner ═══ -->

          <!-- ═══════════════════════════════════════════════════════════════
               LIQUIDATION HEATMAP
          ════════════════════════════════════════════════════════════════ -->
          <StackPanel Spacing="16" IsVisible="{Binding IsLiquidationSectionVisible}">

            <!-- Proximity alert banner -->
            <Border IsVisible="{Binding LiquidationHeatmapVM.IsProximityAlertActive}"
                    Background="#2A1A10" BorderBrush="#FF9500" BorderThickness="0,0,0,1" Padding="14,10">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="⚡" FontSize="16" VerticalAlignment="Center" Foreground="#FF9500" />
                <TextBlock Text="{Binding LiquidationHeatmapVM.ProximityAlertMessage}"
                           Foreground="#FF9500" FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center" TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="10">
              <StackPanel Grid.Column="0">
                <TextBlock Classes="H1" Text="Liquidation Heatmap" />
                <TextBlock Text="{Binding LiquidationHeatmapVM.StatusLabel}"
                           Foreground="#8FA3B8" FontSize="11" />
              </StackPanel>
              <TextBlock Grid.Column="1" Text="{Binding LiquidationHeatmapVM.DataSourceLabel}"
                         Foreground="#21E6C1" FontSize="11" FontWeight="SemiBold"
                         VerticalAlignment="Center" />
              <CheckBox Grid.Column="2" IsChecked="{Binding LiquidationHeatmapVM.ShowLongs}"
                        Content="Longs" Foreground="#21E6C1" VerticalAlignment="Center" />
              <CheckBox Grid.Column="3" IsChecked="{Binding LiquidationHeatmapVM.ShowShorts}"
                        Content="Shorts" Foreground="#FF6B6B" VerticalAlignment="Center" />
              <Button Grid.Column="4" Content="&#x21BA; Refresh"
                      Classes="GhostButton"
                      Command="{Binding LiquidationHeatmapVM.RefreshCommand}"
                      IsEnabled="{Binding !LiquidationHeatmapVM.IsLoading}" />
            </Grid>

            <!-- ── AI Liquidity Magnet (#13) ── -->
            <Border Classes="Panel" Padding="14,12">
              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <StackPanel Grid.Column="0">
                    <TextBlock Text="🧠 AI Liquidity Magnet" FontWeight="SemiBold" Foreground="#E8F0FE" FontSize="13" />
                    <TextBlock Text="Which liquidation cluster is pulling price?" Foreground="#5C6E82" FontSize="11" />
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="{Binding LiquidationHeatmapVM.InsightSource}"
                             Foreground="#5C6E82" FontSize="10" VerticalAlignment="Center" Margin="0,0,10,0" />
                  <Button Grid.Column="2" Content="Analyze with AI"
                          Command="{Binding LiquidationHeatmapVM.AnalyzeWithAiCommand}"
                          IsEnabled="{Binding !LiquidationHeatmapVM.InsightRunning}" Foreground="#21E6C1" />
                </Grid>
                <StackPanel Spacing="5" IsVisible="{Binding LiquidationHeatmapVM.HasInsight}">
                  <TextBlock Text="{Binding LiquidationHeatmapVM.InsightSignal}"
                             Foreground="{Binding LiquidationHeatmapVM.InsightSignalBrush}" FontWeight="Bold" FontSize="13" />
                  <TextBlock Text="{Binding LiquidationHeatmapVM.InsightSummary}" Foreground="#D7E3EE" FontSize="12" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding LiquidationHeatmapVM.InsightBullets}" Foreground="#8FA3B8" FontSize="11" TextWrapping="Wrap"
                             IsVisible="{Binding LiquidationHeatmapVM.InsightBullets, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Symbol quick-select -->
            <WrapPanel Orientation="Horizontal">
              <Button Content="BTC" Classes="GhostButton" Margin="0,0,6,0"
                      Command="{Binding LiquidationHeatmapVM.SetSymbolCommand}"
                      CommandParameter="BTCUSDT" />
              <Button Content="ETH" Classes="GhostButton" Margin="0,0,6,0"
                      Command="{Binding LiquidationHeatmapVM.SetSymbolCommand}"
                      CommandParameter="ETHUSDT" />
              <Button Content="SOL" Classes="GhostButton" Margin="0,0,6,0"
                      Command="{Binding LiquidationHeatmapVM.SetSymbolCommand}"
                      CommandParameter="SOLUSDT" />
              <Button Content="BNB" Classes="GhostButton" Margin="0,0,6,0"
                      Command="{Binding LiquidationHeatmapVM.SetSymbolCommand}"
                      CommandParameter="BNBUSDT" />
              <Button Content="DOGE" Classes="GhostButton" Margin="0,0,6,0"
                      Command="{Binding LiquidationHeatmapVM.SetSymbolCommand}"
                      CommandParameter="DOGEUSDT" />
              <TextBox Text="{Binding LiquidationHeatmapVM.Symbol}"
                       PlaceholderText="XRPUSDT" Width="130" Margin="6,0,0,0" />
            </WrapPanel>

            <!-- KPI row -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
              <Border Grid.Column="0" Classes="SurfaceCard">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Current Price" />
                  <TextBlock Classes="Metric"
                             Text="{Binding LiquidationHeatmapVM.CurrentPrice, StringFormat=$ {0:N2}}"
                             Foreground="#F4B860" />
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Classes="SurfaceCard">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Top Long Liq Level" />
                  <TextBlock Text="{Binding LiquidationHeatmapVM.TopLongLabel}"
                             Foreground="#21E6C1" FontSize="13" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Classes="SurfaceCard">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Top Short Liq Level" />
                  <TextBlock Text="{Binding LiquidationHeatmapVM.TopShortLabel}"
                             Foreground="#FF6B6B" FontSize="13" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
            </Grid>

            <!-- Main heatmap — Canvas 1200×460, no Viewbox (avoids Avalonia 12 stretch bug).
                 HorizontalAlignment="Center" centres on wide screens; ClipToBounds clips
                 symmetrically on narrow ones so longs/shorts stay balanced. -->
            <Grid ColumnDefinitions="*,56" ColumnSpacing="0">

              <Border Grid.Column="0" Background="#04101A" CornerRadius="8"
                      ClipToBounds="True" Height="460">
                <Canvas Width="1200" Height="460"
                        HorizontalAlignment="Center" VerticalAlignment="Top">

                  <!-- Long bars — teal, left of centre -->
                  <Path Data="{Binding LiquidationHeatmapVM.LongBarsGeometry}"
                        Fill="#CC21E6C1"
                        Stroke="#21E6C1"
                        StrokeThickness="1" />

                  <!-- Short bars — red, right of centre -->
                  <Path Data="{Binding LiquidationHeatmapVM.ShortBarsGeometry}"
                        Fill="#CCFF4444"
                        Stroke="#FF4444"
                        StrokeThickness="1" />

                  <!-- Centre divider at X=600 -->
                  <Line StartPoint="600,0" EndPoint="600,460"
                        Stroke="#2A4A60" StrokeThickness="1.5" />

                  <!-- Current price dashed horizontal line -->
                  <Path Data="{Binding LiquidationHeatmapVM.CurrentPriceGeometry}"
                        Stroke="#F4B860"
                        StrokeThickness="2.5"
                        StrokeDashArray="8,4" />

                  <!-- Column headers -->
                  <TextBlock Canvas.Left="4"   Canvas.Top="4"
                             Text="◀  LONGS" Foreground="#6021E6C1" FontSize="14" FontWeight="Bold" />
                  <TextBlock Canvas.Left="610" Canvas.Top="4"
                             Text="SHORTS  ▶" Foreground="#60FF4444" FontSize="14" FontWeight="Bold" />
                </Canvas>
              </Border>

              <!-- Price axis labels — absolute-positioned on a Canvas -->
              <ItemsControl Grid.Column="1"
                            ItemsSource="{Binding LiquidationHeatmapVM.PriceLabels}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <Canvas Width="56" Height="460" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:PriceAxisLabel">
                    <TextBlock Text="{Binding Text}"
                               Foreground="#5A7080"
                               FontSize="10"
                               Canvas.Left="3"
                               Canvas.Top="{Binding Y}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

            </Grid>

            <!-- Legend -->
            <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="8">
              <Border Grid.Column="0" Width="12" Height="12" Background="#4021E6C1"
                      BorderBrush="#21E6C1" BorderThickness="1" CornerRadius="2" />
              <TextBlock Grid.Column="1" Text="Long liquidations (bears buy here)" Foreground="#8FA3B8" FontSize="11" VerticalAlignment="Center" />
              <Border Grid.Column="2" Width="12" Height="12" Background="#40FF4444"
                      BorderBrush="#FF4444" BorderThickness="1" CornerRadius="2" />
              <TextBlock Grid.Column="3" Text="Short liquidations (bulls sell here)" Foreground="#8FA3B8" FontSize="11" VerticalAlignment="Center" />
            </Grid>

            <!-- Note about data source -->
            <TextBlock Foreground="#4A6070" FontSize="11" TextWrapping="Wrap">
              <Run Text="Data: " />
              <Run Text="{Binding LiquidationHeatmapVM.DataSourceLabel}" Foreground="#21E6C1" />
              <Run Text=" · Set COINGLASS_API_KEY env var for real liquidation data. Without key — estimated from Binance Futures order book + leverage model. Refreshes every 5 min." />
            </TextBlock>

          </StackPanel>

          <!-- ═══════════════════════════════════════════════════════════════
               COMPOSITE BOT — Rule Editor
          ════════════════════════════════════════════════════════════════ -->
          <StackPanel Spacing="16" IsVisible="{Binding IsRulesSectionVisible}">

            <!-- Header bar -->
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
              <StackPanel Grid.Column="0">
                <TextBlock Classes="H1" Text="Composite Bot — Rule Engine" />
                <TextBlock Text="{Binding CompositeRuleVM.EngineStatus}"
                           Foreground="{Binding CompositeRuleVM.EngineStatusColor}"
                           FontSize="11" />
              </StackPanel>
              <Button Grid.Column="1"
                      Content="{Binding CompositeRuleVM.EngineButtonLabel}"
                      Command="{Binding CompositeRuleVM.ToggleEngineCommand}"
                      Foreground="{Binding CompositeRuleVM.EngineButtonColor}"
                      Classes="GhostButton" />
              <Button Grid.Column="2" Content="▷ Test Now"
                      Command="{Binding CompositeRuleVM.TestNowCommand}"
                      Classes="GhostButton"
                      ToolTip.Tip="Evaluate all active rules immediately" />
              <Button Grid.Column="3" Content="+ New Rule"
                      Command="{Binding CompositeRuleVM.AddRuleCommand}"
                      Classes="GhostButton"
                      Foreground="#21E6C1" />
            </Grid>

            <!-- ── AI: describe a rule in plain English (#3) ── -->
            <Border Classes="SurfaceCard" Padding="14,12">
              <StackPanel Spacing="8">
                <TextBlock Text="🧠 Describe a rule in plain English"
                           FontWeight="SemiBold" Foreground="#E8F0FE" FontSize="13" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                  <TextBox Grid.Column="0"
                           Text="{Binding CompositeRuleVM.NlPrompt}"
                           PlaceholderText="e.g. When ETHUSDT RSI drops below 30, start DCA buy and notify me"
                           VerticalContentAlignment="Center" />
                  <Button Grid.Column="1" Content="Generate"
                          Command="{Binding CompositeRuleVM.GenerateRuleFromTextCommand}"
                          IsEnabled="{Binding !CompositeRuleVM.AiRuleRunning}"
                          Foreground="#21E6C1" />
                </Grid>
                <TextBlock Text="{Binding CompositeRuleVM.AiRuleStatus}"
                           Foreground="#8FA3B8" FontSize="11" TextWrapping="Wrap"
                           IsVisible="{Binding CompositeRuleVM.AiRuleStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
              </StackPanel>
            </Border>

            <!-- Main split: rule list (left) + editor (right) -->
            <Grid ColumnDefinitions="*,Auto,480" ColumnSpacing="0" MinHeight="500">

              <!-- ── Left: rule list ─────────────────────────────────────── -->
              <Border Grid.Column="0" Classes="SurfaceCard" Padding="0">
                <StackPanel>
                  <TextBlock Text="Rules" Classes="H2" Margin="14,12,14,8" />
                  <ScrollViewer MaxHeight="560">
                    <ItemsControl ItemsSource="{Binding CompositeRuleVM.Rules}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:RuleRowVM">
                          <Border Background="{Binding EnabledBackground}"
                                  BorderBrush="#1E3040" BorderThickness="0,0,0,1"
                                  Padding="14,10">
                            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="4">

                              <!-- Row 1: Name + toggle + edit/delete -->
                              <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           Foreground="#D7E3EE"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding EnabledLabel}"
                                           Foreground="{Binding EnabledColor}"
                                           FontSize="10" FontWeight="Bold"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="2"
                                        Content="ON/OFF"
                                        Command="{Binding ToggleCommand}"
                                        Classes="GhostButton"
                                        FontSize="10" Padding="6,2" />
                                <Button Grid.Column="3"
                                        Content="Edit"
                                        Command="{Binding EditCommand}"
                                        Classes="GhostButton"
                                        FontSize="10" Padding="6,2" />
                                <Button Grid.Column="4"
                                        Content="✕"
                                        Command="{Binding DeleteCommand}"
                                        Classes="GhostButton"
                                        Foreground="#FF5D73"
                                        FontSize="10" Padding="6,2" />
                              </Grid>

                              <!-- Row 2: One-line summary -->
                              <TextBlock Grid.Row="1"
                                         Text="{Binding OneLineSummary}"
                                         Foreground="#8FA3B8"
                                         FontSize="11"
                                         TextWrapping="Wrap" />

                              <!-- Row 3: Stats -->
                              <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding CooldownLabel}"
                                           Foreground="#4A6880"
                                           FontSize="10" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding TriggerCountLabel}"
                                           Foreground="#21E6C1"
                                           FontSize="10" />
                              </Grid>

                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>

                  <!-- No rules placeholder -->
                  <TextBlock Text="No rules yet — click '+ New Rule' to add one."
                             Foreground="#4A6880" FontSize="12"
                             HorizontalAlignment="Center" Margin="0,24"
                             IsVisible="{Binding CompositeRuleVM.HasNoRules}" />
                </StackPanel>
              </Border>

              <!-- Separator -->
              <Border Grid.Column="1" Width="1" Background="#1E3040" Margin="0" />

              <!-- ── Right: editor panel ─────────────────────────────────── -->
              <Border Grid.Column="2" Background="#0D1520" Padding="16">
                <Panel>
                <ScrollViewer>
                  <StackPanel Spacing="14"
                              IsVisible="{Binding CompositeRuleVM.IsEditing}">

                    <!-- Editor header -->
                    <TextBlock Text="Rule Editor" Classes="H2" />

                    <!-- Rule name -->
                    <StackPanel Spacing="4">
                      <TextBlock Text="Rule Name" Foreground="#8FA3B8" FontSize="11" />
                      <TextBox Text="{Binding CompositeRuleVM.EditingName}"
                               Background="#111821" Foreground="#D7E3EE"
                               BorderBrush="#2A3F54" />
                    </StackPanel>

                    <!-- Logic + Cooldown row -->
                    <Grid ColumnDefinitions="*,12,*" >
                      <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Condition Logic" Foreground="#8FA3B8" FontSize="11" />
                        <ComboBox ItemsSource="{Binding CompositeRuleVM.LogicOptions}"
                                  SelectedItem="{Binding CompositeRuleVM.SelectedLogic}"
                                  Background="#111821" Foreground="#D7E3EE" />
                      </StackPanel>
                      <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock Text="Cooldown" Foreground="#8FA3B8" FontSize="11" />
                        <ComboBox ItemsSource="{Binding CompositeRuleVM.CooldownOptions}"
                                  SelectedItem="{Binding CompositeRuleVM.SelectedCooldown}"
                                  Background="#111821" Foreground="#D7E3EE" />
                      </StackPanel>
                    </Grid>

                    <!-- ── CONDITIONS ── -->
                    <Border BorderBrush="#1E3040" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                      <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                          <TextBlock Grid.Column="0" Text="CONDITIONS"
                                     Foreground="#21E6C1" FontSize="11"
                                     FontWeight="SemiBold" LetterSpacing="1" />
                          <Button Grid.Column="1" Content="+ Add Condition"
                                  Command="{Binding CompositeRuleVM.AddConditionCommand}"
                                  Classes="GhostButton" FontSize="10" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding CompositeRuleVM.EditingConditions}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:RuleConditionEditorVM">
                              <Border Background="#0F1825" CornerRadius="6"
                                      Padding="10,8" Margin="0,0,0,6">
                                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6">

                                  <!-- Row 0: Type + Remove -->
                                  <Grid Grid.Row="0"
                                        ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <ComboBox Grid.Column="0"
                                              ItemsSource="{x:Static vm:RuleConditionEditorVM.AllTypes}"
                                              SelectedItem="{Binding SelectedType}"
                                              Background="#111821" Foreground="#D7E3EE" />
                                    <Button Grid.Column="1" Content="✕"
                                            Command="{Binding RemoveCommand}"
                                            Classes="GhostButton"
                                            Foreground="#FF5D73"
                                            FontSize="11" Padding="6,2" />
                                  </Grid>

                                  <!-- Row 1: Symbol + Params -->
                                  <Grid Grid.Row="1"
                                        ColumnDefinitions="Auto,*,Auto,*,Auto,*"
                                        ColumnSpacing="6">
                                    <TextBlock Grid.Column="0" Text="Symbol"
                                               Foreground="#8FA3B8" FontSize="10"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding IsSymbolVisible}" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Symbol}"
                                             IsVisible="{Binding IsSymbolVisible}"
                                             Background="#111821" Foreground="#D7E3EE"
                                             FontSize="11" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Param1Label}"
                                               Foreground="#8FA3B8" FontSize="10"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0" />
                                    <NumericUpDown Grid.Column="3"
                                                   Value="{Binding Param1}"
                                                   Minimum="0" Maximum="999"
                                                   Increment="1"
                                                   Background="#111821" Foreground="#D7E3EE"
                                                   FontSize="11" />
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding Param2Label}"
                                               Foreground="#8FA3B8" FontSize="10"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0"
                                               IsVisible="{Binding IsParam2Visible}" />
                                    <NumericUpDown Grid.Column="5"
                                                   Value="{Binding Param2}"
                                                   Minimum="-9999" Maximum="9999"
                                                   Increment="1"
                                                   Background="#111821" Foreground="#D7E3EE"
                                                   FontSize="11"
                                                   IsVisible="{Binding IsParam2Visible}" />
                                  </Grid>

                                  <!-- Row 2: Summary preview -->
                                  <TextBlock Grid.Row="2"
                                             Text="{Binding Summary}"
                                             Foreground="#4A7090"
                                             FontSize="10" />
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="No conditions yet — click '+ Add Condition'"
                                   Foreground="#4A6880" FontSize="11"
                                   IsVisible="{Binding CompositeRuleVM.HasNoEditingConditions}" />
                      </StackPanel>
                    </Border>

                    <!-- ── ACTIONS ── -->
                    <Border BorderBrush="#1E3040" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                      <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                          <TextBlock Grid.Column="0" Text="ACTIONS"
                                     Foreground="#F4B860" FontSize="11"
                                     FontWeight="SemiBold" LetterSpacing="1" />
                          <Button Grid.Column="1" Content="+ Add Action"
                                  Command="{Binding CompositeRuleVM.AddActionCommand}"
                                  Classes="GhostButton" FontSize="10" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding CompositeRuleVM.EditingActions}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:RuleActionEditorVM">
                              <Border Background="#0F1825" CornerRadius="6"
                                      Padding="10,8" Margin="0,0,0,6">
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="5">

                                  <!-- Row 0: Type + Remove -->
                                  <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <ComboBox Grid.Column="0"
                                              ItemsSource="{x:Static vm:RuleActionEditorVM.AllTypes}"
                                              SelectedItem="{Binding SelectedType}"
                                              Background="#111821" Foreground="#D7E3EE" />
                                    <Button Grid.Column="1" Content="✕"
                                            Command="{Binding RemoveCommand}"
                                            Classes="GhostButton"
                                            Foreground="#FF5D73"
                                            FontSize="11" Padding="6,2" />
                                  </Grid>

                                  <!-- Row 1: Symbol + Amount params -->
                                  <Grid Grid.Row="1"
                                        ColumnDefinitions="Auto,*,Auto,*"
                                        ColumnSpacing="6">
                                    <TextBlock Grid.Column="0" Text="Symbol"
                                               Foreground="#8FA3B8" FontSize="10"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding IsSymbolVisible}" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Symbol}"
                                             IsVisible="{Binding IsSymbolVisible}"
                                             Background="#111821" Foreground="#D7E3EE"
                                             FontSize="11" />
                                    <TextBlock Grid.Column="2" Text="USD $"
                                               Foreground="#8FA3B8" FontSize="10"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0"
                                               IsVisible="{Binding IsAmountVisible}" />
                                    <NumericUpDown Grid.Column="3"
                                                   Value="{Binding Amount}"
                                                   Minimum="0" Maximum="999999"
                                                   Increment="10"
                                                   Background="#111821" Foreground="#D7E3EE"
                                                   FontSize="11"
                                                   IsVisible="{Binding IsAmountVisible}" />
                                  </Grid>

                                  <!-- Row 2: Notification message (only for Notify action) -->
                                  <TextBox Grid.Row="2"
                                           Text="{Binding Message}"
                                           PlaceholderText="Notification message..."
                                           IsVisible="{Binding IsMessageVisible}"
                                           Background="#111821" Foreground="#D7E3EE"
                                           FontSize="11" />

                                  <!-- Row 3: Summary -->
                                  <TextBlock Grid.Row="3"
                                             Text="{Binding Summary}"
                                             Foreground="#4A7090"
                                             FontSize="10" />
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="No actions yet — click '+ Add Action'"
                                   Foreground="#4A6880" FontSize="11"
                                   IsVisible="{Binding CompositeRuleVM.HasNoEditingActions}" />
                      </StackPanel>
                    </Border>

                    <!-- Save / Cancel -->
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                      <Button Grid.Column="1" Content="Cancel"
                              Command="{Binding CompositeRuleVM.CancelEditCommand}"
                              Classes="GhostButton" />
                      <Button Grid.Column="2" Content="✓ Save Rule"
                              Command="{Binding CompositeRuleVM.SaveRuleCommand}"
                              Classes="GhostButton"
                              Foreground="#21E6C1"
                              FontWeight="SemiBold" />
                    </Grid>

                  </StackPanel>
                </ScrollViewer>

                <!-- Placeholder when no rule is being edited -->
                <Border IsVisible="{Binding !CompositeRuleVM.IsEditing}"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                  <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <TextBlock Text="⚡" FontSize="40"
                               HorizontalAlignment="Center"
                               Foreground="#1E3A4C" />
                    <TextBlock Text="Select a rule to edit or click '+ New Rule'"
                               Foreground="#4A6880" FontSize="13"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="The engine evaluates conditions every 10 seconds"
                               Foreground="#2A4A60" FontSize="11"
                               HorizontalAlignment="Center" />
                  </StackPanel>
                </Border>

                </Panel>
              </Border>
            </Grid>

            <!-- Trigger log -->
            <Border Classes="SurfaceCard">
              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="Trigger Log" Classes="H2" />
                  <Button Grid.Column="1" Content="Clear"
                          Command="{Binding CompositeRuleVM.ClearLogCommand}"
                          Classes="GhostButton" FontSize="10" />
                </Grid>
                <ScrollViewer MaxHeight="140">
                  <ItemsControl ItemsSource="{Binding CompositeRuleVM.TriggerLog}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   Foreground="#8FA3B8"
                                   FontSize="11"
                                   FontFamily="Consolas,Courier New,monospace"
                                   Margin="0,1" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
                <TextBlock Text="No triggers yet — start the engine to begin evaluation."
                           Foreground="#4A6880" FontSize="11"
                           IsVisible="{Binding CompositeRuleVM.HasNoTriggerLog}" />
              </StackPanel>
            </Border>

          </StackPanel>

          <!-- ═══════════════════════════════════════════════════════════════
               Trade Journal
          ════════════════════════════════════════════════════════════════ -->
          <StackPanel Spacing="16" IsVisible="{Binding IsJournalSectionVisible}">

            <!-- ── Header ── -->
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
              <TextBlock Grid.Column="0" Classes="H1" Text="Trade Journal" VerticalAlignment="Center" />
              <Button Grid.Column="1" Content="⟳ Refresh"
                      Command="{Binding TradeJournalVM.RefreshCommand}"
                      Classes="GhostButton" FontSize="11" />
              <Button Grid.Column="2" Content="⬇ Export CSV"
                      Command="{Binding TradeJournalVM.ExportCsvCommand}"
                      Classes="GhostButton" FontSize="11" Foreground="#21E6C1" />
            </Grid>
            <TextBlock Text="{Binding TradeJournalVM.ExportStatus}"
                       Foreground="#21E6C1" FontSize="11"
                       IsVisible="{Binding TradeJournalVM.ExportStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <!-- ── AI Coach (#4) ── -->
            <Border Classes="SurfaceCard" Padding="14,12">
              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <StackPanel Grid.Column="0">
                    <TextBlock Text="🧠 AI Coach" FontWeight="SemiBold" Foreground="#E8F0FE" FontSize="13" />
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="{Binding TradeJournalVM.CoachSource}"
                             Foreground="#5C6E82" FontSize="10" VerticalAlignment="Center" Margin="0,0,10,0" />
                  <Button Grid.Column="2" Content="Coach with AI"
                          Command="{Binding TradeJournalVM.ReviewWithAiCommand}"
                          IsEnabled="{Binding !TradeJournalVM.CoachRunning}" Foreground="#21E6C1" />
                </Grid>
                <StackPanel Spacing="6" IsVisible="{Binding TradeJournalVM.HasCoachReview}">
                  <TextBlock Text="{Binding TradeJournalVM.CoachSummary}" Foreground="#D7E3EE" FontSize="12" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding TradeJournalVM.CoachStrengths}" Foreground="#3DDC84" FontSize="11" TextWrapping="Wrap"
                             IsVisible="{Binding TradeJournalVM.CoachStrengths, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                  <TextBlock Text="{Binding TradeJournalVM.CoachLeaks}" Foreground="#F4B860" FontSize="11" TextWrapping="Wrap"
                             IsVisible="{Binding TradeJournalVM.CoachLeaks, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                  <TextBlock Text="{Binding TradeJournalVM.CoachSuggestions}" Foreground="#21E6C1" FontSize="11" TextWrapping="Wrap"
                             IsVisible="{Binding TradeJournalVM.CoachSuggestions, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- ── Filters ── -->
            <Border Classes="SurfaceCard">
              <Grid ColumnDefinitions="Auto,160,Auto,160,*" ColumnSpacing="12">
                <TextBlock Grid.Column="0" Text="Tag" Foreground="#8FA3B8" FontSize="11" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding TradeJournalVM.TagOptions}"
                          SelectedItem="{Binding TradeJournalVM.FilterTag}"
                          FontSize="11" />
                <TextBlock Grid.Column="2" Text="Period" Foreground="#8FA3B8" FontSize="11" VerticalAlignment="Center" />
                <ComboBox Grid.Column="3"
                          ItemsSource="{Binding TradeJournalVM.PeriodOptions}"
                          SelectedItem="{Binding TradeJournalVM.FilterPeriod}"
                          FontSize="11" />
                <TextBox Grid.Column="4"
                         Text="{Binding TradeJournalVM.SearchText}"
                         PlaceholderText="Search symbol / notes…"
                         FontSize="11" />
              </Grid>
            </Border>

            <!-- ── Summary ── -->
            <TextBlock Text="{Binding TradeJournalVM.SummaryLabel}"
                       Foreground="#8FA3B8" FontSize="11" />

            <!-- ── Tag statistics ── -->
            <Border Classes="SurfaceCard">
              <StackPanel Spacing="6">
                <TextBlock Text="BY TAG" Classes="Overline" />
                <ItemsControl ItemsSource="{Binding TradeJournalVM.TagStats}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:TagStatRow">
                      <Grid ColumnDefinitions="110,50,50,80,80" ColumnSpacing="10" Margin="0,2">
                        <Border Grid.Column="0" CornerRadius="3" Padding="6,2"
                                Background="#0D1520">
                          <TextBlock Text="{Binding TagLabel}"
                                     Foreground="{Binding TagBrush}"
                                     FontSize="11" FontWeight="SemiBold" />
                        </Border>
                        <TextBlock Grid.Column="1" Text="{Binding Trades}"
                                   Foreground="#8FA3B8" FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding WinRateLabel}"
                                   Foreground="#D7E3EE" FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="{Binding PnlLabel}"
                                   Foreground="{Binding PnlBrush}"
                                   FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <!-- ── Trade rows ── -->
            <Border Classes="SurfaceCard">
              <StackPanel Spacing="0">
                <Grid ColumnDefinitions="90,60,40,70,80,70,*,80" ColumnSpacing="8" Margin="0,0,0,6">
                  <TextBlock Grid.Column="0" Text="DATE" Classes="Overline" />
                  <TextBlock Grid.Column="1" Text="SYMBOL" Classes="Overline" />
                  <TextBlock Grid.Column="2" Text="DIR" Classes="Overline" />
                  <TextBlock Grid.Column="3" Text="P&amp;L USD" Classes="Overline" />
                  <TextBlock Grid.Column="4" Text="P&amp;L %" Classes="Overline" />
                  <TextBlock Grid.Column="5" Text="EXCHANGE" Classes="Overline" />
                  <TextBlock Grid.Column="6" Text="NOTES" Classes="Overline" />
                  <TextBlock Grid.Column="7" Text="TAG" Classes="Overline" />
                </Grid>

                <TextBlock Text="No trades match the current filter."
                           Foreground="#4A6880" FontSize="12" Margin="0,16"
                           IsVisible="{Binding TradeJournalVM.HasNoRows}" />

                <ScrollViewer MaxHeight="480">
                  <ItemsControl ItemsSource="{Binding TradeJournalVM.Rows}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:JournalEntryRowVM">
                        <Border Padding="0,4" BorderBrush="#0E1820" BorderThickness="0,0,0,1">
                          <StackPanel Spacing="4">
                            <!-- Main row -->
                            <Grid ColumnDefinitions="90,60,40,70,80,70,*,80" ColumnSpacing="8">
                              <TextBlock Grid.Column="0" Text="{Binding DateLabel}"
                                         Foreground="#8FA3B8" FontSize="10" VerticalAlignment="Center" />
                              <TextBlock Grid.Column="1" Text="{Binding SymbolLabel}"
                                         Foreground="#D7E3EE" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                              <TextBlock Grid.Column="2" Text="{Binding DirectionLabel}"
                                         Foreground="{Binding DirectionBrush}" FontSize="11" VerticalAlignment="Center" />
                              <TextBlock Grid.Column="3" Text="{Binding PnlLabel}"
                                         Foreground="{Binding PnlBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
                              <TextBlock Grid.Column="4" Text="{Binding PnlPctLabel}"
                                         Foreground="{Binding PnlBrush}" FontSize="10" VerticalAlignment="Center" />
                              <TextBlock Grid.Column="5" Text="{Binding ExchangeLabel}"
                                         Foreground="#4A7090" FontSize="10" VerticalAlignment="Center" />
                              <!-- Notes (editable on click) -->
                              <Panel Grid.Column="6">
                                <TextBlock Text="{Binding Notes}"
                                           Foreground="#8FA3B8" FontSize="10"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding !IsEditing}" />
                                <TextBox Text="{Binding Notes}"
                                         FontSize="10"
                                         Background="#0B1118"
                                         IsVisible="{Binding IsEditing}" />
                              </Panel>
                              <!-- Tag ComboBox -->
                              <ComboBox Grid.Column="7"
                                        ItemsSource="{Binding $parent[ItemsControl].((vm:TradeJournalViewModel)DataContext).AllTags}"
                                        SelectedItem="{Binding Tag}"
                                        FontSize="10"
                                        Background="#111821" />
                            </Grid>
                            <!-- Edit / Done button -->
                            <Grid ColumnDefinitions="*,Auto,Auto" IsVisible="{Binding IsEditing}">
                              <Button Grid.Column="1" Content="✓ Done"
                                      Command="{Binding DoneCommand}"
                                      Classes="GhostButton" FontSize="10"
                                      Foreground="#21E6C1" />
                            </Grid>
                            <!-- Edit link (shown when not editing) -->
                            <Button Content="✎ Add note"
                                    Command="{Binding EditCommand}"
                                    Classes="GhostButton"
                                    FontSize="9" Padding="0"
                                    Foreground="#4A6880"
                                    HorizontalAlignment="Left"
                                    IsVisible="{Binding !IsEditing}" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </StackPanel>
            </Border>

          </StackPanel>

          <!-- ═══════════════════════════════════════════════════════════════
               Gas / Network Fees Monitor (Feature 14)
          ════════════════════════════════════════════════════════════════ -->
          <StackPanel Spacing="16" IsVisible="{Binding IsGasSectionVisible}">

            <!-- Alert banner -->
            <Border IsVisible="{Binding GasMonitorVM.AlertMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Background="#1A2D1A" BorderBrush="#21E6C1" BorderThickness="0,0,0,1" Padding="14,10">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="⚡" FontSize="16" VerticalAlignment="Center" />
                <TextBlock Text="{Binding GasMonitorVM.AlertMessage}" FontSize="13" FontWeight="SemiBold"
                           Foreground="#21E6C1" VerticalAlignment="Center" TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <!-- Three-column gas cards row -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">

              <!-- Ethereum -->
              <Border Grid.Column="0" Background="#0F1721" CornerRadius="6" Padding="16">
                <StackPanel Spacing="10">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Ξ" FontSize="18" Foreground="#8FA3B8" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Text="Ethereum" Classes="H2" VerticalAlignment="Center" />
                    <Border IsVisible="{Binding GasMonitorVM.IsEthAlertActive}"
                            Background="#163020" CornerRadius="3" Padding="6,2">
                      <TextBlock Text="LOW ⚡" Foreground="#21E6C1" FontSize="10" FontWeight="Bold" />
                    </Border>
                  </StackPanel>
                  <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Slow" Classes="Overline" />
                    <TextBlock Grid.Column="1" Grid.Row="0" Text="Standard" Classes="Overline" />
                    <TextBlock Grid.Column="2" Grid.Row="0" Text="Fast" Classes="Overline" />
                    <TextBlock Grid.Column="0" Grid.Row="1" Text="{Binding GasMonitorVM.EthSlowLabel}"
                               Foreground="{Binding GasMonitorVM.EthSlowColor}" FontSize="15" FontWeight="Bold" />
                    <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding GasMonitorVM.EthStdLabel}"
                               Foreground="{Binding GasMonitorVM.EthStdColor}" FontSize="15" FontWeight="Bold" />
                    <TextBlock Grid.Column="2" Grid.Row="1" Text="{Binding GasMonitorVM.EthFastLabel}"
                               Foreground="{Binding GasMonitorVM.EthFastColor}" FontSize="15" FontWeight="Bold" />
                    <TextBlock Grid.Column="0" Grid.Row="2" Text="{Binding GasMonitorVM.EthSlowTimeLabel}"
                               Foreground="#4A6880" FontSize="10" />
                    <TextBlock Grid.Column="1" Grid.Row="2" Text="{Binding GasMonitorVM.EthStdTimeLabel}"
                               Foreground="#4A6880" FontSize="10" />
                    <TextBlock Grid.Column="2" Grid.Row="2" Text="{Binding GasMonitorVM.EthFastTimeLabel}"
                               Foreground="#4A6880" FontSize="10" />
                  </Grid>
                  <!-- ETH alert threshold -->
                  <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                    <TextBlock Text="Alert below:" Foreground="#4A6880" FontSize="11" VerticalAlignment="Center" />
                    <NumericUpDown Value="{Binding GasMonitorVM.EthAlertGwei}"
                                  Minimum="1" Maximum="200" Increment="1"
                                  FormatString="N0"
                                  Width="80" Height="26" FontSize="11"
                                  Background="#0A1018" Foreground="#C8D8E8" />
                    <TextBlock Text="gwei" Foreground="#4A6880" FontSize="11" VerticalAlignment="Center" />
                  </StackPanel>
                </StackPanel>
              </Border>

              <!-- BSC -->
              <Border Grid.Column="1" Background="#0F1721" CornerRadius="6" Padding="16">
                <StackPanel Spacing="10">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="⬡" FontSize="16" Foreground="#F0B90B" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Text="BNB Chain" Classes="H2" VerticalAlignment="Center" />
                    <Border IsVisible="{Binding GasMonitorVM.IsBscAlertActive}"
                            Background="#163020" CornerRadius="3" Padding="6,2">
                      <TextBlock Text="LOW ⚡" Foreground="#21E6C1" FontSize="10" FontWeight="Bold" />
                    </Border>
                  </StackPanel>
                  <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Slow" Classes="Overline" />
                    <TextBlock Grid.Column="1" Grid.Row="0" Text="Standard" Classes="Overline" />
                    <TextBlock Grid.Column="2" Grid.Row="0" Text="Fast" Classes="Overline" />
                    <TextBlock Grid.Column="0" Grid.Row="1" Text="{Binding GasMonitorVM.BscSlowLabel}"
                               Foreground="{Binding GasMonitorVM.BscSlowColor}" FontSize="15" FontWeight="Bold" />
                    <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding GasMonitorVM.BscStdLabel}"
                               Foreground="{Binding GasMonitorVM.BscStdColor}" FontSize="15" FontWeight="Bold" />
                    <TextBlock Grid.Column="2" Grid.Row="1" Text="{Binding GasMonitorVM.BscFastLabel}"
                               Foreground="{Binding GasMonitorVM.BscFastColor}" FontSize="15" FontWeight="Bold" />
                  </Grid>
                  <!-- BSC alert threshold -->
                  <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                    <TextBlock Text="Alert below:" Foreground="#4A6880" FontSize="11" VerticalAlignment="Center" />
                    <NumericUpDown Value="{Binding GasMonitorVM.BscAlertGwei}"
                                  Minimum="1" Maximum="50" Increment="1"
                                  FormatString="N0"
                                  Width="80" Height="26" FontSize="11"
                                  Background="#0A1018" Foreground="#C8D8E8" />
                    <TextBlock Text="gwei" Foreground="#4A6880" FontSize="11" VerticalAlignment="Center" />
                  </StackPanel>
                </StackPanel>
              </Border>

              <!-- Solana -->
              <Border Grid.Column="2" Background="#0F1721" CornerRadius="6" Padding="16">
                <StackPanel Spacing="10">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="◎" FontSize="16" Foreground="#9B59B6" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Text="Solana" Classes="H2" VerticalAlignment="Center" />
                  </StackPanel>
                  <StackPanel Spacing="4">
                    <TextBlock Text="TPS (avg last 4 samples)" Classes="Overline" />
                    <TextBlock Text="{Binding GasMonitorVM.SolanaTpsLabel}"
                               Foreground="{Binding GasMonitorVM.SolanaColor}"
                               FontSize="22" FontWeight="Bold" />
                    <TextBlock Text="Solana has no gas — congestion is measured by TPS."
                               Foreground="#4A6880" FontSize="10" TextWrapping="Wrap" />
                  </StackPanel>
                </StackPanel>
              </Border>

            </Grid>

            <!-- Last updated / Refresh row -->
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
              <TextBlock Text="{Binding GasMonitorVM.LastUpdatedLabel}"
                         Foreground="#4A6880" FontSize="11" VerticalAlignment="Center" />
              <Button Content="↻  Refresh" Classes="SecondaryAction"
                      Command="{Binding GasMonitorVM.RefreshCommand}"
                      IsEnabled="{Binding !GasMonitorVM.IsLoading}"
                      Padding="12,5" FontSize="12" />
            </StackPanel>

            <!-- Info note -->
            <Border Background="#0A1018" CornerRadius="4" Padding="12,8">
              <TextBlock Foreground="#4A6880" FontSize="11" TextWrapping="Wrap">
                <Run Text="ℹ " />
                <Run Text="Gas prices update every 30 seconds. Powered by Etherscan · BSCScan · Solana RPC.  " />
                <Run Text="Set ETHERSCAN_API_KEY / BSCSCAN_API_KEY environment variables for higher rate limits."
                     Foreground="#2D4A5A" />
              </TextBlock>
            </Border>

          </StackPanel>

          <!-- ═══════════════════════════════════════════════════════════════
               All Positions — unified futures view (Feature 15)
          ════════════════════════════════════════════════════════════════ -->
          <StackPanel Spacing="12" IsVisible="{Binding IsPositionsSectionVisible}">

            <!-- Header row: totals + Close All -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Spacing="4">
                <TextBlock Text="Unrealized PnL (all exchanges)" Classes="Overline" />
                <StackPanel Orientation="Horizontal" Spacing="16">
                  <TextBlock Text="{Binding AllPositionsVM.TotalPnlLabel}"
                             Foreground="{Binding AllPositionsVM.TotalPnlBrush}"
                             FontSize="22" FontWeight="Bold" />
                  <TextBlock Text="{Binding AllPositionsVM.TotalSizeLabel}"
                             Foreground="#4A6880" FontSize="13" VerticalAlignment="Bottom" />
                </StackPanel>
              </StackPanel>

              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                <Button Content="↻  Refresh"
                        Classes="SecondaryAction"
                        Command="{Binding AllPositionsVM.RefreshCommand}"
                        IsEnabled="{Binding !AllPositionsVM.IsRefreshing}"
                        Padding="12,6" FontSize="12" />
                <Button Content="⚠ Close All"
                        Background="#402020" Foreground="#FF6B6B"
                        BorderBrush="#FF6B6B" BorderThickness="1"
                        CornerRadius="4"
                        Command="{Binding AllPositionsVM.CloseAllCommand}"
                        IsEnabled="{Binding AllPositionsVM.HasPositions}"
                        Padding="14,6" FontSize="12" FontWeight="Bold"
                        ToolTip.Tip="Two-step confirmation: first click arms (StatusLabel changes), second click within 8 s closes all positions." />
                <!-- Armed-indicator (видим только когда первый клик уже был): -->
                <Border IsVisible="{Binding AllPositionsVM.CloseAllConfirmRequested}"
                        Background="#FF6B6B" CornerRadius="3" Padding="6,3"
                        VerticalAlignment="Center">
                  <TextBlock Text="⚠ ARMED — click again" Foreground="#0A1018"
                             FontSize="11" FontWeight="Bold" />
                </Border>
              </StackPanel>
            </Grid>

            <!-- Status bar -->
            <TextBlock Text="{Binding AllPositionsVM.StatusLabel}"
                       Foreground="#4A6880" FontSize="11" />

            <!-- Table header row with sort buttons -->
            <Grid ColumnDefinitions="100,80,60,80,80,80,80,*,100" ColumnSpacing="8"
                  Margin="0,4,0,0">
              <Button Grid.Column="0" Content="EXCHANGE" Classes="SortHeader"
                      Command="{Binding AllPositionsVM.SortByExchangeCommand}" />
              <TextBlock Grid.Column="1" Text="SYMBOL" Classes="Overline" VerticalAlignment="Center" />
              <TextBlock Grid.Column="2" Text="SIDE" Classes="Overline" VerticalAlignment="Center" />
              <TextBlock Grid.Column="3" Text="ENTRY" Classes="Overline" VerticalAlignment="Center" />
              <TextBlock Grid.Column="4" Text="MARK" Classes="Overline" VerticalAlignment="Center" />
              <Button Grid.Column="5" Content="SIZE" Classes="SortHeader"
                      Command="{Binding AllPositionsVM.SortBySizeCommand}" />
              <TextBlock Grid.Column="6" Text="LEV. / LIQ." Classes="Overline" VerticalAlignment="Center" />
              <Button Grid.Column="7" Content="UNREAL. PNL" Classes="SortHeader"
                      Command="{Binding AllPositionsVM.SortByPnlCommand}" />
              <TextBlock Grid.Column="8" Text="" />
            </Grid>
            <Border Height="1" Background="#17263A" />

            <!-- Empty state -->
            <Border IsVisible="{Binding AllPositionsVM.HasNoPositions}"
                    Background="#0A1018" CornerRadius="4" Padding="20" Margin="0,4,0,0">
              <StackPanel HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="⊞" FontSize="32" Foreground="#2D4A5A" HorizontalAlignment="Center" />
                <TextBlock Text="No open futures positions across Binance · Bybit · OKX"
                           Foreground="#4A6880" FontSize="13" HorizontalAlignment="Center" />
                <TextBlock Text="Press Refresh to query all connected exchanges."
                           Foreground="#2D4A5A" FontSize="11" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>

            <!-- Positions list -->
            <ScrollViewer IsVisible="{Binding AllPositionsVM.HasPositions}"
                          MaxHeight="520" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding AllPositionsVM.Rows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type vm:UnifiedPositionRowVM}">
                    <Border Background="#0A1018" CornerRadius="4" Padding="8,6" Margin="0,2">
                      <Grid ColumnDefinitions="100,80,60,80,80,80,80,*,100" ColumnSpacing="8">

                        <!-- Exchange badge -->
                        <Border Grid.Column="0" Background="#0F1721" CornerRadius="3" Padding="6,2"
                                HorizontalAlignment="Left" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Exchange}"
                                     Foreground="{Binding ExchangeBrush}"
                                     FontSize="11" FontWeight="SemiBold" />
                        </Border>

                        <!-- Symbol -->
                        <TextBlock Grid.Column="1" Text="{Binding Symbol}"
                                   Foreground="#C8D8E8" FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />

                        <!-- Side -->
                        <Border Grid.Column="2" Background="#0F1721" CornerRadius="3" Padding="5,2"
                                HorizontalAlignment="Left" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Side}"
                                     Foreground="{Binding SideBrush}"
                                     FontSize="11" FontWeight="Bold" />
                        </Border>

                        <!-- Entry price -->
                        <TextBlock Grid.Column="3" Text="{Binding EntryPriceLabel}"
                                   Foreground="#8FA3B8" FontSize="12" VerticalAlignment="Center" />

                        <!-- Mark price -->
                        <TextBlock Grid.Column="4" Text="{Binding MarkPriceLabel}"
                                   Foreground="#C8D8E8" FontSize="12" VerticalAlignment="Center" />

                        <!-- Size + notional -->
                        <StackPanel Grid.Column="5" VerticalAlignment="Center" Spacing="2">
                          <TextBlock Text="{Binding SizeLabel}" Foreground="#C8D8E8" FontSize="12" />
                          <TextBlock Text="{Binding NotionalLabel}" Foreground="#4A6880" FontSize="10" />
                        </StackPanel>

                        <!-- Leverage / Liq -->
                        <StackPanel Grid.Column="6" VerticalAlignment="Center" Spacing="2">
                          <TextBlock Text="{Binding LeverageLabel}" Foreground="#8FA3B8" FontSize="12" />
                          <TextBlock Text="{Binding LiqLabel}" Foreground="#FF6B6B" FontSize="10" />
                        </StackPanel>

                        <!-- PnL -->
                        <TextBlock Grid.Column="7" Text="{Binding PnlLabel}"
                                   Foreground="{Binding PnlBrush}"
                                   FontSize="13" FontWeight="Bold"
                                   VerticalAlignment="Center" />

                        <!-- Partial-close + full-close buttons -->
                        <StackPanel Grid.Column="8" Orientation="Horizontal" Spacing="3"
                                    VerticalAlignment="Center" HorizontalAlignment="Right">
                          <Button Content="25%" Background="#11171F" Foreground="#A0B4C8"
                                  BorderBrush="#2D4A5A" BorderThickness="1" CornerRadius="3"
                                  Padding="5,3" FontSize="10"
                                  Command="{Binding $parent[ItemsControl].((vm:AllPositionsViewModel)DataContext).Close25Command}"
                                  CommandParameter="{Binding}"
                                  ToolTip.Tip="Reduce 25% of position size (reduce-only market order)." />
                          <Button Content="50%" Background="#11171F" Foreground="#A0B4C8"
                                  BorderBrush="#2D4A5A" BorderThickness="1" CornerRadius="3"
                                  Padding="5,3" FontSize="10"
                                  Command="{Binding $parent[ItemsControl].((vm:AllPositionsViewModel)DataContext).Close50Command}"
                                  CommandParameter="{Binding}"
                                  ToolTip.Tip="Reduce 50% of position size." />
                          <Button Content="75%" Background="#11171F" Foreground="#A0B4C8"
                                  BorderBrush="#2D4A5A" BorderThickness="1" CornerRadius="3"
                                  Padding="5,3" FontSize="10"
                                  Command="{Binding $parent[ItemsControl].((vm:AllPositionsViewModel)DataContext).Close75Command}"
                                  CommandParameter="{Binding}"
                                  ToolTip.Tip="Reduce 75% of position size." />
                          <Button Content="Close"
                                  Background="#2A1010" Foreground="#FF6B6B"
                                  BorderBrush="#FF6B6B" BorderThickness="1" CornerRadius="3"
                                  Padding="6,3" FontSize="11"
                                  Command="{Binding $parent[ItemsControl].((vm:AllPositionsViewModel)DataContext).ClosePositionCommand}"
                                  CommandParameter="{Binding}"
                                  ToolTip.Tip="Close 100% of position." />
                        </StackPanel>

                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

          </StackPanel>

          <!-- ═══════════════════════════════════════════════════════════════
               News Feed with Sentiment (Feature 16)
          ════════════════════════════════════════════════════════════════ -->
          <StackPanel Spacing="12" IsVisible="{Binding IsNewsSectionVisible}">

            <!-- AI Market Pulse + digest -->
            <Border Background="#0A1622" BorderBrush="#1A3A50" BorderThickness="1"
                    CornerRadius="8" Padding="16,12">
              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="AI MARKET PULSE" Foreground="#5A7A90" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
                    <Border Background="{Binding NewsFeedVM.PulseBrush}" CornerRadius="3" Padding="8,2">
                      <TextBlock Text="{Binding NewsFeedVM.PulseLabel}" Foreground="#06121C" FontSize="12" FontWeight="Bold" />
                    </Border>
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="{Binding NewsFeedVM.PulseDetail}"
                             Foreground="#7E93A6" FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0" />
                  <Button Grid.Column="2" Content="↻ AI digest" Classes="SecondaryAction"
                          Command="{Binding NewsFeedVM.RefreshDigestCommand}"
                          Padding="10,4" FontSize="11" />
                </Grid>
                <TextBlock Text="{Binding NewsFeedVM.AiDigest}"
                           Foreground="{Binding NewsFeedVM.AiDigestBrush}"
                           FontSize="13" TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="AI: assessing…" Foreground="#5A7A90" FontSize="10" FontStyle="Italic"
                             IsVisible="{Binding NewsFeedVM.AiDigestRunning}" />
                  <TextBlock Text="{Binding NewsFeedVM.AiDigestSource}" Foreground="#3A5A70" FontSize="10" />
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Filter bar -->
            <Grid ColumnDefinitions="120,110,*,Auto,Auto,Auto" ColumnSpacing="8">
              <TextBox Grid.Column="0" Text="{Binding NewsFeedVM.FilterSymbol}"
                       PlaceholderText="Filter: BTC, ETH…"
                       Background="#0A1018" Foreground="#C8D8E8"
                       FontSize="12" Height="30" />
              <ComboBox Grid.Column="1" ItemsSource="{Binding NewsFeedVM.SentimentOptions}"
                        SelectedItem="{Binding NewsFeedVM.FilterSentiment}"
                        Background="#0A1018" Foreground="#C8D8E8"
                        FontSize="12" Height="30" />
              <TextBox Grid.Column="2" Text="{Binding NewsFeedVM.SearchText}"
                       PlaceholderText="Search in headlines…"
                       Background="#0A1018" Foreground="#C8D8E8"
                       FontSize="12" Height="30" />
              <CheckBox Grid.Column="3" Content="Important only"
                        IsChecked="{Binding NewsFeedVM.ShowImportantOnly}"
                        Foreground="#8FA3B8" FontSize="11" VerticalAlignment="Center" />
              <Button Grid.Column="4" Content="Clear filters" Classes="SecondaryAction"
                      Command="{Binding NewsFeedVM.ClearFilterCommand}"
                      Padding="10,4" FontSize="11" />
              <Button Grid.Column="5" Content="Mark read" Classes="SecondaryAction"
                      Command="{Binding NewsFeedVM.ClearUnreadCommand}"
                      IsVisible="{Binding NewsFeedVM.HasUnread}"
                      Padding="10,4" FontSize="11" />
            </Grid>

            <!-- Status / unread badge -->
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="{Binding NewsFeedVM.StatusLabel}" Foreground="#4A6880" FontSize="11" VerticalAlignment="Center" />
              <Border IsVisible="{Binding NewsFeedVM.HasUnread}"
                      Background="#FF6B6B" CornerRadius="8" Padding="6,1">
                <TextBlock Text="{Binding NewsFeedVM.UnreadBadge, StringFormat='{}{0} new'}"
                           Foreground="White" FontSize="10" FontWeight="Bold" />
              </Border>
            </StackPanel>

            <!-- Loading state -->
            <TextBlock IsVisible="{Binding NewsFeedVM.IsLoading}"
                       Text="Fetching news from RSS feeds…"
                       Foreground="#4A6880" FontSize="12" />

            <!-- News rows -->
            <ScrollViewer IsVisible="{Binding !NewsFeedVM.IsLoading}"
                          MaxHeight="580" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding NewsFeedVM.Rows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type vm:NewsItemRowVM}">
                    <Border Background="{Binding SentimentBackground}"
                            CornerRadius="4" Padding="12,8" Margin="0,2"
                            BorderBrush="#17263A" BorderThickness="0,0,0,1">
                      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">

                        <!-- Sentiment badge -->
                        <Border Grid.Column="0" CornerRadius="3" Padding="6,3"
                                VerticalAlignment="Top" Margin="0,2,0,0">
                          <Border.Background>
                            <SolidColorBrush Color="{Binding SentimentBrush}" Opacity="0.15" />
                          </Border.Background>
                          <TextBlock Text="{Binding SentimentLabel}"
                                     Foreground="{Binding SentimentBrush}"
                                     FontSize="10" FontWeight="Bold" />
                        </Border>

                        <!-- Title + meta -->
                        <StackPanel Grid.Column="1" Spacing="3">
                          <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border IsVisible="{Binding IsImportant}"
                                    Background="#2A2010" CornerRadius="2" Padding="4,1">
                              <TextBlock Text="⭐ IMPORTANT" Foreground="#F4B860"
                                         FontSize="9" FontWeight="Bold" />
                            </Border>
                            <TextBlock IsVisible="{Binding HasTags}"
                                       Text="{Binding CurrencyTags}"
                                       Foreground="#3BBFFF" FontSize="10" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                          </StackPanel>
                          <TextBlock Text="{Binding Title}" Foreground="#C8D8E8"
                                     FontSize="12" TextWrapping="Wrap" />
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding Source}" Foreground="#4A6880" FontSize="10" />
                            <TextBlock Text="·" Foreground="#2D4A5A" FontSize="10" />
                            <TextBlock Text="{Binding AgeLabel}" Foreground="#4A6880" FontSize="10" />
                          </StackPanel>
                        </StackPanel>

                        <!-- Votes -->
                        <TextBlock Grid.Column="2" Text="{Binding VotesLabel}"
                                   Foreground="{Binding VotesBrush}"
                                   FontSize="11" FontWeight="Bold"
                                   VerticalAlignment="Top" Margin="0,2,0,0" />

                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <!-- Note about API key -->
            <Border Background="#0A1018" CornerRadius="4" Padding="10,6">
              <TextBlock Foreground="#2D4A5A" FontSize="10" TextWrapping="Wrap">
                <Run Text="Powered by RSS feeds: CoinTelegraph, CoinDesk, Decrypt, The Block, Bitcoin Magazine. " />
                <Run Text="CRYPTOPANIC_API_KEY" FontWeight="Bold" Foreground="#4A6880" />
                <Run Text=" env var enables CryptoPanic as additional source." />
              </TextBlock>
            </Border>

          </StackPanel>

          <!-- ═══════════════════════════════════════════════════════════════
               On-Chain Metrics (Feature 17)
          ════════════════════════════════════════════════════════════════ -->
          <StackPanel Spacing="16" IsVisible="{Binding IsOnChainSectionVisible}">

            <!-- API key status -->
            <Border Background="#0F1721" CornerRadius="4" Padding="12,8">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock IsVisible="{Binding OnChainVM.HasApiKey}"
                           Text="{Binding OnChainVM.ApiKeyStatus}"
                           Foreground="#3DDC84" FontSize="11" />
                <TextBlock IsVisible="{Binding !OnChainVM.HasApiKey}"
                           Text="{Binding OnChainVM.ApiKeyStatus}"
                           Foreground="#F4B860" FontSize="11" />
              </StackPanel>
            </Border>

            <!-- ── AI On-Chain Insight (#7) ── -->
            <Border Background="#0F1721" CornerRadius="6" Padding="14,12">
              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <StackPanel Grid.Column="0">
                    <TextBlock Text="🧠 AI On-Chain Read" FontWeight="SemiBold" Foreground="#E8F0FE" FontSize="13" />
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="{Binding OnChainVM.InsightSource}"
                             Foreground="#5C6E82" FontSize="10" VerticalAlignment="Center" Margin="0,0,10,0" />
                  <Button Grid.Column="2" Content="Analyze with AI"
                          Command="{Binding OnChainVM.AnalyzeWithAiCommand}"
                          IsEnabled="{Binding !OnChainVM.InsightRunning}" Foreground="#21E6C1" />
                </Grid>
                <StackPanel Spacing="5" IsVisible="{Binding OnChainVM.HasInsight}">
                  <TextBlock Text="{Binding OnChainVM.InsightSignal}"
                             Foreground="{Binding OnChainVM.InsightSignalBrush}" FontWeight="Bold" FontSize="13" />
                  <TextBlock Text="{Binding OnChainVM.InsightSummary}" Foreground="#D7E3EE" FontSize="12" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding OnChainVM.InsightBullets}" Foreground="#8FA3B8" FontSize="11" TextWrapping="Wrap"
                             IsVisible="{Binding OnChainVM.InsightBullets, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Two-column cards: BTC + ETH -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

              <!-- BTC card -->
              <Border Grid.Column="0" Background="#0F1721" CornerRadius="6" Padding="16">
                <StackPanel Spacing="12">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="₿" FontSize="18" Foreground="#F0B90B" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Text="Bitcoin On-Chain" Classes="H2" VerticalAlignment="Center" />
                  </StackPanel>

                  <!-- MVRV -->
                  <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="MVRV Ratio" Classes="Overline" />
                      <TextBlock Text="(Market / Realised Value)" Foreground="#2D4A5A" FontSize="10" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                      <TextBlock Text="{Binding OnChainVM.BtcMvrvLabel}"
                                 Foreground="{Binding OnChainVM.BtcMvrvColor}"
                                 FontSize="22" FontWeight="Bold" />
                      <Border Background="#0A1018" CornerRadius="3" Padding="6,2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding OnChainVM.BtcMvrvPhase}"
                                   Foreground="{Binding OnChainVM.BtcMvrvColor}"
                                   FontSize="11" FontWeight="Bold" />
                      </Border>
                    </StackPanel>
                    <!-- MVRV gauge: 5 static colour bands (visual reference) -->
                    <Grid ColumnDefinitions="*,*,*,*,*" Height="6" ColumnSpacing="2">
                      <Border Grid.Column="0" CornerRadius="2" Background="#21E6C1" Opacity="0.35" />
                      <Border Grid.Column="1" CornerRadius="2" Background="#3DDC84" Opacity="0.35" />
                      <Border Grid.Column="2" CornerRadius="2" Background="#F4D03F" Opacity="0.35" />
                      <Border Grid.Column="3" CornerRadius="2" Background="#FF9500" Opacity="0.35" />
                      <Border Grid.Column="4" CornerRadius="2" Background="#FF6B6B" Opacity="0.35" />
                    </Grid>
                    <TextBlock Text="&lt;1 undervalued · 1–2 fair · 2–3.5 overvalued · &gt;3.5 euphoria"
                               Foreground="#2D4A5A" FontSize="9" />
                  </StackPanel>

                  <!-- NUPL -->
                  <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="NUPL" Classes="Overline" />
                      <TextBlock Text="(Net Unrealised P/L)" Foreground="#2D4A5A" FontSize="10" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                      <TextBlock Text="{Binding OnChainVM.BtcNuplLabel}"
                                 Foreground="{Binding OnChainVM.BtcNuplColor}"
                                 FontSize="22" FontWeight="Bold" />
                      <Border Background="#0A1018" CornerRadius="3" Padding="6,2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding OnChainVM.BtcNuplPhase}"
                                   Foreground="{Binding OnChainVM.BtcNuplColor}"
                                   FontSize="11" FontWeight="Bold" />
                      </Border>
                    </StackPanel>
                    <!-- NUPL gauge: 5 colour segments -->
                    <Grid ColumnDefinitions="*,*,*,*,*" Height="6" ColumnSpacing="2">
                      <Border Grid.Column="0" CornerRadius="2" Background="#21E6C1" Opacity="0.3" />
                      <Border Grid.Column="1" CornerRadius="2" Background="#8FA3B8" Opacity="0.3" />
                      <Border Grid.Column="2" CornerRadius="2" Background="#F4D03F" Opacity="0.3" />
                      <Border Grid.Column="3" CornerRadius="2" Background="#FF9500" Opacity="0.3" />
                      <Border Grid.Column="4" CornerRadius="2" Background="#FF6B6B" Opacity="0.3" />
                    </Grid>
                    <TextBlock Text="&lt;0 capitulation · 0–0.5 hope/optimism · 0.5–0.75 belief · &gt;0.75 euphoria"
                               Foreground="#2D4A5A" FontSize="9" />
                  </StackPanel>

                  <!-- Exchange Net Flow -->
                  <StackPanel Spacing="4">
                    <TextBlock Text="Exchange Net Flow" Classes="Overline" />
                    <TextBlock Text="{Binding OnChainVM.BtcNetFlowLabel}"
                               Foreground="{Binding OnChainVM.BtcNetFlowColor}"
                               FontSize="16" FontWeight="Bold" />
                    <TextBlock Text="positive = coins flowing IN (sell pressure) · negative = flowing OUT (accumulation)"
                               Foreground="#2D4A5A" FontSize="9" TextWrapping="Wrap" />
                  </StackPanel>

                  <!-- Realised Price -->
                  <StackPanel Spacing="4">
                    <TextBlock Text="Realised Price" Classes="Overline" />
                    <TextBlock Text="{Binding OnChainVM.BtcRealisedLabel}"
                               Foreground="#8FA3B8" FontSize="16" FontWeight="Bold" />
                    <TextBlock Text="Average cost basis of all coins on-chain"
                               Foreground="#2D4A5A" FontSize="9" />
                  </StackPanel>

                </StackPanel>
              </Border>

              <!-- ETH card -->
              <Border Grid.Column="1" Background="#0F1721" CornerRadius="6" Padding="16">
                <StackPanel Spacing="12">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Ξ" FontSize="18" Foreground="#8FA3B8" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Text="Ethereum On-Chain" Classes="H2" VerticalAlignment="Center" />
                  </StackPanel>

                  <!-- ETH MVRV -->
                  <StackPanel Spacing="4">
                    <TextBlock Text="MVRV Ratio" Classes="Overline" />
                    <TextBlock Text="{Binding OnChainVM.EthMvrvLabel}"
                               Foreground="{Binding OnChainVM.EthMvrvColor}"
                               FontSize="22" FontWeight="Bold" />
                  </StackPanel>

                  <!-- ETH Net Flow -->
                  <StackPanel Spacing="4">
                    <TextBlock Text="Exchange Net Flow" Classes="Overline" />
                    <TextBlock Text="{Binding OnChainVM.EthNetFlowLabel}"
                               Foreground="{Binding OnChainVM.EthNetFlowColor}"
                               FontSize="16" FontWeight="Bold" />
                  </StackPanel>

                  <!-- No API key note -->
                  <Border IsVisible="{Binding !OnChainVM.HasApiKey}"
                          Background="#0A1018" CornerRadius="4" Padding="10,8">
                    <TextBlock Foreground="#4A6880" FontSize="11" TextWrapping="Wrap">
                      <Run Text="Set " />
                      <Run Text="GLASSNODE_API_KEY" FontWeight="Bold" />
                      <Run Text=" environment variable before launching to enable live on-chain data." />
                    </TextBlock>
                  </Border>

                </StackPanel>
              </Border>

            </Grid>

            <!-- Last updated + Refresh -->
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
              <TextBlock Text="{Binding OnChainVM.LastUpdatedLabel}"
                         Foreground="#4A6880" FontSize="11" VerticalAlignment="Center" />
              <Button Content="↻  Refresh" Classes="SecondaryAction"
                      Command="{Binding OnChainVM.RefreshCommand}"
                      IsEnabled="{Binding !OnChainVM.IsLoading}"
                      Padding="12,5" FontSize="12" />
            </StackPanel>

          </StackPanel>

          <!-- ═══════════════════════════════════════════════════════════════
               P&L Dashboard (Analytics section)
          ════════════════════════════════════════════════════════════════ -->
          <StackPanel Spacing="16" IsVisible="{Binding IsAnalyticsSectionVisible}">

            <!-- ── Filters + action bar ── -->
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="10">
              <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Classes="Overline" Text="Period" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding PnlDashboardVM.AvailablePeriods}"
                          SelectedItem="{Binding PnlDashboardVM.SelectedPeriod}"
                          MinWidth="80" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Classes="Overline" Text="Source" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding PnlDashboardVM.AvailableSources}"
                          SelectedItem="{Binding PnlDashboardVM.SelectedSource}"
                          MinWidth="80" />
              </StackPanel>
              <TextBlock Grid.Column="2" Text="{Binding PnlDashboardVM.StatusMessage}"
                         Foreground="#4D5F70" FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0" />
              <Button Grid.Column="3" Classes="SecondaryButton" Command="{Binding PnlDashboardVM.RefreshCommand}">↻ Refresh</Button>
              <Button Grid.Column="4" Classes="SecondaryButton" Command="{Binding PnlDashboardVM.ExportCsvCommand}">⬇ Export CSV</Button>
            </Grid>

            <!-- ── KPI cards ── -->
            <Grid ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="12">
              <Border Grid.Column="0" Classes="SurfaceCard">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Total P&amp;L" />
                  <TextBlock Text="{Binding PnlDashboardVM.TotalPnlLabel}"
                             Foreground="{Binding PnlDashboardVM.TotalPnlBrush}"
                             FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Classes="SurfaceCard">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Win Rate" />
                  <TextBlock Text="{Binding PnlDashboardVM.WinRateLabel}" Foreground="#21E6C1" FontSize="16" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding PnlDashboardVM.TradeCountLabel}" Foreground="#4D5F70" FontSize="11" />
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Classes="SurfaceCard">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Avg Win" />
                  <TextBlock Text="{Binding PnlDashboardVM.AvgWinLabel}" Foreground="#3DDC84" FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border Grid.Column="3" Classes="SurfaceCard">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Avg Loss" />
                  <TextBlock Text="{Binding PnlDashboardVM.AvgLossLabel}" Foreground="#FF5D73" FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border Grid.Column="4" Classes="SurfaceCard">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Max Drawdown" />
                  <TextBlock Text="{Binding PnlDashboardVM.MaxDrawdownLabel}" Foreground="#F4B860" FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border Grid.Column="5" Classes="SurfaceCard">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Profit Factor" />
                  <TextBlock Text="{Binding PnlDashboardVM.ProfitFactorLabel}" Foreground="#A78BFA" FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
            </Grid>

            <!-- ── Equity curve ── -->
            <Border Classes="Panel" Padding="16,12">
              <StackPanel Spacing="8">
                <!-- Header row: title + min/max + legend -->
                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10">
                  <TextBlock Grid.Column="0" Classes="H2" Text="Equity Curve" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Text="{Binding PnlDashboardVM.EquityCurveMaxLabel}"
                             Foreground="#3DDC84" FontSize="11" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="2" Text="{Binding PnlDashboardVM.EquityCurveMinLabel}"
                             Foreground="#FF5D73" FontSize="11" VerticalAlignment="Center" />
                  <!-- Legend -->
                  <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Border Width="12" Height="2" Background="#21E6C1" VerticalAlignment="Center" />
                    <TextBlock Text="Active" Foreground="#8FA3B8" FontSize="10" VerticalAlignment="Center" />
                  </StackPanel>
                  <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                              IsVisible="{Binding PnlDashboardVM.HasHoldLine}">
                    <Border Width="12" Height="2" Background="#5A6A7A" VerticalAlignment="Center" />
                    <TextBlock Text="Hold" Foreground="#8FA3B8" FontSize="10" VerticalAlignment="Center" />
                  </StackPanel>
                  <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Border Width="10" Height="10" Background="#FF5D7340" CornerRadius="2" VerticalAlignment="Center" />
                    <TextBlock Text="Drawdown" Foreground="#8FA3B8" FontSize="10" VerticalAlignment="Center" />
                  </StackPanel>
                  <TextBlock Grid.Column="6" Text="{Binding PnlDashboardVM.HoldDeltaLabel}"
                             Foreground="#F4B860" FontSize="10" VerticalAlignment="Center"
                             IsVisible="{Binding PnlDashboardVM.HasHoldLine}" />
                </Grid>

                <!-- Chart canvas -->
                <Border Background="#070F18" CornerRadius="4" Height="142" IsVisible="{Binding PnlDashboardVM.EquityCurveHasData}">
                  <Canvas Width="560" Height="130" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <!-- Drawdown fill (red translucent area below rolling peak) -->
                    <Path Fill="#33FF5D73" Stroke="Transparent"
                          Data="{Binding PnlDashboardVM.DrawdownPathData}" />
                    <!-- Hold comparison line (gray dashed) -->
                    <Path Stroke="#4D5F70" StrokeThickness="1" StrokeDashArray="5,3" Fill="Transparent"
                          Data="{Binding PnlDashboardVM.HoldPathData}"
                          IsVisible="{Binding PnlDashboardVM.HasHoldLine}" />
                    <!-- Zero line (dynamic Y position via TranslateTransform) -->
                    <Line StartPoint="0,0" EndPoint="560,0"
                          Stroke="#1A2E3A" StrokeThickness="1" StrokeDashArray="4,4">
                      <Line.RenderTransform>
                        <TranslateTransform Y="{Binding PnlDashboardVM.ZeroLineY}" />
                      </Line.RenderTransform>
                    </Line>
                    <!-- Equity curve (teal solid line) -->
                    <Path Stroke="#21E6C1" StrokeThickness="1.5" Fill="Transparent"
                          Data="{Binding PnlDashboardVM.EquityCurvePathData}" />
                  </Canvas>
                </Border>

                <!-- Placeholder when no data -->
                <Border Background="#070F18" CornerRadius="4" Height="60"
                        IsVisible="{Binding PnlDashboardVM.EquityCurveIsEmpty}">
                  <TextBlock Text="No trade data yet. Complete a trade to see the equity curve."
                             Foreground="#2A3D4F" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
                </Border>
              </StackPanel>
            </Border>

            <!-- ── Breakdown tables — row 1: By Day + By Source ── -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">

              <!-- By day -->
              <Border Grid.Column="0" Classes="Panel" Padding="0">
                <StackPanel>
                  <Border Padding="16,10" BorderBrush="#1A2E3A" BorderThickness="0,0,0,1">
                    <TextBlock Classes="H2" Text="P&amp;L by Day" />
                  </Border>
                  <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10" Margin="16,8">
                    <TextBlock Grid.Column="0" Classes="Overline" Text="Date" />
                    <TextBlock Grid.Column="1" Classes="Overline" Text="Trades" />
                    <TextBlock Grid.Column="2" Classes="Overline" Text="Win %" />
                    <TextBlock Grid.Column="3" Classes="Overline" Text="P&amp;L" />
                  </Grid>
                  <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding PnlDashboardVM.ByDayRows}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PeriodRowViewModel">
                          <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10"
                                Margin="16,5" VerticalAlignment="Center">
                            <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="#C8D8E8" />
                            <TextBlock Grid.Column="1" Text="{Binding Trades}" Foreground="#8FA3B8" />
                            <TextBlock Grid.Column="2" Text="{Binding WinRate}" Foreground="#8FA3B8" />
                            <TextBlock Grid.Column="3" Text="{Binding PnlLabel}"
                                       Foreground="{Binding PnlBrush}" FontWeight="SemiBold" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </StackPanel>
              </Border>

              <!-- By source -->
              <Border Grid.Column="1" Classes="Panel" Padding="0">
                <StackPanel>
                  <Border Padding="16,10" BorderBrush="#1A2E3A" BorderThickness="0,0,0,1">
                    <TextBlock Classes="H2" Text="P&amp;L by Source" />
                  </Border>
                  <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10" Margin="16,8">
                    <TextBlock Grid.Column="0" Classes="Overline" Text="Source" />
                    <TextBlock Grid.Column="1" Classes="Overline" Text="Trades" />
                    <TextBlock Grid.Column="2" Classes="Overline" Text="Win %" />
                    <TextBlock Grid.Column="3" Classes="Overline" Text="P&amp;L" />
                  </Grid>
                  <ItemsControl ItemsSource="{Binding PnlDashboardVM.BySourceRows}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:SourceRowViewModel">
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10"
                              Margin="16,6" VerticalAlignment="Center">
                          <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="#C8D8E8" FontWeight="SemiBold" />
                          <TextBlock Grid.Column="1" Text="{Binding Trades}" Foreground="#8FA3B8" />
                          <TextBlock Grid.Column="2" Text="{Binding WinRate}" Foreground="#8FA3B8" />
                          <TextBlock Grid.Column="3" Text="{Binding PnlLabel}"
                                     Foreground="{Binding PnlBrush}" FontWeight="SemiBold" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>

            </Grid>

            <!-- ── Breakdown tables — row 2: By Bot, By Exchange, By Asset ── -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">

              <!-- By Bot -->
              <Border Grid.Column="0" Classes="Panel" Padding="0">
                <StackPanel>
                  <Border Padding="16,10" BorderBrush="#1A2E3A" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="Auto,*">
                      <TextBlock Grid.Column="0" Classes="H2" Text="P&amp;L by Bot" />
                      <TextBlock Grid.Column="1" Text="Grid · DCA · AI · CEX Arb · Funding"
                                 Foreground="#3A5068" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </Grid>
                  </Border>
                  <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10" Margin="16,8">
                    <TextBlock Grid.Column="0" Classes="Overline" Text="Bot" />
                    <TextBlock Grid.Column="1" Classes="Overline" Text="W/T" />
                    <TextBlock Grid.Column="2" Classes="Overline" Text="P&amp;L" />
                  </Grid>
                  <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding PnlDashboardVM.ByBotRows}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SourceRowViewModel">
                          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10"
                                Margin="16,5" VerticalAlignment="Center">
                            <TextBlock Grid.Column="0" Text="{Binding Label}"
                                       Foreground="#C8D8E8" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="{Binding Trades}" Foreground="#8FA3B8" FontSize="11" />
                            <TextBlock Grid.Column="2" Text="{Binding PnlLabel}"
                                       Foreground="{Binding PnlBrush}" FontWeight="SemiBold" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </StackPanel>
              </Border>

              <!-- By Exchange -->
              <Border Grid.Column="1" Classes="Panel" Padding="0">
                <StackPanel>
                  <Border Padding="16,10" BorderBrush="#1A2E3A" BorderThickness="0,0,0,1">
                    <TextBlock Classes="H2" Text="P&amp;L by Exchange" />
                  </Border>
                  <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10" Margin="16,8">
                    <TextBlock Grid.Column="0" Classes="Overline" Text="Exchange" />
                    <TextBlock Grid.Column="1" Classes="Overline" Text="W/T" />
                    <TextBlock Grid.Column="2" Classes="Overline" Text="P&amp;L" />
                  </Grid>
                  <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding PnlDashboardVM.ByExchangeRows}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SourceRowViewModel">
                          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10"
                                Margin="16,5" VerticalAlignment="Center">
                            <TextBlock Grid.Column="0" Text="{Binding Label}"
                                       Foreground="#C8D8E8" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="{Binding Trades}" Foreground="#8FA3B8" FontSize="11" />
                            <TextBlock Grid.Column="2" Text="{Binding PnlLabel}"
                                       Foreground="{Binding PnlBrush}" FontWeight="SemiBold" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </StackPanel>
              </Border>

              <!-- By Asset -->
              <Border Grid.Column="2" Classes="Panel" Padding="0">
                <StackPanel>
                  <Border Padding="16,10" BorderBrush="#1A2E3A" BorderThickness="0,0,0,1">
                    <TextBlock Classes="H2" Text="P&amp;L by Asset" />
                  </Border>
                  <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10" Margin="16,8">
                    <TextBlock Grid.Column="0" Classes="Overline" Text="Asset" />
                    <TextBlock Grid.Column="1" Classes="Overline" Text="W/T" />
                    <TextBlock Grid.Column="2" Classes="Overline" Text="P&amp;L" />
                  </Grid>
                  <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding PnlDashboardVM.ByAssetRows}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SourceRowViewModel">
                          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10"
                                Margin="16,5" VerticalAlignment="Center">
                            <TextBlock Grid.Column="0" Text="{Binding Label}"
                                       Foreground="#C8D8E8" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="{Binding Trades}" Foreground="#8FA3B8" FontSize="11" />
                            <TextBlock Grid.Column="2" Text="{Binding PnlLabel}"
                                       Foreground="{Binding PnlBrush}" FontWeight="SemiBold" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </StackPanel>
              </Border>

            </Grid>

            <!-- ── Trade history table ── -->
            <Border Classes="Panel" Padding="0">
              <StackPanel>
                <Border Padding="16,10" BorderBrush="#1A2E3A" BorderThickness="0,0,0,1">
                  <TextBlock Classes="H2" Text="Trade History" />
                </Border>
                <!-- Column headers -->
                <Grid ColumnDefinitions="120,*,80,70,80,80,80,*" ColumnSpacing="10" Margin="16,8">
                  <TextBlock Grid.Column="0" Classes="Overline" Text="Date" />
                  <TextBlock Grid.Column="1" Classes="Overline" Text="Symbol" />
                  <TextBlock Grid.Column="2" Classes="Overline" Text="Source" />
                  <TextBlock Grid.Column="3" Classes="Overline" Text="Side" />
                  <TextBlock Grid.Column="4" Classes="Overline" Text="P&amp;L" />
                  <TextBlock Grid.Column="5" Classes="Overline" Text="P&amp;L %" />
                  <TextBlock Grid.Column="6" Classes="Overline" Text="Duration" />
                  <TextBlock Grid.Column="7" Classes="Overline" Text="Exit" />
                </Grid>
                <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                  <ItemsControl ItemsSource="{Binding PnlDashboardVM.TradeRows}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:TradeRowViewModel">
                        <Border Padding="16,6" BorderBrush="#1A2E3A" BorderThickness="0,0,0,1">
                          <Grid ColumnDefinitions="120,*,80,70,80,80,80,*" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="{Binding DateLabel}"  Foreground="#8FA3B8" FontSize="11" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding Symbol}"     Foreground="#C8D8E8" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding Source}"     Foreground="#4D7EA8" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="{Binding Direction}"  Foreground="#8FA3B8" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="{Binding PnlLabel}"   Foreground="{Binding PnlBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="5" Text="{Binding PnlPctLabel}" Foreground="{Binding PnlBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="6" Text="{Binding Duration}"   Foreground="#8FA3B8" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="7" Text="{Binding ExitReason}" Foreground="#4D5F70" FontSize="11" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </StackPanel>
            </Border>

            <!-- ── Session summary (existing, kept for legacy compatibility) ── -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">
              <Border Grid.Column="0" Classes="SurfaceCard">
                <StackPanel Spacing="6">
                  <TextBlock Classes="Overline" Text="Session P&amp;L" />
                  <TextBlock Classes="Metric" Text="{Binding SessionPnlLabel}" />
                  <TextBlock Text="{Binding SessionPnlPercentLabel}" Foreground="{Binding SessionPnlBrush}" />
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Classes="SurfaceCard">
                <StackPanel Spacing="6">
                  <TextBlock Classes="Overline" Text="Execution" />
                  <TextBlock Text="{Binding AnalyticsExecutionSummary}" FontWeight="SemiBold" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Classes="SurfaceCard">
                <StackPanel Spacing="6">
                  <TextBlock Classes="Overline" Text="Market Breadth" />
                  <TextBlock Text="{Binding AnalyticsMarketSummary}" FontWeight="SemiBold" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </Grid>

          </StackPanel>

          <StackPanel Spacing="16" IsVisible="{Binding IsSettingsSectionVisible}">

            <!-- ═══ AI Assistant Provider (Claude / ChatGPT) ═══ -->
            <Border Classes="Panel">
              <StackPanel Spacing="12">
                <TextBlock Classes="H2" Text="AI Assistant — Claude or ChatGPT" />
                <TextBlock Foreground="#8FA3B8" FontSize="12" TextWrapping="Wrap"
                           Text="Choose which AI powers every assistant in the terminal (copilot, daily briefing, pre-trade risk, alerts, scanner ranking, options, and the rest). Paste an API key for the provider you pick. Use the 'Log in / get key' button to open the provider's website, sign in, and create a key." />

                <!-- Provider toggle -->
                <StackPanel Orientation="Horizontal" Spacing="20">
                  <RadioButton GroupName="AiProvider" Content="Claude (Anthropic)" IsChecked="{Binding AiIsClaude, Mode=TwoWay}" Foreground="#C5D2DE" />
                  <RadioButton GroupName="AiProvider" Content="ChatGPT (OpenAI)"   IsChecked="{Binding AiIsChatGpt, Mode=TwoWay}" Foreground="#C5D2DE" />
                </StackPanel>

                <!-- Claude credentials -->
                <Border Background="#0E1B27" CornerRadius="6" Padding="12" IsVisible="{Binding AiIsClaude}">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="Overline" Text="Claude (Anthropic) API key" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                      <TextBox Grid.Column="0" Text="{Binding AnthropicKeyInput}" PasswordChar="•" PlaceholderText="sk-ant-…" />
                      <Button Grid.Column="1" Content="🌐 Log in / get key" Command="{Binding OpenAnthropicConsoleCommand}" />
                    </Grid>
                    <TextBlock Classes="Overline" Text="Model" />
                    <TextBox Text="{Binding AnthropicModelInput}" PlaceholderText="claude-sonnet-4-6" />
                  </StackPanel>
                </Border>

                <!-- ChatGPT credentials -->
                <Border Background="#0E1B27" CornerRadius="6" Padding="12" IsVisible="{Binding AiIsChatGpt}">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="Overline" Text="ChatGPT (OpenAI) API key" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                      <TextBox Grid.Column="0" Text="{Binding OpenAiKeyInput}" PasswordChar="•" PlaceholderText="sk-…" />
                      <Button Grid.Column="1" Content="🌐 Log in / get key" Command="{Binding OpenOpenAiConsoleCommand}" />
                    </Grid>
                    <TextBlock Classes="Overline" Text="Model" />
                    <TextBox Text="{Binding OpenAiModelInput}" PlaceholderText="gpt-4o" />
                  </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="12">
                  <Button Content="Save AI provider" Command="{Binding SaveAiSettingsCommand}"
                          Background="#1FE6C2" Foreground="#06121C" FontWeight="Bold" />
                  <TextBlock Text="{Binding AiSettingsStatus}" Foreground="#8FA3B8" FontSize="12"
                             TextWrapping="Wrap" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Foreground="#4A6880" FontSize="11" TextWrapping="Wrap"
                           Text="Keys are stored encrypted on this PC (DPAPI) and never leave it except in calls to the provider you selected. The change applies immediately — no restart needed." />
              </StackPanel>
            </Border>
            <!-- ═══ End AI Assistant Provider ═══ -->

            <!-- License & activation -->
            <Border Classes="Panel">
              <StackPanel Spacing="12">
                <TextBlock Classes="H2" Text="License &amp; Activation" />

                <StackPanel Orientation="Horizontal" Spacing="10">
                  <Border Background="{Binding LicenseVM.StateBrush}" CornerRadius="3" Padding="8,3" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LicenseVM.StateLabel}" Foreground="#06121C" FontSize="12" FontWeight="Bold" />
                  </Border>
                  <TextBlock Text="{Binding LicenseVM.DetailLabel}" Foreground="#8FA3B8" FontSize="12"
                             TextWrapping="Wrap" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Spacing="6">
                  <TextBlock Classes="Overline" Text="Your Machine ID (send this to the bot to bind your key)" />
                  <TextBox Text="{Binding LicenseVM.MachineId, Mode=OneWay}" IsReadOnly="True"
                           FontFamily="Consolas,Menlo,monospace" />
                </StackPanel>

                <StackPanel Spacing="6">
                  <TextBlock Classes="Overline" Text="Activation key" />
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <TextBox Grid.Column="0" Text="{Binding LicenseVM.KeyInput}" PlaceholderText="Paste your license key here" />
                    <Button Grid.Column="1" Content="Activate" Command="{Binding LicenseVM.ActivateCommand}"
                            Background="#1FE6C2" Foreground="#06121C" FontWeight="Bold" />
                  </Grid>
                  <TextBlock Text="{Binding LicenseVM.StatusMessage}" Foreground="#F4B860" FontSize="12" TextWrapping="Wrap" />
                </StackPanel>

                <TextBlock Foreground="#4A6880" FontSize="11" TextWrapping="Wrap"
                           Text="Buy a key in the Telegram bot. Send the Machine ID above to the bot before paying so your key is bound to this PC. Without a valid license, only Demo (paper) mode is available after the trial." />
              </StackPanel>
            </Border>

            <!-- Configuration profiles (save / load / share) -->
            <Border Classes="Panel">
              <StackPanel Spacing="12">
                <TextBlock Classes="H2" Text="Configuration Profiles" />
                <TextBlock Foreground="#4A6880" FontSize="11" TextWrapping="Wrap"
                           Text="Save all bot / sniper / grid / risk settings as a named profile (API keys are never included). Export to share a setup; Import picks up files dropped into the shared folder." />

                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
                  <TextBox Grid.Column="0" Text="{Binding ProfileName}" PlaceholderText="Profile name" />
                  <Button Grid.Column="1" Content="Save" Command="{Binding SaveProfileCommand}" />
                  <Button Grid.Column="2" Content="Load" Command="{Binding LoadProfileCommand}" />
                  <Button Grid.Column="3" Content="Delete" Command="{Binding DeleteProfileCommand}" />
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="10">
                  <Button Content="⬆ Export (share)" Command="{Binding ExportProfileCommand}" />
                  <Button Content="⬇ Import" Command="{Binding ImportProfileCommand}" />
                </StackPanel>

                <TextBlock Text="{Binding ProfileStatus}" Foreground="#8FA3B8" FontSize="12" TextWrapping="Wrap" />

                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Saved profiles" />
                  <ItemsControl ItemsSource="{Binding AvailableProfiles}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="#C5D2DE" FontSize="12" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Telegram setup -->
            <Border Classes="Panel">
              <StackPanel Spacing="12">
                <TextBlock Classes="H2" Text="Telegram Notifications" />
                <Grid ColumnDefinitions="*,*,Auto,Auto" ColumnSpacing="12">
                  <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Classes="Overline" Text="Bot Token" />
                    <TextBox Text="{Binding AlertsVM.TelegramBotToken}" PasswordChar="•" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Classes="Overline" Text="Chat ID" />
                    <TextBox Text="{Binding AlertsVM.TelegramChatId}" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="6">
                    <TextBlock Classes="Overline" Text=" " />
                    <Button Command="{Binding AlertsVM.TestTelegramCommand}" Content="Test" />
                  </StackPanel>
                  <StackPanel Grid.Column="3" Spacing="6">
                    <TextBlock Classes="Overline" Text="Status" />
                    <TextBlock Text="{Binding AlertsVM.TelegramStatus}" Foreground="#8FA3B8" VerticalAlignment="Center" />
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <!-- Discord webhook setup -->
            <Border Classes="Panel">
              <StackPanel Spacing="12">
                <TextBlock Classes="H2" Text="Discord Notifications" />
                <TextBlock Text="Paste a Discord channel webhook URL. Alerts marked Send→Discord will be POSTed to it (Markdown-formatted)."
                           Foreground="#4A6880" FontSize="11" TextWrapping="Wrap" />
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                  <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Classes="Overline" Text="Webhook URL" />
                    <TextBox Text="{Binding AlertsVM.DiscordWebhookUrl}" PasswordChar="•"
                             PlaceholderText="https://discord.com/api/webhooks/..." />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Classes="Overline" Text=" " />
                    <Button Command="{Binding AlertsVM.TestDiscordCommand}" Content="Test" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="6">
                    <TextBlock Classes="Overline" Text="Status" />
                    <TextBlock Text="{Binding AlertsVM.DiscordStatus}" Foreground="#8FA3B8" VerticalAlignment="Center" />
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <!-- ntfy.sh push setup -->
            <Border Classes="Panel">
              <StackPanel Spacing="12">
                <TextBlock Classes="H2" Text="ntfy.sh Push" />
                <TextBlock Text="Free, anonymous push to phone or browser. Install the ntfy app (iOS/Android/web), subscribe to the same topic. Anyone with the topic name can publish — use a long random string."
                           Foreground="#4A6880" FontSize="11" TextWrapping="Wrap" />
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                  <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Classes="Overline" Text="Topic (or full URL)" />
                    <TextBox Text="{Binding AlertsVM.NtfyTopic}"
                             PlaceholderText="crypto-ai-a8f3d7b2c1e9...  or  https://ntfy.sh/my-topic" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Classes="Overline" Text=" " />
                    <Button Command="{Binding AlertsVM.TestNtfyCommand}" Content="Test" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="6">
                    <TextBlock Classes="Overline" Text="Status" />
                    <TextBlock Text="{Binding AlertsVM.NtfyStatus}" Foreground="#8FA3B8" VerticalAlignment="Center" />
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <!-- Email SMTP setup -->
            <Border Classes="Panel">
              <StackPanel Spacing="12">
                <TextBlock Classes="H2" Text="Email Notifications" />
                <TextBlock Text="SMTP-based fallback channel. For Gmail use smtp.gmail.com / port 587 / SSL on + an App Password (not your real password — Google rejects plain auth)."
                           Foreground="#4A6880" FontSize="11" TextWrapping="Wrap" />
                <Grid ColumnDefinitions="2*,Auto,Auto,Auto" ColumnSpacing="12">
                  <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Classes="Overline" Text="SMTP host" />
                    <TextBox Text="{Binding AlertsVM.EmailHost}" PlaceholderText="smtp.gmail.com" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Classes="Overline" Text="Port" />
                    <NumericUpDown Value="{Binding AlertsVM.EmailPort}" Minimum="1" Maximum="65535" Increment="1" Width="90" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="6" VerticalAlignment="Bottom">
                    <TextBlock Classes="Overline" Text="SSL/TLS" />
                    <CheckBox IsChecked="{Binding AlertsVM.EmailUseSsl}" Content="STARTTLS" />
                  </StackPanel>
                  <StackPanel Grid.Column="3" Spacing="6" VerticalAlignment="Bottom">
                    <TextBlock Classes="Overline" Text=" " />
                    <Button Command="{Binding AlertsVM.TestEmailCommand}" Content="Send test" />
                  </StackPanel>
                </Grid>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                  <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Classes="Overline" Text="SMTP username" />
                    <TextBox Text="{Binding AlertsVM.EmailUsername}" PlaceholderText="you@example.com" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Classes="Overline" Text="SMTP password" />
                    <TextBox Text="{Binding AlertsVM.EmailPassword}" PasswordChar="•" />
                  </StackPanel>
                </Grid>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                  <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Classes="Overline" Text="From address" />
                    <TextBox Text="{Binding AlertsVM.EmailFrom}" PlaceholderText="bot@example.com" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Classes="Overline" Text="To address" />
                    <TextBox Text="{Binding AlertsVM.EmailTo}" PlaceholderText="me@example.com" />
                  </StackPanel>
                </Grid>
                <TextBlock Text="{Binding AlertsVM.EmailStatus}" Foreground="#8FA3B8" />
              </StackPanel>
            </Border>

            <!-- ═══ Binance API Keys ═══ -->
            <Border Classes="Panel">
              <StackPanel Spacing="14">

                <!-- Header: title + source badge + ? button -->
                <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
                  <TextBlock Grid.Column="0" Classes="H2" Text="Binance API Keys" VerticalAlignment="Center" />
                  <Border Grid.Column="1" CornerRadius="6" Padding="7,2" VerticalAlignment="Center"
                          Background="{Binding BinanceCredentialSourceBadgeBrush}">
                    <TextBlock Text="{Binding BinanceCredentialSourceLabel}"
                               FontSize="10" FontWeight="Bold" Foreground="#0A121A" />
                  </Border>
                  <TextBlock Grid.Column="2"
                             Text="{Binding BinanceApiKeyMask}"
                             FontFamily="Consolas" FontSize="12" Foreground="#F0B90B"
                             VerticalAlignment="Center" Margin="6,0,0,0" />
                  <Button Grid.Column="3"
                          Content="?"
                          Classes="GhostButton"
                          Width="28" Height="28"
                          FontWeight="Bold" FontSize="13"
                          Padding="0"
                          ToolTip.Tip="How to create Binance API keys"
                          Command="{Binding ToggleBinanceHelpCommand}" />
                </Grid>

                <!-- Help panel (collapsible) -->
                <Border IsVisible="{Binding IsBinanceHelpVisible}"
                        Background="#080F18" BorderBrush="#1E3A52" BorderThickness="1"
                        CornerRadius="8" Padding="14,12">
                  <StackPanel Spacing="8">
                    <TextBlock Text="How to get Binance API keys" FontWeight="Bold"
                               Foreground="#F0B90B" FontSize="13" />
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Foreground="#C8D6E5">
                      <Run Text="1." FontWeight="Bold" /> <Run Text="Log in to " />
                      <Run Text="binance.com" FontWeight="Bold" Foreground="#F0B90B" />
                      <Run Text=" → profile → API Management" />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Foreground="#C8D6E5">
                      <Run Text="2." FontWeight="Bold" /> <Run Text="Create API → select permissions: " />
                      <Run Text="Enable Spot &amp; Margin Trading" FontWeight="Bold" />
                      <Run Text=" and " />
                      <Run Text="Enable Futures" FontWeight="Bold" />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Foreground="#C8D6E5">
                      <Run Text="3." FontWeight="Bold" /> <Run Text="Copy API Key and Secret Key — the Secret is shown " />
                      <Run Text="only once!" FontWeight="Bold" Foreground="#FFAA33" />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Foreground="#C8D6E5">
                      <Run Text="4." FontWeight="Bold" /> <Run Text="Paste below and click «Save»." />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="18"
                               Foreground="#5C6E82" Margin="0,4,0,0">
                      <Run Text="Keys are stored in " />
                      <Run FontFamily="Consolas" Text="%LOCALAPPDATA%\CryptoAITerminal\api-credentials.json" />
                      <Run Text=" (only for your Windows account). Environment variables BINANCE_API_KEY / BINANCE_API_SECRET take priority." />
                    </TextBlock>
                  </StackPanel>
                </Border>

                <!-- Env var active notice -->
                <Border Background="#0E1E10" CornerRadius="6" Padding="10,6"
                        IsVisible="{Binding IsBinanceCredSourceEnv}">
                  <TextBlock FontSize="11" Foreground="#4CAF50" TextWrapping="Wrap">
                    <Run Text="✓ Environment variable BINANCE_API_KEY is active." />
                    <Run Text=" Values below are not applied while it is set." />
                  </TextBlock>
                </Border>

                <!-- Key input row -->
                <Grid ColumnDefinitions="90,*,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                  <TextBlock Grid.Column="0" Text="API Key" FontSize="12" Foreground="#8FA3B8"
                             VerticalAlignment="Center" />
                  <Panel Grid.Column="1">
                    <TextBox Text="{Binding BinanceKeyInput}" PasswordChar="●"
                             IsVisible="{Binding !IsShowingBinanceKey}"
                             PlaceholderText="paste API Key…" />
                    <TextBox Text="{Binding BinanceKeyInput}"
                             IsVisible="{Binding IsShowingBinanceKey}"
                             PlaceholderText="paste API Key…" />
                  </Panel>
                  <Button Grid.Column="2" Content="👁" Classes="GhostButton" Padding="6,4" FontSize="13"
                          ToolTip.Tip="Show / hide"
                          Command="{Binding ToggleBinanceKeyVisibilityCommand}" />
                </Grid>

                <!-- Secret input row -->
                <Grid ColumnDefinitions="90,*,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                  <TextBlock Grid.Column="0" Text="API Secret" FontSize="12" Foreground="#8FA3B8"
                             VerticalAlignment="Center" />
                  <Panel Grid.Column="1">
                    <TextBox Text="{Binding BinanceSecretInput}" PasswordChar="●"
                             IsVisible="{Binding !IsShowingBinanceSecret}"
                             PlaceholderText="paste API Secret…" />
                    <TextBox Text="{Binding BinanceSecretInput}"
                             IsVisible="{Binding IsShowingBinanceSecret}"
                             PlaceholderText="paste API Secret…" />
                  </Panel>
                  <Button Grid.Column="2" Content="👁" Classes="GhostButton" Padding="6,4" FontSize="13"
                          ToolTip.Tip="Show / hide"
                          Command="{Binding ToggleBinanceSecretVisibilityCommand}" />
                </Grid>

                <!-- Save row -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                  <Button Grid.Column="0" Content="💾 Save"
                          Classes="GhostButton" Padding="14,6"
                          Command="{Binding SaveBinanceCredentialsCommand}" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding BinanceSaveStatus}"
                             FontSize="12" Foreground="#F0B90B"
                             VerticalAlignment="Center" />
                </Grid>

              </StackPanel>
            </Border>
            <!-- ═══ End Binance API Keys ═══ -->

            <!-- ═══ Bybit API Keys ═══ -->
            <Border Classes="Panel">
              <StackPanel Spacing="14">

                <!-- Header: title + source badge + ? button -->
                <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
                  <TextBlock Grid.Column="0" Classes="H2" Text="Bybit API Keys" VerticalAlignment="Center" />
                  <!-- Source badge: ENV / FILE / — -->
                  <Border Grid.Column="1" CornerRadius="6" Padding="7,2" VerticalAlignment="Center"
                          Background="{Binding BybitCredentialSourceBadgeBrush}">
                    <TextBlock Text="{Binding BybitCredentialSourceLabel}"
                               FontSize="10" FontWeight="Bold" Foreground="#0A121A" />
                  </Border>
                  <!-- Current masked key -->
                  <TextBlock Grid.Column="2"
                             Text="{Binding BybitApiKeyMask}"
                             FontFamily="Consolas" FontSize="12" Foreground="#21E6C1"
                             VerticalAlignment="Center" Margin="6,0,0,0" />
                  <!-- ? help toggle -->
                  <Button Grid.Column="3"
                          Content="?"
                          Classes="GhostButton"
                          Width="28" Height="28"
                          FontWeight="Bold" FontSize="13"
                          Padding="0"
                          ToolTip.Tip="How to create Bybit API keys"
                          Command="{Binding ToggleBybitHelpCommand}" />
                </Grid>

                <!-- Help panel (collapsible) -->
                <Border IsVisible="{Binding IsBybitHelpVisible}"
                        Background="#080F18" BorderBrush="#1E3A52" BorderThickness="1"
                        CornerRadius="8" Padding="14,12">
                  <StackPanel Spacing="8">
                    <TextBlock Text="How to get Bybit API keys" FontWeight="Bold"
                               Foreground="#21E6C1" FontSize="13" />
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Foreground="#C8D6E5">
                      <Run Text="1." FontWeight="Bold" /> <Run Text="Log in to " />
                      <Run Text="bybit.com" FontWeight="Bold" Foreground="#21E6C1" />
                      <Run Text=" → top-right corner → Account → API" />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Foreground="#C8D6E5">
                      <Run Text="2." FontWeight="Bold" /> <Run Text="Create a new key → select permissions: " />
                      <Run Text="Trade" FontWeight="Bold" /> <Run Text=" and " />
                      <Run Text="Account Info" FontWeight="Bold" />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Foreground="#C8D6E5">
                      <Run Text="3." FontWeight="Bold" /> <Run Text="Copy API Key and Secret Key — the Secret is shown " />
                      <Run Text="only once!" FontWeight="Bold" Foreground="#FFAA33" />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Foreground="#C8D6E5">
                      <Run Text="4." FontWeight="Bold" /> <Run Text="Paste below and click «Save»." />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="18"
                               Foreground="#5C6E82" Margin="0,4,0,0">
                      <Run Text="Keys are stored in " />
                      <Run FontFamily="Consolas" Text="%LOCALAPPDATA%\CryptoAITerminal\api-credentials.json" />
                      <Run Text=" (only for your Windows account). Environment variables BYBIT_API_KEY / BYBIT_API_SECRET take priority." />
                    </TextBlock>
                  </StackPanel>
                </Border>

                <!-- Env var active notice -->
                <Border Background="#0E1E10" CornerRadius="6" Padding="10,6"
                        IsVisible="{Binding IsBybitCredSourceEnv}">
                  <TextBlock FontSize="11" Foreground="#4CAF50" TextWrapping="Wrap">
                    <Run Text="✓ Environment variable BYBIT_API_KEY is active." />
                    <Run Text=" Values below are not applied while it is set." />
                  </TextBlock>
                </Border>

                <!-- Key input row -->
                <Grid ColumnDefinitions="90,*,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                  <TextBlock Grid.Column="0" Text="API Key" FontSize="12" Foreground="#8FA3B8"
                             VerticalAlignment="Center" />
                  <Panel Grid.Column="1">
                    <TextBox Text="{Binding BybitKeyInput}" PasswordChar="●"
                             IsVisible="{Binding !IsShowingBybitKey}"
                             PlaceholderText="paste API Key…" />
                    <TextBox Text="{Binding BybitKeyInput}"
                             IsVisible="{Binding IsShowingBybitKey}"
                             PlaceholderText="paste API Key…" />
                  </Panel>
                  <Button Grid.Column="2" Content="👁" Classes="GhostButton" Padding="6,4" FontSize="13"
                          ToolTip.Tip="Show / hide"
                          Command="{Binding ToggleBybitKeyVisibilityCommand}" />
                </Grid>

                <!-- Secret input row -->
                <Grid ColumnDefinitions="90,*,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                  <TextBlock Grid.Column="0" Text="API Secret" FontSize="12" Foreground="#8FA3B8"
                             VerticalAlignment="Center" />
                  <Panel Grid.Column="1">
                    <TextBox Text="{Binding BybitSecretInput}" PasswordChar="●"
                             IsVisible="{Binding !IsShowingBybitSecret}"
                             PlaceholderText="paste API Secret…" />
                    <TextBox Text="{Binding BybitSecretInput}"
                             IsVisible="{Binding IsShowingBybitSecret}"
                             PlaceholderText="paste API Secret…" />
                  </Panel>
                  <Button Grid.Column="2" Content="👁" Classes="GhostButton" Padding="6,4" FontSize="13"
                          ToolTip.Tip="Show / hide"
                          Command="{Binding ToggleBybitSecretVisibilityCommand}" />
                </Grid>

                <!-- Save row -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                  <Button Grid.Column="0" Content="💾 Save"
                          Classes="GhostButton" Padding="14,6"
                          Command="{Binding SaveBybitCredentialsCommand}" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding BybitSaveStatus}"
                             FontSize="12" Foreground="#21E6C1"
                             VerticalAlignment="Center" />
                </Grid>

              </StackPanel>
            </Border>
            <!-- ═══ End Bybit API Keys ═══ -->

            <!-- ═══ OKX API Keys ═══ -->
            <Border Classes="Panel">
              <StackPanel Spacing="14">

                <!-- Header: title + source badge + ? button -->
                <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
                  <TextBlock Grid.Column="0" Classes="H2" Text="OKX API Keys" VerticalAlignment="Center" />
                  <Border Grid.Column="1" CornerRadius="6" Padding="7,2" VerticalAlignment="Center"
                          Background="{Binding OkxCredentialSourceBadgeBrush}">
                    <TextBlock Text="{Binding OkxCredentialSourceLabel}"
                               FontSize="10" FontWeight="Bold" Foreground="#0A121A" />
                  </Border>
                  <TextBlock Grid.Column="2"
                             Text="{Binding OkxApiKeyMask}"
                             FontFamily="Consolas" FontSize="12" Foreground="#21E6C1"
                             VerticalAlignment="Center" Margin="6,0,0,0" />
                  <Button Grid.Column="3"
                          Content="?"
                          Classes="GhostButton"
                          Width="28" Height="28"
                          FontWeight="Bold" FontSize="13"
                          Padding="0"
                          ToolTip.Tip="How to create OKX API keys"
                          Command="{Binding ToggleOkxHelpCommand}" />
                </Grid>

                <!-- Help panel -->
                <Border IsVisible="{Binding IsOkxHelpVisible}"
                        Background="#080F18" BorderBrush="#1E3A52" BorderThickness="1"
                        CornerRadius="8" Padding="14,12">
                  <StackPanel Spacing="8">
                    <TextBlock Text="How to get OKX API keys" FontWeight="Bold"
                               Foreground="#21E6C1" FontSize="13" />
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Foreground="#C8D6E5">
                      <Run Text="1." FontWeight="Bold" /> <Run Text="Log in to " />
                      <Run Text="okx.com" FontWeight="Bold" Foreground="#21E6C1" />
                      <Run Text=" → avatar (top-right corner) → API Keys" />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Foreground="#C8D6E5">
                      <Run Text="2." FontWeight="Bold" /> <Run Text="Create API Key → set a Passphrase (remember it!)." />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Foreground="#C8D6E5">
                      <Run Text="3." FontWeight="Bold" /> <Run Text="Permissions: " />
                      <Run Text="Trade" FontWeight="Bold" /> <Run Text=" + " />
                      <Run Text="Read" FontWeight="Bold" />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Foreground="#C8D6E5">
                      <Run Text="4." FontWeight="Bold" />
                      <Run Text=" Copy API Key, Secret Key and Passphrase — the Secret is shown " />
                      <Run Text="only once!" FontWeight="Bold" Foreground="#FFAA33" />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Foreground="#C8D6E5">
                      <Run Text="5." FontWeight="Bold" /> <Run Text="Paste all three fields below and click «Save»." />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="18"
                               Foreground="#5C6E82" Margin="0,4,0,0">
                      <Run Text="Keys are stored in " />
                      <Run FontFamily="Consolas" Text="%LOCALAPPDATA%\CryptoAITerminal\api-credentials.json" />
                      <Run Text=". Environment variables OKX_API_KEY / OKX_API_SECRET / OKX_API_PASSPHRASE take priority." />
                    </TextBlock>
                  </StackPanel>
                </Border>

                <!-- Env var active notice -->
                <Border Background="#0E1E10" CornerRadius="6" Padding="10,6"
                        IsVisible="{Binding IsOkxCredSourceEnv}">
                  <TextBlock FontSize="11" Foreground="#4CAF50" TextWrapping="Wrap">
                    <Run Text="✓ Environment variable OKX_API_KEY is active." />
                    <Run Text=" Values below are not applied while it is set." />
                  </TextBlock>
                </Border>

                <!-- Key input row -->
                <Grid ColumnDefinitions="90,*,Auto" ColumnSpacing="8">
                  <TextBlock Grid.Column="0" Text="API Key" FontSize="12" Foreground="#8FA3B8"
                             VerticalAlignment="Center" />
                  <Panel Grid.Column="1">
                    <TextBox Text="{Binding OkxKeyInput}" PasswordChar="●"
                             IsVisible="{Binding !IsShowingOkxKey}"
                             PlaceholderText="paste API Key…" />
                    <TextBox Text="{Binding OkxKeyInput}"
                             IsVisible="{Binding IsShowingOkxKey}"
                             PlaceholderText="paste API Key…" />
                  </Panel>
                  <Button Grid.Column="2" Content="👁" Classes="GhostButton" Padding="6,4" FontSize="13"
                          ToolTip.Tip="Show / hide"
                          Command="{Binding ToggleOkxKeyVisibilityCommand}" />
                </Grid>

                <!-- Secret input row -->
                <Grid ColumnDefinitions="90,*,Auto" ColumnSpacing="8">
                  <TextBlock Grid.Column="0" Text="API Secret" FontSize="12" Foreground="#8FA3B8"
                             VerticalAlignment="Center" />
                  <Panel Grid.Column="1">
                    <TextBox Text="{Binding OkxSecretInput}" PasswordChar="●"
                             IsVisible="{Binding !IsShowingOkxSecret}"
                             PlaceholderText="paste API Secret…" />
                    <TextBox Text="{Binding OkxSecretInput}"
                             IsVisible="{Binding IsShowingOkxSecret}"
                             PlaceholderText="paste API Secret…" />
                  </Panel>
                  <Button Grid.Column="2" Content="👁" Classes="GhostButton" Padding="6,4" FontSize="13"
                          ToolTip.Tip="Show / hide"
                          Command="{Binding ToggleOkxSecretVisibilityCommand}" />
                </Grid>

                <!-- Passphrase input row (OKX-specific) -->
                <Grid ColumnDefinitions="90,*,Auto" ColumnSpacing="8">
                  <TextBlock Grid.Column="0" Text="Passphrase" FontSize="12" Foreground="#8FA3B8"
                             VerticalAlignment="Center" />
                  <Panel Grid.Column="1">
                    <TextBox Text="{Binding OkxPassphraseInput}" PasswordChar="●"
                             IsVisible="{Binding !IsShowingOkxPassphrase}"
                             PlaceholderText="your API Key Passphrase…" />
                    <TextBox Text="{Binding OkxPassphraseInput}"
                             IsVisible="{Binding IsShowingOkxPassphrase}"
                             PlaceholderText="your API Key Passphrase…" />
                  </Panel>
                  <Button Grid.Column="2" Content="👁" Classes="GhostButton" Padding="6,4" FontSize="13"
                          ToolTip.Tip="Show / hide"
                          Command="{Binding ToggleOkxPassphraseVisibilityCommand}" />
                </Grid>

                <!-- Save row -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                  <Button Grid.Column="0" Content="💾 Save"
                          Classes="GhostButton" Padding="14,6"
                          Command="{Binding SaveOkxCredentialsCommand}" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding OkxSaveStatus}"
                             FontSize="12" Foreground="#21E6C1"
                             VerticalAlignment="Center" />
                </Grid>

              </StackPanel>
            </Border>
            <!-- ═══ End OKX API Keys ═══ -->

            <!-- ═══ KuCoin API Keys ═══ -->
            <Border Classes="Panel">
              <StackPanel Spacing="14">

                <!-- Header: title + source badge + ? button -->
                <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
                  <TextBlock Grid.Column="0" Classes="H2" Text="KuCoin API Keys" VerticalAlignment="Center" />
                  <Border Grid.Column="1" CornerRadius="6" Padding="7,2" VerticalAlignment="Center"
                          Background="{Binding KucoinCredentialSourceBadgeBrush}">
                    <TextBlock Text="{Binding KucoinCredentialSourceLabel}"
                               FontSize="10" FontWeight="Bold" Foreground="#0A121A" />
                  </Border>
                  <TextBlock Grid.Column="2"
                             Text="{Binding KucoinApiKeyMask}"
                             FontFamily="Consolas" FontSize="12" Foreground="#21E6C1"
                             VerticalAlignment="Center" Margin="6,0,0,0" />
                  <Button Grid.Column="3"
                          Content="?"
                          Classes="GhostButton"
                          Width="28" Height="28"
                          FontWeight="Bold" FontSize="13"
                          Padding="0"
                          ToolTip.Tip="How to create KuCoin API keys"
                          Command="{Binding ToggleKucoinHelpCommand}" />
                </Grid>

                <!-- Help panel (collapsible) -->
                <Border IsVisible="{Binding IsKucoinHelpVisible}"
                        Background="#080F18" BorderBrush="#1E3A52" BorderThickness="1"
                        CornerRadius="8" Padding="14,12">
                  <StackPanel Spacing="8">
                    <TextBlock Text="How to get KuCoin API keys" FontWeight="Bold"
                               Foreground="#21E6C1" FontSize="13" />
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Foreground="#C8D6E5">
                      <Run Text="1." FontWeight="Bold" /> <Run Text="Log in to " />
                      <Run Text="kucoin.com" FontWeight="Bold" Foreground="#21E6C1" />
                      <Run Text=" → avatar (top-right corner) → API Management" />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Foreground="#C8D6E5">
                      <Run Text="2." FontWeight="Bold" /> <Run Text="Create API → set an API Name and Trading Password (Passphrase)." />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Foreground="#C8D6E5">
                      <Run Text="3." FontWeight="Bold" /> <Run Text="Permissions: " />
                      <Run Text="General + Trade" FontWeight="Bold" />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Foreground="#C8D6E5">
                      <Run Text="4." FontWeight="Bold" />
                      <Run Text=" Copy API Key, Secret and Passphrase — the Secret is shown " />
                      <Run Text="only once!" FontWeight="Bold" Foreground="#FFAA33" />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Foreground="#C8D6E5">
                      <Run Text="5." FontWeight="Bold" /> <Run Text="Paste all three fields below and click «Save»." />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="18"
                               Foreground="#5C6E82" Margin="0,4,0,0">
                      <Run Text="Keys are stored in " />
                      <Run FontFamily="Consolas" Text="%LOCALAPPDATA%\CryptoAITerminal\api-credentials.json" />
                      <Run Text=". Environment variables KUCOIN_API_KEY / KUCOIN_API_SECRET / KUCOIN_API_PASSPHRASE take priority." />
                    </TextBlock>
                  </StackPanel>
                </Border>

                <!-- Env var active notice -->
                <Border Background="#0E1E10" CornerRadius="6" Padding="10,6"
                        IsVisible="{Binding IsKucoinCredSourceEnv}">
                  <TextBlock FontSize="11" Foreground="#4CAF50" TextWrapping="Wrap">
                    <Run Text="✓ Environment variable KUCOIN_API_KEY is active." />
                    <Run Text=" Values below are not applied while it is set." />
                  </TextBlock>
                </Border>

                <!-- Key input row -->
                <Grid ColumnDefinitions="90,*,Auto" ColumnSpacing="8">
                  <TextBlock Grid.Column="0" Text="API Key" FontSize="12" Foreground="#8FA3B8"
                             VerticalAlignment="Center" />
                  <Panel Grid.Column="1">
                    <TextBox Text="{Binding KucoinKeyInput}" PasswordChar="●"
                             IsVisible="{Binding !IsShowingKucoinKey}"
                             PlaceholderText="paste API Key…" />
                    <TextBox Text="{Binding KucoinKeyInput}"
                             IsVisible="{Binding IsShowingKucoinKey}"
                             PlaceholderText="paste API Key…" />
                  </Panel>
                  <Button Grid.Column="2" Content="👁" Classes="GhostButton" Padding="6,4" FontSize="13"
                          ToolTip.Tip="Show / hide"
                          Command="{Binding ToggleKucoinKeyVisibilityCommand}" />
                </Grid>

                <!-- Secret input row -->
                <Grid ColumnDefinitions="90,*,Auto" ColumnSpacing="8">
                  <TextBlock Grid.Column="0" Text="API Secret" FontSize="12" Foreground="#8FA3B8"
                             VerticalAlignment="Center" />
                  <Panel Grid.Column="1">
                    <TextBox Text="{Binding KucoinSecretInput}" PasswordChar="●"
                             IsVisible="{Binding !IsShowingKucoinSecret}"
                             PlaceholderText="paste API Secret…" />
                    <TextBox Text="{Binding KucoinSecretInput}"
                             IsVisible="{Binding IsShowingKucoinSecret}"
                             PlaceholderText="paste API Secret…" />
                  </Panel>
                  <Button Grid.Column="2" Content="👁" Classes="GhostButton" Padding="6,4" FontSize="13"
                          ToolTip.Tip="Show / hide"
                          Command="{Binding ToggleKucoinSecretVisibilityCommand}" />
                </Grid>

                <!-- Passphrase input row -->
                <Grid ColumnDefinitions="90,*,Auto" ColumnSpacing="8">
                  <TextBlock Grid.Column="0" Text="Passphrase" FontSize="12" Foreground="#8FA3B8"
                             VerticalAlignment="Center" />
                  <Panel Grid.Column="1">
                    <TextBox Text="{Binding KucoinPassphraseInput}" PasswordChar="●"
                             IsVisible="{Binding !IsShowingKucoinPassphrase}"
                             PlaceholderText="your API Key Passphrase…" />
                    <TextBox Text="{Binding KucoinPassphraseInput}"
                             IsVisible="{Binding IsShowingKucoinPassphrase}"
                             PlaceholderText="your API Key Passphrase…" />
                  </Panel>
                  <Button Grid.Column="2" Content="👁" Classes="GhostButton" Padding="6,4" FontSize="13"
                          ToolTip.Tip="Show / hide"
                          Command="{Binding ToggleKucoinPassphraseVisibilityCommand}" />
                </Grid>

                <!-- Save row -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                  <Button Grid.Column="0" Content="💾 Save"
                          Classes="GhostButton" Padding="14,6"
                          Command="{Binding SaveKucoinCredentialsCommand}" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding KucoinSaveStatus}"
                             FontSize="12" Foreground="#21E6C1"
                             VerticalAlignment="Center" />
                </Grid>

              </StackPanel>
            </Border>
            <!-- ═══ End KuCoin API Keys ═══ -->

            <!-- ═══ Affiliate / Referral Links ═══ -->
            <Border Classes="SurfaceCard">
              <StackPanel Spacing="10">
                <TextBlock Classes="H2" Text="Affiliate / Referral Links" />
                <TextBlock Foreground="#8FA3B8" FontSize="11" TextWrapping="Wrap"
                           Text="Add your referral links here. The 'Open' button launches the URL in the browser so you can share it with users. Binance pays up to 40 %, Bybit up to 30 %, OKX up to 50 % of referred users' trading fees." />

                <!-- Binance -->
                <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                  <TextBlock Grid.Column="0" Text="Binance" Foreground="#F4B860" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <TextBox   Grid.Column="1" Text="{Binding BinanceAffiliateUrl}"
                             PlaceholderText="https://www.binance.com/en/activity/referral/..."
                             FontFamily="Consolas" FontSize="11" />
                  <Button    Grid.Column="2" Classes="GhostButton" Content="Open"
                             Command="{Binding OpenBinanceAffiliateCommand}" />
                </Grid>

                <!-- Bybit -->
                <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                  <TextBlock Grid.Column="0" Text="Bybit" Foreground="#FFAA00" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <TextBox   Grid.Column="1" Text="{Binding BybitAffiliateUrl}"
                             PlaceholderText="https://www.bybit.com/invite?ref=..."
                             FontFamily="Consolas" FontSize="11" />
                  <Button    Grid.Column="2" Classes="GhostButton" Content="Open"
                             Command="{Binding OpenBybitAffiliateCommand}" />
                </Grid>

                <!-- OKX -->
                <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                  <TextBlock Grid.Column="0" Text="OKX" Foreground="#3BBFFF" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <TextBox   Grid.Column="1" Text="{Binding OkxAffiliateUrl}"
                             PlaceholderText="https://www.okx.com/join/..."
                             FontFamily="Consolas" FontSize="11" />
                  <Button    Grid.Column="2" Classes="GhostButton" Content="Open"
                             Command="{Binding OpenOkxAffiliateCommand}" />
                </Grid>

                <!-- KuCoin -->
                <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                  <TextBlock Grid.Column="0" Text="KuCoin" Foreground="#24AE8F" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <TextBox   Grid.Column="1" Text="{Binding KucoinAffiliateUrl}"
                             PlaceholderText="https://www.kucoin.com/r/..."
                             FontFamily="Consolas" FontSize="11" />
                  <Button    Grid.Column="2" Classes="GhostButton" Content="Open"
                             Command="{Binding OpenKucoinAffiliateCommand}" />
                </Grid>

                <!-- Save row -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                  <Button Grid.Column="0" Content="💾 Save Links"
                          Classes="GhostButton" Padding="14,6"
                          Command="{Binding SaveAffiliateLinksCommand}" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding AffiliateSaveStatus}"
                             FontSize="12" Foreground="#21E6C1"
                             VerticalAlignment="Center" />
                </Grid>
              </StackPanel>
            </Border>
            <!-- ═══ End Affiliate / Referral Links ═══ -->

            <!-- ═══ Trading Hotkeys ═══ -->
            <Border Classes="SurfaceCard">
              <StackPanel Spacing="10">
                <TextBlock Classes="H2" Text="Trading Hotkeys" />
                <TextBlock Text="Single-key shortcuts active when no input field is focused."
                           Foreground="#4A6880" FontSize="11" TextWrapping="Wrap" />

                <!-- Hotkey table -->
                <Grid ColumnDefinitions="160,60,*" ColumnSpacing="12">
                  <TextBlock Grid.Column="0" Text="ACTION"    Classes="Overline" />
                  <TextBlock Grid.Column="1" Text="KEY"       Classes="Overline" />
                  <TextBlock Grid.Column="2" Text="CONFIGURE" Classes="Overline" />
                </Grid>

                <!-- Buy Market -->
                <Grid ColumnDefinitions="160,60,120" ColumnSpacing="12">
                  <TextBlock Grid.Column="0" Text="Buy Market" Foreground="#D7E3EE" FontSize="11" VerticalAlignment="Center" />
                  <Border Grid.Column="1" Background="#0D1828" CornerRadius="4" Padding="8,3">
                    <TextBlock Text="{Binding HotkeySettings.BuyMarketDisplay}"
                               Foreground="#21E6C1" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" />
                  </Border>
                  <TextBox Grid.Column="2" Text="{Binding HotkeySettings.BuyMarket}"
                           FontSize="11" Background="#111821" PlaceholderText="e.g. B" />
                </Grid>

                <!-- Sell Market -->
                <Grid ColumnDefinitions="160,60,120" ColumnSpacing="12">
                  <TextBlock Grid.Column="0" Text="Sell Market" Foreground="#D7E3EE" FontSize="11" VerticalAlignment="Center" />
                  <Border Grid.Column="1" Background="#0D1828" CornerRadius="4" Padding="8,3">
                    <TextBlock Text="{Binding HotkeySettings.SellMarketDisplay}"
                               Foreground="#FF6B6B" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" />
                  </Border>
                  <TextBox Grid.Column="2" Text="{Binding HotkeySettings.SellMarket}"
                           FontSize="11" Background="#111821" PlaceholderText="e.g. S" />
                </Grid>

                <!-- Allocation 25 / 50 / 100 -->
                <Grid ColumnDefinitions="160,60,120" ColumnSpacing="12">
                  <TextBlock Grid.Column="0" Text="Allocation 25%" Foreground="#D7E3EE" FontSize="11" VerticalAlignment="Center" />
                  <Border Grid.Column="1" Background="#0D1828" CornerRadius="4" Padding="8,3">
                    <TextBlock Text="{Binding HotkeySettings.Allocation25Display}"
                               Foreground="#F4B860" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" />
                  </Border>
                  <TextBox Grid.Column="2" Text="{Binding HotkeySettings.Allocation25}"
                           FontSize="11" Background="#111821" PlaceholderText="e.g. D1" />
                </Grid>
                <Grid ColumnDefinitions="160,60,120" ColumnSpacing="12">
                  <TextBlock Grid.Column="0" Text="Allocation 50%" Foreground="#D7E3EE" FontSize="11" VerticalAlignment="Center" />
                  <Border Grid.Column="1" Background="#0D1828" CornerRadius="4" Padding="8,3">
                    <TextBlock Text="{Binding HotkeySettings.Allocation50Display}"
                               Foreground="#F4B860" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" />
                  </Border>
                  <TextBox Grid.Column="2" Text="{Binding HotkeySettings.Allocation50}"
                           FontSize="11" Background="#111821" PlaceholderText="e.g. D2" />
                </Grid>
                <Grid ColumnDefinitions="160,60,120" ColumnSpacing="12">
                  <TextBlock Grid.Column="0" Text="Allocation 100%" Foreground="#D7E3EE" FontSize="11" VerticalAlignment="Center" />
                  <Border Grid.Column="1" Background="#0D1828" CornerRadius="4" Padding="8,3">
                    <TextBlock Text="{Binding HotkeySettings.Allocation100Display}"
                               Foreground="#F4B860" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" />
                  </Border>
                  <TextBox Grid.Column="2" Text="{Binding HotkeySettings.Allocation100}"
                           FontSize="11" Background="#111821" PlaceholderText="e.g. D3" />
                </Grid>

                <!-- Cancel All Orders -->
                <Grid ColumnDefinitions="160,60,120" ColumnSpacing="12">
                  <TextBlock Grid.Column="0" Text="Cancel All Orders" Foreground="#D7E3EE" FontSize="11" VerticalAlignment="Center" />
                  <Border Grid.Column="1" Background="#0D1828" CornerRadius="4" Padding="8,3">
                    <TextBlock Text="{Binding HotkeySettings.CancelOrdersDisplay}"
                               Foreground="#FF6B6B" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" />
                  </Border>
                  <TextBox Grid.Column="2" Text="{Binding HotkeySettings.CancelOrders}"
                           FontSize="11" Background="#111821" PlaceholderText="e.g. Escape" />
                </Grid>

                <!-- Focus Trading Pair -->
                <Grid ColumnDefinitions="160,60,120" ColumnSpacing="12">
                  <TextBlock Grid.Column="0" Text="Focus Trading Pair" Foreground="#D7E3EE" FontSize="11" VerticalAlignment="Center" />
                  <Border Grid.Column="1" Background="#0D1828" CornerRadius="4" Padding="8,3">
                    <TextBlock Text="{Binding HotkeySettings.FocusPairDisplay}"
                               Foreground="#8FA3B8" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" />
                  </Border>
                  <TextBox Grid.Column="2" Text="{Binding HotkeySettings.FocusPair}"
                           FontSize="11" Background="#111821" PlaceholderText="e.g. F" />
                </Grid>

                <TextBlock Text="Changes take effect immediately — no restart needed."
                           Foreground="#4A6880" FontSize="10" />
              </StackPanel>
            </Border>

            <!-- ═══ Telegram Inline Button Signals ═══ -->
            <Border Classes="SurfaceCard">
              <StackPanel Spacing="10">
                <TextBlock Classes="H2" Text="Telegram Inline Signals" />
                <TextBlock Foreground="#8FA3B8" FontSize="11" TextWrapping="Wrap"
                           Text="When enabled, alert and bot signals are sent to Telegram with [✅ Accept] [❌ Skip] inline buttons. Pressing Accept executes a market order in the terminal (via polling — no port-forwarding needed)." />
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                  <CheckBox Grid.Column="0"
                            IsChecked="{Binding TelegramSignalVM.InlineButtonsEnabled}"
                            Content="Enable inline-button signals" />
                </Grid>
                <!-- Pending signals list (live panel) -->
                <TextBlock Text="PENDING SIGNALS" Classes="Overline"
                           IsVisible="{Binding TelegramSignalVM.HasPendingSignals}" />
                <ItemsControl ItemsSource="{Binding TelegramSignalVM.PendingRows}"
                              IsVisible="{Binding TelegramSignalVM.HasPendingSignals}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:TelegramSignalRowVM">
                      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Margin="0,3">
                        <StackPanel Grid.Column="0" Spacing="2">
                          <TextBlock Text="{Binding Label}"
                                     Foreground="{Binding SideBrush}"
                                     FontSize="12" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding Description}"
                                     Foreground="#8FA3B8" FontSize="10" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="✅ Accept"
                                Command="{Binding AcceptCommand}"
                                Classes="GhostButton" FontSize="11"
                                Foreground="#21E6C1" />
                        <Button Grid.Column="2" Content="❌ Skip"
                                Command="{Binding SkipCommand}"
                                Classes="GhostButton" FontSize="11"
                                Foreground="#FF6B6B" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="No pending signals."
                           Foreground="#4A6880" FontSize="11"
                           IsVisible="{Binding TelegramSignalVM.HasNoSignals}" />
              </StackPanel>
            </Border>

            <!-- ── AI alert builder (natural language → alert form) ── -->
            <Border Classes="Panel">
              <StackPanel Spacing="8">
                <StackPanel Spacing="2">
                  <TextBlock Classes="H2" Text="🧠 Describe an alert" />
                  <TextBlock Text="e.g. &quot;ping me when BTC breaks 75k&quot; or &quot;tell me if ETH drops 10% in 1h&quot;. Fills the form below for review."
                             Foreground="#8FA3B8" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                  <TextBox Grid.Column="0" Text="{Binding AlertsVM.NlPrompt}"
                           PlaceholderText="Alert me when…" />
                  <Button Grid.Column="1" Content="Generate" Command="{Binding AlertsVM.GenerateAlertFromTextCommand}"
                          IsEnabled="{Binding !AlertsVM.NlRunning}" />
                </Grid>
                <TextBlock Text="{Binding AlertsVM.NlStatus}" Foreground="#21E6C1" FontSize="11"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <!-- New alert form -->
            <Border Classes="Panel">
              <StackPanel Spacing="12">
                <TextBlock Classes="H2" Text="Add Alert" />
                <Grid ColumnDefinitions="*,*,*,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12">
                  <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Classes="Overline" Text="Symbol" />
                    <TextBox Text="{Binding AlertsVM.NewAlertSymbol}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Classes="Overline" Text="Condition" />
                    <ComboBox ItemsSource="{Binding AlertsVM.AvailableConditions}"
                              SelectedItem="{Binding AlertsVM.SelectedCondition}" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="6">
                    <TextBlock Classes="Overline" Text="Threshold" />
                    <NumericUpDown Value="{Binding AlertsVM.NewAlertThreshold}" Increment="100" Minimum="0" />
                  </StackPanel>
                  <StackPanel Grid.Column="3" Spacing="6">
                    <TextBlock Classes="Overline" Text="Telegram" />
                    <CheckBox IsChecked="{Binding AlertsVM.NewAlertSendTelegram}" />
                  </StackPanel>
                  <StackPanel Grid.Column="4" Spacing="6">
                    <TextBlock Classes="Overline" Text="Discord" />
                    <CheckBox IsChecked="{Binding AlertsVM.NewAlertSendDiscord}" />
                  </StackPanel>
                  <StackPanel Grid.Column="5" Spacing="6">
                    <TextBlock Classes="Overline" Text="ntfy" />
                    <CheckBox IsChecked="{Binding AlertsVM.NewAlertSendNtfy}" />
                  </StackPanel>
                  <StackPanel Grid.Column="6" Spacing="6">
                    <TextBlock Classes="Overline" Text="Email" />
                    <CheckBox IsChecked="{Binding AlertsVM.NewAlertSendEmail}" />
                  </StackPanel>
                  <StackPanel Grid.Column="7" Spacing="6">
                    <TextBlock Classes="Overline" Text="Repeat" />
                    <CheckBox IsChecked="{Binding AlertsVM.NewAlertRepeat}" />
                  </StackPanel>
                  <StackPanel Grid.Column="8" Spacing="6">
                    <TextBlock Classes="Overline" Text=" " />
                    <Button Command="{Binding AlertsVM.AddAlertCommand}" Content="+ Add" Classes="AccentButton" />
                  </StackPanel>
                </Grid>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="20" Margin="0,4,0,0">
                  <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <CheckBox IsChecked="{Binding AlertsVM.SoundEnabled}" VerticalAlignment="Center" />
                    <TextBlock Text="Sound on alert" Foreground="#8FA3B8" VerticalAlignment="Center" FontSize="12" />
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="Note: VolumeSpike requires exchange volume data not available in the live stream." Foreground="#4A6070" FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap" />
                </Grid>
              </StackPanel>
            </Border>

            <!-- Alert list -->
            <Border Classes="Panel">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                  <TextBlock Classes="H2" Text="Active Alerts" VerticalAlignment="Center" />
                  <Button Grid.Column="1" Command="{Binding AlertsVM.ClearFiredCommand}" Content="Clear Fired" />
                </Grid>
                <ListBox ItemsSource="{Binding AlertsVM.Alerts}" Background="Transparent" MaxHeight="240">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:AlertItemViewModel">
                      <Grid ColumnDefinitions="80,*,80,60,Auto" ColumnSpacing="12">
                        <TextBlock Grid.Column="0" Text="{Binding Symbol}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding ConditionLabel}" Foreground="#8FA3B8" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding StatusLabel}" Foreground="{Binding StatusColor}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="{Binding SendTelegram}" Foreground="#8FA3B8" VerticalAlignment="Center" />
                        <Button Grid.Column="4" Content="✕" FontSize="11"
                                Command="{Binding $parent[Window].DataContext.AlertsVM.DeleteAlertCommand}"
                                CommandParameter="{Binding Id}" />
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock Text="{Binding AlertsVM.LogText}" Foreground="#8FA3B8" FontFamily="Courier New" FontSize="11"
                           TextWrapping="Wrap" MaxHeight="80" />
              </StackPanel>
            </Border>

            <!-- Fired alert history -->
            <Border Classes="Panel">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                  <TextBlock Classes="H2" Text="Alert History" VerticalAlignment="Center" />
                  <Button Grid.Column="1" Command="{Binding AlertsVM.ClearHistoryCommand}" Content="Clear" />
                </Grid>
                <Grid ColumnDefinitions="80,*,80,100" ColumnSpacing="12" Margin="0,0,0,4">
                  <TextBlock Grid.Column="0" Classes="Overline" Text="Symbol" />
                  <TextBlock Grid.Column="1" Classes="Overline" Text="Condition" />
                  <TextBlock Grid.Column="2" Classes="Overline" Text="Price" />
                  <TextBlock Grid.Column="3" Classes="Overline" Text="Fired At" />
                </Grid>
                <ListBox ItemsSource="{Binding AlertsVM.AlertHistory}" Background="Transparent" MaxHeight="220">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:AlertHistoryItemViewModel">
                      <Grid ColumnDefinitions="80,*,80,100" ColumnSpacing="12">
                        <TextBlock Grid.Column="0" Text="{Binding Symbol}" FontWeight="SemiBold" Foreground="#F4B860" VerticalAlignment="Center" FontSize="12" />
                        <TextBlock Grid.Column="1" Text="{Binding ConditionLabel}" Foreground="#8FA3B8" VerticalAlignment="Center" FontSize="12" />
                        <TextBlock Grid.Column="2" Text="{Binding TriggerValueFormatted}" Foreground="#E0E8F0" VerticalAlignment="Center" FontSize="12" />
                        <TextBlock Grid.Column="3" Text="{Binding FiredAtFormatted}" Foreground="#4A6070" VerticalAlignment="Center" FontSize="11" />
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
              <Border Classes="SectionPanel">
                <StackPanel Spacing="12">
                  <TextBlock Classes="H2" Text="Execution Defaults" />
                  <TextBlock Text="{Binding SettingsConnectivitySummary}" Foreground="#8FA3B8" TextWrapping="Wrap" />
                  <StackPanel Spacing="6">
                    <TextBlock Classes="Overline" Text="Quote Asset" />
                    <ComboBox ItemsSource="{Binding WalletVM.GlobalQuoteAssetOptions}"
                              SelectedItem="{Binding WalletVM.GlobalQuoteAssetSymbol}" />
                  </StackPanel>
                  <StackPanel Spacing="6">
                    <TextBlock Classes="Overline" Text="Position Sizing" />
                    <WrapPanel Orientation="Horizontal">
                      <Button Classes="GhostButton"
                              Content="25%"
                              Margin="0,0,10,10"
                              Command="{Binding WalletVM.ApplyGlobalPositionSizingCommand}"
                              CommandParameter="25" />
                      <Button Classes="GhostButton"
                              Content="50%"
                              Margin="0,0,10,10"
                              Command="{Binding WalletVM.ApplyGlobalPositionSizingCommand}"
                              CommandParameter="50" />
                      <Button Classes="GhostButton"
                              Content="75%"
                              Margin="0,0,10,10"
                              Command="{Binding WalletVM.ApplyGlobalPositionSizingCommand}"
                              CommandParameter="75" />
                      <Button Classes="GhostButton"
                              Content="100%"
                              Margin="0,0,10,10"
                              Command="{Binding WalletVM.ApplyGlobalPositionSizingCommand}"
                              CommandParameter="100" />
                    </WrapPanel>
                  </StackPanel>
                  <WrapPanel Orientation="Horizontal">
                    <Button Classes="GhostButton"
                            Content="Paper Only"
                            Margin="0,0,10,10"
                            Command="{Binding WalletVM.ApplyGlobalExecutionModeCommand}"
                            CommandParameter="PAPER" />
                    <Button Classes="GhostButton"
                            Content="Live Allowed"
                            Margin="0,0,10,10"
                            Command="{Binding WalletVM.ApplyGlobalExecutionModeCommand}"
                            CommandParameter="LIVE" />
                  </WrapPanel>
                </StackPanel>
              </Border>

              <Border Classes="SectionPanel">
                <StackPanel Spacing="12">
                  <TextBlock Classes="H2" Text="Wallet Session" />
                  <StackPanel Spacing="6">
                    <TextBlock Classes="Overline" Text="Provider" />
                    <ComboBox ItemsSource="{Binding WalletVM.AvailableProviders}"
                              SelectedItem="{Binding WalletVM.SelectedProvider}" />
                  </StackPanel>
                  <StackPanel Spacing="6">
                    <TextBlock Classes="Overline" Text="Network" />
                    <ComboBox ItemsSource="{Binding WalletVM.AvailableNetworks}"
                              SelectedItem="{Binding WalletVM.SelectedNetwork}" />
                  </StackPanel>
                  <WrapPanel Orientation="Horizontal">
                    <Button Classes="GhostButton"
                            Content="Refresh Wallet"
                            Margin="0,0,10,10"
                            Command="{Binding WalletVM.RefreshWalletCommand}" />
                    <Button Classes="GhostButton"
                            Content="Open Provider"
                            Margin="0,0,10,10"
                            Command="{Binding WalletVM.OpenProviderCommand}" />
                    <Button Classes="GhostButton"
                            Content="Disconnect"
                            Margin="0,0,10,10"
                            Command="{Binding WalletVM.DisconnectWalletCommand}" />
                  </WrapPanel>
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>

          <StackPanel Spacing="16" IsVisible="{Binding IsHelpSectionVisible}">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
              <Border Classes="SectionPanel">
                <StackPanel Spacing="10">
                  <TextBlock Classes="H2" Text="Quick Start" />
                  <TextBlock Text="{Binding HelpQuickStartSummary}" TextWrapping="Wrap" />
                  <TextBlock Text="1. Pick a market or token." Classes="SecondaryCopy" />
                  <TextBlock Text="2. Verify wallet mode, quote asset, and sizing." Classes="SecondaryCopy" />
                  <TextBlock Text="3. Trade manually or arm the sniper after reviewing risk." Classes="SecondaryCopy" />
                </StackPanel>
              </Border>
              <Border Classes="SectionPanel">
                <StackPanel Spacing="10">
                  <TextBlock Classes="H2" Text="Safety" />
                  <TextBlock Text="{Binding HelpSafetySummary}" TextWrapping="Wrap" />
                  <TextBlock Text="Use Logs after every failed execution attempt." Classes="SecondaryCopy" />
                  <TextBlock Text="Keep paper mode on while checking new routers or wallet sessions." Classes="SecondaryCopy" />
                  <TextBlock Text="Run Safe Logout before leaving the workstation." Classes="SecondaryCopy" />
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>

          <StackPanel Spacing="16" IsVisible="{Binding IsLogoutSectionVisible}">
            <Border Classes="ExecutionGuardCard">
              <StackPanel Spacing="10">
                <TextBlock Classes="H2" Text="Current Session State" />
                <TextBlock Text="{Binding LogoutStatusLabel}" Foreground="#D7E3EE" TextWrapping="Wrap" />
                <TextBlock Text="This action forces paper mode, stops the rule bot, disarms sniper, disconnects the wallet, and returns to the dashboard."
                           Foreground="#8FA3B8"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <WrapPanel Orientation="Horizontal">
              <Button Classes="GhostButton"
                      Content="Safe Logout"
                      Margin="0,0,10,10"
                      Command="{Binding SafeLogoutCommand}" />
              <Button Classes="GhostButton"
                      Content="Open Dashboard"
                      Margin="0,0,10,10"
                      Command="{Binding SelectMainTabCommand}"
                      CommandParameter="dashboard" />
              <Button Classes="GhostButton"
                      Content="Open Logs"
                      Margin="0,0,10,10"
                      Command="{Binding SelectMainTabCommand}"
                      CommandParameter="logs" />
            </WrapPanel>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </Border>
    </Grid>
    </Grid>

    <Border x:Name="SplashOverlay" Classes="SplashOverlay" ZIndex="300">
      <Border.Transitions>
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.65" />
        </Transitions>
      </Border.Transitions>
      <Grid RowDefinitions="*,Auto,*" ClipToBounds="True">
        <Canvas IsHitTestVisible="False">
          <Ellipse Width="520" Height="520" Classes="SplashAuraPrimary" Canvas.Left="-80" Canvas.Top="-120" />
          <Ellipse Width="360" Height="360" Classes="SplashAuraSecondary" Canvas.Right="80" Canvas.Top="90" />
          <Ellipse Width="300" Height="300" Classes="SplashAuraTertiary" Canvas.Left="680" Canvas.Top="520" />
        </Canvas>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    Width="640"
                    Spacing="18">
          <Border x:Name="SplashLogoShell" Classes="SplashLogoShell" HorizontalAlignment="Center">
            <Grid>
              <Ellipse Width="214" Height="214" Classes="SplashLogoHalo" />
              <Border Classes="SplashLogoCore">
                <Grid Width="128" Height="128">
                  <Path Data="M 64 12 L 106 108 L 22 108 Z" Fill="#1FE6C2" Stretch="Uniform" />
                  <Path Data="M 64 38 L 86 90 L 42 90 Z" Fill="#071018" Stretch="Uniform" />
                  <Path x:Name="SplashSpinner"
                        Data="M 64 6 A 58 58 0 1 1 63.9 6"
                        Stroke="#6FDFFF"
                        StrokeThickness="4"
                        StrokeLineCap="Round"
                        StrokeDashArray="8,12"
                        Stretch="None"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Grid>
              </Border>
            </Grid>
          </Border>

          <StackPanel Spacing="8">
            <TextBlock Text="CRYPTO AI TERMINAL"
                       Classes="SplashTitle"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Launching the AI-driven trading workspace"
                       Classes="SplashSubtitle"
                       HorizontalAlignment="Center" />
          </StackPanel>

          <Grid Width="420" Height="12" HorizontalAlignment="Center" ClipToBounds="True">
            <Border Classes="SplashProgressTrack" />
            <Border x:Name="SplashProgressFill"
                    Classes="SplashProgressFill"
                    RenderTransformOrigin="0,0.5">
              <Border.RenderTransform>
                <ScaleTransform ScaleX="0.03" ScaleY="1" />
              </Border.RenderTransform>
            </Border>
          </Grid>

          <TextBlock x:Name="SplashStatusText"
                     Text="Syncing market feeds..."
                     Classes="SplashStatus"
                     HorizontalAlignment="Center" />

          <WrapPanel HorizontalAlignment="Center">
            <Border Classes="SplashMetricChip" Margin="0,0,10,0">
              <TextBlock Text="DEX streams" />
            </Border>
            <Border Classes="SplashMetricChip" Margin="0,0,10,0">
              <TextBlock Text="Risk engine" />
            </Border>
            <Border Classes="SplashMetricChip">
              <TextBlock Text="AI signals" />
            </Border>
          </WrapPanel>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Alert toast notification overlay -->
    <Border IsVisible="{Binding IsToastVisible}"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,24,32"
            Padding="16,12"
            Background="#0D2233"
            BorderBrush="#1FE6C2"
            BorderThickness="1"
            CornerRadius="8"
            MaxWidth="380"
            ZIndex="100">
      <Border.Transitions>
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.25" />
        </Transitions>
      </Border.Transitions>
      <StackPanel Spacing="4">
        <TextBlock Text="Alert Fired" Foreground="#1FE6C2" FontSize="11" FontWeight="SemiBold" />
        <TextBlock Text="{Binding ToastMessage}" Foreground="#E0E8F0" TextWrapping="Wrap" FontSize="13" />
      </StackPanel>
    </Border>

    <!-- Update available banner -->
    <Border IsVisible="{Binding IsUpdateAvailable}"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Margin="24,0,0,32"
            Padding="16,12"
            Background="#0D2233"
            BorderBrush="#1FE6C2"
            BorderThickness="1"
            CornerRadius="8"
            MaxWidth="420"
            ZIndex="100">
      <StackPanel Spacing="8">
        <TextBlock Text="⬆ Update available" Foreground="#1FE6C2" FontSize="11" FontWeight="SemiBold" />
        <TextBlock Text="{Binding UpdateBannerText}" Foreground="#E0E8F0" TextWrapping="Wrap" FontSize="13" />
        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
          <Button Content="Later" Command="{Binding DismissUpdateCommand}"
                  Padding="12,5" Background="Transparent" BorderBrush="#2C4257" BorderThickness="1" Foreground="#C5D2DE" />
          <Button Content="Download" Command="{Binding OpenUpdateCommand}"
                  Padding="14,5" Background="#1FE6C2" Foreground="#06121C" FontWeight="Bold" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- License status chip (trial / expired) -->
    <Border IsVisible="{Binding LicenseVM.ShowTrialBanner}"
            HorizontalAlignment="Right" VerticalAlignment="Top"
            Margin="0,16,24,0" Padding="12,7"
            Background="#0D2233" BorderBrush="{Binding LicenseVM.StateBrush}"
            BorderThickness="1" CornerRadius="8" ZIndex="90">
      <StackPanel Orientation="Horizontal" Spacing="10">
        <TextBlock Text="{Binding LicenseVM.StateLabel}" Foreground="{Binding LicenseVM.StateBrush}"
                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
        <Button Content="Activate" Command="{Binding LicenseVM.OpenCommand}"
                Padding="10,3" Background="#1FE6C2" Foreground="#06121C" FontSize="11" FontWeight="Bold" />
      </StackPanel>
    </Border>

    <!-- License activation overlay -->
    <Border IsVisible="{Binding LicenseVM.IsVisible}" Background="#CC050A12" ZIndex="220">
      <Border Width="560" HorizontalAlignment="Center" VerticalAlignment="Center"
              Background="#0B1622" BorderBrush="#1FE6C2" BorderThickness="1"
              CornerRadius="14" Padding="32,28">
        <StackPanel Spacing="16">
          <TextBlock Text="License activation" Foreground="#F0F6FC" FontSize="22" FontWeight="Bold" />
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Border Background="{Binding LicenseVM.StateBrush}" CornerRadius="3" Padding="8,3">
              <TextBlock Text="{Binding LicenseVM.StateLabel}" Foreground="#06121C" FontSize="12" FontWeight="Bold" />
            </Border>
          </StackPanel>
          <TextBlock Text="{Binding LicenseVM.DetailLabel}" Foreground="#9FB2C4" FontSize="13" TextWrapping="Wrap" />
          <TextBox Text="{Binding LicenseVM.KeyInput}" PlaceholderText="Paste license key"
                   Background="#0A1018" Foreground="#C8D8E8" Height="34" AcceptsReturn="False" />
          <TextBlock Text="{Binding LicenseVM.StatusMessage}" Foreground="#F4B860" FontSize="12" TextWrapping="Wrap" />
          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
            <TextBlock Grid.Column="0" Text="{Binding LicenseVM.MachineId, StringFormat='Machine ID: {0}'}"
                       Foreground="#48586A" FontSize="10" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="Close" Command="{Binding LicenseVM.CloseCommand}"
                    Padding="16,9" Background="Transparent" BorderBrush="#2C4257" BorderThickness="1" Foreground="#C5D2DE" />
            <Button Grid.Column="2" Content="Activate" Command="{Binding LicenseVM.ActivateCommand}"
                    Padding="18,9" Background="#1FE6C2" Foreground="#06121C" FontWeight="Bold" />
          </Grid>
        </StackPanel>
      </Border>
    </Border>

    <!-- First-run Welcome / Demo overlay -->
    <Border IsVisible="{Binding IsWelcomeVisible}"
            Background="#CC050A12"
            ZIndex="200">
      <Border Width="560"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Background="#0B1622"
              BorderBrush="#1FE6C2"
              BorderThickness="1"
              CornerRadius="14"
              Padding="32,28">
        <StackPanel Spacing="18">
          <StackPanel Spacing="6">
            <Border Background="#13312C"
                    CornerRadius="4"
                    Padding="8,3"
                    HorizontalAlignment="Left">
              <TextBlock Text="DEMO · NO API KEYS NEEDED"
                         Foreground="#1FE6C2"
                         FontSize="11"
                         FontWeight="Bold" />
            </Border>
            <TextBlock Text="Welcome to Crypto AI Terminal"
                       Foreground="#F0F6FC"
                       FontSize="24"
                       FontWeight="Bold" />
            <TextBlock Foreground="#9FB2C4"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Text="You're starting in Paper (Demo) mode. Every order — spot, futures, DEX, and the sniper — is simulated. No real funds can leave the terminal until you add API keys and switch to Live yourself." />
          </StackPanel>

          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <TextBlock Grid.Column="0" Text="✓" Foreground="#3DDC84" FontWeight="Bold" />
              <TextBlock Grid.Column="1" Foreground="#C5D2DE" FontSize="13" TextWrapping="Wrap"
                         Text="Explore live market data, charts, the DEX sniper and AI verdicts with zero setup." />
            </Grid>
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <TextBlock Grid.Column="0" Text="✓" Foreground="#3DDC84" FontWeight="Bold" />
              <TextBlock Grid.Column="1" Foreground="#C5D2DE" FontSize="13" TextWrapping="Wrap"
                         Text="Run bots, backtests and paper trades — results are tracked in the journal and P&amp;L dashboard." />
            </Grid>
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <TextBlock Grid.Column="0" Text="✓" Foreground="#3DDC84" FontWeight="Bold" />
              <TextBlock Grid.Column="1" Foreground="#C5D2DE" FontSize="13" TextWrapping="Wrap"
                         Text="Add exchange API keys any time from Settings when you're ready to trade live." />
            </Grid>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
            <Button Content="Add API keys"
                    Command="{Binding OpenApiKeysFromWelcomeCommand}"
                    Padding="18,10"
                    Background="Transparent"
                    BorderBrush="#2C4257"
                    BorderThickness="1"
                    Foreground="#C5D2DE" />
            <Button Content="Start exploring in Demo"
                    Command="{Binding StartDemoCommand}"
                    Padding="20,10"
                    Background="#1FE6C2"
                    Foreground="#06121C"
                    FontWeight="Bold" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>

    <!-- Onboarding wizard overlay -->
    <Border IsVisible="{Binding OnboardingVM.IsVisible}"
            Background="#CC050A12"
            ZIndex="210">
      <Border Width="560"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Background="#0B1622"
              BorderBrush="#1FE6C2"
              BorderThickness="1"
              CornerRadius="14"
              Padding="32,28">
        <StackPanel Spacing="18">

          <!-- Step 1: choose exchange -->
          <StackPanel Spacing="16" IsVisible="{Binding OnboardingVM.IsChooseStep}">
            <StackPanel Spacing="6">
              <TextBlock Text="Connect an exchange" Foreground="#F0F6FC" FontSize="22" FontWeight="Bold" />
              <TextBlock Foreground="#9FB2C4" FontSize="13" TextWrapping="Wrap"
                         Text="Pick where you trade. Keys are stored encrypted on this PC only (Windows DPAPI) and never leave the machine." />
            </StackPanel>
            <UniformGrid Columns="2" Margin="0,4,0,0">
              <Button Content="Binance" Command="{Binding OnboardingVM.ChooseExchangeCommand}" CommandParameter="Binance"
                      Margin="0,0,8,8" Height="46" Background="#10202E" Foreground="#E0E8F0" FontWeight="SemiBold" />
              <Button Content="Bybit" Command="{Binding OnboardingVM.ChooseExchangeCommand}" CommandParameter="Bybit"
                      Margin="0,0,0,8" Height="46" Background="#10202E" Foreground="#E0E8F0" FontWeight="SemiBold" />
              <Button Content="OKX" Command="{Binding OnboardingVM.ChooseExchangeCommand}" CommandParameter="OKX"
                      Margin="0,0,8,0" Height="46" Background="#10202E" Foreground="#E0E8F0" FontWeight="SemiBold" />
              <Button Content="KuCoin" Command="{Binding OnboardingVM.ChooseExchangeCommand}" CommandParameter="KuCoin"
                      Height="46" Background="#10202E" Foreground="#E0E8F0" FontWeight="SemiBold" />
            </UniformGrid>
            <Button Content="Skip — I'll explore in Demo first"
                    Command="{Binding OnboardingVM.SkipCommand}"
                    HorizontalAlignment="Center" Background="Transparent" Foreground="#7E93A6" FontSize="12" />
          </StackPanel>

          <!-- Step 2: enter keys -->
          <StackPanel Spacing="12" IsVisible="{Binding OnboardingVM.IsKeysStep}">
            <TextBlock Text="{Binding OnboardingVM.KeysStepTitle}" Foreground="#F0F6FC" FontSize="22" FontWeight="Bold" />
            <TextBlock Foreground="#9FB2C4" FontSize="12" TextWrapping="Wrap"
                       Text="Create an API key with trade permission only (no withdrawals), ideally IP-restricted." />
            <TextBox Text="{Binding OnboardingVM.KeyInput}" PlaceholderText="API key"
                     Background="#0A1018" Foreground="#C8D8E8" Height="34" />
            <TextBox Text="{Binding OnboardingVM.SecretInput}" PlaceholderText="API secret" PasswordChar="•"
                     Background="#0A1018" Foreground="#C8D8E8" Height="34" />
            <TextBox Text="{Binding OnboardingVM.PassphraseInput}" PlaceholderText="Passphrase" PasswordChar="•"
                     IsVisible="{Binding OnboardingVM.NeedsPassphrase}"
                     Background="#0A1018" Foreground="#C8D8E8" Height="34" />
            <TextBlock Text="{Binding OnboardingVM.StatusMessage}" Foreground="#FF8A4C" FontSize="12" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
              <Button Content="Back" Command="{Binding OnboardingVM.BackCommand}"
                      Padding="16,9" Background="Transparent" BorderBrush="#2C4257" BorderThickness="1" Foreground="#C5D2DE" />
              <Button Content="Save securely" Command="{Binding OnboardingVM.SaveKeysCommand}"
                      Padding="18,9" Background="#1FE6C2" Foreground="#06121C" FontWeight="Bold" />
            </StackPanel>
          </StackPanel>

          <!-- Step 3: done -->
          <StackPanel Spacing="16" IsVisible="{Binding OnboardingVM.IsDoneStep}">
            <TextBlock Text="✓ Keys saved" Foreground="#3DDC84" FontSize="22" FontWeight="Bold" />
            <TextBlock Foreground="#9FB2C4" FontSize="13" TextWrapping="Wrap"
                       Text="Your API keys are encrypted on this PC. Restart the terminal to connect them — until then you stay in Demo (paper) mode, so nothing trades live by accident." />
            <Button Content="Done"
                    Command="{Binding OnboardingVM.FinishCommand}"
                    HorizontalAlignment="Right" Padding="22,10"
                    Background="#1FE6C2" Foreground="#06121C" FontWeight="Bold" />
          </StackPanel>

        </StackPanel>
      </Border>
    </Border>

    <!-- ═══ Global AI Command Bar (Ctrl+K) ═══ -->
    <Border IsVisible="{Binding IsCommandPaletteOpen}"
            Background="#CC04101A" ZIndex="100">
      <Grid>
        <!-- click-outside to close -->
        <Button Command="{Binding CloseCommandPaletteCommand}"
                Background="Transparent" BorderThickness="0"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

        <Border VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,120,0,0" Width="680" MaxWidth="680"
                Background="#0E1B27" BorderBrush="#21E6C1" BorderThickness="1"
                CornerRadius="12" Padding="18" BoxShadow="0 18 60 0 #99000000">
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="⚡ AI Command" Classes="H2" />
                <TextBlock Text="Navigate or ask anything — Enter to run, Esc to close."
                           Foreground="#8FA3B8" FontSize="12" />
              </StackPanel>
              <Button Grid.Column="1" Content="✕" Command="{Binding CloseCommandPaletteCommand}"
                      Background="Transparent" Foreground="#8FA3B8" FontSize="16"
                      VerticalAlignment="Top" Padding="8,2" />
            </Grid>

            <TextBox x:Name="CommandPaletteBox"
                     Text="{Binding CommandPaletteInput}"
                     FontSize="16" Padding="12,10"
                     PlaceholderText="e.g. “open scanner”, “go to settings”, “what's my biggest risk?”">
              <TextBox.KeyBindings>
                <KeyBinding Gesture="Enter"  Command="{Binding RunCommandPaletteCommand}" />
                <KeyBinding Gesture="Escape" Command="{Binding CloseCommandPaletteCommand}" />
              </TextBox.KeyBindings>
            </TextBox>

            <StackPanel Orientation="Horizontal" Spacing="10">
              <Button Content="Run" Command="{Binding RunCommandPaletteCommand}"
                      Background="#1FE6C2" Foreground="#06121C" FontWeight="Bold" Padding="18,8" />
              <TextBlock Text="Thinking…" Foreground="#21E6C1" VerticalAlignment="Center"
                         IsVisible="{Binding CommandPaletteBusy}" />
            </StackPanel>

            <Border Background="#0A1722" CornerRadius="6" Padding="12"
                    IsVisible="{Binding CommandPaletteResult, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
              <TextBlock Text="{Binding CommandPaletteResult}" Foreground="#D7E3EE"
                         TextWrapping="Wrap" />
            </Border>

            <TextBlock Foreground="#4A6880" FontSize="11" TextWrapping="Wrap"
                       Text="Tip: type a destination (scanner, settings, whales, liquidations…) to jump there, or ask a question to get an AI answer. The command bar never trades — it only advises and navigates." />
          </StackPanel>
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>





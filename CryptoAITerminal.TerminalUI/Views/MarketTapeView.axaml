<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CryptoAITerminal.TerminalUI.ViewModels"
             x:Class="CryptoAITerminal.TerminalUI.Views.MarketTapeView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">
  <StackPanel Spacing="16" IsVisible="{Binding IsTapeSectionVisible}">

    <Border Classes="Panel">
      <StackPanel Spacing="10">
        <TextBlock Classes="H2" Text="Live Tape (public market trades)" />
        <TextBlock Text="Other participants' trades on a venue. CEX = a symbol's anonymous fills (no identity). DEX = a pool's on-chain swaps, including the originating wallet. Large prints are highlighted."
                   Foreground="#8FA3B8" TextWrapping="Wrap" />

        <!-- venue toggle -->
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="CEX" Width="80"
                  Background="{Binding MarketTapeVM.CexTabBrush}" Foreground="{Binding MarketTapeVM.CexTabFg}"
                  Command="{Binding MarketTapeVM.SelectCexCommand}" />
          <Button Content="DEX" Width="80"
                  Background="{Binding MarketTapeVM.DexTabBrush}" Foreground="{Binding MarketTapeVM.DexTabFg}"
                  Command="{Binding MarketTapeVM.SelectDexCommand}" />
        </StackPanel>

        <!-- CEX input -->
        <Grid ColumnDefinitions="Auto,160,Auto,160,Auto" ColumnSpacing="12"
              IsVisible="{Binding MarketTapeVM.IsCex}">
          <TextBlock Grid.Column="0" Text="Symbol" VerticalAlignment="Center" />
          <TextBox Grid.Column="1" Text="{Binding MarketTapeVM.Symbol}" Watermark="BTCUSDT" />
          <TextBlock Grid.Column="2" Text="Large print ≥ (USDT)" VerticalAlignment="Center" />
          <NumericUpDown Grid.Column="3" Minimum="0" Increment="10000"
                         Value="{Binding MarketTapeVM.LargePrintThreshold}" />
          <Button Grid.Column="4" Classes="GhostButton" Content="Apply"
                  VerticalAlignment="Center" Command="{Binding MarketTapeVM.RefreshCommand}" />
        </Grid>

        <!-- DEX input -->
        <StackPanel Spacing="8" IsVisible="{Binding MarketTapeVM.IsDex}">
          <Grid ColumnDefinitions="Auto,120,Auto,*" ColumnSpacing="12">
            <TextBlock Grid.Column="0" Text="Network" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding MarketTapeVM.Network}" Watermark="eth" />
            <TextBlock Grid.Column="2" Text="Pool address" VerticalAlignment="Center" />
            <TextBox Grid.Column="3" Text="{Binding MarketTapeVM.PoolAddress}" Watermark="0x…" />
          </Grid>
          <Grid ColumnDefinitions="Auto,160,Auto" ColumnSpacing="12">
            <TextBlock Grid.Column="0" Text="Large print ≥ (USD)" VerticalAlignment="Center" />
            <NumericUpDown Grid.Column="1" Minimum="0" Increment="10000"
                           Value="{Binding MarketTapeVM.LargePrintThreshold}" />
            <Button Grid.Column="2" Classes="GhostButton" Content="Apply"
                    VerticalAlignment="Center" Command="{Binding MarketTapeVM.RefreshCommand}" />
          </Grid>
          <TextBlock Text="Network ids: eth, bsc, solana, base, arbitrum, polygon_pos. Pool = the pair/pool address on that chain."
                     Foreground="#6E8198" FontSize="11" TextWrapping="Wrap" />
        </StackPanel>

        <TextBlock Text="{Binding MarketTapeVM.PressureLabel}" FontWeight="SemiBold"
                   Foreground="{Binding MarketTapeVM.PressureBrush}" />
        <TextBlock Text="{Binding MarketTapeVM.StatusLabel}" Foreground="#8FA3B8" FontSize="11" />
      </StackPanel>
    </Border>

    <Border Classes="Panel">
      <StackPanel Spacing="6">
        <Grid ColumnDefinitions="44,90,60,*,*,80,110" Margin="0,0,0,2">
          <TextBlock Grid.Column="0" Text="Src"    Foreground="#8FA3B8" FontSize="11" />
          <TextBlock Grid.Column="1" Text="Time"   Foreground="#8FA3B8" FontSize="11" />
          <TextBlock Grid.Column="2" Text="Side"   Foreground="#8FA3B8" FontSize="11" />
          <TextBlock Grid.Column="3" Text="Price"  Foreground="#8FA3B8" FontSize="11" />
          <TextBlock Grid.Column="4" Text="Qty"    Foreground="#8FA3B8" FontSize="11" />
          <TextBlock Grid.Column="5" Text="USD"    Foreground="#8FA3B8" FontSize="11" HorizontalAlignment="Right" />
          <TextBlock Grid.Column="6" Text="Wallet" Foreground="#8FA3B8" FontSize="11" />
        </Grid>
        <ItemsControl ItemsSource="{Binding MarketTapeVM.Rows}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Background="{Binding RowBrush}" CornerRadius="3" Padding="2,1">
                <Grid ColumnDefinitions="44,90,60,*,*,80,110">
                  <TextBlock Grid.Column="0" Text="{Binding VenueLabel}"
                             Foreground="{Binding VenueBrush}" FontSize="11" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="1" Text="{Binding TimeLabel}"
                             FontFamily="Cascadia Code,Consolas,monospace" FontSize="12" Foreground="#8FA3B8" />
                  <TextBlock Grid.Column="2" Text="{Binding Side}"
                             Foreground="{Binding SideBrush}" FontWeight="{Binding Weight}" FontSize="12" />
                  <TextBlock Grid.Column="3" Text="{Binding PriceLabel}"
                             FontFamily="Cascadia Code,Consolas,monospace" FontWeight="{Binding Weight}" FontSize="12" />
                  <TextBlock Grid.Column="4" Text="{Binding QtyLabel}"
                             FontFamily="Cascadia Code,Consolas,monospace" FontSize="12" Foreground="#C7D3DF" />
                  <TextBlock Grid.Column="5" Text="{Binding QuoteLabel}"
                             FontFamily="Cascadia Code,Consolas,monospace" FontWeight="{Binding Weight}" FontSize="12"
                             HorizontalAlignment="Right" Foreground="#C7D3DF" />
                  <TextBlock Grid.Column="6" Text="{Binding TraderLabel}"
                             FontFamily="Cascadia Code,Consolas,monospace" FontSize="11" Foreground="#8FA3B8" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>

  </StackPanel>
</UserControl>

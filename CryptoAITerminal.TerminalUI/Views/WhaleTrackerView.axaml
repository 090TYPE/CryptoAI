<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CryptoAITerminal.TerminalUI.ViewModels"
             xmlns:ctrl="clr-namespace:CryptoAITerminal.TerminalUI.Controls"
             xmlns:wt="clr-namespace:CryptoAITerminal.WhaleTracker.Models;assembly=CryptoAITerminal.WhaleTracker"
             x:Class="CryptoAITerminal.TerminalUI.Views.WhaleTrackerView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">
          <StackPanel Spacing="16" IsVisible="{Binding IsWhaleTrackerSectionVisible}">

            <!-- Header stats + controls -->
            <Grid ColumnDefinitions="*,*,*,Auto,Auto" ColumnSpacing="12">
              <Border Grid.Column="0" Classes="SurfaceCard">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Min Transfer" />
                  <TextBlock Text="{Binding WhaleTrackerVM.MinUsdValue, StringFormat='${0:N0}'}" Foreground="#21E6C1" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Classes="SurfaceCard">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Alerts Captured" />
                  <TextBlock Text="{Binding WhaleTrackerVM.TotalAlertsCount}" Foreground="#21E6C1" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Classes="SurfaceCard">
                <StackPanel Spacing="4">
                  <TextBlock Classes="Overline" Text="Labeled Wallet Alerts" />
                  <TextBlock Text="{Binding WhaleTrackerVM.LabeledAlertsCount}" Foreground="#F4B860" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Button Grid.Column="3" Classes="BuyButton" Command="{Binding WhaleTrackerVM.StartCommand}" Width="110" IsVisible="{Binding !WhaleTrackerVM.IsTracking}">Start Tracking</Button>
              <Button Grid.Column="4" Classes="SellButton" Command="{Binding WhaleTrackerVM.StopCommand}" Width="110" IsVisible="{Binding WhaleTrackerVM.IsTracking}">Stop Tracking</Button>
            </Grid>

            <!-- Status bar -->
            <Border Classes="Panel" Padding="12,8">
              <StackPanel Orientation="Horizontal" Spacing="16">
                <Ellipse Width="8" Height="8" Fill="{Binding WhaleTrackerVM.IsTracking, Converter={StaticResource BoolToColorConverter}}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding WhaleTrackerVM.KnownWalletCount, StringFormat='{}Polling ETH · BSC · Solana  ·  {0} known wallets tracked'}" Foreground="#8FA3B8" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Text="·  ETHERSCAN_API_KEY / BSCSCAN_API_KEY env vars for higher rate limits" Foreground="#4D5F70" FontSize="11" VerticalAlignment="Center" />
                <Button Classes="LinkButton" Command="{Binding WhaleTrackerVM.ClearCommand}" HorizontalAlignment="Right">Clear</Button>
              </StackPanel>
            </Border>

            <!-- ── AI Flow Insight (#6) ── -->
            <Border Classes="Panel" Padding="14,12">
              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <StackPanel Grid.Column="0">
                    <TextBlock Text="🧠 AI Flow Insight" FontWeight="SemiBold" Foreground="#E8F0FE" FontSize="13" />
                    <TextBlock Text="Accumulation or distribution? AI reads recent whale flows."
                               Foreground="#5C6E82" FontSize="11" />
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="{Binding WhaleTrackerVM.InsightSource}"
                             Foreground="#5C6E82" FontSize="10" VerticalAlignment="Center" Margin="0,0,10,0" />
                  <Button Grid.Column="2" Content="Analyze with AI"
                          Command="{Binding WhaleTrackerVM.AnalyzeWithAiCommand}"
                          IsEnabled="{Binding !WhaleTrackerVM.InsightRunning}" Foreground="#21E6C1" />
                </Grid>
                <StackPanel Spacing="5" IsVisible="{Binding WhaleTrackerVM.HasInsight}">
                  <TextBlock Text="{Binding WhaleTrackerVM.InsightSignal}"
                             Foreground="{Binding WhaleTrackerVM.InsightSignalBrush}" FontWeight="Bold" FontSize="13" />
                  <TextBlock Text="{Binding WhaleTrackerVM.InsightSummary}" Foreground="#D7E3EE" FontSize="12" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding WhaleTrackerVM.InsightBullets}" Foreground="#8FA3B8" FontSize="11" TextWrapping="Wrap"
                             IsVisible="{Binding WhaleTrackerVM.InsightBullets, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Main split: alerts list + known wallets sidebar -->
            <Grid ColumnDefinitions="*,280" ColumnSpacing="16">

              <!-- Alerts feed -->
              <Border Grid.Column="0" Classes="Panel" Padding="0">
                <StackPanel>
                  <Border Padding="16,12" BorderBrush="#1A2E3A" BorderThickness="0,0,0,1">
                    <TextBlock Classes="H2" Text="Live Whale Alerts" />
                  </Border>
                  <ScrollViewer MaxHeight="520" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding WhaleTrackerVM.RecentAlerts}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:WhaleAlertViewModel">
                          <Border Padding="16,10" BorderBrush="#1A2E3A" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" ColumnSpacing="10">

                              <!-- Chain badge -->
                              <Border Grid.Column="0" CornerRadius="3" Padding="5,2" Background="#0D1E2A" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ChainBadge}" Foreground="{Binding ChainBrush}" FontSize="10" FontWeight="Bold" />
                              </Border>

                              <!-- Alert type -->
                              <Border Grid.Column="1" CornerRadius="3" Padding="5,2" Background="#0D1E2A" VerticalAlignment="Center">
                                <TextBlock Text="{Binding AlertBadge}" Foreground="{Binding AlertBrush}" FontSize="10" FontWeight="Bold" />
                              </Border>

                              <!-- Main info -->
                              <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                  <TextBlock Text="{Binding AmountLabel}" Foreground="#E8F4FF" FontWeight="SemiBold" />
                                  <TextBlock Text="{Binding TokenSymbol}" Foreground="#8FA3B8" FontSize="12" />
                                </StackPanel>
                                <TextBlock Text="{Binding Description}" Foreground="#8FA3B8" FontSize="11" />
                                <TextBlock Text="{Binding ActiveWalletLabel}" Foreground="#F4B860" FontSize="11" IsVisible="{Binding HasLabel}" />
                              </StackPanel>

                              <!-- Time -->
                              <TextBlock Grid.Column="3" Text="{Binding TimeLabel}" Foreground="#4D5F70" FontSize="11" VerticalAlignment="Center" />

                              <!-- 1h price trend (Alchemy-enriched, appears asynchronously) -->
                              <Border Grid.Column="4" CornerRadius="3" Padding="6,2"
                                      Background="#0D1E2A" VerticalAlignment="Center"
                                      IsVisible="{Binding HasPriceTrend}">
                                <TextBlock Text="{Binding PriceTrendLabel}"
                                           Foreground="{Binding PriceTrendBrush}"
                                           FontSize="10" FontWeight="SemiBold" />
                              </Border>

                              <!-- Snipe button -->
                              <Button Grid.Column="5" Classes="BuyButton" Command="{Binding SniperBuyCommand}"
                                      IsVisible="{Binding CanSnipe}" Padding="8,4" FontSize="11" VerticalAlignment="Center">
                                ⚡ Snipe
                              </Button>

                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </StackPanel>
              </Border>

              <!-- Known wallets sidebar -->
              <StackPanel Grid.Column="1" Spacing="12">
                <Border Classes="Panel" Padding="0">
                  <StackPanel>
                    <Border Padding="14,10" BorderBrush="#1A2E3A" BorderThickness="0,0,0,1">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Classes="H2" Text="Tracked Wallets" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding WhaleTrackerVM.KnownWalletCount}" Foreground="#21E6C1" FontSize="12" VerticalAlignment="Center" />
                      </StackPanel>
                    </Border>
                    <ScrollViewer MaxHeight="480" VerticalScrollBarVisibility="Auto">
                      <ItemsControl ItemsSource="{Binding WhaleTrackerVM.KnownWallets}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="wt:LabeledWallet">
                            <Border Padding="14,8" BorderBrush="#1A2E3A" BorderThickness="0,0,0,1">
                              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Border Grid.Column="0" CornerRadius="3" Padding="4,2" Background="#0D1E2A" VerticalAlignment="Top">
                                  <TextBlock Text="{Binding Chain}" FontSize="9" Foreground="#8FA3B8" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="1">
                                  <TextBlock Text="{Binding Label}" Foreground="#C8D8E8" FontSize="12" />
                                  <TextBlock Text="{Binding Category}" Foreground="#4D7EA8" FontSize="10" />
                                </StackPanel>
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </StackPanel>
                </Border>

                <!-- API keys note -->
                <Border Classes="Panel">
                  <StackPanel Spacing="6">
                    <TextBlock Classes="H2" Text="API Keys" />
                    <TextBlock Text="ETHERSCAN_API_KEY" Foreground="#21E6C1" FontFamily="Consolas" FontSize="11" />
                    <TextBlock Text="BSCSCAN_API_KEY" Foreground="#21E6C1" FontFamily="Consolas" FontSize="11" />
                    <TextBlock Text="Free keys increase rate limits from 1 req/5s to 5 req/s. Solscan uses public API." Foreground="#4D5F70" FontSize="11" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </StackPanel>

            </Grid>
          </StackPanel>
</UserControl>
